    {
      "text": "export function renderResultSummary(info: CompletedToolInfo): VDOMNode {\n  const input = info.request.input as Input;\n  const result = info.result.result;\n  const totalAgents = input.agents?.length ?? 0;\n\n  if (result.status === \"error\") {\n    const errorPreview =\n      result.error.length \u003e 50\n        ? `${result.error.substring(0, 50)}...`\n        : result.error;\n    return d`${errorPreview}`;\n  }\n\n  return d`${totalAgents.toString()} agent${totalAgents === 1 ? \"\" : \"s\"}`;\n}",
      "contextualizedText": "// node/render-tools/spawn-subagents.ts \u003e function renderResultSummary\n\nexport function renderResultSummary(info: CompletedToolInfo): VDOMNode {\n  const input = info.request.input as Input;\n  const result = info.result.result;\n  const totalAgents = input.agents?.length ?? 0;\n\n  if (result.status === \"error\") {\n    const errorPreview =\n      result.error.length \u003e 50\n        ? `${result.error.substring(0, 50)}...`\n        : result.error;\n    return d`${errorPreview}`;\n  }\n\n  return d`${totalAgents.toString()} agent${totalAgents === 1 ? \"\" : \"s\"}`;\n}",
