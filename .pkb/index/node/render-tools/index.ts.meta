    {
      "text": "export function renderToolResultSummaryExpansion(\n  info: CompletedToolInfo,\n): VDOMNode | undefined {\n  const toolName = info.request.toolName as StaticToolName;\n  switch (toolName) {\n    case \"edl\":\n      return EdlRender.renderResultSummaryExpansion(info);\n    default:\n      return undefined;\n  }\n}",
      "contextualizedText": "// node/render-tools/index.ts \u003e function renderToolResultSummaryExpansion\n\nexport function renderToolResultSummaryExpansion(\n  info: CompletedToolInfo,\n): VDOMNode | undefined {\n  const toolName = info.request.toolName as StaticToolName;\n  switch (toolName) {\n    case \"edl\":\n      return EdlRender.renderResultSummaryExpansion(info);\n    default:\n      return undefined;\n  }\n}",
      "headingContext": "node/render-tools/index.ts \u003e function renderToolResultSummaryExpansion",
