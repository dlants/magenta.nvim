      "endLine": 46,
      "endCol": 3
    },
    {
      "text": "function isError(result: ProviderToolResult): boolean {\n  return result.result.status === \"error\";\n}",
      "contextualizedText": "// node/render-tools/index.ts \u003e function isError\n\nfunction isError(result: ProviderToolResult): boolean {\n  return result.result.status === \"error\";\n}",
      "headingContext": "node/render-tools/index.ts \u003e function isError",
      "startLine": 48,
      "startCol": 1,
      "endLine": 50,
      "endCol": 2
    },
    {
      "text": "function formatTokenEstimate(result: ProviderToolResult): string {\n  const content =\n    result.result.status === \"error\"\n      ? result.result.error\n      : JSON.stringify(result.result.value);\n  return formatTokens(content.length);\n}",
      "contextualizedText": "// node/render-tools/index.ts \u003e function formatTokenEstimate\n\nfunction formatTokenEstimate(result: ProviderToolResult): string {\n  const content =\n    result.result.status === \"error\"\n      ? result.result.error\n      : JSON.stringify(result.result.value);\n  return formatTokens(content.length);\n}",
      "headingContext": "node/render-tools/index.ts \u003e function formatTokenEstimate",
      "startLine": 52,
      "startCol": 1,
      "endLine": 58,
      "endCol": 2
    },
    {
      "text": "export function renderToolSummary(\n  request: ToolRequest,\n  displayContext: DisplayContext,\n): VDOMNode {\n  const toolName = request.toolName as StaticToolName;\n\n  if (isMCPTool(toolName)) {\n    return MCPToolRender.renderSummary(request, displayContext);\n  }\n\n  switch (toolName) {\n    case \"get_file\":\n      return GetFileRender.renderSummary(request, displayContext);\n    case \"hover\":\n      return HoverRender.renderSummary(request, displayContext);\n    case \"find_references\":\n      return FindReferencesRender.renderSummary(request, displayContext);\n    case \"thread_title\":\n      return ThreadTitleRender.renderSummary(request, displayContext);\n    case \"edl\":\n      return EdlRender.renderSummary(request, displayContext);\n    case \"bash_command\":\n      return BashCommandRender.renderSummary(request, displayContext);\n    case \"spawn_subagents\":\n      return SpawnSubagentsRender.renderSummary(request, displayContext);\n    case \"yield_to_parent\":\n      return YieldToParentRender.renderSummary(request, displayContext);\n    case \"docs\":\n      return DocsRender.renderSummary(request, displayContext);\n    case \"run_script\": {\n      const input = request.input as RunScript.Input;\n      return d`🚀 run_script: ${input.scriptName}`;\n    }\n    case \"nvim_lua\":\n      return NvimLuaRender.renderSummary(request, displayContext);\n    case \"scratchpad\":\n      return d`📝 scratchpad`;\n    default:\n      assertUnreachable(toolName);\n  }\n}",
      "contextualizedText": "// node/render-tools/index.ts \u003e function renderToolSummary\n\nexport function renderToolSummary(\n  request: ToolRequest,\n  displayContext: DisplayContext,\n): VDOMNode {\n  const toolName = request.toolName as StaticToolName;\n\n  if (isMCPTool(toolName)) {\n    return MCPToolRender.renderSummary(request, displayContext);\n  }\n\n  switch (toolName) {\n    case \"get_file\":\n      return GetFileRender.renderSummary(request, displayContext);\n    case \"hover\":\n      return HoverRender.renderSummary(request, displayContext);\n    case \"find_references\":\n      return FindReferencesRender.renderSummary(request, displayContext);\n    case \"thread_title\":\n      return ThreadTitleRender.renderSummary(request, displayContext);\n    case \"edl\":\n      return EdlRender.renderSummary(request, displayContext);\n    case \"bash_command\":\n      return BashCommandRender.renderSummary(request, displayContext);\n    case \"spawn_subagents\":\n      return SpawnSubagentsRender.renderSummary(request, displayContext);\n    case \"yield_to_parent\":\n      return YieldToParentRender.renderSummary(request, displayContext);\n    case \"docs\":\n      return DocsRender.renderSummary(request, displayContext);\n    case \"run_script\": {\n      const input = request.input as RunScript.Input;\n      return d`🚀 run_script: ${input.scriptName}`;\n    }\n    case \"nvim_lua\":\n      return NvimLuaRender.renderSummary(request, displayContext);\n    case \"scratchpad\":\n      return d`📝 scratchpad`;\n    default:\n      assertUnreachable(toolName);\n  }\n}",
      "headingContext": "node/render-tools/index.ts \u003e function renderToolSummary",
      "startLine": 60,
      "startCol": 1,
      "endLine": 100,
      "endCol": 2
    },
    {
      "text": "export function renderToolInput(\n  request: ToolRequest,\n  displayContext: DisplayContext,\n  expanded: boolean,\n  inFlight: boolean,\n): VDOMNode | undefined {\n  const toolName = request.toolName as StaticToolName;\n\n  if (isMCPTool(toolName)) {\n    return undefined;\n  }\n\n  switch (toolName) {\n    case \"bash_command\":\n      return BashCommandRender.renderInput(request, displayContext, expanded);\n    case \"edl\":\n      return EdlRender.renderInput(request, displayContext, expanded, inFlight);\n    case \"nvim_lua\":\n      return NvimLuaRender.renderInput(request, displayContext, expanded);\n    case \"spawn_subagents\":\n      return SpawnSubagentsRender.renderInput(\n        request,\n        displayContext,\n        expanded,\n      );\n    default:\n      return undefined;\n  }\n}",
      "contextualizedText": "// node/render-tools/index.ts \u003e function renderToolInput\n\nexport function renderToolInput(\n  request: ToolRequest,\n  displayContext: DisplayContext,\n  expanded: boolean,\n  inFlight: boolean,\n): VDOMNode | undefined {\n  const toolName = request.toolName as StaticToolName;\n\n  if (isMCPTool(toolName)) {\n    return undefined;\n  }\n\n  switch (toolName) {\n    case \"bash_command\":\n      return BashCommandRender.renderInput(request, displayContext, expanded);\n    case \"edl\":\n      return EdlRender.renderInput(request, displayContext, expanded, inFlight);\n    case \"nvim_lua\":\n      return NvimLuaRender.renderInput(request, displayContext, expanded);\n    case \"spawn_subagents\":\n      return SpawnSubagentsRender.renderInput(\n        request,\n        displayContext,\n        expanded,\n      );\n    default:\n      return undefined;\n  }\n}",
      "headingContext": "node/render-tools/index.ts \u003e function renderToolInput",
      "startLine": 102,
      "startCol": 1,
      "endLine": 130,
      "endCol": 2
    },
    {
      "text": "export function renderToolInputSummaryExpansion(\n  request: ToolRequest,\n): VDOMNode | undefined {\n  const toolName = request.toolName as StaticToolName;\n  switch (toolName) {\n    case \"edl\":\n      return EdlRender.renderInputSummary(request);\n    default:\n      return undefined;\n  }\n}",
      "contextualizedText": "// node/render-tools/index.ts \u003e function renderToolInputSummaryExpansion\n\nexport function renderToolInputSummaryExpansion(\n  request: ToolRequest,\n): VDOMNode | undefined {\n  const toolName = request.toolName as StaticToolName;\n  switch (toolName) {\n    case \"edl\":\n      return EdlRender.renderInputSummary(request);\n    default:\n      return undefined;\n  }\n}",
