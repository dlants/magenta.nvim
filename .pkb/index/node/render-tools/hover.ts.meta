      "text": "import type {\n  CompletedToolInfo,\n  DisplayContext,\n  ToolRequest as UnionToolRequest,\n} from \"@magenta/core\";\nimport { d, type VDOMNode, withInlineCode } from \"../tea/view.ts\";\nimport {\n  displayPath,\n  resolveFilePath,\n  type UnresolvedFilePath,\n} from \"../utils/files.ts\";\n\ntype Input = {\n  filePath: UnresolvedFilePath;\n  symbol: string;\n  context?: string;\n};",
