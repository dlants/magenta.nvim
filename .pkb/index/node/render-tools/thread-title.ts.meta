      "text": "import type {\n  CompletedToolInfo,\n  DisplayContext,\n  ToolRequest as UnionToolRequest,\n} from \"@magenta/core\";\nimport { d, type VDOMNode } from \"../tea/view.ts\";\n\ntype Input = {\n  title: string;\n};",
