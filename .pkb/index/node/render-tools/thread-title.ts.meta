    {
      "text": "export function renderSummary(\n  request: UnionToolRequest,\n  _displayContext: DisplayContext,\n): VDOMNode {\n  const input = request.input as Input;\n  return d`📝 Setting thread title: \"${input.title}\"`;\n}",
