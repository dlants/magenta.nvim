{
  "blobSha": "03779b97b37a93bcdcb413ba08fd56b60b25733f",
  "modelName": "voyage-context-4@256",
  "chunks": [
    {
      "text": "import type {\n  CompletedToolInfo,\n  DisplayContext,\n  Edl,\n  ToolRequestId,\n  ToolRequest as UnionToolRequest,\n} from \"@magenta/core\";\nimport type { Msg as ThreadMsg, ToolViewState } from \"../chat/thread.ts\";\nimport type { Dispatch } from \"../tea/tea.ts\";\nimport {\n  d,\n  type VDOMNode,\n  withBindings,\n  withCode,\n  withError,\n  withInlineCode,\n  withMuted,\n} from \"../tea/view.ts\";\nimport {\n  displayPath,\n  type HomeDir,\n  type NvimCwd,\n  resolveFilePath,\n  type UnresolvedFilePath,\n} from \"../utils/files.ts\";\n\ntype Input = {\n  script: string;\n};\n\nconst PREVIEW_MAX_LINES = 10;\nconst PREVIEW_MAX_LINE_LENGTH = 80;",
      "contextualizedText": "// node/render-tools/edl.ts\n\nimport type {\n  CompletedToolInfo,\n  DisplayContext,\n  Edl,\n  ToolRequestId,\n  ToolRequest as UnionToolRequest,\n} from \"@magenta/core\";\nimport type { Msg as ThreadMsg, ToolViewState } from \"../chat/thread.ts\";\nimport type { Dispatch } from \"../tea/tea.ts\";\nimport {\n  d,\n  type VDOMNode,\n  withBindings,\n  withCode,\n  withError,\n  withInlineCode,\n  withMuted,\n} from \"../tea/view.ts\";\nimport {\n  displayPath,\n  type HomeDir,\n  type NvimCwd,\n  resolveFilePath,\n  type UnresolvedFilePath,\n} from \"../utils/files.ts\";\n\ntype Input = {\n  script: string;\n};\n\nconst PREVIEW_MAX_LINES = 10;\nconst PREVIEW_MAX_LINE_LENGTH = 80;",
      "headingContext": "node/render-tools/edl.ts",
      "startLine": 1,
      "startCol": 1,
      "endLine": 32,
      "endCol": 36
    },
    {
      "text": "function abridgeScript(script: string): string {\n  const lines = script.split(\"\\n\");\n  const preview = lines\n    .slice(-PREVIEW_MAX_LINES)\n    .map((line) =\u003e\n      line.length \u003e PREVIEW_MAX_LINE_LENGTH\n        ? `${line.substring(0, PREVIEW_MAX_LINE_LENGTH)}...`\n        : line,\n    );\n  if (lines.length \u003e PREVIEW_MAX_LINES) {\n    preview.unshift(`... (${lines.length - PREVIEW_MAX_LINES} more lines)`);\n  }\n  return preview.join(\"\\n\");\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function abridgeScript\n\nfunction abridgeScript(script: string): string {\n  const lines = script.split(\"\\n\");\n  const preview = lines\n    .slice(-PREVIEW_MAX_LINES)\n    .map((line) =\u003e\n      line.length \u003e PREVIEW_MAX_LINE_LENGTH\n        ? `${line.substring(0, PREVIEW_MAX_LINE_LENGTH)}...`\n        : line,\n    );\n  if (lines.length \u003e PREVIEW_MAX_LINES) {\n    preview.unshift(`... (${lines.length - PREVIEW_MAX_LINES} more lines)`);\n  }\n  return preview.join(\"\\n\");\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function abridgeScript",
      "startLine": 34,
      "startCol": 1,
      "endLine": 47,
      "endCol": 2
    },
    {
      "text": "function isError(result: CompletedToolInfo[\"result\"]): boolean {\n  return result.result.status === \"error\";\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function isError\n\nfunction isError(result: CompletedToolInfo[\"result\"]): boolean {\n  return result.result.status === \"error\";\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function isError",
      "startLine": 49,
      "startCol": 1,
      "endLine": 51,
      "endCol": 2
    },
    {
      "text": "function extractEdlDisplayData(\n  info: CompletedToolInfo,\n): Edl.EdlDisplayData | undefined {\n  if (info.structuredResult.toolName === \"edl\") {\n    return (info.structuredResult as Edl.StructuredResult).displayData;\n  }\n  return undefined;\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function extractEdlDisplayData\n\nfunction extractEdlDisplayData(\n  info: CompletedToolInfo,\n): Edl.EdlDisplayData | undefined {\n  if (info.structuredResult.toolName === \"edl\") {\n    return (info.structuredResult as Edl.StructuredResult).displayData;\n  }\n  return undefined;\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function extractEdlDisplayData",
      "startLine": 53,
      "startCol": 1,
      "endLine": 60,
      "endCol": 2
    },
    {
      "text": "function extractFormattedResult(info: CompletedToolInfo): string {\n  if (info.structuredResult.toolName === \"edl\") {\n    return (info.structuredResult as Edl.StructuredResult).formattedResult;\n  }\n  if (info.result.result.status !== \"ok\") {\n    return info.result.result.error;\n  }\n  return \"\";\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function extractFormattedResult\n\nfunction extractFormattedResult(info: CompletedToolInfo): string {\n  if (info.structuredResult.toolName === \"edl\") {\n    return (info.structuredResult as Edl.StructuredResult).formattedResult;\n  }\n  if (info.result.result.status !== \"ok\") {\n    return info.result.result.error;\n  }\n  return \"\";\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function extractFormattedResult",
      "startLine": 62,
      "startCol": 1,
      "endLine": 70,
      "endCol": 2
    },
    {
      "text": "export function renderSummary(\n  _request: UnionToolRequest,\n  _displayContext: DisplayContext,\n): VDOMNode {\n  return d`📝 edl script`;\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderSummary\n\nexport function renderSummary(\n  _request: UnionToolRequest,\n  _displayContext: DisplayContext,\n): VDOMNode {\n  return d`📝 edl script`;\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function renderSummary",
      "startLine": 72,
      "startCol": 1,
      "endLine": 77,
      "endCol": 2
    },
    {
      "text": "export function renderInput(\n  request: UnionToolRequest,\n  _displayContext: DisplayContext,\n  expanded: boolean,\n  inFlight: boolean,\n): VDOMNode | undefined {\n  const input = request.input as Input;\n  if (expanded) {\n    return withCode(d`${input.script}`);\n  }\n  // Once the tool has finished, hide the streaming preview so the request\n  // collapses to a single line. The raw script remains available via the\n  // input-summary expansion.\n  if (!inFlight) {\n    return undefined;\n  }\n  const abridged = abridgeScript(input.script);\n  return withCode(d`${abridged}`);\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderInput\n\nexport function renderInput(\n  request: UnionToolRequest,\n  _displayContext: DisplayContext,\n  expanded: boolean,\n  inFlight: boolean,\n): VDOMNode | undefined {\n  const input = request.input as Input;\n  if (expanded) {\n    return withCode(d`${input.script}`);\n  }\n  // Once the tool has finished, hide the streaming preview so the request\n  // collapses to a single line. The raw script remains available via the\n  // input-summary expansion.\n  if (!inFlight) {\n    return undefined;\n  }\n  const abridged = abridgeScript(input.script);\n  return withCode(d`${abridged}`);\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function renderInput",
      "startLine": 79,
      "startCol": 1,
      "endLine": 97,
      "endCol": 2
    },
    {
      "text": "export function renderInputSummary(request: UnionToolRequest): VDOMNode {\n  const input = request.input as Input;\n  return withCode(d`${input.script}`);\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderInputSummary\n\nexport function renderInputSummary(request: UnionToolRequest): VDOMNode {\n  const input = request.input as Input;\n  return withCode(d`${input.script}`);\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function renderInputSummary",
      "startLine": 99,
      "startCol": 1,
      "endLine": 102,
      "endCol": 2
    },
    {
      "text": "export function renderResultSummaryExpansion(\n  info: CompletedToolInfo,\n): VDOMNode {\n  return withCode(d`${extractFormattedResult(info)}`);\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderResultSummaryExpansion\n\nexport function renderResultSummaryExpansion(\n  info: CompletedToolInfo,\n): VDOMNode {\n  return withCode(d`${extractFormattedResult(info)}`);\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function renderResultSummaryExpansion",
      "startLine": 104,
      "startCol": 1,
      "endLine": 108,
      "endCol": 2
    },
    {
      "text": "export function renderResultSummary(info: CompletedToolInfo): VDOMNode {\n  const data = extractEdlDisplayData(info);\n\n  if (data) {\n    const totalMutations = data.mutations.reduce(\n      (acc, m) =\u003e\n        acc +\n        m.summary.replacements +\n        m.summary.insertions +\n        m.summary.deletions,\n      0,\n    );\n    const filesCount = data.mutations.length;\n    const fileErrorCount = data.fileErrors.length;\n    const errorSuffix =\n      fileErrorCount \u003e 0\n        ? ` (${String(fileErrorCount)} file error${fileErrorCount !== 1 ? \"s\" : \"\"})`\n        : \"\";\n    const totalLinesAdded = data.mutations.reduce(\n      (acc, m) =\u003e acc + m.summary.linesAdded,\n      0,\n    );\n    const totalLinesRemoved = data.mutations.reduce(\n      (acc, m) =\u003e acc + m.summary.linesRemoved,\n      0,\n    );\n    return d`edl: ${String(totalMutations)} mutations in ${String(filesCount)} file${filesCount !== 1 ? \"s\" : \"\"}, +${String(totalLinesAdded)}/-${String(totalLinesRemoved)} lines${errorSuffix}`;\n  }\n\n  return d`edl script`;\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderResultSummary\n\nexport function renderResultSummary(info: CompletedToolInfo): VDOMNode {\n  const data = extractEdlDisplayData(info);\n\n  if (data) {\n    const totalMutations = data.mutations.reduce(\n      (acc, m) =\u003e\n        acc +\n        m.summary.replacements +\n        m.summary.insertions +\n        m.summary.deletions,\n      0,\n    );\n    const filesCount = data.mutations.length;\n    const fileErrorCount = data.fileErrors.length;\n    const errorSuffix =\n      fileErrorCount \u003e 0\n        ? ` (${String(fileErrorCount)} file error${fileErrorCount !== 1 ? \"s\" : \"\"})`\n        : \"\";\n    const totalLinesAdded = data.mutations.reduce(\n      (acc, m) =\u003e acc + m.summary.linesAdded,\n      0,\n    );\n    const totalLinesRemoved = data.mutations.reduce(\n      (acc, m) =\u003e acc + m.summary.linesRemoved,\n      0,\n    );\n    return d`edl: ${String(totalMutations)} mutations in ${String(filesCount)} file${filesCount !== 1 ? \"s\" : \"\"}, +${String(totalLinesAdded)}/-${String(totalLinesRemoved)} lines${errorSuffix}`;\n  }\n\n  return d`edl script`;\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function renderResultSummary",
      "startLine": 110,
      "startCol": 1,
      "endLine": 140,
      "endCol": 2
    },
    {
      "text": "function renderTrace(data: Edl.EdlDisplayData): VDOMNode {\n  const lines: VDOMNode[] = [];\n\n  if (data.trace.length \u003e 0) {\n    lines.push(withMuted(d`Trace:\\n`));\n    for (const t of data.trace) {\n      lines.push(d`  ${withInlineCode(d`${t.command}`)} → ${t.snippet}\\n`);\n    }\n  }\n\n  if (data.fileErrors.length \u003e 0) {\n    if (lines.length \u003e 0) lines.push(d`\\n`);\n    lines.push(withMuted(d`Errors:\\n`));\n    for (const fe of data.fileErrors) {\n      lines.push(\n        d`  ❌ ${withInlineCode(d`${fe.path}`)} ${withError(d`(${String(fe.failedMutations)} mutation${fe.failedMutations !== 1 ? \"s\" : \"\"} failed)`)}: ${fe.error}\\n`,\n      );\n    }\n  }\n\n  if (lines.length === 0) {\n    lines.push(withMuted(d`(no trace)\\n`));\n  }\n\n  return d`${lines}`;\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderTrace\n\nfunction renderTrace(data: Edl.EdlDisplayData): VDOMNode {\n  const lines: VDOMNode[] = [];\n\n  if (data.trace.length \u003e 0) {\n    lines.push(withMuted(d`Trace:\\n`));\n    for (const t of data.trace) {\n      lines.push(d`  ${withInlineCode(d`${t.command}`)} → ${t.snippet}\\n`);\n    }\n  }\n\n  if (data.fileErrors.length \u003e 0) {\n    if (lines.length \u003e 0) lines.push(d`\\n`);\n    lines.push(withMuted(d`Errors:\\n`));\n    for (const fe of data.fileErrors) {\n      lines.push(\n        d`  ❌ ${withInlineCode(d`${fe.path}`)} ${withError(d`(${String(fe.failedMutations)} mutation${fe.failedMutations !== 1 ? \"s\" : \"\"} failed)`)}: ${fe.error}\\n`,\n      );\n    }\n  }\n\n  if (lines.length === 0) {\n    lines.push(withMuted(d`(no trace)\\n`));\n  }\n\n  return d`${lines}`;\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function renderTrace",
      "startLine": 142,
      "startCol": 1,
      "endLine": 167,
      "endCol": 2
    },
    {
      "text": "export function renderResult(\n  info: CompletedToolInfo,\n  context: {\n    threadDispatch: Dispatch\u003cThreadMsg\u003e;\n    cwd: NvimCwd;\n    homeDir: HomeDir;\n  },\n  toolViewState: ToolViewState,\n  toolRequestId: ToolRequestId,\n): VDOMNode | undefined {\n  const expanded = toolViewState.resultExpanded;\n  const data = extractEdlDisplayData(info);",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderResult\n\nexport function renderResult(\n  info: CompletedToolInfo,\n  context: {\n    threadDispatch: Dispatch\u003cThreadMsg\u003e;\n    cwd: NvimCwd;\n    homeDir: HomeDir;\n  },\n  toolViewState: ToolViewState,\n  toolRequestId: ToolRequestId,\n): VDOMNode | undefined {\n  const expanded = toolViewState.resultExpanded;\n  const data = extractEdlDisplayData(info);",
      "headingContext": "node/render-tools/edl.ts \u003e function renderResult",
      "startLine": 169,
      "startCol": 1,
      "endLine": 180,
      "endCol": 44
    },
    {
      "text": "  const toggleExpanded = () =\u003e\n    context.threadDispatch({\n      type: \"toggle-tool-result\",\n      toolRequestId,\n    })",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderResult \u003e function toggleExpanded\n\n  const toggleExpanded = () =\u003e\n    context.threadDispatch({\n      type: \"toggle-tool-result\",\n      toolRequestId,\n    })",
      "headingContext": "node/render-tools/edl.ts \u003e function renderResult \u003e function toggleExpanded",
      "startLine": 182,
      "startCol": 1,
      "endLine": 186,
      "endCol": 7
    },
    {
      "text": "if (!data || isError(info.result)) {\n    if (expanded) {\n      return withBindings(withCode(d`${extractFormattedResult(info)}`), {\n        \"=\": toggleExpanded,\n      });\n    }\n    return undefined;\n  }\n\n  if (expanded) {\n    return withBindings(renderTrace(data), { \"=\": toggleExpanded });\n  }\n\n  const rows: VDOMNode[] = [];\n\n  for (const { path, summary } of data.mutations) {\n    const parts: string[] = [];\n    if (summary.replacements \u003e 0) parts.push(`${summary.replacements} replace`);\n    if (summary.insertions \u003e 0) parts.push(`${summary.insertions} insert`);\n    if (summary.deletions \u003e 0) parts.push(`${summary.deletions} delete`);\n\n    const absPath = resolveFilePath(\n      context.cwd,\n      path as UnresolvedFilePath,\n      context.homeDir,\n    );\n    const shownPath = displayPath(context.cwd, absPath, context.homeDir);\n\n    rows.push(\n      withBindings(\n        d`${withInlineCode(d`${shownPath}`)} ${parts.join(\", \")} ${withMuted(d`(+${String(summary.linesAdded)}/-${String(summary.linesRemoved)})`)}\\n`,\n        {\n          \"\u003cCR\u003e\": () =\u003e\n            context.threadDispatch({\n              type: \"open-edit-file\",\n              filePath: path as UnresolvedFilePath,\n            }),\n          \"=\": toggleExpanded,\n        },\n      ),\n    );\n  }\n\n  for (const { path, error, failedMutations } of data.fileErrors) {\n    const absPath = resolveFilePath(\n      context.cwd,\n      path as UnresolvedFilePath,\n      context.homeDir,\n    );\n    const shownPath = displayPath(context.cwd, absPath, context.homeDir);\n\n    rows.push(\n      withBindings(\n        d`❌ ${withInlineCode(d`${shownPath}`)} ${withError(d`${String(failedMutations)} mutation${failedMutations !== 1 ? \"s\" : \"\"} failed`)}: ${error}\\n`,\n        {\n          \"\u003cCR\u003e\": () =\u003e\n            context.threadDispatch({\n              type: \"open-edit-file\",\n              filePath: path as UnresolvedFilePath,\n            }),\n          \"=\": toggleExpanded,\n        },\n      ),\n    );\n  }",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderResult\n\nif (!data || isError(info.result)) {\n    if (expanded) {\n      return withBindings(withCode(d`${extractFormattedResult(info)}`), {\n        \"=\": toggleExpanded,\n      });\n    }\n    return undefined;\n  }\n\n  if (expanded) {\n    return withBindings(renderTrace(data), { \"=\": toggleExpanded });\n  }\n\n  const rows: VDOMNode[] = [];\n\n  for (const { path, summary } of data.mutations) {\n    const parts: string[] = [];\n    if (summary.replacements \u003e 0) parts.push(`${summary.replacements} replace`);\n    if (summary.insertions \u003e 0) parts.push(`${summary.insertions} insert`);\n    if (summary.deletions \u003e 0) parts.push(`${summary.deletions} delete`);\n\n    const absPath = resolveFilePath(\n      context.cwd,\n      path as UnresolvedFilePath,\n      context.homeDir,\n    );\n    const shownPath = displayPath(context.cwd, absPath, context.homeDir);\n\n    rows.push(\n      withBindings(\n        d`${withInlineCode(d`${shownPath}`)} ${parts.join(\", \")} ${withMuted(d`(+${String(summary.linesAdded)}/-${String(summary.linesRemoved)})`)}\\n`,\n        {\n          \"\u003cCR\u003e\": () =\u003e\n            context.threadDispatch({\n              type: \"open-edit-file\",\n              filePath: path as UnresolvedFilePath,\n            }),\n          \"=\": toggleExpanded,\n        },\n      ),\n    );\n  }\n\n  for (const { path, error, failedMutations } of data.fileErrors) {\n    const absPath = resolveFilePath(\n      context.cwd,\n      path as UnresolvedFilePath,\n      context.homeDir,\n    );\n    const shownPath = displayPath(context.cwd, absPath, context.homeDir);\n\n    rows.push(\n      withBindings(\n        d`❌ ${withInlineCode(d`${shownPath}`)} ${withError(d`${String(failedMutations)} mutation${failedMutations !== 1 ? \"s\" : \"\"} failed`)}: ${error}\\n`,\n        {\n          \"\u003cCR\u003e\": () =\u003e\n            context.threadDispatch({\n              type: \"open-edit-file\",\n              filePath: path as UnresolvedFilePath,\n            }),\n          \"=\": toggleExpanded,\n        },\n      ),\n    );\n  }",
      "headingContext": "node/render-tools/edl.ts \u003e function renderResult",
      "startLine": 188,
      "startCol": 3,
      "endLine": 252,
      "endCol": 4
    },
    {
      "text": "if (data.finalSelectionCount !== undefined) {\n    rows.push(\n      withBindings(\n        withMuted(\n          d`Final selection: ${String(data.finalSelectionCount)} range${data.finalSelectionCount !== 1 ? \"s\" : \"\"}\\n`,\n        ),\n        { \"=\": toggleExpanded },\n      ),\n    );\n  }\n\n  if (rows.length === 0) return undefined;\n\n  return d`${rows}`;\n}",
      "contextualizedText": "// node/render-tools/edl.ts \u003e function renderResult\n\nif (data.finalSelectionCount !== undefined) {\n    rows.push(\n      withBindings(\n        withMuted(\n          d`Final selection: ${String(data.finalSelectionCount)} range${data.finalSelectionCount !== 1 ? \"s\" : \"\"}\\n`,\n        ),\n        { \"=\": toggleExpanded },\n      ),\n    );\n  }\n\n  if (rows.length === 0) return undefined;\n\n  return d`${rows}`;\n}",
      "headingContext": "node/render-tools/edl.ts \u003e function renderResult",
      "startLine": 254,
      "startCol": 3,
      "endLine": 268,
      "endCol": 2
    }
  ]
}
