      "text": "subagent2Request.respond({\n        stopReason: \"tool_use\",\n        text: \"I'll yield the result back to the parent.\",\n        toolRequests: [\n          {\n            status: \"ok\",\n            value: {\n              id: \"yield-2\" as ToolRequestId,\n              toolName: \"yield_to_parent\" as ToolName,\n              input: {\n                result: \"Hello from subagent 2\",\n              },\n            },\n          },\n        ],\n      });\n\n      // Verify both agents have completed\n      await driver.assertDisplayBufferContains(\"✅ 2 agents\");\n    });\n  });\n\n  it(\"spawn_subagents progress view allows clicking to navigate to child thread\"",
      "contextualizedText": "// node/render-tools/spawn-subagents.test.ts\n\nsubagent2Request.respond({\n        stopReason: \"tool_use\",\n        text: \"I'll yield the result back to the parent.\",\n        toolRequests: [\n          {\n            status: \"ok\",\n            value: {\n              id: \"yield-2\" as ToolRequestId,\n              toolName: \"yield_to_parent\" as ToolName,\n              input: {\n                result: \"Hello from subagent 2\",\n              },\n            },\n          },\n        ],\n      });\n\n      // Verify both agents have completed\n      await driver.assertDisplayBufferContains(\"✅ 2 agents\");\n    });\n  });\n\n  it(\"spawn_subagents progress view allows clicking to navigate to child thread\"",
