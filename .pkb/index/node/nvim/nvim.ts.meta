    {
      "text": "export function getOption(option: string, nvim: Nvim) {\n  return nvim.call(\"nvim_get_option\", [option]);\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function getOption\n\nexport function getOption(option: string, nvim: Nvim) {\n  return nvim.call(\"nvim_get_option\", [option]);\n}",
