    },
    {
      "text": "export async function getcwd(nvim: Nvim): Promise\u003cNvimCwd\u003e {\n  const res = await nvim.call(\"nvim_exec2\", [\n    \"echo getcwd()\",\n    { output: true },\n  ]);\n  if (typeof res.output !== \"string\") {\n    throw new Error(`Unable to get cwd`);\n  }\n  return res.output as NvimCwd;\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function getcwd\n\nexport async function getcwd(nvim: Nvim): Promise\u003cNvimCwd\u003e {\n  const res = await nvim.call(\"nvim_exec2\", [\n    \"echo getcwd()\",\n    { output: true },\n  ]);\n  if (typeof res.output !== \"string\") {\n    throw new Error(`Unable to get cwd`);\n  }\n  return res.output as NvimCwd;\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function getcwd",
      "startLine": 34,
      "startCol": 1,
      "endLine": 43,
      "endCol": 2
    },
    {
      "text": "export async function mode(nvim: Nvim) {\n  const res = await nvim.call(\"nvim_exec2\", [\"echo mode()\", { output: true }]);\n  if (typeof res.output !== \"string\") {\n    throw new Error(`Unable to get mode`);\n  }\n  return res.output;\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function mode\n\nexport async function mode(nvim: Nvim) {\n  const res = await nvim.call(\"nvim_exec2\", [\"echo mode()\", { output: true }]);\n  if (typeof res.output !== \"string\") {\n    throw new Error(`Unable to get mode`);\n  }\n  return res.output;\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function mode",
      "startLine": 45,
      "startCol": 1,
      "endLine": 51,
      "endCol": 2
    },
    {
      "text": "export async function getpos(\n  nvim: Nvim,\n  str: string,\n): Promise\u003cPosition1IndexedCol1Indexed\u003e {\n  const res = await nvim.call(\"nvim_exec2\", [\n    `echo getpos(\"${str}\")`,\n    { output: true },\n  ]);\n  if (typeof res.output !== \"string\") {\n    throw new Error(`Unable to getpos`);\n  }\n  const posStr = res.output;\n\n  const [_, row, col] = posStr\n    .replace(/[[\\]]/g, \"\")\n    .split(\",\")\n    .map((n) =\u003e parseInt(n.trim(), 10));\n\n  return {\n    row,\n    col,\n  } as Position1IndexedCol1Indexed;\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function getpos\n\nexport async function getpos(\n  nvim: Nvim,\n  str: string,\n): Promise\u003cPosition1IndexedCol1Indexed\u003e {\n  const res = await nvim.call(\"nvim_exec2\", [\n    `echo getpos(\"${str}\")`,\n    { output: true },\n  ]);\n  if (typeof res.output !== \"string\") {\n    throw new Error(`Unable to getpos`);\n  }\n  const posStr = res.output;\n\n  const [_, row, col] = posStr\n    .replace(/[[\\]]/g, \"\")\n    .split(\",\")\n    .map((n) =\u003e parseInt(n.trim(), 10));\n\n  return {\n    row,\n    col,\n  } as Position1IndexedCol1Indexed;\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function getpos",
      "startLine": 53,
      "startCol": 1,
      "endLine": 75,
      "endCol": 2
    },
    {
      "text": "export function diffthis(nvim: Nvim) {\n  return nvim.call(\"nvim_command\", [\"diffthis\"]);\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function diffthis\n\nexport function diffthis(nvim: Nvim) {\n  return nvim.call(\"nvim_command\", [\"diffthis\"]);\n}",
