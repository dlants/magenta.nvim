      "text": "import type { NvimCwd } from \"../utils/files.ts\";\nimport { type BufNr, NvimBuffer } from \"./buffer.ts\";\nimport type { Nvim } from \"./nvim-node/index.ts\";\nimport {\n  NvimWindow,\n  type Position1IndexedCol1Indexed,\n  type WindowId,\n} from \"./window.ts\";",
      "contextualizedText": "// node/nvim/nvim.ts\n\nimport type { NvimCwd } from \"../utils/files.ts\";\nimport { type BufNr, NvimBuffer } from \"./buffer.ts\";\nimport type { Nvim } from \"./nvim-node/index.ts\";\nimport {\n  NvimWindow,\n  type Position1IndexedCol1Indexed,\n  type WindowId,\n} from \"./window.ts\";",
