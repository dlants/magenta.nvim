    },
    {
      "text": "export interface QuickfixEntry {\n  bufnr: number;\n  lnum: number;\n  col: number;\n  text: string;\n  type?: string;\n  filename?: string;\n  valid?: number;\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e interface QuickfixEntry\n\nexport interface QuickfixEntry {\n  bufnr: number;\n  lnum: number;\n  col: number;\n  text: string;\n  type?: string;\n  filename?: string;\n  valid?: number;\n}",
      "headingContext": "node/nvim/nvim.ts \u003e interface QuickfixEntry",
      "startLine": 81,
      "startCol": 1,
      "endLine": 89,
      "endCol": 2
    },
    {
      "text": "export async function getQuickfixList(nvim: Nvim): Promise\u003cQuickfixEntry[]\u003e {\n  const qflist = await nvim.call(\"nvim_exec2\", [\n    \"echo json_encode(getqflist())\",\n    { output: true },\n  ]);\n  if (typeof qflist.output !== \"string\") {\n    throw new Error(\"Unable to get quickfix list\");\n  }\n  return JSON.parse(qflist.output) as QuickfixEntry[];\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function getQuickfixList\n\nexport async function getQuickfixList(nvim: Nvim): Promise\u003cQuickfixEntry[]\u003e {\n  const qflist = await nvim.call(\"nvim_exec2\", [\n    \"echo json_encode(getqflist())\",\n    { output: true },\n  ]);\n  if (typeof qflist.output !== \"string\") {\n    throw new Error(\"Unable to get quickfix list\");\n  }\n  return JSON.parse(qflist.output) as QuickfixEntry[];\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function getQuickfixList",
      "startLine": 91,
      "startCol": 1,
      "endLine": 100,
      "endCol": 2
    },
    {
      "text": "export async function quickfixListToString(\n  entries: QuickfixEntry[],\n  nvim: Nvim,\n): Promise\u003cstring\u003e {\n  const lines: string[] = [];\n\n  for (const entry of entries) {\n    let filename: string;\n    if (entry.filename) {\n      filename = entry.filename;\n    } else if (entry.bufnr \u003e 0) {\n      // Get the filename from buffer number\n      const bufname = await nvim.call(\"nvim_buf_get_name\", [entry.bufnr]);\n      filename = bufname ? bufname : `buffer ${entry.bufnr}`;\n    } else {\n      filename = `buffer ${entry.bufnr}`;\n    }\n\n    const line = entry.lnum \u003e 0 ? `:${entry.lnum}` : \"\";\n    const col = entry.col \u003e 0 ? `:${entry.col}` : \"\";\n    lines.push(`${filename}${line}${col}: ${entry.text}`);\n  }\n\n  return lines.join(\"\\n\");\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function quickfixListToString\n\nexport async function quickfixListToString(\n  entries: QuickfixEntry[],\n  nvim: Nvim,\n): Promise\u003cstring\u003e {\n  const lines: string[] = [];\n\n  for (const entry of entries) {\n    let filename: string;\n    if (entry.filename) {\n      filename = entry.filename;\n    } else if (entry.bufnr \u003e 0) {\n      // Get the filename from buffer number\n      const bufname = await nvim.call(\"nvim_buf_get_name\", [entry.bufnr]);\n      filename = bufname ? bufname : `buffer ${entry.bufnr}`;\n    } else {\n      filename = `buffer ${entry.bufnr}`;\n    }\n\n    const line = entry.lnum \u003e 0 ? `:${entry.lnum}` : \"\";\n    const col = entry.col \u003e 0 ? `:${entry.col}` : \"\";\n    lines.push(`${filename}${line}${col}: ${entry.text}`);\n  }\n\n  return lines.join(\"\\n\");\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function quickfixListToString",
      "startLine": 102,
      "startCol": 1,
      "endLine": 126,
      "endCol": 2
    },
    {
      "text": "/** Capture the scroll/cursor view (winsaveview) of every window currently\n * displaying `bufId`. Returns an opaque value to pass back to restoreWinViews.\n * No-op (empty result) when the buffer is not visible in any window. */\nexport async function saveWinViews(nvim: Nvim, bufId: BufNr): Promise\u003cunknown\u003e {\n  return nvim.call(\"nvim_exec_lua\", [\n    `\nlocal bufid = ...\nlocal res = {}\nlocal lastline = vim.api.nvim_buf_line_count(bufid)\nfor _, win in ipairs(vim.fn.win_findbuf(bufid)) do\n  local v = vim.api.nvim_win_call(win, function() return vim.fn.winsaveview() end)\n  table.insert(res, { win = win, view = v, atBottom = (v.lnum \u003e= lastline) })\nend\nreturn res\n`,\n    [bufId],\n  ]);\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function saveWinViews\n\n/** Capture the scroll/cursor view (winsaveview) of every window currently\n * displaying `bufId`. Returns an opaque value to pass back to restoreWinViews.\n * No-op (empty result) when the buffer is not visible in any window. */\nexport async function saveWinViews(nvim: Nvim, bufId: BufNr): Promise\u003cunknown\u003e {\n  return nvim.call(\"nvim_exec_lua\", [\n    `\nlocal bufid = ...\nlocal res = {}\nlocal lastline = vim.api.nvim_buf_line_count(bufid)\nfor _, win in ipairs(vim.fn.win_findbuf(bufid)) do\n  local v = vim.api.nvim_win_call(win, function() return vim.fn.winsaveview() end)\n  table.insert(res, { win = win, view = v, atBottom = (v.lnum \u003e= lastline) })\nend\nreturn res\n`,\n    [bufId],\n  ]);\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function saveWinViews",
      "startLine": 128,
      "startCol": 1,
      "endLine": 145,
      "endCol": 2
    },
    {
      "text": "/** Restore views captured by saveWinViews, but only for windows that are still\n * valid and still display `bufId` (so we don't clobber a window the user moved\n * to a different buffer). */\nexport async function restoreWinViews(\n  nvim: Nvim,\n  bufId: BufNr,\n  saved: unknown,\n): Promise\u003cvoid\u003e {\n  await nvim.call(\"nvim_exec_lua\", [\n    `\nlocal bufid, saved = ...\nfor _, item in ipairs(saved) do\n  if vim.api.nvim_win_is_valid(item.win) and vim.api.nvim_win_get_buf(item.win) == bufid then\n    vim.api.nvim_win_call(item.win, function()\n      if item.atBottom then\n        -- cursor was pinned to the last line: follow the new bottom as content streams in\n        vim.cmd(\"normal! G\")\n      else\n        vim.fn.winrestview(item.view)\n      end\n    end)\n  end\nend\n`,\n    [bufId, saved],\n  ]);\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function restoreWinViews\n\n/** Restore views captured by saveWinViews, but only for windows that are still\n * valid and still display `bufId` (so we don't clobber a window the user moved\n * to a different buffer). */\nexport async function restoreWinViews(\n  nvim: Nvim,\n  bufId: BufNr,\n  saved: unknown,\n): Promise\u003cvoid\u003e {\n  await nvim.call(\"nvim_exec_lua\", [\n    `\nlocal bufid, saved = ...\nfor _, item in ipairs(saved) do\n  if vim.api.nvim_win_is_valid(item.win) and vim.api.nvim_win_get_buf(item.win) == bufid then\n    vim.api.nvim_win_call(item.win, function()\n      if item.atBottom then\n        -- cursor was pinned to the last line: follow the new bottom as content streams in\n        vim.cmd(\"normal! G\")\n      else\n        vim.fn.winrestview(item.view)\n      end\n    end)\n  end\nend\n`,\n    [bufId, saved],\n  ]);\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function restoreWinViews",
      "startLine": 147,
      "startCol": 1,
      "endLine": 173,
      "endCol": 2
    },
    {
      "text": "export async function notify(nvim: Nvim, message: string) {\n  const luaScript = `\n      vim.notify(\n        [[${message}]],\n        vim.log.levels.INFO\n      )\n    `;\n\n  return nvim.call(\"nvim_exec_lua\", [luaScript, []]);\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function notify\n\nexport async function notify(nvim: Nvim, message: string) {\n  const luaScript = `\n      vim.notify(\n        [[${message}]],\n        vim.log.levels.INFO\n      )\n    `;\n\n  return nvim.call(\"nvim_exec_lua\", [luaScript, []]);\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function notify",
      "startLine": 175,
      "startCol": 1,
      "endLine": 184,
      "endCol": 2
    },
    {
      "text": "export function notifyErr(nvim: Nvim, err: Error | string, ...rest: unknown[]) {\n  return nvim.call(\"nvim_notify\", [\n    `Unexpected error:\n${err instanceof Error ? err.message : JSON.stringify(err)}\n${err instanceof Error ? err.stack : \"\"}\n${rest.length ? JSON.stringify(rest) : \"\"}`,\n    3,\n    {},\n  ]);\n}",
      "contextualizedText": "// node/nvim/nvim.ts \u003e function notifyErr\n\nexport function notifyErr(nvim: Nvim, err: Error | string, ...rest: unknown[]) {\n  return nvim.call(\"nvim_notify\", [\n    `Unexpected error:\n${err instanceof Error ? err.message : JSON.stringify(err)}\n${err instanceof Error ? err.stack : \"\"}\n${rest.length ? JSON.stringify(rest) : \"\"}`,\n    3,\n    {},\n  ]);\n}",
      "headingContext": "node/nvim/nvim.ts \u003e function notifyErr",
      "startLine": 186,
      "startCol": 1,
      "endLine": 195,
