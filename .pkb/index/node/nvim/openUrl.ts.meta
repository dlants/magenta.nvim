      "text": "export async function openUrl(url: string, nvim: Nvim): Promise\u003cvoid\u003e {\n  const escaped = url.replace(/\\\\/g, \"\\\\\\\\\").replace(/\"/g, '\\\\\"');\n  await nvim.call(\"nvim_exec_lua\", [`vim.ui.open(\"${escaped}\")`, []]);\n}",
