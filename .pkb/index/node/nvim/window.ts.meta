      "contextualizedText": "// node/nvim/window.ts \u003e class NvimWindow \u003e method buffer\n\n  async buffer(): Promise\u003cNvimBuffer\u003e {\n    const bufNr = (await this.nvim.call(\"nvim_win_get_buf\", [\n      this.id,\n    ])) as BufNr;\n    return new NvimBuffer(bufNr, this.nvim);\n  }",
