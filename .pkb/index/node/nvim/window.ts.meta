      "text": "import { type BufNr, NvimBuffer } from \"./buffer.ts\";\nimport type { Nvim } from \"./nvim-node/index.ts\";\n\nexport type Row0Indexed = number \u0026 { __row0Indexed: true };\nexport type Row1Indexed = number \u0026 { __row1Indexed: true };\nexport type ByteIdx = number \u0026 { __byteIdx: true };\nexport type ByteIdx1Indexed = number \u0026 { __byteIdx1Indexed: true };\n\n/** A coordinate in a js string, which are utf-16 encoded by default. This is the coordinate that lsp clients typically expect.\n */\nexport type StringIdx = number \u0026 { __charIdx: true };\n\nexport type PositionString = {\n  row: Row0Indexed;\n  col: StringIdx;\n};\n\nexport type Position1Indexed = {\n  row: Row1Indexed;\n  col: ByteIdx;\n};\n\nexport type Position1IndexedCol1Indexed = {\n  row: Row1Indexed;\n  col: ByteIdx1Indexed;\n};\n\nexport type Position0Indexed = {\n  row: Row0Indexed;\n  col: ByteIdx;\n};",
      "contextualizedText": "// node/nvim/window.ts\n\nimport { type BufNr, NvimBuffer } from \"./buffer.ts\";\nimport type { Nvim } from \"./nvim-node/index.ts\";\n\nexport type Row0Indexed = number \u0026 { __row0Indexed: true };\nexport type Row1Indexed = number \u0026 { __row1Indexed: true };\nexport type ByteIdx = number \u0026 { __byteIdx: true };\nexport type ByteIdx1Indexed = number \u0026 { __byteIdx1Indexed: true };\n\n/** A coordinate in a js string, which are utf-16 encoded by default. This is the coordinate that lsp clients typically expect.\n */\nexport type StringIdx = number \u0026 { __charIdx: true };\n\nexport type PositionString = {\n  row: Row0Indexed;\n  col: StringIdx;\n};\n\nexport type Position1Indexed = {\n  row: Row1Indexed;\n  col: ByteIdx;\n};\n\nexport type Position1IndexedCol1Indexed = {\n  row: Row1Indexed;\n  col: ByteIdx1Indexed;\n};\n\nexport type Position0Indexed = {\n  row: Row0Indexed;\n  col: ByteIdx;\n};",
      "headingContext": "node/nvim/window.ts",
      "startLine": 1,
      "startCol": 1,
      "endLine": 31,
      "endCol": 3
    },
    {
      "text": "export function pos0to1(pos: Position0Indexed): Position1Indexed {\n  return {\n    row: pos.row + 1,\n    col: pos.col,\n  } as Position1Indexed;\n}",
      "contextualizedText": "// node/nvim/window.ts \u003e function pos0to1\n\nexport function pos0to1(pos: Position0Indexed): Position1Indexed {\n  return {\n    row: pos.row + 1,\n    col: pos.col,\n  } as Position1Indexed;\n}",
      "headingContext": "node/nvim/window.ts \u003e function pos0to1",
      "startLine": 33,
      "startCol": 1,
      "endLine": 38,
      "endCol": 2
    },
    {
      "text": "export function pos1to0(pos: Position1Indexed): Position0Indexed {\n  return {\n    row: pos.row - 1,\n    col: pos.col,\n  } as Position0Indexed;\n}",
      "contextualizedText": "// node/nvim/window.ts \u003e function pos1to0\n\nexport function pos1to0(pos: Position1Indexed): Position0Indexed {\n  return {\n    row: pos.row - 1,\n    col: pos.col,\n  } as Position0Indexed;\n}",
      "headingContext": "node/nvim/window.ts \u003e function pos1to0",
      "startLine": 40,
      "startCol": 1,
      "endLine": 45,
      "endCol": 2
    },
    {
      "text": "export function pos1col1to0(\n  pos: Position1IndexedCol1Indexed,\n): Position0Indexed {\n  return {\n    row: pos.row - 1,\n    col: Math.max(0, pos.col - 1),\n  } as Position0Indexed;\n}",
      "contextualizedText": "// node/nvim/window.ts \u003e function pos1col1to0\n\nexport function pos1col1to0(\n  pos: Position1IndexedCol1Indexed,\n): Position0Indexed {\n  return {\n    row: pos.row - 1,\n    col: Math.max(0, pos.col - 1),\n  } as Position0Indexed;\n}",
      "headingContext": "node/nvim/window.ts \u003e function pos1col1to0",
      "startLine": 47,
      "startCol": 1,
      "endLine": 54,
      "endCol": 2
    },
    {
      "text": "export type WindowId = number \u0026 { __winId: true };",
      "contextualizedText": "// node/nvim/window.ts\n\nexport type WindowId = number \u0026 { __winId: true };",
      "headingContext": "node/nvim/window.ts",
