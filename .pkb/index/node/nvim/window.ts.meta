    {
      "text": "/**\n   * Get the window position (row, column) in the grid\n   * @returns Promise\u003c[row, col]\u003e where (0,0) is top-left\n   */\n  async getPosition(): Promise\u003c[number, number]\u003e {\n    return await this.nvim.call(\"nvim_win_get_position\", [this.id]);\n  }",
      "contextualizedText": "// node/nvim/window.ts \u003e class NvimWindow \u003e method getPosition\n\n/**\n   * Get the window position (row, column) in the grid\n   * @returns Promise\u003c[row, col]\u003e where (0,0) is top-left\n   */\n  async getPosition(): Promise\u003c[number, number]\u003e {\n    return await this.nvim.call(\"nvim_win_get_position\", [this.id]);\n  }",
      "headingContext": "node/nvim/window.ts \u003e class NvimWindow \u003e method getPosition",
      "startLine": 140,
      "startCol": 3,
      "endLine": 146,
      "endCol": 4
    },
    {
      "text": "  async setBuffer(buffer: NvimBuffer): Promise\u003cvoid\u003e {\n    await this.nvim.call(\"nvim_win_set_buf\", [this.id, buffer.id]);\n  }",
      "contextualizedText": "// node/nvim/window.ts \u003e class NvimWindow \u003e method setBuffer\n\n  async setBuffer(buffer: NvimBuffer): Promise\u003cvoid\u003e {\n    await this.nvim.call(\"nvim_win_set_buf\", [this.id, buffer.id]);\n  }",
      "headingContext": "node/nvim/window.ts \u003e class NvimWindow \u003e method setBuffer",
      "startLine": 148,
      "startCol": 1,
      "endLine": 150,
      "endCol": 4
    },
    {
      "text": "/** Set the window's buffer even when 'winfixbuf' is enabled on this window.\n   * Magenta windows keep 'winfixbuf' on to block accidental buffer swaps (e.g.\n   * :edit, oil), so intentional swaps must temporarily lift it. */\n  async setBufferForced(buffer: NvimBuffer): Promise\u003cvoid\u003e {\n    await this.setOption(\"winfixbuf\", false);\n    try {\n      await this.nvim.call(\"nvim_win_set_buf\", [this.id, buffer.id]);\n    } finally {\n      await this.setOption(\"winfixbuf\", true);\n    }\n  }",
      "contextualizedText": "// node/nvim/window.ts \u003e class NvimWindow \u003e method setBufferForced\n\n/** Set the window's buffer even when 'winfixbuf' is enabled on this window.\n   * Magenta windows keep 'winfixbuf' on to block accidental buffer swaps (e.g.\n   * :edit, oil), so intentional swaps must temporarily lift it. */\n  async setBufferForced(buffer: NvimBuffer): Promise\u003cvoid\u003e {\n    await this.setOption(\"winfixbuf\", false);\n    try {\n      await this.nvim.call(\"nvim_win_set_buf\", [this.id, buffer.id]);\n    } finally {\n      await this.setOption(\"winfixbuf\", true);\n    }\n  }",
      "headingContext": "node/nvim/window.ts \u003e class NvimWindow \u003e method setBufferForced",
      "startLine": 152,
      "startCol": 3,
      "endLine": 162,
      "endCol": 4
    },
    {
      "text": "  async topLine(): Promise\u003cnumber\u003e {\n    const res = await this.nvim.call(\"nvim_exec2\", [\n      `echo line('w0', \"${this.id}\")`,\n      { output: true },\n    ]);\n\n    return Number(res.output);\n  }",
      "contextualizedText": "// node/nvim/window.ts \u003e class NvimWindow \u003e method topLine\n\n  async topLine(): Promise\u003cnumber\u003e {\n    const res = await this.nvim.call(\"nvim_exec2\", [\n      `echo line('w0', \"${this.id}\")`,\n      { output: true },\n    ]);\n\n    return Number(res.output);\n  }",
      "headingContext": "node/nvim/window.ts \u003e class NvimWindow \u003e method topLine",
