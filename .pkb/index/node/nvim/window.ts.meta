      "startCol": 1,
      "endLine": 56,
      "endCol": 51
    },
    {
      "text": "export class NvimWindow {\n  constructor(\n    public readonly id: WindowId,\n    private nvim: Nvim,\n  ) {}",
      "contextualizedText": "// node/nvim/window.ts \u003e class NvimWindow\n\nexport class NvimWindow {\n  constructor(\n    public readonly id: WindowId,\n    private nvim: Nvim,\n  ) {}",
      "headingContext": "node/nvim/window.ts \u003e class NvimWindow",
      "startLine": 58,
      "startCol": 1,
      "endLine": 62,
      "endCol": 7
    },
    {
      "text": "  valid(): Promise\u003cboolean\u003e {\n    return this.nvim.call(\"nvim_win_is_valid\", [this.id]);\n  }",
      "contextualizedText": "// node/nvim/window.ts \u003e class NvimWindow \u003e method valid\n\n  valid(): Promise\u003cboolean\u003e {\n    return this.nvim.call(\"nvim_win_is_valid\", [this.id]);\n  }",
