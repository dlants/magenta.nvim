    {
      "text": "import { type Line, NvimBuffer } from \"../nvim/buffer.ts\";\nimport { getAllWindows } from \"../nvim/nvim.ts\";\nimport { NvimWindow, type Row0Indexed, type WindowId } from \"../nvim/window.ts\";\nimport type { MagentaOptions } from \"../options.ts\";\nimport {\n  type AbsFilePath,\n  type HomeDir,\n  type NvimCwd,\n  resolveFilePath,\n  type UnresolvedFilePath,\n} from \"../utils/files.ts\";\nimport type { Nvim } from \"./nvim-node/index.ts\";",
      "contextualizedText": "// node/nvim/openFileInNonMagentaWindow.ts\n\nimport { type Line, NvimBuffer } from \"../nvim/buffer.ts\";\nimport { getAllWindows } from \"../nvim/nvim.ts\";\nimport { NvimWindow, type Row0Indexed, type WindowId } from \"../nvim/window.ts\";\nimport type { MagentaOptions } from \"../options.ts\";\nimport {\n  type AbsFilePath,\n  type HomeDir,\n  type NvimCwd,\n  resolveFilePath,\n  type UnresolvedFilePath,\n} from \"../utils/files.ts\";\nimport type { Nvim } from \"./nvim-node/index.ts\";",
      "headingContext": "node/nvim/openFileInNonMagentaWindow.ts",
      "startLine": 1,
      "startCol": 1,
      "endLine": 12,
      "endCol": 50
    },
    {
      "text": "/** Find an existing non-magenta window, or create one on the opposite side of the sidebar. */\nexport async function findOrCreateNonMagentaWindow(context: {\n  nvim: Nvim;\n  options: MagentaOptions;\n}): Promise\u003cNvimWindow\u003e {\n  const windows = await getAllWindows(context.nvim);\n  const nonMagentaWindows: NvimWindow[] = [];\n  const magentaWindows: NvimWindow[] = [];\n\n  for (const window of windows) {\n    const isMagenta = await window.getVar(\"magenta\");\n    if (!isMagenta) {\n      nonMagentaWindows.push(window);\n    } else {\n      magentaWindows.push(window);\n    }\n  }\n\n  if (nonMagentaWindows.length \u003e 0) {\n    return nonMagentaWindows[0];\n  }\n\n  // No non-magenta windows exist — create one on the opposite side of the sidebar\n  const emptyBuf = await NvimBuffer.create(false, true, context.nvim);\n  const sidebarPosition = context.options.sidebarPosition;\n  const newWindowSide = sidebarPosition === \"left\" ? \"right\" : \"left\";\n\n  const newWinId = (await context.nvim.call(\"nvim_open_win\", [\n    emptyBuf.id,\n    true,\n    {\n      win: -1,\n      split: newWindowSide,\n    },\n  ])) as WindowId;\n\n  const newWindow = new NvimWindow(newWinId, context.nvim);\n  // A split inherits window-local options from the magenta window it was\n  // created from, including 'winfixbuf'. Clear it so this window can host\n  // arbitrary buffers.\n  await newWindow.setOption(\"winfixbuf\", false);\n  return newWindow;\n}",
      "contextualizedText": "// node/nvim/openFileInNonMagentaWindow.ts \u003e function findOrCreateNonMagentaWindow\n\n/** Find an existing non-magenta window, or create one on the opposite side of the sidebar. */\nexport async function findOrCreateNonMagentaWindow(context: {\n  nvim: Nvim;\n  options: MagentaOptions;\n}): Promise\u003cNvimWindow\u003e {\n  const windows = await getAllWindows(context.nvim);\n  const nonMagentaWindows: NvimWindow[] = [];\n  const magentaWindows: NvimWindow[] = [];\n\n  for (const window of windows) {\n    const isMagenta = await window.getVar(\"magenta\");\n    if (!isMagenta) {\n      nonMagentaWindows.push(window);\n    } else {\n      magentaWindows.push(window);\n    }\n  }\n\n  if (nonMagentaWindows.length \u003e 0) {\n    return nonMagentaWindows[0];\n  }\n\n  // No non-magenta windows exist — create one on the opposite side of the sidebar\n  const emptyBuf = await NvimBuffer.create(false, true, context.nvim);\n  const sidebarPosition = context.options.sidebarPosition;\n  const newWindowSide = sidebarPosition === \"left\" ? \"right\" : \"left\";\n\n  const newWinId = (await context.nvim.call(\"nvim_open_win\", [\n    emptyBuf.id,\n    true,\n    {\n      win: -1,\n      split: newWindowSide,\n    },\n  ])) as WindowId;\n\n  const newWindow = new NvimWindow(newWinId, context.nvim);\n  // A split inherits window-local options from the magenta window it was\n  // created from, including 'winfixbuf'. Clear it so this window can host\n  // arbitrary buffers.\n  await newWindow.setOption(\"winfixbuf\", false);\n  return newWindow;\n}",
      "headingContext": "node/nvim/openFileInNonMagentaWindow.ts \u003e function findOrCreateNonMagentaWindow",
      "startLine": 14,
      "startCol": 1,
      "endLine": 56,
      "endCol": 2
    },
    {
      "text": "export async function openScratchInNonMagentaWindow(\n  lines: string[],\n  name: string,\n  context: {\n    nvim: Nvim;\n    options: MagentaOptions;\n  },\n): Promise\u003cvoid\u003e {\n  try {\n    const buffer = await NvimBuffer.create(false, true, context.nvim);\n    await buffer.setLines({\n      start: 0 as Row0Indexed,\n      end: -1 as Row0Indexed,\n      lines: lines.map((line) =\u003e line as Line),\n    });\n    await buffer.setOption(\"filetype\", \"markdown\");\n    await buffer.setOption(\"modifiable\", false);\n    await buffer.setName(name);\n    const targetWindow = await findOrCreateNonMagentaWindow(context);\n    await targetWindow.setBuffer(buffer);\n  } catch (error) {\n    context.nvim.logger.error(\n      `Error opening scratch buffer ${name}: ${error instanceof Error ? error.message : String(error)}`,\n    );\n  }\n}",
      "contextualizedText": "// node/nvim/openFileInNonMagentaWindow.ts \u003e function openScratchInNonMagentaWindow\n\nexport async function openScratchInNonMagentaWindow(\n  lines: string[],\n  name: string,\n  context: {\n    nvim: Nvim;\n    options: MagentaOptions;\n  },\n): Promise\u003cvoid\u003e {\n  try {\n    const buffer = await NvimBuffer.create(false, true, context.nvim);\n    await buffer.setLines({\n      start: 0 as Row0Indexed,\n      end: -1 as Row0Indexed,\n      lines: lines.map((line) =\u003e line as Line),\n    });\n    await buffer.setOption(\"filetype\", \"markdown\");\n    await buffer.setOption(\"modifiable\", false);\n    await buffer.setName(name);\n    const targetWindow = await findOrCreateNonMagentaWindow(context);\n    await targetWindow.setBuffer(buffer);\n  } catch (error) {\n    context.nvim.logger.error(\n      `Error opening scratch buffer ${name}: ${error instanceof Error ? error.message : String(error)}`,\n    );\n  }\n}",
      "headingContext": "node/nvim/openFileInNonMagentaWindow.ts \u003e function openScratchInNonMagentaWindow",
      "startLine": 58,
      "startCol": 1,
      "endLine": 83,
      "endCol": 2
    },
    {
      "text": "export async function openFileInNonMagentaWindow(\n  filePath: UnresolvedFilePath | AbsFilePath,\n  context: {\n    nvim: Nvim;\n    cwd: NvimCwd;\n    homeDir: HomeDir;\n    options: MagentaOptions;\n  },\n): Promise\u003cvoid\u003e {\n  try {\n    const absFilePath = resolveFilePath(context.cwd, filePath, context.homeDir);\n    const fileBuffer = await NvimBuffer.bufadd(absFilePath, context.nvim);\n    const targetWindow = await findOrCreateNonMagentaWindow(context);\n    await targetWindow.setBuffer(fileBuffer);\n  } catch (error) {\n    context.nvim.logger.error(\n      `Error opening file ${filePath}: ${(error as Error).message}`,\n    );\n  }\n}",
      "contextualizedText": "// node/nvim/openFileInNonMagentaWindow.ts \u003e function openFileInNonMagentaWindow\n\nexport async function openFileInNonMagentaWindow(\n  filePath: UnresolvedFilePath | AbsFilePath,\n  context: {\n    nvim: Nvim;\n    cwd: NvimCwd;\n    homeDir: HomeDir;\n    options: MagentaOptions;\n  },\n): Promise\u003cvoid\u003e {\n  try {\n    const absFilePath = resolveFilePath(context.cwd, filePath, context.homeDir);\n    const fileBuffer = await NvimBuffer.bufadd(absFilePath, context.nvim);\n    const targetWindow = await findOrCreateNonMagentaWindow(context);\n    await targetWindow.setBuffer(fileBuffer);\n  } catch (error) {\n    context.nvim.logger.error(\n      `Error opening file ${filePath}: ${(error as Error).message}`,\n    );\n  }\n}",
      "headingContext": "node/nvim/openFileInNonMagentaWindow.ts \u003e function openFileInNonMagentaWindow",
