      "text": "import fs from \"node:fs/promises\";\nimport { resolve } from \"node:path\";\nimport { beforeEach, describe, expect, it } from \"vitest\";\nimport { withNvimClient } from \"../../test/preamble.ts\";\n\ndescribe(\"src/logger.test.ts\", () =\u003e {\n  const logFilePath = resolve(`/tmp/magenta-test/test-logging.log`);\n\n  beforeEach(async () =\u003e {\n    try {\n      await fs.unlink(logFilePath);\n    } catch {\n      // ok if file doesn't exist\n    }\n  });\n\n  it(\"logs messages in correct format and order\", async () =\u003e {\n    await withNvimClient",
      "contextualizedText": "// node/nvim/nvim-node/logger.test.ts\n\nimport fs from \"node:fs/promises\";\nimport { resolve } from \"node:path\";\nimport { beforeEach, describe, expect, it } from \"vitest\";\nimport { withNvimClient } from \"../../test/preamble.ts\";\n\ndescribe(\"src/logger.test.ts\", () =\u003e {\n  const logFilePath = resolve(`/tmp/magenta-test/test-logging.log`);\n\n  beforeEach(async () =\u003e {\n    try {\n      await fs.unlink(logFilePath);\n    } catch {\n      // ok if file doesn't exist\n    }\n  });\n\n  it(\"logs messages in correct format and order\", async () =\u003e {\n    await withNvimClient",
      "headingContext": "node/nvim/nvim-node/logger.test.ts",
