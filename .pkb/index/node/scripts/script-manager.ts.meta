      "text": "  private terminateInvocation(id: ScriptInvocationId): void {\n    const invocation = this.invocations.get(id);\n    if (!invocation) return;\n    terminateProcess(invocation.child);\n    const child = invocation.child;\n    setTimeout(() =\u003e {\n      if (child.exitCode === null \u0026\u0026 child.signalCode === null) {\n        escalateToSigkill(child);\n      }\n    }, SIGKILL_GRACE_MS);\n  }",
      "contextualizedText": "// node/scripts/script-manager.ts \u003e class ScriptManager \u003e method terminateInvocation\n\n  private terminateInvocation(id: ScriptInvocationId): void {\n    const invocation = this.invocations.get(id);\n    if (!invocation) return;\n    terminateProcess(invocation.child);\n    const child = invocation.child;\n    setTimeout(() =\u003e {\n      if (child.exitCode === null \u0026\u0026 child.signalCode === null) {\n        escalateToSigkill(child);\n      }\n    }, SIGKILL_GRACE_MS);\n  }",
