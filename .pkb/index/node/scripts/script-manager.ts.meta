    {
      "text": "  getCatalog(): ScriptMeta[] {\n    return [...this.catalog.values()].map((c) =\u003e c.meta);\n  }",
      "contextualizedText": "// node/scripts/script-manager.ts \u003e class ScriptManager \u003e method getCatalog\n\n  getCatalog(): ScriptMeta[] {\n    return [...this.catalog.values()].map((c) =\u003e c.meta);\n  }",
