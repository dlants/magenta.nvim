    {
      "text": "  getScriptCatalog(): ScriptCatalogEntry[] {\n    return [...this.catalog.values()].map((c) =\u003e ({\n      ...c.meta,\n      file: c.file,\n    }));\n  }",
      "contextualizedText": "// node/scripts/script-manager.ts \u003e class ScriptManager \u003e method getScriptCatalog\n\n  getScriptCatalog(): ScriptCatalogEntry[] {\n    return [...this.catalog.values()].map((c) =\u003e ({\n      ...c.meta,\n      file: c.file,\n    }));\n  }",
