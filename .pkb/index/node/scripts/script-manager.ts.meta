    {
      "text": "export type ScriptInvocation = {\n  id: ScriptInvocationId;\n  scriptName: string;\n  title?: string;\n  file: string;\n  parameters: unknown;\n  status: ScriptInvocationStatus;\n  logs: string[];\n  threadIds: ThreadId[];\n  entries: ScriptInvocationEntry[];\n  sandboxBypassed: boolean;\n  child: ChildProcess;\n  pendingThreads: Map\u003cnumber, ThreadId\u003e;\n};\n\nconst REGISTRATION_TIMEOUT_MS = 5000;\nconst SIGKILL_GRACE_MS = 2000;",
      "contextualizedText": "// node/scripts/script-manager.ts\n\nexport type ScriptInvocation = {\n  id: ScriptInvocationId;\n  scriptName: string;\n  title?: string;\n  file: string;\n  parameters: unknown;\n  status: ScriptInvocationStatus;\n  logs: string[];\n  threadIds: ThreadId[];\n  entries: ScriptInvocationEntry[];\n  sandboxBypassed: boolean;\n  child: ChildProcess;\n  pendingThreads: Map\u003cnumber, ThreadId\u003e;\n};\n\nconst REGISTRATION_TIMEOUT_MS = 5000;\nconst SIGKILL_GRACE_MS = 2000;",
