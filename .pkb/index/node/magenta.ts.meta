    {
      "text": "  destroy() {\n    this.scriptManager.terminateAll();\n    // BufferManager's mounted apps will be cleaned up when nvim exits\n  }",
      "contextualizedText": "// node/magenta.ts \u003e class Magenta \u003e method destroy\n\n  destroy() {\n    this.scriptManager.terminateAll();\n    // BufferManager's mounted apps will be cleaned up when nvim exits\n  }",
      "headingContext": "node/magenta.ts \u003e class Magenta \u003e method destroy",
