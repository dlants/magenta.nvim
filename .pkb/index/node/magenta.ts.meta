    },
    {
      "text": "// Open the sidebar if it isn't visible, then append the given content to\n  // the active thread's input buffer. Matches the paste-selection flow.\n  private async pasteIntoActiveInputBuffer(content: string): Promise\u003cvoid\u003e {\n    if (!this.sidebar.isVisible()) {\n      await this.command(\"toggle\");\n    }\n    await this.activeBuffers.inputBuffer.setLines({\n      start: -1 as Row0Indexed,\n      end: -1 as Row0Indexed,\n      lines: content.split(\"\\n\") as Line[],\n    });\n  }",
      "contextualizedText": "// node/magenta.ts \u003e class Magenta \u003e method pasteIntoActiveInputBuffer\n\n// Open the sidebar if it isn't visible, then append the given content to\n  // the active thread's input buffer. Matches the paste-selection flow.\n  private async pasteIntoActiveInputBuffer(content: string): Promise\u003cvoid\u003e {\n    if (!this.sidebar.isVisible()) {\n      await this.command(\"toggle\");\n    }\n    await this.activeBuffers.inputBuffer.setLines({\n      start: -1 as Row0Indexed,\n      end: -1 as Row0Indexed,\n      lines: content.split(\"\\n\") as Line[],\n    });\n  }",
      "headingContext": "node/magenta.ts \u003e class Magenta \u003e method pasteIntoActiveInputBuffer",
      "startLine": 888,
      "startCol": 3,
      "endLine": 899,
      "endCol": 4
    },
    {
      "text": "  async onWinClosed() {\n    await this.sidebar.onWinClosed();\n  }",
      "contextualizedText": "// node/magenta.ts \u003e class Magenta \u003e method onWinClosed\n\n  async onWinClosed() {\n    await this.sidebar.onWinClosed();\n  }",
