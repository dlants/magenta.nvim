    {
      "text": "      { warn: (msg) =\u003e nvim.logger.warn(`Settings: ${msg}`)",
      "contextualizedText": "// node/magenta.ts \u003e class Magenta \u003e method start \u003e function warn\n\n      { warn: (msg) =\u003e nvim.logger.warn(`Settings: ${msg}`)",
      "headingContext": "node/magenta.ts \u003e class Magenta \u003e method start \u003e function warn",
