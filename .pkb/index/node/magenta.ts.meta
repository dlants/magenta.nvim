      "text": "  async selectThreadEffect(id: ThreadId): Promise\u003cvoid\u003e {\n    this.dispatch({\n      type: \"chat-msg\",\n      msg: { type: \"set-active-thread\", id },\n    });\n    await this.syncActiveView();\n    this.dispatch({\n      type: \"sidebar-msg\",\n      msg: { type: \"set-cursor-to-bottom\" },\n    });\n  }",
