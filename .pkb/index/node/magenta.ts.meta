    {
      "text": "default:\n        this.nvim.logger.error(`Unrecognized command ${command}\\n`);\n        notifyErr(\n          this.nvim,\n          \"unrecognized command\",\n          new Error(`Unrecognized command ${command}\\n`),\n        );\n    }\n  }",
      "contextualizedText": "// node/magenta.ts \u003e class Magenta \u003e method command\n\ndefault:\n        this.nvim.logger.error(`Unrecognized command ${command}\\n`);\n        notifyErr(\n          this.nvim,\n          \"unrecognized command\",\n          new Error(`Unrecognized command ${command}\\n`),\n        );\n    }\n  }",
