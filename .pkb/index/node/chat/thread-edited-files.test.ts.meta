      "text": "      setupFiles: async (tmpDir) =\u003e {\n        await fs.writeFile(path.join(tmpDir, \"a.txt\"), \"hello\\n\");\n      }",
      "contextualizedText": "// node/chat/thread-edited-files.test.ts \u003e function setupFiles\n\n      setupFiles: async (tmpDir) =\u003e {\n        await fs.writeFile(path.join(tmpDir, \"a.txt\"), \"hello\\n\");\n      }",
      "headingContext": "node/chat/thread-edited-files.test.ts \u003e function setupFiles",
      "startLine": 127,
      "startCol": 1,
