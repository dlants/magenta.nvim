    {
      "text": "const chat = driver.magenta.chat;",
      "contextualizedText": "// node/chat/supervisor-wiring.test.ts\n\nconst chat = driver.magenta.chat;",
      "headingContext": "node/chat/supervisor-wiring.test.ts",
      "startLine": 100,
