    {
      "text": "  private getRootAncestorId(threadId: ThreadId): ThreadId {\n    let current = threadId;\n    let parentId = this.threadWrappers[current]?.parentThreadId;\n    while (parentId !== undefined) {\n      current = parentId;\n      parentId = this.threadWrappers[current]?.parentThreadId;\n    }\n    return current;\n  }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method getRootAncestorId\n\n  private getRootAncestorId(threadId: ThreadId): ThreadId {\n    let current = threadId;\n    let parentId = this.threadWrappers[current]?.parentThreadId;\n    while (parentId !== undefined) {\n      current = parentId;\n      parentId = this.threadWrappers[current]?.parentThreadId;\n    }\n    return current;\n  }",
