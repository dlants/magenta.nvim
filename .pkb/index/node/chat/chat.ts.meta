    {
      "text": "    const visit = (id: ThreadId): boolean =\u003e\n      this.threadNeedsAttention(id) || (childrenMap.get(id) ?? []).some(visit)",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method scriptSubtreeNeedsAttention \u003e function visit\n\n    const visit = (id: ThreadId): boolean =\u003e\n      this.threadNeedsAttention(id) || (childrenMap.get(id) ?? []).some(visit)",
      "headingContext": "node/chat/chat.ts \u003e class Chat \u003e method scriptSubtreeNeedsAttention \u003e function visit",
