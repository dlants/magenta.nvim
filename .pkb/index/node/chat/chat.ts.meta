    {
      "text": "  onThreadYielded(threadId: ThreadId, callback: () =\u003e void): void {\n    let callbacks = this.threadYieldCallbacks.get(threadId);\n    if (!callbacks) {\n      callbacks = [];\n      this.threadYieldCallbacks.set(threadId, callbacks);\n    }\n    callbacks.push(callback);\n  }",
