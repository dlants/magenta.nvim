      "text": "bindings.t = () =\u003e\n      this.context.dispatch({\n        type: \"thread-msg\",\n        id: threadId,\n        msg: { type: \"toggle-sandbox-bypass\" },\n      });\n\n    if (options?.hasChildren) {\n      bindings[\"=\"] = () =\u003e\n        this.context.dispatch({\n          type: \"chat-msg\",\n          msg: {\n            type: \"toggle-thread-expand\",\n            id: threadId,\n          },\n        });\n    }\n\n    return withBindings(displayLine, bindings);\n  }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method renderThread\n\nbindings.t = () =\u003e\n      this.context.dispatch({\n        type: \"thread-msg\",\n        id: threadId,\n        msg: { type: \"toggle-sandbox-bypass\" },\n      });\n\n    if (options?.hasChildren) {\n      bindings[\"=\"] = () =\u003e\n        this.context.dispatch({\n          type: \"chat-msg\",\n          msg: {\n            type: \"toggle-thread-expand\",\n            id: threadId,\n          },\n        });\n    }\n\n    return withBindings(displayLine, bindings);\n  }",
