    {
      "text": "  private fireThreadYieldCallbacks(threadId: ThreadId): void {\n    const callbacks = this.threadYieldCallbacks.get(threadId);\n    if (callbacks \u0026\u0026 callbacks.length \u003e 0) {\n      for (const callback of callbacks) {\n        callback();\n      }\n      this.threadYieldCallbacks.delete(threadId);\n    }\n  }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method fireThreadYieldCallbacks\n\n  private fireThreadYieldCallbacks(threadId: ThreadId): void {\n    const callbacks = this.threadYieldCallbacks.get(threadId);\n    if (callbacks \u0026\u0026 callbacks.length \u003e 0) {\n      for (const callback of callbacks) {\n        callback();\n      }\n      this.threadYieldCallbacks.delete(threadId);\n    }\n  }",
