      "endLine": 930,
      "endCol": 4
    },
    {
      "text": "/**\n   * Render a script-owned thread and its subtree, indented starting at the\n   * given base depth (the script row sits above at depth 0). Used by the\n   * Scripts section in the overview.\n   */\n  renderScriptThreadSubtree(threadId: ThreadId, baseDepth: number): VDOMNode[] {\n    const childrenMap = this.buildChildrenMap();\n    const views: VDOMNode[] = [];\n    this.renderScriptSubtreeInner(threadId, childrenMap, baseDepth, views);\n    return views;\n  }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method renderScriptThreadSubtree\n\n/**\n   * Render a script-owned thread and its subtree, indented starting at the\n   * given base depth (the script row sits above at depth 0). Used by the\n   * Scripts section in the overview.\n   */\n  renderScriptThreadSubtree(threadId: ThreadId, baseDepth: number): VDOMNode[] {\n    const childrenMap = this.buildChildrenMap();\n    const views: VDOMNode[] = [];\n    this.renderScriptSubtreeInner(threadId, childrenMap, baseDepth, views);\n    return views;\n  }",
      "headingContext": "node/chat/chat.ts \u003e class Chat \u003e method renderScriptThreadSubtree",
      "startLine": 932,
      "startCol": 3,
      "endLine": 942,
      "endCol": 4
    },
    {
      "text": "  private renderScriptSubtreeInner(\n    threadId: ThreadId,\n    childrenMap: Map\u003cThreadId, ThreadId[]\u003e,\n    depth: number,\n    views: VDOMNode[],\n  ) {\n    if (!this.threadWrappers[threadId]) return;\n    views.push(\n      this.renderThread(threadId, depth, this.state.activeThreadId, undefined, {\n        showTokenCount: true,\n      }),\n    );\n    for (const childId of childrenMap.get(threadId) ?? []) {\n      this.renderScriptSubtreeInner(childId, childrenMap, depth + 1, views);\n    }\n  }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method renderScriptSubtreeInner\n\n  private renderScriptSubtreeInner(\n    threadId: ThreadId,\n    childrenMap: Map\u003cThreadId, ThreadId[]\u003e,\n    depth: number,\n    views: VDOMNode[],\n  ) {\n    if (!this.threadWrappers[threadId]) return;\n    views.push(\n      this.renderThread(threadId, depth, this.state.activeThreadId, undefined, {\n        showTokenCount: true,\n      }),\n    );\n    for (const childId of childrenMap.get(threadId) ?? []) {\n      this.renderScriptSubtreeInner(childId, childrenMap, depth + 1, views);\n    }\n  }",
      "headingContext": "node/chat/chat.ts \u003e class Chat \u003e method renderScriptSubtreeInner",
      "startLine": 944,
      "startCol": 1,
      "endLine": 959,
      "endCol": 4
    },
    {
      "text": "/**\n   * Collect pending-permission views for a script-owned thread's subtree, so a\n   * collapsed script row never hides a blocking permission prompt.\n   */\n  approveAllPendingInSubtree(threadId: ThreadId): void {\n    this.approveSubtreePending(threadId, this.buildChildrenMap());\n  }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method approveAllPendingInSubtree\n\n/**\n   * Collect pending-permission views for a script-owned thread's subtree, so a\n   * collapsed script row never hides a blocking permission prompt.\n   */\n  approveAllPendingInSubtree(threadId: ThreadId): void {\n    this.approveSubtreePending(threadId, this.buildChildrenMap());\n  }",
      "headingContext": "node/chat/chat.ts \u003e class Chat \u003e method approveAllPendingInSubtree",
      "startLine": 961,
      "startCol": 3,
      "endLine": 967,
      "endCol": 4
    },
    {
      "text": "  private approveSubtreePending(\n    threadId: ThreadId,\n    childrenMap: Map\u003cThreadId, ThreadId[]\u003e,\n  ): void {\n    const wrapper = this.threadWrappers[threadId];\n    if (wrapper?.state === \"initialized\") {\n      wrapper.thread.sandboxViolationHandler?.approveAll();\n    }\n    for (const childId of childrenMap.get(threadId) ?? []) {\n      this.approveSubtreePending(childId, childrenMap);\n    }\n  }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method approveSubtreePending\n\n  private approveSubtreePending(\n    threadId: ThreadId,\n    childrenMap: Map\u003cThreadId, ThreadId[]\u003e,\n  ): void {\n    const wrapper = this.threadWrappers[threadId];\n    if (wrapper?.state === \"initialized\") {\n      wrapper.thread.sandboxViolationHandler?.approveAll();\n    }\n    for (const childId of childrenMap.get(threadId) ?? []) {\n      this.approveSubtreePending(childId, childrenMap);\n    }\n  }",
      "headingContext": "node/chat/chat.ts \u003e class Chat \u003e method approveSubtreePending",
      "startLine": 969,
      "startCol": 1,
      "endLine": 980,
      "endCol": 4
    },
    {
      "text": "  collectScriptSubtreeViolationViews(threadId: ThreadId): VDOMNode[] {\n    return this.collectSubtreeViolationViews(threadId, this.buildChildrenMap());\n  }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method collectScriptSubtreeViolationViews\n\n  collectScriptSubtreeViolationViews(threadId: ThreadId): VDOMNode[] {\n    return this.collectSubtreeViolationViews(threadId, this.buildChildrenMap());\n  }",
