      "endLine": 120,
      "endCol": 7
    },
    {
      "text": "export type Msg =\n  | {\n      type: \"thread-initialized\";\n      thread: Thread;\n    }\n  | {\n      type: \"thread-error\";\n      id: ThreadId;\n      error: Error;\n    }\n  | {\n      type: \"set-active-thread\";\n      id: ThreadId;\n    }\n  | {\n      type: \"threads-navigate-up\";\n    }\n  | {\n      type: \"threads-overview\";\n    }\n  | {\n      type: \"toggle-thread-expand\";\n      id: ThreadId;\n    }\n  | {\n      type: \"delete-thread\";\n      id: ThreadId;\n    }\n  | {\n      type: \"delete-thread-subtree\";\n      id: ThreadId;\n    }\n  | {\n      type: \"archive-open\";\n    }\n  | {\n      type: \"archive-listed\";\n      threadIds: ThreadId[];\n    }\n  | {\n      type: \"archive-navigate-back\";\n    }\n  | {\n      type: \"archive-load-more\";\n    }\n  | {\n      type: \"archive-delete-thread\";\n      id: ThreadId;\n    }\n  | {\n      type: \"archive-delete-threads\";\n      ids: ThreadId[];\n    }\n  | {\n      type: \"archive-meta-loaded\";\n      id: ThreadId;\n      title: ArchiveTitle;\n    };\n\nexport type ChatMsg = {\n  type: \"chat-msg\";\n  msg: Msg;\n};",
      "contextualizedText": "// node/chat/chat.ts\n\nexport type Msg =\n  | {\n      type: \"thread-initialized\";\n      thread: Thread;\n    }\n  | {\n      type: \"thread-error\";\n      id: ThreadId;\n      error: Error;\n    }\n  | {\n      type: \"set-active-thread\";\n      id: ThreadId;\n    }\n  | {\n      type: \"threads-navigate-up\";\n    }\n  | {\n      type: \"threads-overview\";\n    }\n  | {\n      type: \"toggle-thread-expand\";\n      id: ThreadId;\n    }\n  | {\n      type: \"delete-thread\";\n      id: ThreadId;\n    }\n  | {\n      type: \"delete-thread-subtree\";\n      id: ThreadId;\n    }\n  | {\n      type: \"archive-open\";\n    }\n  | {\n      type: \"archive-listed\";\n      threadIds: ThreadId[];\n    }\n  | {\n      type: \"archive-navigate-back\";\n    }\n  | {\n      type: \"archive-load-more\";\n    }\n  | {\n      type: \"archive-delete-thread\";\n      id: ThreadId;\n    }\n  | {\n      type: \"archive-delete-threads\";\n      ids: ThreadId[];\n    }\n  | {\n      type: \"archive-meta-loaded\";\n      id: ThreadId;\n      title: ArchiveTitle;\n    };\n\nexport type ChatMsg = {\n  type: \"chat-msg\";\n  msg: Msg;\n};",
      "headingContext": "node/chat/chat.ts",
