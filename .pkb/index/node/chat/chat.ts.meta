      "text": "  async createNewThread(): Promise\u003cThreadId\u003e {\n    const id = uuidv7() as ThreadId;\n\n    await this.createThreadWithContext({\n      threadId: id,\n      profile: getActiveProfile(\n        this.context.getOptions().profiles,\n        this.context.getOptions().activeProfile,\n      ),\n      threadType: \"root\",\n    });\n\n    return id;\n  }",
