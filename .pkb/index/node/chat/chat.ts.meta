    {
      "text": "    const collectIds = (id: ThreadId) =\u003e {\n      idsToDelete.push(id);\n      for (const childId of childrenMap.get(id) ?? []) {\n        collectIds(childId);\n      }\n    }",
      "contextualizedText": "// node/chat/chat.ts \u003e class Chat \u003e method deleteThreadSubtree \u003e function collectIds\n\n    const collectIds = (id: ThreadId) =\u003e {\n      idsToDelete.push(id);\n      for (const childId of childrenMap.get(id) ?? []) {\n        collectIds(childId);\n      }\n    }",
      "headingContext": "node/chat/chat.ts \u003e class Chat \u003e method deleteThreadSubtree \u003e function collectIds",
