      "text": "async function inputText(driver: NvimDriver): Promise\u003cstring\u003e {\n  const inputBuffer = driver.getInputBuffer();\n  const lines = await inputBuffer.getLines({\n    start: 0 as Row0Indexed,\n    end: -1 as Row0Indexed,\n  });\n  return lines.join(\"\\n\");\n}",
      "contextualizedText": "// node/chat/commands/file-paste.test.ts \u003e function inputText\n\nasync function inputText(driver: NvimDriver): Promise\u003cstring\u003e {\n  const inputBuffer = driver.getInputBuffer();\n  const lines = await inputBuffer.getLines({\n    start: 0 as Row0Indexed,\n    end: -1 as Row0Indexed,\n  });\n  return lines.join(\"\\n\");\n}",
