    {
      "text": "/** Sanitize display buffer text for stable snapshots by removing dynamic content */\nfunction sanitizeDisplayForSnapshot(text: string): string {\n  // Replace timing info like \"exit code 0 (16ms)\" with stable placeholder\n  return text.replace(/\\((\\d+)ms\\)/g, \"(\u003ctiming\u003ems)\");\n}",
      "contextualizedText": "// node/chat/thread.test.ts \u003e function sanitizeDisplayForSnapshot\n\n/** Sanitize display buffer text for stable snapshots by removing dynamic content */\nfunction sanitizeDisplayForSnapshot(text: string): string {\n  // Replace timing info like \"exit code 0 (16ms)\" with stable placeholder\n  return text.replace(/\\((\\d+)ms\\)/g, \"(\u003ctiming\u003ems)\");\n}",
      "headingContext": "node/chat/thread.test.ts \u003e function sanitizeDisplayForSnapshot",
