    {
      "text": "function renderStreamingBlock(thread: Thread): string | VDOMNode {\n  const state = thread.agent.getState();\n  const block = state.streamingBlock;\n  if (!block) return d``;\n\n  switch (block.type) {\n    case \"text\":\n      return d`${block.text}`;\n    case \"thinking\": {\n      const lastLine = block.thinking.slice(\n        block.thinking.lastIndexOf(\"\\n\") + 1,\n      );\n      return withExtmark(d`\\n💭 [Thinking] ${lastLine}`, {\n        hl_group: \"@comment\",\n      });\n    }\n    case \"tool_use\": {\n      return renderStreamdedTool(block);\n    }\n  }\n}",
      "contextualizedText": "// node/chat/thread-view.ts \u003e function renderStreamingBlock\n\nfunction renderStreamingBlock(thread: Thread): string | VDOMNode {\n  const state = thread.agent.getState();\n  const block = state.streamingBlock;\n  if (!block) return d``;\n\n  switch (block.type) {\n    case \"text\":\n      return d`${block.text}`;\n    case \"thinking\": {\n      const lastLine = block.thinking.slice(\n        block.thinking.lastIndexOf(\"\\n\") + 1,\n      );\n      return withExtmark(d`\\n💭 [Thinking] ${lastLine}`, {\n        hl_group: \"@comment\",\n      });\n    }\n    case \"tool_use\": {\n      return renderStreamdedTool(block);\n    }\n  }\n}",
      "headingContext": "node/chat/thread-view.ts \u003e function renderStreamingBlock",
      "startLine": 1100,
