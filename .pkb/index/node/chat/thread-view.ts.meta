    {
      "text": "  const forkedToAtIdx = (messageIdx: number) =\u003e {\n    const forks = thread.state.forkedTo.filter(\n      (fork) =\u003e fork.atMessageIdx === messageIdx,\n    );\n    return forks.length \u003e 0\n      ? d`${forks.map((fork) =\u003e renderForkIndicator(fork))}`\n      : d``;\n  }",
