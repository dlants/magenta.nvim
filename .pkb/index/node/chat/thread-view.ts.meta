      "text": "        const isMeta = (c: (typeof message.content)[number]) =\u003e\n          c.type === \"system_reminder\" || c.type === \"system_info\"",
      "contextualizedText": "// node/chat/thread-view.ts \u003e function view \u003e function isMeta\n\n        const isMeta = (c: (typeof message.content)[number]) =\u003e\n          c.type === \"system_reminder\" || c.type === \"system_info\"",
