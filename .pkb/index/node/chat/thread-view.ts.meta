    {
      "text": "const PENDING_PREVIEW_LINES = 3;\nconst PENDING_PREVIEW_CHARS = 200;",
      "contextualizedText": "// node/chat/thread-view.ts\n\nconst PENDING_PREVIEW_LINES = 3;\nconst PENDING_PREVIEW_CHARS = 200;",
      "headingContext": "node/chat/thread-view.ts",
