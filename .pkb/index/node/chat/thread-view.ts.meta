    {
      "text": "/** Find the tool result for a given tool request ID using the cached map */\nexport function findToolResult(\n  thread: Thread,\n  toolRequestId: ToolRequestId,\n): ProviderToolResult | undefined {\n  return thread.state.toolResultMap.get(toolRequestId);\n}",
      "contextualizedText": "// node/chat/thread-view.ts \u003e function findToolResult\n\n/** Find the tool result for a given tool request ID using the cached map */\nexport function findToolResult(\n  thread: Thread,\n  toolRequestId: ToolRequestId,\n): ProviderToolResult | undefined {\n  return thread.state.toolResultMap.get(toolRequestId);\n}",
      "headingContext": "node/chat/thread-view.ts \u003e function findToolResult",
