    {
      "text": "      isBypassed: () =\u003e bypassRef.get()",
      "contextualizedText": "// node/chat/thread.ts \u003e class Thread \u003e method cloneFromNativeMessageIdx \u003e function isBypassed\n\n      isBypassed: () =\u003e bypassRef.get()",
