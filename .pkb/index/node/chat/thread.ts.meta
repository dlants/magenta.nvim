    {
      "text": "environment = createLocalEnvironment({\n      nvim,\n      lsp,\n      cwd,\n      homeDir,\n      getOptions,\n      threadId: newThreadId,\n      sandbox",
      "contextualizedText": "// node/chat/thread.ts \u003e class Thread \u003e method cloneFromNativeMessageIdx\n\nenvironment = createLocalEnvironment({\n      nvim,\n      lsp,\n      cwd,\n      homeDir,\n      getOptions,\n      threadId: newThreadId,\n      sandbox",
