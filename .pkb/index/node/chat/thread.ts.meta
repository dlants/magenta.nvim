      "text": "      onPendingChange: () =\u003e\n        dispatch({\n          type: \"thread-msg\",\n          id: newThreadId,\n          msg: { type: \"permission-pending-change\" },\n        })",
      "contextualizedText": "// node/chat/thread.ts \u003e class Thread \u003e method cloneFromNativeMessageIdx \u003e function onPendingChange\n\n      onPendingChange: () =\u003e\n        dispatch({\n          type: \"thread-msg\",\n          id: newThreadId,\n          msg: { type: \"permission-pending-change\" },\n        })",
