    {
      "text": "  update(msg: RootMsg): void {\n    if (msg.type === \"thread-msg\" \u0026\u0026 msg.id === this.id) {\n      this.myUpdate(msg.msg);\n    }\n  }",
      "contextualizedText": "// node/chat/thread.ts \u003e class Thread \u003e method update\n\n  update(msg: RootMsg): void {\n    if (msg.type === \"thread-msg\" \u0026\u0026 msg.id === this.id) {\n      this.myUpdate(msg.msg);\n    }\n  }",
      "headingContext": "node/chat/thread.ts \u003e class Thread \u003e method update",
