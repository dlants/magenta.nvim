    {
      "text": "        getProvider: (p) =\u003e getProvider(nvim, p)",
      "contextualizedText": "// node/chat/thread.ts \u003e class Thread \u003e method cloneFromNativeMessageIdx \u003e function getProvider\n\n        getProvider: (p) =\u003e getProvider(nvim, p)",
      "headingContext": "node/chat/thread.ts \u003e class Thread \u003e method cloneFromNativeMessageIdx \u003e function getProvider",
      "startLine": 573,
