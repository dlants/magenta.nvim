    {
      "text": "        getAgents: () =\u003e\n          loadAgents({\n            cwd: environment.cwd,\n            logger: nvim.logger,\n            options: getOptions(),\n          })",
      "contextualizedText": "// node/chat/thread.ts \u003e class Thread \u003e method cloneFromNativeMessageIdx \u003e function getAgents\n\n        getAgents: () =\u003e\n          loadAgents({\n            cwd: environment.cwd,\n            logger: nvim.logger,\n            options: getOptions(),\n          })",
