      "text": "import * as fs from \"node:fs\";\nimport * as path from \"node:path\";\nimport type Anthropic from \"@anthropic-ai/sdk\";\nimport {\n  type EndTurnAction,\n  pollUntil,\n  type ThreadId,\n  type ThreadSupervisor,\n  type ToolName,\n  type ToolRequestId,\n  type YieldAction,\n} from \"@magenta/core\";\nimport { describe, expect, it } from \"vitest\";\nimport type { Chat } from \"../chat/chat.ts\";\nimport { withDriver } from \"../test/preamble.ts\";\n\ntype ToolResultBlockParam = Anthropic.Messages.ToolResultBlockParam;",
      "contextualizedText": "// node/tools/spawn-subagents.test.ts\n\nimport * as fs from \"node:fs\";\nimport * as path from \"node:path\";\nimport type Anthropic from \"@anthropic-ai/sdk\";\nimport {\n  type EndTurnAction,\n  pollUntil,\n  type ThreadId,\n  type ThreadSupervisor,\n  type ToolName,\n  type ToolRequestId,\n  type YieldAction,\n} from \"@magenta/core\";\nimport { describe, expect, it } from \"vitest\";\nimport type { Chat } from \"../chat/chat.ts\";\nimport { withDriver } from \"../test/preamble.ts\";\n\ntype ToolResultBlockParam = Anthropic.Messages.ToolResultBlockParam;",
      "headingContext": "node/tools/spawn-subagents.test.ts",
