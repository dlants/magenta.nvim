      "contextualizedText": "// node/tools/edl.test.ts \u003e function setupFiles\n\n        setupFiles: async (tmpDir) =\u003e {\n          await fs.writeFile(path.join(tmpDir, \"test.txt\"), \"hello world\\n\");\n        }",
      "headingContext": "node/tools/edl.test.ts \u003e function setupFiles",
