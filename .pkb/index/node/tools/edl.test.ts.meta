    {
      "text": "async (driver, dirs) =\u003e {\n        await driver.showSidebar();\n        await driver.inputMagentaText(\"run edl script\");\n        await driver.send();\n\n        const filePath = path.join(dirs.tmpDir, \"test.txt\");\n        const script = `file \\`${filePath}\\`\n# PREVIEW_ONLY_MARKER\nnarrow /hello/\nreplace \"goodbye\"`;\n\n        const stream = await driver.mockAnthropic.awaitPendingStream();\n        stream.respond({\n          stopReason: \"tool_use\",\n          text: \"I'll run an EDL script\",\n          toolRequests: [\n            {\n              status: \"ok\",\n              value: {\n                id: \"tool_1\" as ToolRequestId,\n                toolName: \"edl\" as ToolName,\n                input: { script },\n              },\n            },\n          ],\n        });\n\n        await driver.assertDisplayBufferContains(\"✅ edl:\");\n\n        // Once completed, the streaming script preview is hidden\n        await driver.assertDisplayBufferDoesNotContain(\"PREVIEW_ONLY_MARKER\");\n      },\n    );\n  });\n\n  test(\"detail view shows full unabridged script\", async () =\u003e {\n    await withDriver",
      "contextualizedText": "// node/tools/edl.test.ts\n\nasync (driver, dirs) =\u003e {\n        await driver.showSidebar();\n        await driver.inputMagentaText(\"run edl script\");\n        await driver.send();\n\n        const filePath = path.join(dirs.tmpDir, \"test.txt\");\n        const script = `file \\`${filePath}\\`\n# PREVIEW_ONLY_MARKER\nnarrow /hello/\nreplace \"goodbye\"`;\n\n        const stream = await driver.mockAnthropic.awaitPendingStream();\n        stream.respond({\n          stopReason: \"tool_use\",\n          text: \"I'll run an EDL script\",\n          toolRequests: [\n            {\n              status: \"ok\",\n              value: {\n                id: \"tool_1\" as ToolRequestId,\n                toolName: \"edl\" as ToolName,\n                input: { script },\n              },\n            },\n          ],\n        });\n\n        await driver.assertDisplayBufferContains(\"✅ edl:\");\n\n        // Once completed, the streaming script preview is hidden\n        await driver.assertDisplayBufferDoesNotContain(\"PREVIEW_ONLY_MARKER\");\n      },\n    );\n  });\n\n  test(\"detail view shows full unabridged script\", async () =\u003e {\n    await withDriver",
      "headingContext": "node/tools/edl.test.ts",
