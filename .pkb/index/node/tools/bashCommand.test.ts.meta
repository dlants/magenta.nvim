    {
      "text": "await pollUntil(\n        async () =\u003e {\n          const text = await driver.getDisplayBufferText();\n          const match = text.match(/pid: (\\d+)/);\n          if (match) {\n            pid = parseInt(match[1], 10);\n            return true;\n          }\n          throw new Error(\"PID not found in display buffer\");\n        },\n        { timeout: 5000 },\n      );",
      "contextualizedText": "// node/tools/bashCommand.test.ts\n\nawait pollUntil(\n        async () =\u003e {\n          const text = await driver.getDisplayBufferText();\n          const match = text.match(/pid: (\\d+)/);\n          if (match) {\n            pid = parseInt(match[1], 10);\n            return true;\n          }\n          throw new Error(\"PID not found in display buffer\");\n        },\n        { timeout: 5000 },\n      );",
