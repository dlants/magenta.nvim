    {
      "text": "expect(logContent).toContain('$ echo \"line1\" \u0026\u0026 echo \"line2\"');\n      expect(logContent).toContain(\"stdout:\");\n      expect(logContent).toContain(\"line1\");\n      expect(logContent).toContain(\"line2\");\n      expect(logContent).toContain(\"exit code 0\");\n    });\n  });\n\n  it(\"abbreviates output when it exceeds token budget\"",
      "contextualizedText": "// node/tools/bashCommand.test.ts\n\nexpect(logContent).toContain('$ echo \"line1\" \u0026\u0026 echo \"line2\"');\n      expect(logContent).toContain(\"stdout:\");\n      expect(logContent).toContain(\"line1\");\n      expect(logContent).toContain(\"line2\");\n      expect(logContent).toContain(\"exit code 0\");\n    });\n  });\n\n  it(\"abbreviates output when it exceeds token budget\"",
      "headingContext": "node/tools/bashCommand.test.ts",
