    {
      "text": "export function strWidthInBytes(str: string) {\n  return Buffer.from(str, \"utf8\").byteLength;\n}",
      "contextualizedText": "// node/tea/util.ts \u003e function strWidthInBytes\n\nexport function strWidthInBytes(str: string) {\n  return Buffer.from(str, \"utf8\").byteLength;\n}",
