    {
      "text": "export async function logBuffer(buffer: NvimBuffer, context: { nvim: Nvim }) {\n  const lines = await buffer.getLines({\n    start: 0 as Row0Indexed,\n    end: -1 as Row0Indexed,\n  });\n  context.nvim.logger.info(`buffer:\\n${lines.join(\"\\n\")}\\nend`);\n}",
      "contextualizedText": "// node/tea/util.ts \u003e function logBuffer\n\nexport async function logBuffer(buffer: NvimBuffer, context: { nvim: Nvim }) {\n  const lines = await buffer.getLines({\n    start: 0 as Row0Indexed,\n    end: -1 as Row0Indexed,\n  });\n  context.nvim.logger.info(`buffer:\\n${lines.join(\"\\n\")}\\nend`);\n}",
      "headingContext": "node/tea/util.ts \u003e function logBuffer",
      "startLine": 64,
