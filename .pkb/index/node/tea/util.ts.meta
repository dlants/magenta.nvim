    {
      "text": "import type { Line, NvimBuffer } from \"../nvim/buffer.ts\";\nimport type { Nvim } from \"../nvim/nvim-node/index.ts\";\nimport type { ByteIdx, Position0Indexed, Row0Indexed } from \"../nvim/window.ts\";",
      "contextualizedText": "// node/tea/util.ts\n\nimport type { Line, NvimBuffer } from \"../nvim/buffer.ts\";\nimport type { Nvim } from \"../nvim/nvim-node/index.ts\";\nimport type { ByteIdx, Position0Indexed, Row0Indexed } from \"../nvim/window.ts\";",
      "headingContext": "node/tea/util.ts",
      "startLine": 1,
