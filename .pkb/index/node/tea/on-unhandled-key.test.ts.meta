      "text": "        View: () =\u003e\n          d`plain ${withBindings(d`[btn]`, { \"\u003cCR\u003e\": boundSpy })} tail`",
      "contextualizedText": "// node/tea/on-unhandled-key.test.ts \u003e function View\n\n        View: () =\u003e\n          d`plain ${withBindings(d`[btn]`, { \"\u003cCR\u003e\": boundSpy })} tail`",
