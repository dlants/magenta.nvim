      "text": "import type { NvimBuffer } from \"../nvim/buffer.ts\";\nimport {\n  getCurrentWindow,\n  restoreWinViews,\n  saveWinViews,\n} from \"../nvim/nvim.ts\";\nimport type { Nvim } from \"../nvim/nvim-node/index.ts\";\nimport type { Row0Indexed } from \"../nvim/window.ts\";\nimport { Defer } from \"../utils/async.ts\";\nimport {\n  BINDING_KEYS,\n  BINDING_MODES,\n  type BindingCtx,\n  type BindingKey,\n  getBinding,\n} from \"./bindings.ts\";\nimport {\n  d,\n  type MountedVDOM,\n  type MountedView,\n  type MountPoint,\n  mountView,\n  prettyPrintMountedNode,\n  type VDOMNode,\n} from \"./view.ts\";\n\nexport type Dispatch\u003cMsg\u003e = (msg: Msg) =\u003e void;\nexport type View\u003cModel\u003e = ({ model }: { model: Model }) =\u003e VDOMNode;\n\ntype AppState\u003cModel\u003e =\n  | {\n      status: \"running\";\n      model: Model;\n    }\n  | {\n      status: \"error\";\n      error: string;\n    };\n\nexport type MountedApp",
