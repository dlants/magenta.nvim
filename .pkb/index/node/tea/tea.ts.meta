    {
      "text": "export function createApp\u003cModel\u003e({\n  nvim,\n  initialModel,\n  View,\n  onUnhandledKey,\n}: {\n  nvim: Nvim;\n  initialModel: Model;\n  View: View\u003cModel\u003e;\n  onUnhandledKey?: UnhandledKeyHandler;\n}): App\u003cModel\u003e {\n  let currentState: AppState\u003cModel\u003e = {\n    status: \"running\",\n    model: initialModel,\n  };\n  let root: MountedView\u003c{ currentState: AppState\u003cModel\u003e }\u003e | undefined;\n\n  let renderDefer: Defer\u003cvoid\u003e | undefined;\n  let renderPromise: Promise\u003cvoid\u003e | undefined;\n  let pendingRender = false;\n  let mountPoint: MountPoint | undefined;\n  let renderVersion = 0;",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp\n\nexport function createApp\u003cModel\u003e({\n  nvim,\n  initialModel,\n  View,\n  onUnhandledKey,\n}: {\n  nvim: Nvim;\n  initialModel: Model;\n  View: View\u003cModel\u003e;\n  onUnhandledKey?: UnhandledKeyHandler;\n}): App\u003cModel\u003e {\n  let currentState: AppState\u003cModel\u003e = {\n    status: \"running\",\n    model: initialModel,\n  };\n  let root: MountedView\u003c{ currentState: AppState\u003cModel\u003e }\u003e | undefined;\n\n  let renderDefer: Defer\u003cvoid\u003e | undefined;\n  let renderPromise: Promise\u003cvoid\u003e | undefined;\n  let pendingRender = false;\n  let mountPoint: MountPoint | undefined;\n  let renderVersion = 0;",
      "headingContext": "node/tea/tea.ts \u003e function createApp",
      "startLine": 63,
      "startCol": 1,
      "endLine": 84,
      "endCol": 25
    },
    {
      "text": "  function render() {\n    if (renderPromise) {\n      pendingRender = true;\n    } else {\n      if (!renderDefer) {\n        renderDefer = new Defer();\n      }\n\n      if (root) {\n        renderPromise = (async () =\u003e {\n          try {\n            const bufId = mountPoint?.buffer.id;\n            let savedViews: unknown;\n            if (bufId != null) {\n              try {\n                savedViews = await saveWinViews(nvim, bufId);\n              } catch {\n                savedViews = undefined;\n              }\n            }\n            await root.render({ currentState });\n            renderVersion++;\n            if (bufId != null \u0026\u0026 savedViews) {\n              try {\n                await restoreWinViews(nvim, bufId, savedViews);\n              } catch {\n                // best-effort: scroll preservation should never break rendering\n              }\n            }\n          }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e function render\n\n  function render() {\n    if (renderPromise) {\n      pendingRender = true;\n    } else {\n      if (!renderDefer) {\n        renderDefer = new Defer();\n      }\n\n      if (root) {\n        renderPromise = (async () =\u003e {\n          try {\n            const bufId = mountPoint?.buffer.id;\n            let savedViews: unknown;\n            if (bufId != null) {\n              try {\n                savedViews = await saveWinViews(nvim, bufId);\n              } catch {\n                savedViews = undefined;\n              }\n            }\n            await root.render({ currentState });\n            renderVersion++;\n            if (bufId != null \u0026\u0026 savedViews) {\n              try {\n                await restoreWinViews(nvim, bufId, savedViews);\n              } catch {\n                // best-effort: scroll preservation should never break rendering\n              }\n            }\n          }",
      "headingContext": "node/tea/tea.ts \u003e function createApp \u003e function render",
      "startLine": 86,
      "startCol": 1,
      "endLine": 115,
      "endCol": 12
    },
    {
      "text": "catch (err) {\n            nvim.logger.error(\n              err instanceof Error\n                ? `render failed: ${err.message}\\n${err.stack}`\n                : `render failed: ${JSON.stringify(err)}`,\n            );\n            if (root) {\n              nvim.logger.error(\n                `mounted view: ${prettyPrintMountedNode(root._getMountedNode())}`,\n              );\n            }\n\n            // attempt to recover by re-mounting\n            if (mountPoint) {\n              try {\n                nvim.logger.info(\"Attempting to recover by re-mounting view\");\n                await mountPoint.buffer.clearAllExtmarks();\n                await mountPoint.buffer.setLines({\n                  start: 0 as Row0Indexed,\n                  end: -1 as Row0Indexed,\n                  lines: [],\n                });\n                root = await mountView({\n                  view: App,\n                  mount: mountPoint,\n                  props: { currentState },\n                });\n                renderVersion++;\n                nvim.logger.info(\"Successfully re-mounted view after error\");\n              } catch (remountErr) {\n                nvim.logger.error(\n                  remountErr instanceof Error\n                    ? `Re-mount failed: ${remountErr.message}\\n${remountErr.stack}`\n                    : `Re-mount failed: ${JSON.stringify(remountErr)}`,\n                );\n                if (renderDefer) {\n                  renderDefer.reject(err as Error);\n                  renderDefer = undefined;\n                }\n                return;\n              }\n            } else {\n              if (renderDefer) {\n                renderDefer.reject(err as Error);\n                renderDefer = undefined;\n              }\n              return;\n            }\n          }\n\n          renderPromise = undefined;",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e function render\n\ncatch (err) {\n            nvim.logger.error(\n              err instanceof Error\n                ? `render failed: ${err.message}\\n${err.stack}`\n                : `render failed: ${JSON.stringify(err)}`,\n            );\n            if (root) {\n              nvim.logger.error(\n                `mounted view: ${prettyPrintMountedNode(root._getMountedNode())}`,\n              );\n            }\n\n            // attempt to recover by re-mounting\n            if (mountPoint) {\n              try {\n                nvim.logger.info(\"Attempting to recover by re-mounting view\");\n                await mountPoint.buffer.clearAllExtmarks();\n                await mountPoint.buffer.setLines({\n                  start: 0 as Row0Indexed,\n                  end: -1 as Row0Indexed,\n                  lines: [],\n                });\n                root = await mountView({\n                  view: App,\n                  mount: mountPoint,\n                  props: { currentState },\n                });\n                renderVersion++;\n                nvim.logger.info(\"Successfully re-mounted view after error\");\n              } catch (remountErr) {\n                nvim.logger.error(\n                  remountErr instanceof Error\n                    ? `Re-mount failed: ${remountErr.message}\\n${remountErr.stack}`\n                    : `Re-mount failed: ${JSON.stringify(remountErr)}`,\n                );\n                if (renderDefer) {\n                  renderDefer.reject(err as Error);\n                  renderDefer = undefined;\n                }\n                return;\n              }\n            } else {\n              if (renderDefer) {\n                renderDefer.reject(err as Error);\n                renderDefer = undefined;\n              }\n              return;\n            }\n          }\n\n          renderPromise = undefined;",
      "headingContext": "node/tea/tea.ts \u003e function createApp \u003e function render",
      "startLine": 115,
      "startCol": 13,
      "endLine": 165,
      "endCol": 37
    },
    {
      "text": "if (pendingRender) {\n            pendingRender = false;\n            render();\n          } else {\n            if (renderDefer) {\n              renderDefer.resolve();\n              renderDefer = undefined;\n            }\n          }\n        })();\n      }\n    }\n  }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e function render\n\nif (pendingRender) {\n            pendingRender = false;\n            render();\n          } else {\n            if (renderDefer) {\n              renderDefer.resolve();\n              renderDefer = undefined;\n            }\n          }\n        })();\n      }\n    }\n  }",
      "headingContext": "node/tea/tea.ts \u003e function createApp \u003e function render",
      "startLine": 166,
      "startCol": 11,
      "endLine": 178,
      "endCol": 4
    },
    {
      "text": "  function App({ currentState }: { currentState: AppState\u003cModel\u003e }) {\n    return d`${\n      currentState.status === \"running\"\n        ? View({ model: currentState.model })\n        : d`Error: ${currentState.error}`\n    }`;\n  }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e function App\n\n  function App({ currentState }: { currentState: AppState\u003cModel\u003e }) {\n    return d`${\n      currentState.status === \"running\"\n        ? View({ model: currentState.model })\n        : d`Error: ${currentState.error}`\n    }`;\n  }",
      "headingContext": "node/tea/tea.ts \u003e function createApp \u003e function App",
      "startLine": 180,
      "startCol": 1,
      "endLine": 186,
      "endCol": 4
    },
    {
      "text": "    async mount(mount: MountPoint) {\n      mountPoint = mount;\n      root = await mountView({\n        view: App,\n        mount,\n        props: { currentState },\n      });\n\n      for (const vimKey of BINDING_KEYS) {\n        const modes = BINDING_MODES[vimKey] ?? [\"n\"];\n        for (const mode of modes) {\n          try {\n            await nvim.call(\"nvim_exec_lua\", [\n              `require('magenta').listenToBufKey(${mount.buffer.id}, \"${vimKey}\", \"${mode}\")`,\n              [],\n            ]);\n          } catch (e) {\n            throw new Error(`failed to nvim_exec_lua: ${JSON.stringify(e)}`);\n          }\n        }\n      }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e method mount\n\n    async mount(mount: MountPoint) {\n      mountPoint = mount;\n      root = await mountView({\n        view: App,\n        mount,\n        props: { currentState },\n      });\n\n      for (const vimKey of BINDING_KEYS) {\n        const modes = BINDING_MODES[vimKey] ?? [\"n\"];\n        for (const mode of modes) {\n          try {\n            await nvim.call(\"nvim_exec_lua\", [\n              `require('magenta').listenToBufKey(${mount.buffer.id}, \"${vimKey}\", \"${mode}\")`,\n              [],\n            ]);\n          } catch (e) {\n            throw new Error(`failed to nvim_exec_lua: ${JSON.stringify(e)}`);\n          }\n        }\n      }",
      "headingContext": "node/tea/tea.ts \u003e function createApp \u003e method mount",
      "startLine": 189,
      "startCol": 1,
      "endLine": 209,
      "endCol": 8
    },
    {
      "text": "        getMountedNode() {\n          return root!._getMountedNode();\n        }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e method mount \u003e method getMountedNode\n\n        getMountedNode() {\n          return root!._getMountedNode();\n        }",
