    {
      "text": "        async waitForRender() {\n          if (renderDefer) {\n            await renderDefer.promise;\n          }\n        }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e method mount \u003e method waitForRender\n\n        async waitForRender() {\n          if (renderDefer) {\n            await renderDefer.promise;\n          }\n        }",
