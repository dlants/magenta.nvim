    {
      "text": "        get renderVersion() {\n          return renderVersion;\n        }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e method mount \u003e method renderVersion\n\n        get renderVersion() {\n          return renderVersion;\n        }",
      "headingContext": "node/tea/tea.ts \u003e function createApp \u003e method mount \u003e method renderVersion",
      "startLine": 240,
      "startCol": 1,
      "endLine": 242,
      "endCol": 10
    },
    {
      "text": "        async onKey(key: BindingKey, ctx?: BindingCtx): Promise\u003cvoid\u003e {\n          // Wait for any in-flight render to finish so buffer content\n          // and VDOM positions are consistent when we read the cursor.\n          if (renderPromise) {\n            await renderPromise;\n          }\n          const window = await getCurrentWindow(mount.nvim);\n          const buffer = await window.buffer();\n          if (buffer.id !== mount.buffer.id) {\n            nvim.logger.warn(\n              `Got onKey event ${key}, but current window is not showing mounted buffer`,\n            );\n            return;\n          }\n          const { row, col } = await window.getCursor();\n          if (root) {\n            // win_get_cursor is 1-indexed, while our positions are 0-indexed\n            const mode: \"n\" | \"v\" = ctx?.selection !== undefined ? \"v\" : \"n\";\n            const binding = getBinding(\n              root._getMountedNode(),\n              { row: (row - 1) as Row0Indexed, col },\n              mode,\n              key,\n            );\n\n            if (binding) {\n              binding(ctx);\n            } else if (onUnhandledKey) {\n              try {\n                await onUnhandledKey({\n                  key,\n                  buffer: mount.buffer,\n                  row: (row - 1) as Row0Indexed,\n                  col,\n                });\n              } catch (err) {\n                nvim.logger.error(\n                  err instanceof Error\n                    ? `onUnhandledKey failed: ${err.message}\\n${err.stack}`\n                    : `onUnhandledKey failed: ${JSON.stringify(err)}`,\n                );\n              }\n            }\n          } else {\n            nvim.logger.debug(\n              `Got onKey event ${key}, but root is no longer mounted.`,\n            );\n          }\n        }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e method mount \u003e method onKey\n\n        async onKey(key: BindingKey, ctx?: BindingCtx): Promise\u003cvoid\u003e {\n          // Wait for any in-flight render to finish so buffer content\n          // and VDOM positions are consistent when we read the cursor.\n          if (renderPromise) {\n            await renderPromise;\n          }\n          const window = await getCurrentWindow(mount.nvim);\n          const buffer = await window.buffer();\n          if (buffer.id !== mount.buffer.id) {\n            nvim.logger.warn(\n              `Got onKey event ${key}, but current window is not showing mounted buffer`,\n            );\n            return;\n          }\n          const { row, col } = await window.getCursor();\n          if (root) {\n            // win_get_cursor is 1-indexed, while our positions are 0-indexed\n            const mode: \"n\" | \"v\" = ctx?.selection !== undefined ? \"v\" : \"n\";\n            const binding = getBinding(\n              root._getMountedNode(),\n              { row: (row - 1) as Row0Indexed, col },\n              mode,\n              key,\n            );\n\n            if (binding) {\n              binding(ctx);\n            } else if (onUnhandledKey) {\n              try {\n                await onUnhandledKey({\n                  key,\n                  buffer: mount.buffer,\n                  row: (row - 1) as Row0Indexed,\n                  col,\n                });\n              } catch (err) {\n                nvim.logger.error(\n                  err instanceof Error\n                    ? `onUnhandledKey failed: ${err.message}\\n${err.stack}`\n                    : `onUnhandledKey failed: ${JSON.stringify(err)}`,\n                );\n              }\n            }\n          } else {\n            nvim.logger.debug(\n              `Got onKey event ${key}, but root is no longer mounted.`,\n            );\n          }\n        }",
      "headingContext": "node/tea/tea.ts \u003e function createApp \u003e method mount \u003e method onKey",
      "startLine": 244,
      "startCol": 1,
      "endLine": 292,
      "endCol": 10
    },
    {
      "text": "    getState() {\n      return currentState;\n    }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e method getState\n\n    getState() {\n      return currentState;\n    }",
      "headingContext": "node/tea/tea.ts \u003e function createApp \u003e method getState",
      "startLine": 295,
      "startCol": 1,
      "endLine": 297,
      "endCol": 6
    },
    {
      "text": "    destroy() {\n      if (root) {\n        root.unmount();\n        root = undefined;\n      }\n      if (mountPoint) {\n        mountPoint.buffer.clearAllExtmarks().catch((err) =\u003e {\n          nvim.logger.error(\n            err instanceof Error\n              ? `Failed to clear extmarks on destroy: ${err.message}`\n              : `Failed to clear extmarks on destroy: ${JSON.stringify(err)}`,\n          );\n        });\n        mountPoint = undefined;\n      }\n      currentState = {\n        status: \"error\",\n        error: \"destroyed\",\n      };\n    }",
