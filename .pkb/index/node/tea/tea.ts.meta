    {
      "text": "        async waitForNextRender() {\n          const startVersion = renderVersion;\n          while (renderVersion === startVersion \u0026\u0026 renderPromise) {\n            await renderPromise;\n          }\n        }",
      "contextualizedText": "// node/tea/tea.ts \u003e function createApp \u003e method mount \u003e method waitForNextRender\n\n        async waitForNextRender() {\n          const startVersion = renderVersion;\n          while (renderVersion === startVersion \u0026\u0026 renderPromise) {\n            await renderPromise;\n          }\n        }",
