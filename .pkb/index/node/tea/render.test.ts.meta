    {
      "text": "      const view = () =\u003e d`before${multiLineValue}after`",
      "contextualizedText": "// node/tea/render.test.ts \u003e function view\n\n      const view = () =\u003e d`before${multiLineValue}after`",
      "headingContext": "node/tea/render.test.ts \u003e function view",
      "startLine": 54,
