    {
      "text": "import { describe, expect, it } from \"vitest\";\nimport { type Line, NvimBuffer } from \"../nvim/buffer.ts\";\nimport type { Row0Indexed } from \"../nvim/window.ts\";\nimport { extractMountTree, withNvimClient } from \"../test/preamble.ts\";\nimport {\n  d,\n  mountView,\n  pos,\n  withError,\n  withExtmark,\n  withInfo,\n  withWarning,\n} from \"./view.ts\";\n\ndescribe(\"tea/render.test.ts\", () =\u003e {\n  it(\"rendering empty string\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const buffer = await NvimBuffer.create(false, true, nvim);\n      await buffer.setOption(\"modifiable\", false);",
      "contextualizedText": "// node/tea/render.test.ts\n\nimport { describe, expect, it } from \"vitest\";\nimport { type Line, NvimBuffer } from \"../nvim/buffer.ts\";\nimport type { Row0Indexed } from \"../nvim/window.ts\";\nimport { extractMountTree, withNvimClient } from \"../test/preamble.ts\";\nimport {\n  d,\n  mountView,\n  pos,\n  withError,\n  withExtmark,\n  withInfo,\n  withWarning,\n} from \"./view.ts\";\n\ndescribe(\"tea/render.test.ts\", () =\u003e {\n  it(\"rendering empty string\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const buffer = await NvimBuffer.create(false, true, nvim);\n      await buffer.setOption(\"modifiable\", false);",
