      "text": "        const view = () =\u003e\n          withExtmark(\n            d`${withExtmark(d`nested`, { hl_group: \"String\", priority: 300 })}`,\n            { hl_group: \"ErrorMsg\", priority: 100 },\n          )",
      "contextualizedText": "// node/tea/render.test.ts \u003e function view\n\n        const view = () =\u003e\n          withExtmark(\n            d`${withExtmark(d`nested`, { hl_group: \"String\", priority: 300 })}`,\n            { hl_group: \"ErrorMsg\", priority: 100 },\n          )",
