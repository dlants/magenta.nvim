    {
      "text": "      const view = ({ arr }: { arr: string[] }) =\u003e\n        d`${arr.map((c) =\u003e d`${c}`)}`",
      "contextualizedText": "// node/tea/render.test.ts \u003e function view\n\n      const view = ({ arr }: { arr: string[] }) =\u003e\n        d`${arr.map((c) =\u003e d`${c}`)}`",
