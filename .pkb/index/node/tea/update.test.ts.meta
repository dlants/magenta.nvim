      "text": "      const view = (props: { items: string[] }) =\u003e {\n        const arrayNode = {\n          type: \"array\" as const,\n          children: props.items.map((item) =\u003e withWarning(d`${item} `)),\n        };\n        return d`${withError(arrayNode)}`;\n      }",
