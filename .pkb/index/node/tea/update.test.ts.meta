    {
      "text": "      const view = (props: { isError: boolean }) =\u003e\n        props.isError\n          ? withError(d`Error message`)\n          : withWarning(d`Error message`)",
      "contextualizedText": "// node/tea/update.test.ts \u003e function view\n\n      const view = (props: { isError: boolean }) =\u003e\n        props.isError\n          ? withError(d`Error message`)\n          : withWarning(d`Error message`)",
      "headingContext": "node/tea/update.test.ts \u003e function view",
      "startLine": 890,
