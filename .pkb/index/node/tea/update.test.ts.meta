    },
    {
      "text": "      const view = (props: { prop: string }) =\u003e d`1${props.prop}3`",
      "contextualizedText": "// node/tea/update.test.ts \u003e function view\n\n      const view = (props: { prop: string }) =\u003e d`1${props.prop}3`",
      "headingContext": "node/tea/update.test.ts \u003e function view",
      "startLine": 260,
      "startCol": 1,
      "endLine": 260,
      "endCol": 67
    },
    {
      "text": "const mountedView = await mountView({\n        view,\n        props: { prop: \"\" },\n        mount: {\n          nvim,\n          buffer,\n          startPos: pos(0, 0),\n          endPos: pos(0, 0),\n        },\n      });\n\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(lines[0]).toEqual(\"13\" as Line);\n      }\n\n      await mountedView.render({ prop: \"2\" });\n\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(lines[0]).toEqual(\"123\" as Line);\n      }\n\n      await mountedView.render({ prop: \"\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(lines[0]).toEqual(\"13\" as Line);\n      }\n\n      await mountedView.render({ prop: \"\\n\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 2 as Row0Indexed,\n        });\n\n        expect(lines).toEqual([\"1\", \"3\"] as Line[]);\n      }\n\n      await mountedView.render({ prop: \"\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 2 as Row0Indexed,\n        });\n\n        expect(lines).toEqual([\"13\"] as Line[]);\n      }\n    });\n  });\n\n  it(\"updates to multiple items in the same line\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const buffer = await NvimBuffer.create(false, true, nvim);\n      await buffer.setOption(\"modifiable\", false);",
      "contextualizedText": "// node/tea/update.test.ts\n\nconst mountedView = await mountView({\n        view,\n        props: { prop: \"\" },\n        mount: {\n          nvim,\n          buffer,\n          startPos: pos(0, 0),\n          endPos: pos(0, 0),\n        },\n      });\n\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(lines[0]).toEqual(\"13\" as Line);\n      }\n\n      await mountedView.render({ prop: \"2\" });\n\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(lines[0]).toEqual(\"123\" as Line);\n      }\n\n      await mountedView.render({ prop: \"\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(lines[0]).toEqual(\"13\" as Line);\n      }\n\n      await mountedView.render({ prop: \"\\n\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 2 as Row0Indexed,\n        });\n\n        expect(lines).toEqual([\"1\", \"3\"] as Line[]);\n      }\n\n      await mountedView.render({ prop: \"\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 2 as Row0Indexed,\n        });\n\n        expect(lines).toEqual([\"13\"] as Line[]);\n      }\n    });\n  });\n\n  it(\"updates to multiple items in the same line\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const buffer = await NvimBuffer.create(false, true, nvim);\n      await buffer.setOption(\"modifiable\", false);",
      "headingContext": "node/tea/update.test.ts",
      "startLine": 261,
      "startCol": 7,
      "endLine": 327,
      "endCol": 51
    },
    {
      "text": "      const view = (props: { prop1: string; prop2: string }) =\u003e\n        d`${props.prop1}${props.prop2}`",
      "contextualizedText": "// node/tea/update.test.ts \u003e function view\n\n      const view = (props: { prop1: string; prop2: string }) =\u003e\n        d`${props.prop1}${props.prop2}`",
      "headingContext": "node/tea/update.test.ts \u003e function view",
      "startLine": 329,
      "startCol": 1,
      "endLine": 330,
      "endCol": 40
    },
    {
      "text": "const mountedView = await mountView({\n        view,\n        props: { prop1: \"\", prop2: \"\" },\n        mount: {\n          nvim,\n          buffer,\n          startPos: pos(0, 0),\n          endPos: pos(0, 0),\n        },\n      });\n\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle multiple empty interpolations in a row\",\n        ).toEqual(\"\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"1\", prop2: \"2\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle going from empty to segments on the same line\",\n        ).toEqual(\"12\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"11\", prop2: \"22\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle growing multiple segments on the same line\",\n        ).toEqual(\"1122\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"1\", prop2: \"2\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle shrinking multiple segments on the same line\",\n        ).toEqual(\"12\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"1\", prop2: \"2\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle shrinking multiple segments on the same line\",\n        ).toEqual(\"12\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"1\\n111\", prop2: \"22\" });",
      "contextualizedText": "// node/tea/update.test.ts\n\nconst mountedView = await mountView({\n        view,\n        props: { prop1: \"\", prop2: \"\" },\n        mount: {\n          nvim,\n          buffer,\n          startPos: pos(0, 0),\n          endPos: pos(0, 0),\n        },\n      });\n\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle multiple empty interpolations in a row\",\n        ).toEqual(\"\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"1\", prop2: \"2\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle going from empty to segments on the same line\",\n        ).toEqual(\"12\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"11\", prop2: \"22\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle growing multiple segments on the same line\",\n        ).toEqual(\"1122\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"1\", prop2: \"2\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle shrinking multiple segments on the same line\",\n        ).toEqual(\"12\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"1\", prop2: \"2\" });\n      {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: 1 as Row0Indexed,\n        });\n\n        expect(\n          lines[0],\n          \"should handle shrinking multiple segments on the same line\",\n        ).toEqual(\"12\" as Line);\n      }\n\n      await mountedView.render({ prop1: \"1\\n111\", prop2: \"22\" });",
      "headingContext": "node/tea/update.test.ts",
