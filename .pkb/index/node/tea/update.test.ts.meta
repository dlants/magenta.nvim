      "text": "// This mimics the Message view structure from message.ts\n      const view = (props: Props) =\u003e {\n        const fileEdits = [];\n        if (props.edits) {\n          fileEdits.push(d`  edit. \\n`);\n        }\n\n        return d`\\\n${props.streamingBlock ? d`edit ${props.streamingBlock}` : \"\"}${\n  fileEdits.length\n    ? d`\nEdits:\n${fileEdits}`\n    : \"\"\n}${props.awaitingResponse ? d`\\nAwaiting response ⠂` : \"\"}`;\n      }",
