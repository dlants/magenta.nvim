    {
      "text": "      const view = (props: { inner: string }) =\u003e\n        withError(d`Error: ${withWarning(d`${props.inner}`)} end`)",
      "contextualizedText": "// node/tea/update.test.ts \u003e function view\n\n      const view = (props: { inner: string }) =\u003e\n        withError(d`Error: ${withWarning(d`${props.inner}`)} end`)",
      "headingContext": "node/tea/update.test.ts \u003e function view",
      "startLine": 1085,
