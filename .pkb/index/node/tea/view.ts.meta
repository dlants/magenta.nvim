    },
    {
      "text": "    _getMountedNode: () =\u003e mountedNode",
      "contextualizedText": "// node/tea/view.ts \u003e function mountView \u003e function _getMountedNode\n\n    _getMountedNode: () =\u003e mountedNode",
      "headingContext": "node/tea/view.ts \u003e function mountView \u003e function _getMountedNode",
      "startLine": 165,
