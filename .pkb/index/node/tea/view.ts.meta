    },
    {
      "text": "/** for testing */\n  _getMountedNode(): MountedVDOM",
      "contextualizedText": "// node/tea/view.ts \u003e method _getMountedNode\n\n/** for testing */\n  _getMountedNode(): MountedVDOM",
