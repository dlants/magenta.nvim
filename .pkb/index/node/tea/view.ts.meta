      "endLine": 165,
      "endCol": 39
    },
    {
      "text": "export function d(\n  template: TemplateStringsArray,\n  ...values: (VDOMNode[] | VDOMNode | string)[]\n): VDOMNode {\n  const children: VDOMNode[] = [];\n  if (template[0].length) {\n    children.push({ type: \"string\", content: template[0] });\n  }\n  for (let i = 0; i \u003c values.length; i++) {\n    if (typeof values[i] === \"string\") {\n      children.push({ type: \"string\", content: values[i] as string });\n    } else if (Array.isArray(values[i])) {\n      children.push({ type: \"array\", children: values[i] as VDOMNode[] });\n    } else {\n      children.push(values[i] as VDOMNode);\n    }\n    if (template[i + 1].length \u003e 0) {\n      children.push({ type: \"string\", content: template[i + 1] });\n    }\n  }\n\n  return { type: \"node\", children: children, template: template };\n}",
      "contextualizedText": "// node/tea/view.ts \u003e function d\n\nexport function d(\n  template: TemplateStringsArray,\n  ...values: (VDOMNode[] | VDOMNode | string)[]\n): VDOMNode {\n  const children: VDOMNode[] = [];\n  if (template[0].length) {\n    children.push({ type: \"string\", content: template[0] });\n  }\n  for (let i = 0; i \u003c values.length; i++) {\n    if (typeof values[i] === \"string\") {\n      children.push({ type: \"string\", content: values[i] as string });\n    } else if (Array.isArray(values[i])) {\n      children.push({ type: \"array\", children: values[i] as VDOMNode[] });\n    } else {\n      children.push(values[i] as VDOMNode);\n    }\n    if (template[i + 1].length \u003e 0) {\n      children.push({ type: \"string\", content: template[i + 1] });\n    }\n  }\n\n  return { type: \"node\", children: children, template: template };\n}",
      "headingContext": "node/tea/view.ts \u003e function d",
      "startLine": 169,
      "startCol": 1,
      "endLine": 191,
      "endCol": 2
    },
    {
      "text": "/** Replace the bindings for this node\n */\nexport function withBindings(node: VDOMNode, bindings: Bindings) {\n  return {\n    ...node,\n    bindings,\n  };\n}",
      "contextualizedText": "// node/tea/view.ts \u003e function withBindings\n\n/** Replace the bindings for this node\n */\nexport function withBindings(node: VDOMNode, bindings: Bindings) {\n  return {\n    ...node,\n    bindings,\n  };\n}",
      "headingContext": "node/tea/view.ts \u003e function withBindings",
      "startLine": 193,
      "startCol": 1,
      "endLine": 200,
      "endCol": 2
    },
    {
      "text": "export function withExtmark(\n  node: VDOMNode,\n  extmarkOptions: ExtmarkOptions | undefined,\n) {\n  return {\n    ...node,\n    ...(extmarkOptions ? { extmarkOptions } : {}),\n  };\n}",
      "contextualizedText": "// node/tea/view.ts \u003e function withExtmark\n\nexport function withExtmark(\n  node: VDOMNode,\n  extmarkOptions: ExtmarkOptions | undefined,\n) {\n  return {\n    ...node,\n    ...(extmarkOptions ? { extmarkOptions } : {}),\n  };\n}",
      "headingContext": "node/tea/view.ts \u003e function withExtmark",
      "startLine": 202,
      "startCol": 1,
      "endLine": 210,
      "endCol": 2
    },
    {
      "text": "export function withError(node: VDOMNode) {\n  return withExtmark(node, { hl_group: \"ErrorMsg\" });\n}",
      "contextualizedText": "// node/tea/view.ts \u003e function withError\n\nexport function withError(node: VDOMNode) {\n  return withExtmark(node, { hl_group: \"ErrorMsg\" });\n}",
      "headingContext": "node/tea/view.ts \u003e function withError",
