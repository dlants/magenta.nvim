    },
    {
      "text": "export interface MountPoint {\n  nvim: Nvim;\n  buffer: NvimBuffer;\n  startPos: Position0Indexed;\n  endPos: Position0Indexed;\n}",
      "contextualizedText": "// node/tea/view.ts \u003e interface MountPoint\n\nexport interface MountPoint {\n  nvim: Nvim;\n  buffer: NvimBuffer;\n  startPos: Position0Indexed;\n  endPos: Position0Indexed;\n}",
      "headingContext": "node/tea/view.ts \u003e interface MountPoint",
