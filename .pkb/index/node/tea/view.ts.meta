      "endCol": 33
    },
    {
      "text": "export async function mountView\u003cP\u003e({\n  view,\n  mount,\n  props,\n}: {\n  view: View\u003cP\u003e;\n  mount: MountPoint;\n  props: P;\n}): Promise\u003cMountedView\u003cP\u003e\u003e {\n  let mountedNode = await render({ vdom: view(props), mount });",
      "contextualizedText": "// node/tea/view.ts \u003e function mountView\n\nexport async function mountView\u003cP\u003e({\n  view,\n  mount,\n  props,\n}: {\n  view: View\u003cP\u003e;\n  mount: MountPoint;\n  props: P;\n}): Promise\u003cMountedView\u003cP\u003e\u003e {\n  let mountedNode = await render({ vdom: view(props), mount });",
      "headingContext": "node/tea/view.ts \u003e function mountView",
      "startLine": 131,
      "startCol": 1,
      "endLine": 140,
      "endCol": 64
    },
    {
      "text": "    async render(props) {\n      const next = view(props);\n      try {\n        mountedNode = await update({\n          currentRoot: mountedNode,\n          nextRoot: next,\n          mount,\n        });\n      } catch (e) {\n        // Check if the buffer/mount point is still valid\n        const isBufferValid = await mount.buffer.isValid();\n        if (!isBufferValid) {\n          // Buffer is no longer valid, ignore the error\n          return;\n        }\n        // Buffer is still valid, re-throw the error\n        throw e;\n      }\n    }",
      "contextualizedText": "// node/tea/view.ts \u003e function mountView \u003e method render\n\n    async render(props) {\n      const next = view(props);\n      try {\n        mountedNode = await update({\n          currentRoot: mountedNode,\n          nextRoot: next,\n          mount,\n        });\n      } catch (e) {\n        // Check if the buffer/mount point is still valid\n        const isBufferValid = await mount.buffer.isValid();\n        if (!isBufferValid) {\n          // Buffer is no longer valid, ignore the error\n          return;\n        }\n        // Buffer is still valid, re-throw the error\n        throw e;\n      }\n    }",
      "headingContext": "node/tea/view.ts \u003e function mountView \u003e method render",
      "startLine": 143,
      "startCol": 1,
      "endLine": 161,
      "endCol": 6
    },
    {
      "text": "    unmount() {\n      // TODO\n    }",
      "contextualizedText": "// node/tea/view.ts \u003e function mountView \u003e method unmount\n\n    unmount() {\n      // TODO\n    }",
      "headingContext": "node/tea/view.ts \u003e function mountView \u003e method unmount",
