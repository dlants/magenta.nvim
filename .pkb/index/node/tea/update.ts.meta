    {
      "text": "function comparePositions(pos1: Position0Indexed, pos2: Position0Indexed) {\n  if (pos1.row \u003e pos2.row) {\n    return \"gt\";\n  }\n\n  if (pos1.row \u003c pos2.row) {\n    return \"lt\";\n  }\n\n  if (pos1.col \u003e pos2.col) {\n    return \"gt\";\n  }\n\n  if (pos1.col \u003c pos2.col) {\n    return \"lt\";\n  }\n\n  return \"eq\";\n}",
      "contextualizedText": "// node/tea/update.ts \u003e function comparePositions\n\nfunction comparePositions(pos1: Position0Indexed, pos2: Position0Indexed) {\n  if (pos1.row \u003e pos2.row) {\n    return \"gt\";\n  }\n\n  if (pos1.row \u003c pos2.row) {\n    return \"lt\";\n  }\n\n  if (pos1.col \u003e pos2.col) {\n    return \"gt\";\n  }\n\n  if (pos1.col \u003c pos2.col) {\n    return \"lt\";\n  }\n\n  return \"eq\";\n}",
      "headingContext": "node/tea/update.ts \u003e function comparePositions",
      "startLine": 553,
      "startCol": 1,
      "endLine": 571,
      "endCol": 2
    }
