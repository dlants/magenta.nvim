    {
      "text": "return (await visitNode(currentRoot, nextRoot)) as unknown as MountedVDOM;\n}",
      "contextualizedText": "// node/tea/update.ts \u003e function update\n\nreturn (await visitNode(currentRoot, nextRoot)) as unknown as MountedVDOM;\n}",
