    {
      "text": "  interceptSendMessage() {\n    const thread = this.magenta.chat.getActiveThread();\n    const callDefer = new Defer\u003cParameters\u003ctypeof thread.core.sendMessage\u003e\u003e();\n    const executeDefer = new Defer\u003cvoid\u003e();\n\n    const spy = vi\n      .spyOn(thread.core, \"sendMessage\")\n      .mockImplementation(\n        async (...args: Parameters\u003ctypeof thread.core.sendMessage\u003e) =\u003e {\n          callDefer.resolve(args);\n          return executeDefer.promise;\n        },\n      );\n\n    return {\n      promise: callDefer.promise,\n      spy",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method interceptSendMessage\n\n  interceptSendMessage() {\n    const thread = this.magenta.chat.getActiveThread();\n    const callDefer = new Defer\u003cParameters\u003ctypeof thread.core.sendMessage\u003e\u003e();\n    const executeDefer = new Defer\u003cvoid\u003e();\n\n    const spy = vi\n      .spyOn(thread.core, \"sendMessage\")\n      .mockImplementation(\n        async (...args: Parameters\u003ctypeof thread.core.sendMessage\u003e) =\u003e {\n          callDefer.resolve(args);\n          return executeDefer.promise;\n        },\n      );\n\n    return {\n      promise: callDefer.promise,\n      spy",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method interceptSendMessage",
      "startLine": 124,
      "startCol": 1,
      "endLine": 140,
      "endCol": 10
    },
    {
      "text": "      execute: (...args: Parameters\u003ctypeof thread.core.sendMessage\u003e) =\u003e {\n        spy.mockRestore();\n        return thread.core.sendMessage(...args).then(\n          () =\u003e executeDefer.resolve(),\n          (err: Error) =\u003e executeDefer.reject(err),\n        );\n      }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method interceptSendMessage \u003e function execute\n\n      execute: (...args: Parameters\u003ctypeof thread.core.sendMessage\u003e) =\u003e {\n        spy.mockRestore();\n        return thread.core.sendMessage(...args).then(\n          () =\u003e executeDefer.resolve(),\n          (err: Error) =\u003e executeDefer.reject(err),\n        );\n      }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method interceptSendMessage \u003e function execute",
      "startLine": 141,
