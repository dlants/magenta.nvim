      "endLine": 726,
      "endCol": 4
    },
    {
      "text": "  async addContextFiles(...filePaths: string[]) {\n    const quotedPaths = filePaths.map((path) =\u003e `'${path}'`).join(\" \");\n    await this.nvim.call(\"nvim_command\", [\n      `Magenta context-files ${quotedPaths}`,\n    ]);\n\n    // Wait for all files to be tracked in the context manager\n    await pollUntil(async () =\u003e {\n      const contextManager = this.magenta.chat.getActiveThread().contextManager;\n      const tracked = Object.values(contextManager.files).map(\n        (f) =\u003e f.relFilePath,\n      );\n      for (const filePath of filePaths) {\n        const normalizedPath = filePath.replace(/^\\.\\//, \"\");\n        if (!tracked.some((rel) =\u003e rel === normalizedPath)) {\n          throw new Error(`Context file ${filePath} not yet tracked`);\n        }\n      }\n    });\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method addContextFiles\n\n  async addContextFiles(...filePaths: string[]) {\n    const quotedPaths = filePaths.map((path) =\u003e `'${path}'`).join(\" \");\n    await this.nvim.call(\"nvim_command\", [\n      `Magenta context-files ${quotedPaths}`,\n    ]);\n\n    // Wait for all files to be tracked in the context manager\n    await pollUntil(async () =\u003e {\n      const contextManager = this.magenta.chat.getActiveThread().contextManager;\n      const tracked = Object.values(contextManager.files).map(\n        (f) =\u003e f.relFilePath,\n      );\n      for (const filePath of filePaths) {\n        const normalizedPath = filePath.replace(/^\\.\\//, \"\");\n        if (!tracked.some((rel) =\u003e rel === normalizedPath)) {\n          throw new Error(`Context file ${filePath} not yet tracked`);\n        }\n      }\n    });\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method addContextFiles",
      "startLine": 727,
      "startCol": 1,
      "endLine": 746,
      "endCol": 4
    },
    {
      "text": "  async sendKeysToInputBuffer(keys: string): Promise\u003cvoid\u003e {\n    const { inputWindow } = this.getVisibleState();\n    await this.nvim.call(\"nvim_set_current_win\", [inputWindow.id]);\n    const escapedKeys = await this.nvim.call(\"nvim_replace_termcodes\", [\n      keys,\n      true,\n      false,\n      true,\n    ]);\n    await this.nvim.call(\"nvim_feedkeys\", [escapedKeys, \"n\", false]);\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method sendKeysToInputBuffer\n\n  async sendKeysToInputBuffer(keys: string): Promise\u003cvoid\u003e {\n    const { inputWindow } = this.getVisibleState();\n    await this.nvim.call(\"nvim_set_current_win\", [inputWindow.id]);\n    const escapedKeys = await this.nvim.call(\"nvim_replace_termcodes\", [\n      keys,\n      true,\n      false,\n      true,\n    ]);\n    await this.nvim.call(\"nvim_feedkeys\", [escapedKeys, \"n\", false]);\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method sendKeysToInputBuffer",
      "startLine": 748,
      "startCol": 1,
      "endLine": 758,
      "endCol": 4
    },
