    {
      "text": "  async awaitExtmarks(\n    buffer: NvimBuffer,\n    expectedCount?: number,\n    timeout: number = 2000,\n    predicate?: (\n      marks: Awaited\u003cReturnType\u003cNvimBuffer[\"getExtmarks\"]\u003e\u003e,\n    ) =\u003e boolean,\n  ) {\n    return await pollUntil(\n      async () =\u003e {\n        const marks = await buffer.getExtmarks();\n\n        // If predicate is provided, use it as the primary filter\n        if (predicate) {\n          if (!predicate(marks)) {\n            throw new Error(\n              `Extmarks predicate not satisfied. Buffer ${buffer.id}. Extmarks: ${JSON.stringify(marks, null, 2)}`,\n            );\n          }\n        }\n\n        // Then apply count check if specified\n        if (expectedCount !== undefined) {\n          if (marks.length !== expectedCount) {\n            throw new Error(\n              `Expected ${expectedCount} extmarks, but found ${marks.length}`,\n            );\n          }\n        } else if (!predicate \u0026\u0026 marks.length === 0) {\n          throw new Error(\"No extmarks found yet\");\n        }\n        return marks;\n      },\n      {\n        timeout,\n      },\n    );\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method awaitExtmarks\n\n  async awaitExtmarks(\n    buffer: NvimBuffer,\n    expectedCount?: number,\n    timeout: number = 2000,\n    predicate?: (\n      marks: Awaited\u003cReturnType\u003cNvimBuffer[\"getExtmarks\"]\u003e\u003e,\n    ) =\u003e boolean,\n  ) {\n    return await pollUntil(\n      async () =\u003e {\n        const marks = await buffer.getExtmarks();\n\n        // If predicate is provided, use it as the primary filter\n        if (predicate) {\n          if (!predicate(marks)) {\n            throw new Error(\n              `Extmarks predicate not satisfied. Buffer ${buffer.id}. Extmarks: ${JSON.stringify(marks, null, 2)}`,\n            );\n          }\n        }\n\n        // Then apply count check if specified\n        if (expectedCount !== undefined) {\n          if (marks.length !== expectedCount) {\n            throw new Error(\n              `Expected ${expectedCount} extmarks, but found ${marks.length}`,\n            );\n          }\n        } else if (!predicate \u0026\u0026 marks.length === 0) {\n          throw new Error(\"No extmarks found yet\");\n        }\n        return marks;\n      },\n      {\n        timeout,\n      },\n    );\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method awaitExtmarks",
      "startLine": 772,
      "startCol": 1,
      "endLine": 809,
      "endCol": 4
