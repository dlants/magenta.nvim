      "text": "  async getVimMessages(): Promise\u003cstring\u003e {\n    const messages = await this.nvim.call(\"nvim_exec2\", [\n      \"messages\",\n      { output: true },\n    ]);\n    return (messages.output as string) || \"\";\n  }",
