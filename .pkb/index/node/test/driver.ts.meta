      "text": "  async assertDisplayBufferContains(\n    text: string,\n    start: number = 0,\n    timeout: number = 2000,\n  ): Promise\u003cPosition0Indexed\u003e {\n    let latestContent;\n    try {\n      return await pollUntil(\n        async () =\u003e {\n          const displayBuffer = this.getDisplayBuffer();\n          const lines = await displayBuffer.getLines({\n            start: 0 as Row0Indexed,\n            end: -1 as Row0Indexed,\n          });\n          latestContent = lines.slice(start).join(\"\\n\");\n          const index = Buffer.from(latestContent).indexOf(text) as ByteIdx;\n          if (index === -1) {\n            throw new Error(\n              `! Unable to find text ${text} after line ${start} in displayBuffer`,\n            );\n          }\n\n          return calculatePosition(\n            { row: start, col: 0 } as Position0Indexed,\n            Buffer.from(latestContent),\n            index,\n          );\n        },\n        { timeout },\n      );\n    } catch (e) {\n      expect(latestContent, (e as Error).message).toContain(text);\n      throw e;\n    }\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method assertDisplayBufferContains\n\n  async assertDisplayBufferContains(\n    text: string,\n    start: number = 0,\n    timeout: number = 2000,\n  ): Promise\u003cPosition0Indexed\u003e {\n    let latestContent;\n    try {\n      return await pollUntil(\n        async () =\u003e {\n          const displayBuffer = this.getDisplayBuffer();\n          const lines = await displayBuffer.getLines({\n            start: 0 as Row0Indexed,\n            end: -1 as Row0Indexed,\n          });\n          latestContent = lines.slice(start).join(\"\\n\");\n          const index = Buffer.from(latestContent).indexOf(text) as ByteIdx;\n          if (index === -1) {\n            throw new Error(\n              `! Unable to find text ${text} after line ${start} in displayBuffer`,\n            );\n          }\n\n          return calculatePosition(\n            { row: start, col: 0 } as Position0Indexed,\n            Buffer.from(latestContent),\n            index,\n          );\n        },\n        { timeout },\n      );\n    } catch (e) {\n      expect(latestContent, (e as Error).message).toContain(text);\n      throw e;\n    }\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method assertDisplayBufferContains",
      "startLine": 233,
      "startCol": 1,
      "endLine": 267,
      "endCol": 4
    },
    {
      "text": "  async assertInputBufferContains(\n    text: string,\n    start: number = 0,\n  ): Promise\u003cPosition0Indexed\u003e {\n    return pollUntil(async () =\u003e {\n      const inputBuffer = this.getInputBuffer();\n      const lines = await inputBuffer.getLines({\n        start: 0 as Row0Indexed,\n        end: -1 as Row0Indexed,\n      });\n      const content = lines.slice(start).join(\"\\n\");\n      const index = Buffer.from(content).indexOf(text) as ByteIdx;\n      if (index === -1) {\n        throw new Error(\n          `Unable to find text:\\n\"${text}\"\\nafter line ${start} in inputBuffer.\\ninputBuffer content:\\n${content}`,\n        );\n      }\n\n      return calculatePosition(\n        { row: start, col: 0 } as Position0Indexed,\n        Buffer.from(content),\n        index,\n      );\n    });\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method assertInputBufferContains\n\n  async assertInputBufferContains(\n    text: string,\n    start: number = 0,\n  ): Promise\u003cPosition0Indexed\u003e {\n    return pollUntil(async () =\u003e {\n      const inputBuffer = this.getInputBuffer();\n      const lines = await inputBuffer.getLines({\n        start: 0 as Row0Indexed,\n        end: -1 as Row0Indexed,\n      });\n      const content = lines.slice(start).join(\"\\n\");\n      const index = Buffer.from(content).indexOf(text) as ByteIdx;\n      if (index === -1) {\n        throw new Error(\n          `Unable to find text:\\n\"${text}\"\\nafter line ${start} in inputBuffer.\\ninputBuffer content:\\n${content}`,\n        );\n      }\n\n      return calculatePosition(\n        { row: start, col: 0 } as Position0Indexed,\n        Buffer.from(content),\n        index,\n      );\n    });\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method assertInputBufferContains",
      "startLine": 269,
