      "endLine": 293,
      "endCol": 4
    },
    {
      "text": "  awaitChatState(\n    desiredState:\n      | { state: \"thread-overview\" }\n      | { state: \"thread-selected\"; id?: ThreadId },\n    message?: string,\n  ) {\n    return pollUntil(() =\u003e {\n      const state = this.magenta.chat.state;\n      if (state.state !== desiredState.state) {\n        throw new Error(\n          `Unexpected chat state. Desired: ${JSON.stringify(desiredState)} actual:${state.state} ${message}`,\n        );\n      }\n\n      if (\n        desiredState.state === \"thread-selected\" \u0026\u0026\n        desiredState.id !== undefined \u0026\u0026\n        desiredState.id !== state.activeThreadId\n      ) {\n        throw new Error(\n          `Unexpected chat state. Desired: ${JSON.stringify(desiredState)} actual: ${JSON.stringify(state)}`,\n        );\n      }\n\n      return;\n    });\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method awaitChatState\n\n  awaitChatState(\n    desiredState:\n      | { state: \"thread-overview\" }\n      | { state: \"thread-selected\"; id?: ThreadId },\n    message?: string,\n  ) {\n    return pollUntil(() =\u003e {\n      const state = this.magenta.chat.state;\n      if (state.state !== desiredState.state) {\n        throw new Error(\n          `Unexpected chat state. Desired: ${JSON.stringify(desiredState)} actual:${state.state} ${message}`,\n        );\n      }\n\n      if (\n        desiredState.state === \"thread-selected\" \u0026\u0026\n        desiredState.id !== undefined \u0026\u0026\n        desiredState.id !== state.activeThreadId\n      ) {\n        throw new Error(\n          `Unexpected chat state. Desired: ${JSON.stringify(desiredState)} actual: ${JSON.stringify(state)}`,\n        );\n      }\n\n      return;\n    });\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method awaitChatState",
      "startLine": 295,
      "startCol": 1,
      "endLine": 321,
      "endCol": 4
    },
    {
      "text": "/** Get thread IDs in creation order */\n  getThreadIds(): ThreadId[] {\n    return Object.keys(this.magenta.chat.threadWrappers).sort() as ThreadId[];\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method getThreadIds\n\n/** Get thread IDs in creation order */\n  getThreadIds(): ThreadId[] {\n    return Object.keys(this.magenta.chat.threadWrappers).sort() as ThreadId[];\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method getThreadIds",
      "startLine": 323,
      "startCol": 3,
      "endLine": 326,
      "endCol": 4
    },
    {
      "text": "/** Get the nth thread ID (0-indexed) */\n  getThreadId(index: number): ThreadId {\n    const ids = this.getThreadIds();\n    if (index \u003c 0 || index \u003e= ids.length) {\n      throw new Error(\n        `Thread index ${index} out of bounds. Available threads: ${ids.length}`,\n      );\n    }\n    return ids[index];\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method getThreadId\n\n/** Get the nth thread ID (0-indexed) */\n  getThreadId(index: number): ThreadId {\n    const ids = this.getThreadIds();\n    if (index \u003c 0 || index \u003e= ids.length) {\n      throw new Error(\n        `Thread index ${index} out of bounds. Available threads: ${ids.length}`,\n      );\n    }\n    return ids[index];\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method getThreadId",
      "startLine": 328,
      "startCol": 3,
      "endLine": 337,
      "endCol": 4
    },
    {
      "text": "/** Get the active thread ID */\n  getActiveThreadId(): ThreadId | undefined {\n    const state = this.magenta.chat.state;\n    if (state.state === \"thread-selected\") {\n      return state.activeThreadId;\n    }\n    return undefined;\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method getActiveThreadId\n\n/** Get the active thread ID */\n  getActiveThreadId(): ThreadId | undefined {\n    const state = this.magenta.chat.state;\n    if (state.state === \"thread-selected\") {\n      return state.activeThreadId;\n    }\n    return undefined;\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method getActiveThreadId",
      "startLine": 339,
      "startCol": 3,
      "endLine": 346,
      "endCol": 4
    },
    {
      "text": "/** Wait until the specified number of threads exist */\n  async awaitThreadCount(count: number) {\n    return pollUntil(() =\u003e {\n      const ids = this.getThreadIds();\n      if (ids.length \u003c count) {\n        throw new Error(\n          `Expected ${count} threads, but only ${ids.length} exist`,\n        );\n      }\n      return ids;\n    });\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method awaitThreadCount\n\n/** Wait until the specified number of threads exist */\n  async awaitThreadCount(count: number) {\n    return pollUntil(() =\u003e {\n      const ids = this.getThreadIds();\n      if (ids.length \u003c count) {\n        throw new Error(\n          `Expected ${count} threads, but only ${ids.length} exist`,\n        );\n      }\n      return ids;\n    });\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method awaitThreadCount",
      "startLine": 348,
      "startCol": 3,
      "endLine": 359,
      "endCol": 4
    },
    {
      "text": "  async assertBufferContains(\n    buffer: NvimBuffer,\n    text: string,\n    start: number = 0,\n  ): Promise\u003cPosition0Indexed\u003e {\n    try {\n      return await pollUntil(async () =\u003e {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: -1 as Row0Indexed,\n        });\n        const content = lines.slice(start).join(\"\\n\");\n        const index = Buffer.from(content).indexOf(text) as ByteIdx;\n        if (index === -1) {\n          throw new Error(\n            `Unable to find text:\\n\"${text}\"\\nafter line ${start} in inputBuffer.\\ninputBuffer content:\\n${content}`,\n          );\n        }\n\n        return calculatePosition(\n          { row: start, col: 0 } as Position0Indexed,\n          Buffer.from(content),\n          index,\n        );\n      });\n    } catch (e) {\n      const lines = await buffer.getLines({\n        start: 0 as Row0Indexed,\n        end: -1 as Row0Indexed,\n      });\n      const content = lines.slice(start).join(\"\\n\");\n      expect(content).toContain(text);\n      throw e;\n    }\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method assertBufferContains\n\n  async assertBufferContains(\n    buffer: NvimBuffer,\n    text: string,\n    start: number = 0,\n  ): Promise\u003cPosition0Indexed\u003e {\n    try {\n      return await pollUntil(async () =\u003e {\n        const lines = await buffer.getLines({\n          start: 0 as Row0Indexed,\n          end: -1 as Row0Indexed,\n        });\n        const content = lines.slice(start).join(\"\\n\");\n        const index = Buffer.from(content).indexOf(text) as ByteIdx;\n        if (index === -1) {\n          throw new Error(\n            `Unable to find text:\\n\"${text}\"\\nafter line ${start} in inputBuffer.\\ninputBuffer content:\\n${content}`,\n          );\n        }\n\n        return calculatePosition(\n          { row: start, col: 0 } as Position0Indexed,\n          Buffer.from(content),\n          index,\n        );\n      });\n    } catch (e) {\n      const lines = await buffer.getLines({\n        start: 0 as Row0Indexed,\n        end: -1 as Row0Indexed,\n      });\n      const content = lines.slice(start).join(\"\\n\");\n      expect(content).toContain(text);\n      throw e;\n    }\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method assertBufferContains",
      "startLine": 361,
      "startCol": 1,
      "endLine": 395,
      "endCol": 4
    },
    {
      "text": "  async assertDisplayBufferContent(text: string): Promise\u003cvoid\u003e {\n    try {\n      return await pollUntil(async () =\u003e {\n        const displayBuffer = this.getDisplayBuffer();\n        const lines = await displayBuffer.getLines({\n          start: 0 as Row0Indexed,\n          end: -1 as Row0Indexed,\n        });\n        const content = lines.join(\"\\n\");\n        if (content !== text) {\n          throw new Error(\n            `display buffer content does not match text:\\n\"${text}\"\\ndisplayBuffer content:\\n${content}`,\n          );\n        }\n      });\n    } catch (e) {\n      const displayBuffer = this.getDisplayBuffer();\n      const lines = await displayBuffer.getLines({\n        start: 0 as Row0Indexed,\n        end: -1 as Row0Indexed,\n      });\n      const content = lines.join(\"\\n\");\n      expect(content).toEqual(text);\n      throw e;\n    }\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method assertDisplayBufferContent\n\n  async assertDisplayBufferContent(text: string): Promise\u003cvoid\u003e {\n    try {\n      return await pollUntil(async () =\u003e {\n        const displayBuffer = this.getDisplayBuffer();\n        const lines = await displayBuffer.getLines({\n          start: 0 as Row0Indexed,\n          end: -1 as Row0Indexed,\n        });\n        const content = lines.join(\"\\n\");\n        if (content !== text) {\n          throw new Error(\n            `display buffer content does not match text:\\n\"${text}\"\\ndisplayBuffer content:\\n${content}`,\n          );\n        }\n      });\n    } catch (e) {\n      const displayBuffer = this.getDisplayBuffer();\n      const lines = await displayBuffer.getLines({\n        start: 0 as Row0Indexed,\n        end: -1 as Row0Indexed,\n      });\n      const content = lines.join(\"\\n\");\n      expect(content).toEqual(text);\n      throw e;\n    }\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method assertDisplayBufferContent",
