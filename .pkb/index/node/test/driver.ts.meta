    {
      "text": "  async showSidebar() {\n    // Check if magenta windows are already visible\n    const magentaWindowExists = await this.checkMagentaWindowsExist();\n\n    if (!magentaWindowExists) {\n      await this.magenta.command(\"toggle\");\n    }\n\n    // Wait until magenta windows are actually visible\n    await pollUntil(async () =\u003e {\n      const windowsExist = await this.checkMagentaWindowsExist();\n      if (!windowsExist) {\n        throw new Error(`Magenta windows not visible yet`);\n      }\n    });\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method showSidebar\n\n  async showSidebar() {\n    // Check if magenta windows are already visible\n    const magentaWindowExists = await this.checkMagentaWindowsExist();\n\n    if (!magentaWindowExists) {\n      await this.magenta.command(\"toggle\");\n    }\n\n    // Wait until magenta windows are actually visible\n    await pollUntil(async () =\u003e {\n      const windowsExist = await this.checkMagentaWindowsExist();\n      if (!windowsExist) {\n        throw new Error(`Magenta windows not visible yet`);\n      }\n    });\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method showSidebar",
      "startLine": 53,
      "startCol": 1,
      "endLine": 68,
      "endCol": 4
    },
    {
      "text": "  private async checkMagentaWindowsExist(): Promise\u003cboolean\u003e {\n    try {\n      const windows = await getAllWindows(this.nvim);\n      let inputWindowExists = false;\n\n      for (const window of windows) {\n        try {\n          const magentaVar = await window.getVar(\"magenta\");\n          if (magentaVar) {\n            // Check if this is specifically the input window (not display window)\n            const isDisplayWindow = await window\n              .getVar(\"magenta_display_window\")\n              .catch(() =\u003e false);\n            if (!isDisplayWindow) {\n              inputWindowExists = true;\n              break;\n            }\n          }\n        } catch {\n          // Window doesn't have magenta var, continue\n        }\n      }\n\n      return inputWindowExists;\n    } catch {\n      return false;\n    }\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method checkMagentaWindowsExist\n\n  private async checkMagentaWindowsExist(): Promise\u003cboolean\u003e {\n    try {\n      const windows = await getAllWindows(this.nvim);\n      let inputWindowExists = false;\n\n      for (const window of windows) {\n        try {\n          const magentaVar = await window.getVar(\"magenta\");\n          if (magentaVar) {\n            // Check if this is specifically the input window (not display window)\n            const isDisplayWindow = await window\n              .getVar(\"magenta_display_window\")\n              .catch(() =\u003e false);\n            if (!isDisplayWindow) {\n              inputWindowExists = true;\n              break;\n            }\n          }\n        } catch {\n          // Window doesn't have magenta var, continue\n        }\n      }\n\n      return inputWindowExists;\n    } catch {\n      return false;\n    }\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method checkMagentaWindowsExist",
      "startLine": 70,
      "startCol": 1,
      "endLine": 97,
      "endCol": 4
    },
    {
      "text": "  async waitForChatReady() {\n    return await pollUntil(\n      () =\u003e {\n        try {\n          this.magenta.chat.getActiveThread();\n          return true;\n        } catch (e) {\n          if ((e as Error).message.includes(\"Chat is not initialized yet\")) {\n            throw new Error(\"Chat is not ready yet\");\n          }\n          throw e;\n        }\n      },\n      { timeout: 1000 },\n    );\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method waitForChatReady\n\n  async waitForChatReady() {\n    return await pollUntil(\n      () =\u003e {\n        try {\n          this.magenta.chat.getActiveThread();\n          return true;\n        } catch (e) {\n          if ((e as Error).message.includes(\"Chat is not initialized yet\")) {\n            throw new Error(\"Chat is not ready yet\");\n          }\n          throw e;\n        }\n      },\n      { timeout: 1000 },\n    );\n  }",
      "headingContext": "node/test/driver.ts \u003e class NvimDriver \u003e method waitForChatReady",
      "startLine": 99,
      "startCol": 1,
      "endLine": 114,
      "endCol": 4
    },
    {
      "text": "  async inputMagentaText(text: string) {\n    await this.magenta.activeBuffers.inputBuffer.setLines({\n      start: 0 as Row0Indexed,\n      end: -1 as Row0Indexed,\n      lines: text.split(\"\\n\") as Line[],\n    });\n  }",
      "contextualizedText": "// node/test/driver.ts \u003e class NvimDriver \u003e method inputMagentaText\n\n  async inputMagentaText(text: string) {\n    await this.magenta.activeBuffers.inputBuffer.setLines({\n      start: 0 as Row0Indexed,\n      end: -1 as Row0Indexed,\n      lines: text.split(\"\\n\") as Line[],\n    });\n  }",
