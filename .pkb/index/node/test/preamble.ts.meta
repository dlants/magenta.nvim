      "text": "export type TestOptions = Partial\u003cMagentaOptions\u003e \u0026 {\n  changeDebounceMs?: number;\n};\n\nexport type TestDirs = {\n  tmpDir: string;\n  homeDir: string;\n  baseDir: string;\n};",
