    {
      "text": "/**\n * Normalizes paths in test data by replacing the tmpDir prefix with a placeholder.\n * This allows tests to match results that contain absolute paths.\n */\nexport function normalizePaths\u003cT\u003e(data: T, tmpDir: string): T {\n  const normalizedTmpDir = tmpDir.replace(/\\/+$/, \"\"); // remove trailing slashes\n  // On macOS, /tmp is a symlink to /private/tmp, so we need to handle both\n  const privateTmpDir = `/private${normalizedTmpDir}`;",
      "contextualizedText": "// node/test/preamble.ts \u003e function normalizePaths\n\n/**\n * Normalizes paths in test data by replacing the tmpDir prefix with a placeholder.\n * This allows tests to match results that contain absolute paths.\n */\nexport function normalizePaths\u003cT\u003e(data: T, tmpDir: string): T {\n  const normalizedTmpDir = tmpDir.replace(/\\/+$/, \"\"); // remove trailing slashes\n  // On macOS, /tmp is a symlink to /private/tmp, so we need to handle both\n  const privateTmpDir = `/private${normalizedTmpDir}`;",
      "headingContext": "node/test/preamble.ts \u003e function normalizePaths",
      "startLine": 523,
      "startCol": 1,
      "endLine": 530,
      "endCol": 55
    },
    {
      "text": "  const replacePath = (str: string): string =\u003e {\n    // Replace both variations of the tmpDir path with a placeholder\n    return str\n      .replaceAll(privateTmpDir, \"\u003ctmpDir\u003e\")\n      .replaceAll(normalizedTmpDir, \"\u003ctmpDir\u003e\");\n  }",
      "contextualizedText": "// node/test/preamble.ts \u003e function normalizePaths \u003e function replacePath\n\n  const replacePath = (str: string): string =\u003e {\n    // Replace both variations of the tmpDir path with a placeholder\n    return str\n      .replaceAll(privateTmpDir, \"\u003ctmpDir\u003e\")\n      .replaceAll(normalizedTmpDir, \"\u003ctmpDir\u003e\");\n  }",
      "headingContext": "node/test/preamble.ts \u003e function normalizePaths \u003e function replacePath",
      "startLine": 532,
      "startCol": 1,
      "endLine": 537,
      "endCol": 4
    },
    {
      "text": "  const normalize = (value: unknown): unknown =\u003e {\n    if (typeof value === \"string\") {\n      return replacePath(value);\n    }\n    if (Array.isArray(value)) {\n      return value.map(normalize);\n    }\n    if (value !== null \u0026\u0026 typeof value === \"object\") {\n      const result: Record\u003cstring, unknown\u003e = {};\n      for (const [key, val] of Object.entries(value)) {\n        result[key] = normalize(val);\n      }\n      return result;\n    }\n    return value;\n  }",
      "contextualizedText": "// node/test/preamble.ts \u003e function normalizePaths \u003e function normalize\n\n  const normalize = (value: unknown): unknown =\u003e {\n    if (typeof value === \"string\") {\n      return replacePath(value);\n    }\n    if (Array.isArray(value)) {\n      return value.map(normalize);\n    }\n    if (value !== null \u0026\u0026 typeof value === \"object\") {\n      const result: Record\u003cstring, unknown\u003e = {};\n      for (const [key, val] of Object.entries(value)) {\n        result[key] = normalize(val);\n      }\n      return result;\n    }\n    return value;\n  }",
      "headingContext": "node/test/preamble.ts \u003e function normalizePaths \u003e function normalize",
      "startLine": 539,
      "startCol": 1,
      "endLine": 554,
      "endCol": 4
    },
    {
      "text": "return normalize(data) as T;\n}",
      "contextualizedText": "// node/test/preamble.ts \u003e function normalizePaths\n\nreturn normalize(data) as T;\n}",
      "headingContext": "node/test/preamble.ts \u003e function normalizePaths",
      "startLine": 556,
      "startCol": 3,
      "endLine": 557,
      "endCol": 2
    },
    {
      "text": "export function extractMountTree(mounted: MountedVDOM): unknown {\n  switch (mounted.type) {\n    case \"string\":\n      return {\n        type: \"string\",\n        startPos: mounted.startPos,\n        endPos: mounted.endPos,\n        content: mounted.content,\n      };\n    case \"node\":\n      return {\n        type: \"node\",\n        children: mounted.children.map(extractMountTree),\n        startPos: mounted.startPos,\n        endPos: mounted.endPos,\n      };\n\n    case \"array\":\n      return {\n        type: \"array\",\n        children: mounted.children.map(extractMountTree),\n        startPos: mounted.startPos,\n        endPos: mounted.endPos,\n      };\n\n    default:\n      assertUnreachable(mounted);\n  }\n}",
      "contextualizedText": "// node/test/preamble.ts \u003e function extractMountTree\n\nexport function extractMountTree(mounted: MountedVDOM): unknown {\n  switch (mounted.type) {\n    case \"string\":\n      return {\n        type: \"string\",\n        startPos: mounted.startPos,\n        endPos: mounted.endPos,\n        content: mounted.content,\n      };\n    case \"node\":\n      return {\n        type: \"node\",\n        children: mounted.children.map(extractMountTree),\n        startPos: mounted.startPos,\n        endPos: mounted.endPos,\n      };\n\n    case \"array\":\n      return {\n        type: \"array\",\n        children: mounted.children.map(extractMountTree),\n        startPos: mounted.startPos,\n        endPos: mounted.endPos,\n      };\n\n    default:\n      assertUnreachable(mounted);\n  }\n}",
      "headingContext": "node/test/preamble.ts \u003e function extractMountTree",
      "startLine": 559,
      "startCol": 1,
      "endLine": 587,
      "endCol": 2
    }
  ]
