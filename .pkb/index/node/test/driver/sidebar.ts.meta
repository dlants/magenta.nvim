      "text": "/**\n   * Assert that input buffer content exactly matches expected text\n   */\n  async assertInputContent(\n    expectedText: string,\n    timeout: number = 2000,\n  ): Promise\u003cvoid\u003e {\n    await pollUntil(\n      async () =\u003e {\n        const content = await this.getInputText();\n        if (content !== expectedText) {\n          throw new Error(\n            `Input buffer content does not match.\\nExpected:\\n\"${expectedText}\"\\nActual:\\n\"${content}\"`,\n          );\n        }\n      },\n      { timeout },\n    );\n  }",
      "contextualizedText": "// node/test/driver/sidebar.ts \u003e class SidebarInteraction \u003e method assertInputContent\n\n/**\n   * Assert that input buffer content exactly matches expected text\n   */\n  async assertInputContent(\n    expectedText: string,\n    timeout: number = 2000,\n  ): Promise\u003cvoid\u003e {\n    await pollUntil(\n      async () =\u003e {\n        const content = await this.getInputText();\n        if (content !== expectedText) {\n          throw new Error(\n            `Input buffer content does not match.\\nExpected:\\n\"${expectedText}\"\\nActual:\\n\"${content}\"`,\n          );\n        }\n      },\n      { timeout },\n    );\n  }",
