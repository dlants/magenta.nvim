    {
      "text": "/**\n   * Wait for chat to be ready\n   */\n  async waitForChatReady(timeout: number = 1000): Promise\u003cvoid\u003e {\n    await pollUntil(\n      () =\u003e {\n        try {\n          this.magenta.chat.getActiveThread();\n          return true;\n        } catch (e) {\n          if ((e as Error).message.includes(\"Chat is not initialized yet\")) {\n            throw new Error(\"Chat is not ready yet\");\n          }\n          throw e;\n        }\n      },\n      { timeout },\n    );\n  }",
      "contextualizedText": "// node/test/driver/sidebar.ts \u003e class SidebarInteraction \u003e method waitForChatReady\n\n/**\n   * Wait for chat to be ready\n   */\n  async waitForChatReady(timeout: number = 1000): Promise\u003cvoid\u003e {\n    await pollUntil(\n      () =\u003e {\n        try {\n          this.magenta.chat.getActiveThread();\n          return true;\n        } catch (e) {\n          if ((e as Error).message.includes(\"Chat is not initialized yet\")) {\n            throw new Error(\"Chat is not ready yet\");\n          }\n          throw e;\n        }\n      },\n      { timeout },\n    );\n  }",
