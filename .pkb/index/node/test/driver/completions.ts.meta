      "text": "import type { Nvim } from \"../../nvim/nvim-node/index.ts\";\nimport { pollUntil } from \"../../utils/async.ts\";",
      "contextualizedText": "// node/test/driver/completions.ts\n\nimport type { Nvim } from \"../../nvim/nvim-node/index.ts\";\nimport { pollUntil } from \"../../utils/async.ts\";",
