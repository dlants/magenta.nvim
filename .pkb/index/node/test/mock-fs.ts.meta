    {
      "text": "// Mock filesystem helpers for GitHub token files\nexport class MockFileSystem {\n  private files: Map\u003cstring, string\u003e = new Map()",
      "contextualizedText": "// node/test/mock-fs.ts \u003e class MockFileSystem\n\n// Mock filesystem helpers for GitHub token files\nexport class MockFileSystem {\n  private files: Map\u003cstring, string\u003e = new Map()",
      "headingContext": "node/test/mock-fs.ts \u003e class MockFileSystem",
      "startLine": 6,
      "startCol": 1,
