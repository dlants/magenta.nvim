    {
      "text": "  private static async createReadOnlyInputBuffer(\n    nvim: Nvim,\n    name: string,\n  ): Promise\u003cNvimBuffer\u003e {\n    const buffer = await NvimBuffer.create(false, true, nvim);\n    await buffer.setName(name);\n    await buffer.setOption(\"bufhidden\", \"hide\");\n    await buffer.setOption(\"buftype\", \"nofile\");\n    await buffer.setOption(\"swapfile\", false);\n    await buffer.setOption(\"modifiable\", false);\n    return buffer;\n  }",
      "contextualizedText": "// node/buffer-manager.ts \u003e class BufferManager \u003e method createReadOnlyInputBuffer\n\n  private static async createReadOnlyInputBuffer(\n    nvim: Nvim,\n    name: string,\n  ): Promise\u003cNvimBuffer\u003e {\n    const buffer = await NvimBuffer.create(false, true, nvim);\n    await buffer.setName(name);\n    await buffer.setOption(\"bufhidden\", \"hide\");\n    await buffer.setOption(\"buftype\", \"nofile\");\n    await buffer.setOption(\"swapfile\", false);\n    await buffer.setOption(\"modifiable\", false);\n    return buffer;\n  }",
      "headingContext": "node/buffer-manager.ts \u003e class BufferManager \u003e method createReadOnlyInputBuffer",
