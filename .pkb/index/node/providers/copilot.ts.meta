      "contextualizedText": "// node/providers/copilot.ts\n\n// import OpenAI from \"openai\";\n// import { promises as fs } from \"fs\";\n// import * as os from \"os\";\n// import * as path from \"path\";\n// import type {\n//   StopReason,\n//   Provider,\n//   ProviderMessage,\n//   Usage,\n//   ProviderStreamRequest,\n//   ProviderToolSpec,\n//   ProviderStreamEvent,\n//   ProviderToolUseRequest,\n//   ProviderToolUseResponse,\n//   ProviderThread,\n//   ProviderThreadOptions,\n// } from \"./provider-types.ts\";\n// import type { Nvim } from \"../nvim/nvim-node/index.ts\";\n// import { \"You are a helpful coding assistant.\" } from \"./system-prompt.ts\";\n// import { validateInput } from \"@magenta/core\";\n// import type { Result } from \"../utils/result.ts\";\n// import type { ToolRequestId } from \"@magenta/core\";\n// import { assertUnreachable } from \"../utils/assertUnreachable.ts\";\n// import type { ToolRequest } from \"@magenta/core\";\n// import type {\n//   JSONSchemaObject,\n//   JSONSchemaType,\n// } from \"openai/lib/jsonschema.mjs\";\n// import type { Stream } from \"openai/streaming\";\n//\n// class CopilotAuth {\n//   private tokenInfo?: {\n//     token: string;\n//     endpoints: { api: string };\n//     expiresAt: Date;\n//   };\n//\n//   private static readonly TOKEN_PATHS = [\n//     path.join(os.homedir(), \".config\", \"github-copilot\", \"hosts.json\"),\n//     path.join(os.homedir(), \".config\", \"github-copilot\", \"apps.json\"),\n//   ];\n//\n//   async getGitHubToken(): Promise\u003c{\n//     token: string;\n//     endpoints: { api: string };\n//   }\u003e {\n//     await this.refreshTokenIfNeeded();\n//     if (!this.tokenInfo) {\n//       throw new Error(\"Failed to obtain GitHub token\");\n//     }\n//     return {\n//       token: this.tokenInfo.token,\n//       endpoints: this.tokenInfo.endpoints,\n//     };\n//   }\n//\n//   private async refreshTokenIfNeeded(): Promise\u003cvoid\u003e {\n//     const now = new Date();\n//    