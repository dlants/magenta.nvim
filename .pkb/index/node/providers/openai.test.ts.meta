  "chunks": [
    {
      "text": "import { describe, it } from \"vitest\";\n\ndescribe.skip(\"OpenAIProvider\", () =\u003e {\n  it.todo(\"placeholder - tests commented out\");\n});",
      "contextualizedText": "// node/providers/openai.test.ts\n\nimport { describe, it } from \"vitest\";\n\ndescribe.skip(\"OpenAIProvider\", () =\u003e {\n  it.todo(\"placeholder - tests commented out\");\n});",
      "headingContext": "node/providers/openai.test.ts",
      "startLine": 1,
      "startCol": 1,
      "endLine": 5,
      "endCol": 4
    },
    {
      "text": "/*\nimport { describe, it, expect, vi, beforeEach, afterEach } from \"vitest\";\nimport { getProvider, setMockProvider } from \"./provider.ts\";\nimport type {\n  ProviderMessage,\n  ProviderName,\n  ProviderStreamEvent,\n} from \"./provider-types.ts\";\nimport { withNvimClient } from \"../test/preamble.ts\";\nimport { OpenAIProvider } from \"./openai.ts\";\nimport type { ResponseInput } from \"openai/resources/responses/responses.mjs\";\n\ninterface MockOpenAIConfig {\n  baseURL?: string;\n  apiKey?: string;\n}\n\nlet lastOpenAIConfig: MockOpenAIConfig | undefined;\nlet mockStreamEvents: unknown[] = [];\nvi.mock(\"openai\", () =\u003e {\n  class MockOpenAI {\n    responses = {\n      create: vi.fn().mockImplementation(() =\u003e {\n        return {\n          [Symbol.asyncIterator]: async function* () {\n            for (const event of mockStreamEvents) {\n              yield event;\n            }\n          },\n          controller: {\n            abort: vi.fn(() =\u003e {}),\n          },\n        };\n      }),\n    };\n\n    constructor(config: MockOpenAIConfig) {\n      lastOpenAIConfig = config;\n    }\n  }\n\n  return {\n    default: MockOpenAI,\n  };\n});\n\ndescribe(\"OpenAIProvider\", () =\u003e {\n  beforeEach(() =\u003e {\n    vi.clearAllMocks();\n    lastOpenAIConfig = undefined;\n    mockStreamEvents = [];\n    process.env.OPENAI_API_KEY = \"test-key\";\n    setMockProvider(undefined);\n  });\n\n  afterEach(() =\u003e {\n    delete process.env.OPENAI_API_KEY;\n  });\n\n  it(\"should correctly reset baseUrl when switching between profiles with different baseUrls\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile1 = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n        baseUrl: \"https://api.openai.com/v1\",\n      };\n\n      const profile2 = {\n        name: \"qwen3:14b\",\n        provider: \"openai\" as ProviderName,\n        model: \"qwen3:14b\",\n        fastModel: \"qwen3:14b\",\n        baseUrl: \"http://localhost:11434/v1\",\n      };\n\n      const provider1 = getProvider(nvim, profile1);\n      expect(provider1).toBeDefined();\n\n      expect(lastOpenAIConfig).toHaveProperty(\n        \"baseURL\",\n        \"https://api.openai.com/v1\",\n      );\n\n      const provider2 = getProvider(nvim, profile2);\n      expect(provider2).toBeDefined();\n\n      expect(lastOpenAIConfig).toHaveProperty(\n        \"baseURL\",\n        \"http://localhost:11434/v1\",\n      );\n\n      expect(provider1).not.toBe(provider2);\n    });\n  });\n\n  it(\"should handle reasoning events correctly\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n      };\n\n      // Set up mock stream events from the notes\n      mockStreamEvents = [\n        // Initial reasoning item with encrypted content\n        {\n          type: \"response.output_item.added\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-123\",\n            encrypted_content: \"encrypted-data-456\",\n          },\n        },\n        // First summary part\n        {\n          type: \"response.reasoning_summary_part.added\",\n          summary_index: 0,\n          item_id: \"item-123\",\n        },\n        {\n          type: \"response.reasoning_summary_text.delta\",\n          summary_index: 0,\n          item_id: \"item-123\",\n          delta: \"First part of thinking\",\n        },\n        {\n          type: \"response.reasoning_summary_text.delta\",\n          summary_index: 0,\n          item_id: \"item-123\",\n          delta: \" continues here\",\n        },\n        {\n          type: \"response.reasoning_summary_text.done\",\n          summary_index: 0,\n          item_id: \"item-123\",\n        },\n        {\n          type: \"response.reasoning_summary_part.done\",\n          summary_index: 0,\n          item_id: \"item-123\",\n        },\n        // Second summary part\n        {\n          type: \"response.reasoning_summary_part.added\",\n          summary_index: 1,\n          item_id: \"item-123\",\n        },\n        {\n          type: \"response.reasoning_summary_text.delta\",\n          summary_index: 1,\n          item_id: \"item-123\",\n          delta: \"Second thinking part\",\n        },\n        {\n          type: \"response.reasoning_summary_text.done\",\n          summary_index: 1,\n          item_id: \"item-123\",\n        },\n        {\n          type: \"response.reasoning_summary_part.done\",\n          summary_index: 1,\n          item_id: \"item-123\",\n        },\n        // End reasoning item\n        {\n          type: \"response.output_item.done\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-123\",\n          },\n        },\n        // Completion event\n        {\n          type: \"response.completed\",\n          response: {\n            usage: {\n              input_tokens: 100,\n              output_tokens: 50,\n            },\n          },\n        },\n      ];\n\n      const provider = getProvider(nvim, profile);\n      const capturedEvents: ProviderStreamEvent[] = [];\n\n      const streamRequest = provider.sendMessage({\n        model: \"gpt-4o\",\n        messages: [\n          { role: \"user\", content: [{ type: \"text\", text: \"Test message\" }] },\n        ],\n        onStreamEvent: (event) =\u003e capturedEvents.push(event),\n        tools: [],\n      });\n\n      await streamRequest.promise;\n\n      // Expected events based on the implementation:\n      expect(capturedEvents).toEqual([\n        // Redacted thinking block (start + end)\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"redacted_thinking\",\n            data: \"encrypted-data-456\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n        // First thinking block\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_delta\",\n          index: 0,\n          delta: {\n            type: \"thinking_delta\",\n            thinking: \"First part of thinking\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_delta\",\n          index: 0,\n          delta: {\n            type: \"thinking_delta\",\n            thinking: \" continues here\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n        // Second thinking block\n        {\n          type: \"content_block_start\",\n          index: 1,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_delta\",\n          index: 1,\n          delta: {\n            type: \"thinking_delta\",\n            thinking: \"Second thinking part\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 1,\n        },\n      ]);\n    });\n  });\n\n  it(\"should aggregate thinking blocks back into reasoning messages\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      // Create a message with multiple thinking blocks that should be aggregated\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            // Redacted thinking block\n            {\n              type: \"redacted_thinking\" as const,\n              data: \"encrypted-data-123\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // First thinking summary\n            {\n              type: \"thinking\" as const,\n              thinking: \"Let me think about this step by step.\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Second thinking summary (same itemId)\n            {\n              type: \"thinking\" as const,\n              thinking: \"Now I need to consider the implications.\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Regular text response\n            {\n              type: \"text\" as const,\n              text: \"Here's my answer based on my thinking.\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"text-item-1\",\n                },\n              },\n            },\n            // Another reasoning block with different itemId\n            {\n              type: \"thinking\" as const,\n              thinking: \"Actually, let me double-check this.\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-2\",\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      const params = provider.createStreamParameters({\n        model: \"gpt-4o\",\n        messages,\n        tools: [],\n      });\n\n      // Extract the input messages from the parameters\n      const inputMessages = params.input as ResponseInput;\n\n      // Find the reasoning messages in the input\n      const reasoningMessages = inputMessages.filter(\n        (msg) =\u003e msg.type === \"reasoning\",\n      );\n\n      expect(reasoningMessages).toHaveLength(2);\n\n      // First reasoning message should aggregate the redacted + 2 thinking blocks\n      expect(reasoningMessages[0]).toEqual({\n        type: \"reasoning\",\n        id: \"reasoning-item-1\",\n        encrypted_content: \"encrypted-data-123\",\n        summary: [\n          {\n            type: \"summary_text\",\n            text: \"Let me think about this step by step.\",\n          },\n          {\n            type: \"summary_text\",\n            text: \"Now I need to consider the implications.\",\n          },\n        ],\n      });\n\n      // Second reasoning message should have just the single thinking block\n      expect(reasoningMessages[1]).toEqual({\n        type: \"reasoning\",\n        id: \"reasoning-item-2\",\n        encrypted_content: null,\n        summary: [\n          {\n            type: \"summary_text\",\n            text: \"Actually, let me double-check this.\",\n          },\n        ],\n      });\n\n      // Verify the assistant message content is also present\n      const assistantMessages = inputMessages.filter(\n        (msg) =\u003e (msg as { role: string }).role === \"assistant\",\n      );\n      expect(assistantMessages).toHaveLength(1);\n      expect(\n        (assistantMessages[0] as { content: unknown[] }).content[0],\n      ).toEqual({\n        type: \"output_text\",\n        text: \"Here's my answer based on my thinking.\",\n        annotations: [],\n      });\n    });\n  });\n\n  it(\"should place reasoning messages in correct position in stream\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      // Create messages where reasoning blocks appear between other content\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            // First text message\n            {\n              type: \"text\" as const,\n              text: \"Let me start with this.\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"text-item-1\",\n                },\n              },\n            },\n            // Reasoning block appears in the middle\n            {\n              type: \"thinking\" as const,\n              thinking: \"Now let me think about this.\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Another text message after reasoning\n            {\n              type: \"text\" as const,\n              text: \"And here's my final answer.\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"text-item-2\",\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      const params = provider.createStreamParameters({\n        model: \"gpt-4o\",\n        messages,\n        tools: [],\n      });\n\n      const inputMessages = params.input as ResponseInput;\n\n      // Verify the order: system, user, assistant-text, reasoning, assistant-text\n      expect(inputMessages).toHaveLength(5);\n      expect(inputMessages[0]).toHaveProperty(\"role\", \"system\");\n      expect(inputMessages[1]).toHaveProperty(\"role\", \"user\");\n      expect(inputMessages[2]).toHaveProperty(\"role\", \"assistant\");\n      expect(inputMessages[2]).toHaveProperty(\"id\", \"text-item-1\");\n      expect(inputMessages[3]).toHaveProperty(\"type\", \"reasoning\");\n      expect(inputMessages[3]).toHaveProperty(\"id\", \"reasoning-item-1\");\n      expect(inputMessages[4]).toHaveProperty(\"role\", \"assistant\");\n      expect(inputMessages[4]).toHaveProperty(\"id\", \"text-item-2\");\n    });\n  });\n\n  it(\"should throw error for multiple redacted thinking blocks with same itemId\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            {\n              type: \"redacted_thinking\" as const,\n              data: \"encrypted-data-1\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            {\n              type: \"redacted_thinking\" as const,\n              data: \"encrypted-data-2\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\", // Same itemId!\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      expect(() =\u003e\n        provider.createStreamParameters({\n          model: \"gpt-4o\",\n          messages,\n          tools: [],\n        }),\n      ).toThrow(\n        \"Multiple redacted thinking blocks found for itemId reasoning-item-1. Expected at most one.\",\n      );\n    });\n  });\n\n  it(\"should throw error for thinking blocks without itemId\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            {\n              type: \"thinking\" as const,\n              thinking: \"Thinking without itemId\",\n              signature: \"\",\n              // Missing providerMetadata.openai.itemId\n            },\n          ],\n        },\n      ];\n\n      expect(() =\u003e\n        provider.createStreamParameters({\n          model: \"gpt-4o\",\n          messages,\n          tools: [],\n        }),\n      ).toThrow(\n        \"Thinking content must have an itemId in providerMetadata.openai\",\n      );\n    });\n  });\n\n  it(\"should throw error for thinking blocks in non-assistant messages\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [\n            {\n              type: \"thinking\" as const, // Invalid: thinking in user message\n              thinking: \"User thinking\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      expect(() =\u003e\n        provider.createStreamParameters({\n          model: \"gpt-4o\",\n          messages,\n          tools: [],\n        }),\n      ).toThrow(\"encountered thinking block in non-assistant message\");\n    });\n  });\n\n  it(\"should not create reasoning summaries for empty thinking blocks\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            // Empty thinking block (should be skipped in summary)\n            {\n              type: \"thinking\" as const,\n              thinking: \"\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Whitespace-only thinking block (should be skipped in summary)\n            {\n              type: \"thinking\" as const,\n              thinking: \"   \\n  \\t  \",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Non-empty thinking block (should be included in summary)\n            {\n              type: \"thinking\" as const,\n              thinking: \"This has actual content\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Another empty thinking block with different itemId\n            {\n              type: \"thinking\" as const,\n              thinking: \"\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-2\",\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      const params = provider.createStreamParameters({\n        model: \"gpt-4o\",\n        messages,\n        tools: [],\n      });\n\n      const inputMessages = params.input as ResponseInput;\n      const reasoningMessages = inputMessages.filter(\n        (msg) =\u003e msg.type === \"reasoning\",\n      );\n\n      expect(reasoningMessages).toHaveLength(2);\n\n      // First reasoning message should only include the non-empty thinking block\n      expect(reasoningMessages[0]).toEqual({\n        type: \"reasoning\",\n        id: \"reasoning-item-1\",\n        encrypted_content: null,\n        summary: [\n          {\n            type: \"summary_text\",\n            text: \"This has actual content\",\n          },\n        ],\n      });\n\n      // Second reasoning message should have empty summary (no content blocks)\n      expect(reasoningMessages[1]).toEqual({\n        type: \"reasoning\",\n        id: \"reasoning-item-2\",\n        encrypted_content: null,\n        summary: [],\n      });\n    });\n  });\n  it(\"should handle empty reasoning blocks correctly\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n      };\n\n      // Test 1: Entirely empty reasoning block\n      mockStreamEvents = [\n        {\n          type: \"response.output_item.added\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-empty\",\n            encrypted_content: null,\n          },\n        },\n        {\n          type: \"response.output_item.done\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-empty\",\n            encrypted_content: null,\n          },\n        },\n        {\n          type: \"response.completed\",\n          response: {\n            usage: {\n              input_tokens: 100,\n              output_tokens: 50,\n            },\n          },\n        },\n      ];\n\n      const provider = getProvider(nvim, profile);\n      const capturedEvents: ProviderStreamEvent[] = [];\n\n      const streamRequest = provider.sendMessage({\n        model: \"gpt-4o\",\n        messages: [\n          { role: \"user\", content: [{ type: \"text\", text: \"Test message\" }] },\n        ],\n        onStreamEvent: (event) =\u003e capturedEvents.push(event),\n        tools: [],\n      });\n\n      await streamRequest.promise;\n\n      // Should create an empty thinking block and immediately close it\n      expect(capturedEvents).toEqual([\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-empty\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n      ]);\n    });\n  });\n\n  it(\"should handle reasoning block with only encrypted content\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n      };\n\n      // Test 2: Only encrypted content, no summary parts\n      mockStreamEvents = [\n        {\n          type: \"response.output_item.added\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-encrypted-only\",\n            encrypted_content: \"encrypted-signature-data\",\n          },\n        },\n        {\n          type: \"response.output_item.done\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-encrypted-only\",\n            encrypted_content: \"encrypted-signature-data\",\n          },\n        },\n        {\n          type: \"response.completed\",\n          response: {\n            usage: {\n              input_tokens: 100,\n              output_tokens: 50,\n            },\n          },\n        },\n      ];\n\n      const provider = getProvider(nvim, profile);\n      const capturedEvents: ProviderStreamEvent[] = [];\n\n      const streamRequest = provider.sendMessage({\n        model: \"gpt-4o\",\n        messages: [\n          { role: \"user\", content: [{ type: \"text\", text: \"Test message\" }] },\n        ],\n        onStreamEvent: (event) =\u003e capturedEvents.push(event),\n        tools: [],\n      });\n\n      await streamRequest.promise;\n\n      // Should create a redacted thinking block and immediately close it\n      expect(capturedEvents).toEqual([\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"redacted_thinking\",\n            data: \"encrypted-signature-data\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-encrypted-only\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n      ]);\n    });\n  });\n\n  it(\"should handle reasoning block starting empty then getting summary content\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n      };\n\n      // Test 3: Empty start, then summary content arrives\n      mockStreamEvents = [\n        {\n          type: \"response.output_item.added\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-delayed-content\",\n            encrypted_content: null,\n          },\n        },\n        // Summary content arrives later\n        {\n          type: \"response.reasoning_summary_part.added\",\n          summary_index: 0,\n          item_id: \"item-delayed-content\",\n        },\n        {\n          type: \"response.reasoning_summary_text.delta\",\n          summary_index: 0,\n          item_id: \"item-delayed-content\",\n          delta: \"Thinking that arrives later\",\n        },\n        {\n          type: \"response.reasoning_summary_text.done\",\n          summary_index: 0,\n          item_id: \"item-delayed-content\",\n        },\n        {\n          type: \"response.reasoning_summary_part.done\",\n          summary_index: 0,\n          item_id: \"item-delayed-content\",\n        },\n        {\n          type: \"response.output_item.done\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-delayed-content\",\n            encrypted_content: null,\n          },\n        },\n        {\n          type: \"response.completed\",\n          response: {\n            usage: {\n              input_tokens: 100,\n              output_tokens: 50,\n            },\n          },\n        },\n      ];\n\n      const provider = getProvider(nvim, profile);\n      const capturedEvents: ProviderStreamEvent[] = [];\n\n      const streamRequest = provider.sendMessage({\n        model: \"gpt-4o\",\n        messages: [\n          { role: \"user\", content: [{ type: \"text\", text: \"Test message\" }] },\n        ],\n        onStreamEvent: (event) =\u003e capturedEvents.push(event),\n        tools: [],\n      });\n\n      await streamRequest.promise;\n\n      // Should create empty thinking block and immediately close it, then handle summary content separately\n      expect(capturedEvents).toEqual([\n        // Initial empty thinking block from reasoning item (immediately closed)\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-delayed-content\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n        // Summary part starts (new thinking block)\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-delayed-content\",\n            },\n          },\n        },\n        // Content arrives\n        {\n          type: \"content_block_delta\",\n          index: 0,\n          delta: {\n            type: \"thinking_delta\",\n            thinking: \"Thinking that arrives later\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-delayed-content\",\n            },\n          },\n        },\n        // Summary part closes\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n      ]);\n    });\n  });\n});\n*/",
      "contextualizedText": "// node/providers/openai.test.ts\n\n/*\nimport { describe, it, expect, vi, beforeEach, afterEach } from \"vitest\";\nimport { getProvider, setMockProvider } from \"./provider.ts\";\nimport type {\n  ProviderMessage,\n  ProviderName,\n  ProviderStreamEvent,\n} from \"./provider-types.ts\";\nimport { withNvimClient } from \"../test/preamble.ts\";\nimport { OpenAIProvider } from \"./openai.ts\";\nimport type { ResponseInput } from \"openai/resources/responses/responses.mjs\";\n\ninterface MockOpenAIConfig {\n  baseURL?: string;\n  apiKey?: string;\n}\n\nlet lastOpenAIConfig: MockOpenAIConfig | undefined;\nlet mockStreamEvents: unknown[] = [];\nvi.mock(\"openai\", () =\u003e {\n  class MockOpenAI {\n    responses = {\n      create: vi.fn().mockImplementation(() =\u003e {\n        return {\n          [Symbol.asyncIterator]: async function* () {\n            for (const event of mockStreamEvents) {\n              yield event;\n            }\n          },\n          controller: {\n            abort: vi.fn(() =\u003e {}),\n          },\n        };\n      }),\n    };\n\n    constructor(config: MockOpenAIConfig) {\n      lastOpenAIConfig = config;\n    }\n  }\n\n  return {\n    default: MockOpenAI,\n  };\n});\n\ndescribe(\"OpenAIProvider\", () =\u003e {\n  beforeEach(() =\u003e {\n    vi.clearAllMocks();\n    lastOpenAIConfig = undefined;\n    mockStreamEvents = [];\n    process.env.OPENAI_API_KEY = \"test-key\";\n    setMockProvider(undefined);\n  });\n\n  afterEach(() =\u003e {\n    delete process.env.OPENAI_API_KEY;\n  });\n\n  it(\"should correctly reset baseUrl when switching between profiles with different baseUrls\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile1 = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n        baseUrl: \"https://api.openai.com/v1\",\n      };\n\n      const profile2 = {\n        name: \"qwen3:14b\",\n        provider: \"openai\" as ProviderName,\n        model: \"qwen3:14b\",\n        fastModel: \"qwen3:14b\",\n        baseUrl: \"http://localhost:11434/v1\",\n      };\n\n      const provider1 = getProvider(nvim, profile1);\n      expect(provider1).toBeDefined();\n\n      expect(lastOpenAIConfig).toHaveProperty(\n        \"baseURL\",\n        \"https://api.openai.com/v1\",\n      );\n\n      const provider2 = getProvider(nvim, profile2);\n      expect(provider2).toBeDefined();\n\n      expect(lastOpenAIConfig).toHaveProperty(\n        \"baseURL\",\n        \"http://localhost:11434/v1\",\n      );\n\n      expect(provider1).not.toBe(provider2);\n    });\n  });\n\n  it(\"should handle reasoning events correctly\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n      };\n\n      // Set up mock stream events from the notes\n      mockStreamEvents = [\n        // Initial reasoning item with encrypted content\n        {\n          type: \"response.output_item.added\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-123\",\n            encrypted_content: \"encrypted-data-456\",\n          },\n        },\n        // First summary part\n        {\n          type: \"response.reasoning_summary_part.added\",\n          summary_index: 0,\n          item_id: \"item-123\",\n        },\n        {\n          type: \"response.reasoning_summary_text.delta\",\n          summary_index: 0,\n          item_id: \"item-123\",\n          delta: \"First part of thinking\",\n        },\n        {\n          type: \"response.reasoning_summary_text.delta\",\n          summary_index: 0,\n          item_id: \"item-123\",\n          delta: \" continues here\",\n        },\n        {\n          type: \"response.reasoning_summary_text.done\",\n          summary_index: 0,\n          item_id: \"item-123\",\n        },\n        {\n          type: \"response.reasoning_summary_part.done\",\n          summary_index: 0,\n          item_id: \"item-123\",\n        },\n        // Second summary part\n        {\n          type: \"response.reasoning_summary_part.added\",\n          summary_index: 1,\n          item_id: \"item-123\",\n        },\n        {\n          type: \"response.reasoning_summary_text.delta\",\n          summary_index: 1,\n          item_id: \"item-123\",\n          delta: \"Second thinking part\",\n        },\n        {\n          type: \"response.reasoning_summary_text.done\",\n          summary_index: 1,\n          item_id: \"item-123\",\n        },\n        {\n          type: \"response.reasoning_summary_part.done\",\n          summary_index: 1,\n          item_id: \"item-123\",\n        },\n        // End reasoning item\n        {\n          type: \"response.output_item.done\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-123\",\n          },\n        },\n        // Completion event\n        {\n          type: \"response.completed\",\n          response: {\n            usage: {\n              input_tokens: 100,\n              output_tokens: 50,\n            },\n          },\n        },\n      ];\n\n      const provider = getProvider(nvim, profile);\n      const capturedEvents: ProviderStreamEvent[] = [];\n\n      const streamRequest = provider.sendMessage({\n        model: \"gpt-4o\",\n        messages: [\n          { role: \"user\", content: [{ type: \"text\", text: \"Test message\" }] },\n        ],\n        onStreamEvent: (event) =\u003e capturedEvents.push(event),\n        tools: [],\n      });\n\n      await streamRequest.promise;\n\n      // Expected events based on the implementation:\n      expect(capturedEvents).toEqual([\n        // Redacted thinking block (start + end)\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"redacted_thinking\",\n            data: \"encrypted-data-456\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n        // First thinking block\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_delta\",\n          index: 0,\n          delta: {\n            type: \"thinking_delta\",\n            thinking: \"First part of thinking\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_delta\",\n          index: 0,\n          delta: {\n            type: \"thinking_delta\",\n            thinking: \" continues here\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n        // Second thinking block\n        {\n          type: \"content_block_start\",\n          index: 1,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_delta\",\n          index: 1,\n          delta: {\n            type: \"thinking_delta\",\n            thinking: \"Second thinking part\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-123\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 1,\n        },\n      ]);\n    });\n  });\n\n  it(\"should aggregate thinking blocks back into reasoning messages\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      // Create a message with multiple thinking blocks that should be aggregated\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            // Redacted thinking block\n            {\n              type: \"redacted_thinking\" as const,\n              data: \"encrypted-data-123\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // First thinking summary\n            {\n              type: \"thinking\" as const,\n              thinking: \"Let me think about this step by step.\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Second thinking summary (same itemId)\n            {\n              type: \"thinking\" as const,\n              thinking: \"Now I need to consider the implications.\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Regular text response\n            {\n              type: \"text\" as const,\n              text: \"Here's my answer based on my thinking.\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"text-item-1\",\n                },\n              },\n            },\n            // Another reasoning block with different itemId\n            {\n              type: \"thinking\" as const,\n              thinking: \"Actually, let me double-check this.\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-2\",\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      const params = provider.createStreamParameters({\n        model: \"gpt-4o\",\n        messages,\n        tools: [],\n      });\n\n      // Extract the input messages from the parameters\n      const inputMessages = params.input as ResponseInput;\n\n      // Find the reasoning messages in the input\n      const reasoningMessages = inputMessages.filter(\n        (msg) =\u003e msg.type === \"reasoning\",\n      );\n\n      expect(reasoningMessages).toHaveLength(2);\n\n      // First reasoning message should aggregate the redacted + 2 thinking blocks\n      expect(reasoningMessages[0]).toEqual({\n        type: \"reasoning\",\n        id: \"reasoning-item-1\",\n        encrypted_content: \"encrypted-data-123\",\n        summary: [\n          {\n            type: \"summary_text\",\n            text: \"Let me think about this step by step.\",\n          },\n          {\n            type: \"summary_text\",\n            text: \"Now I need to consider the implications.\",\n          },\n        ],\n      });\n\n      // Second reasoning message should have just the single thinking block\n      expect(reasoningMessages[1]).toEqual({\n        type: \"reasoning\",\n        id: \"reasoning-item-2\",\n        encrypted_content: null,\n        summary: [\n          {\n            type: \"summary_text\",\n            text: \"Actually, let me double-check this.\",\n          },\n        ],\n      });\n\n      // Verify the assistant message content is also present\n      const assistantMessages = inputMessages.filter(\n        (msg) =\u003e (msg as { role: string }).role === \"assistant\",\n      );\n      expect(assistantMessages).toHaveLength(1);\n      expect(\n        (assistantMessages[0] as { content: unknown[] }).content[0],\n      ).toEqual({\n        type: \"output_text\",\n        text: \"Here's my answer based on my thinking.\",\n        annotations: [],\n      });\n    });\n  });\n\n  it(\"should place reasoning messages in correct position in stream\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      // Create messages where reasoning blocks appear between other content\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            // First text message\n            {\n              type: \"text\" as const,\n              text: \"Let me start with this.\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"text-item-1\",\n                },\n              },\n            },\n            // Reasoning block appears in the middle\n            {\n              type: \"thinking\" as const,\n              thinking: \"Now let me think about this.\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Another text message after reasoning\n            {\n              type: \"text\" as const,\n              text: \"And here's my final answer.\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"text-item-2\",\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      const params = provider.createStreamParameters({\n        model: \"gpt-4o\",\n        messages,\n        tools: [],\n      });\n\n      const inputMessages = params.input as ResponseInput;\n\n      // Verify the order: system, user, assistant-text, reasoning, assistant-text\n      expect(inputMessages).toHaveLength(5);\n      expect(inputMessages[0]).toHaveProperty(\"role\", \"system\");\n      expect(inputMessages[1]).toHaveProperty(\"role\", \"user\");\n      expect(inputMessages[2]).toHaveProperty(\"role\", \"assistant\");\n      expect(inputMessages[2]).toHaveProperty(\"id\", \"text-item-1\");\n      expect(inputMessages[3]).toHaveProperty(\"type\", \"reasoning\");\n      expect(inputMessages[3]).toHaveProperty(\"id\", \"reasoning-item-1\");\n      expect(inputMessages[4]).toHaveProperty(\"role\", \"assistant\");\n      expect(inputMessages[4]).toHaveProperty(\"id\", \"text-item-2\");\n    });\n  });\n\n  it(\"should throw error for multiple redacted thinking blocks with same itemId\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            {\n              type: \"redacted_thinking\" as const,\n              data: \"encrypted-data-1\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            {\n              type: \"redacted_thinking\" as const,\n              data: \"encrypted-data-2\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\", // Same itemId!\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      expect(() =\u003e\n        provider.createStreamParameters({\n          model: \"gpt-4o\",\n          messages,\n          tools: [],\n        }),\n      ).toThrow(\n        \"Multiple redacted thinking blocks found for itemId reasoning-item-1. Expected at most one.\",\n      );\n    });\n  });\n\n  it(\"should throw error for thinking blocks without itemId\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            {\n              type: \"thinking\" as const,\n              thinking: \"Thinking without itemId\",\n              signature: \"\",\n              // Missing providerMetadata.openai.itemId\n            },\n          ],\n        },\n      ];\n\n      expect(() =\u003e\n        provider.createStreamParameters({\n          model: \"gpt-4o\",\n          messages,\n          tools: [],\n        }),\n      ).toThrow(\n        \"Thinking content must have an itemId in providerMetadata.openai\",\n      );\n    });\n  });\n\n  it(\"should throw error for thinking blocks in non-assistant messages\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [\n            {\n              type: \"thinking\" as const, // Invalid: thinking in user message\n              thinking: \"User thinking\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      expect(() =\u003e\n        provider.createStreamParameters({\n          model: \"gpt-4o\",\n          messages,\n          tools: [],\n        }),\n      ).toThrow(\"encountered thinking block in non-assistant message\");\n    });\n  });\n\n  it(\"should not create reasoning summaries for empty thinking blocks\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const provider = new OpenAIProvider(nvim);\n\n      const messages: ProviderMessage[] = [\n        {\n          role: \"user\" as const,\n          content: [{ type: \"text\" as const, text: \"Test question\" }],\n        },\n        {\n          role: \"assistant\" as const,\n          content: [\n            // Empty thinking block (should be skipped in summary)\n            {\n              type: \"thinking\" as const,\n              thinking: \"\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Whitespace-only thinking block (should be skipped in summary)\n            {\n              type: \"thinking\" as const,\n              thinking: \"   \\n  \\t  \",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Non-empty thinking block (should be included in summary)\n            {\n              type: \"thinking\" as const,\n              thinking: \"This has actual content\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-1\",\n                },\n              },\n            },\n            // Another empty thinking block with different itemId\n            {\n              type: \"thinking\" as const,\n              thinking: \"\",\n              signature: \"\",\n              providerMetadata: {\n                openai: {\n                  itemId: \"reasoning-item-2\",\n                },\n              },\n            },\n          ],\n        },\n      ];\n\n      const params = provider.createStreamParameters({\n        model: \"gpt-4o\",\n        messages,\n        tools: [],\n      });\n\n      const inputMessages = params.input as ResponseInput;\n      const reasoningMessages = inputMessages.filter(\n        (msg) =\u003e msg.type === \"reasoning\",\n      );\n\n      expect(reasoningMessages).toHaveLength(2);\n\n      // First reasoning message should only include the non-empty thinking block\n      expect(reasoningMessages[0]).toEqual({\n        type: \"reasoning\",\n        id: \"reasoning-item-1\",\n        encrypted_content: null,\n        summary: [\n          {\n            type: \"summary_text\",\n            text: \"This has actual content\",\n          },\n        ],\n      });\n\n      // Second reasoning message should have empty summary (no content blocks)\n      expect(reasoningMessages[1]).toEqual({\n        type: \"reasoning\",\n        id: \"reasoning-item-2\",\n        encrypted_content: null,\n        summary: [],\n      });\n    });\n  });\n  it(\"should handle empty reasoning blocks correctly\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n      };\n\n      // Test 1: Entirely empty reasoning block\n      mockStreamEvents = [\n        {\n          type: \"response.output_item.added\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-empty\",\n            encrypted_content: null,\n          },\n        },\n        {\n          type: \"response.output_item.done\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-empty\",\n            encrypted_content: null,\n          },\n        },\n        {\n          type: \"response.completed\",\n          response: {\n            usage: {\n              input_tokens: 100,\n              output_tokens: 50,\n            },\n          },\n        },\n      ];\n\n      const provider = getProvider(nvim, profile);\n      const capturedEvents: ProviderStreamEvent[] = [];\n\n      const streamRequest = provider.sendMessage({\n        model: \"gpt-4o\",\n        messages: [\n          { role: \"user\", content: [{ type: \"text\", text: \"Test message\" }] },\n        ],\n        onStreamEvent: (event) =\u003e capturedEvents.push(event),\n        tools: [],\n      });\n\n      await streamRequest.promise;\n\n      // Should create an empty thinking block and immediately close it\n      expect(capturedEvents).toEqual([\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-empty\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n      ]);\n    });\n  });\n\n  it(\"should handle reasoning block with only encrypted content\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n      };\n\n      // Test 2: Only encrypted content, no summary parts\n      mockStreamEvents = [\n        {\n          type: \"response.output_item.added\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-encrypted-only\",\n            encrypted_content: \"encrypted-signature-data\",\n          },\n        },\n        {\n          type: \"response.output_item.done\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-encrypted-only\",\n            encrypted_content: \"encrypted-signature-data\",\n          },\n        },\n        {\n          type: \"response.completed\",\n          response: {\n            usage: {\n              input_tokens: 100,\n              output_tokens: 50,\n            },\n          },\n        },\n      ];\n\n      const provider = getProvider(nvim, profile);\n      const capturedEvents: ProviderStreamEvent[] = [];\n\n      const streamRequest = provider.sendMessage({\n        model: \"gpt-4o\",\n        messages: [\n          { role: \"user\", content: [{ type: \"text\", text: \"Test message\" }] },\n        ],\n        onStreamEvent: (event) =\u003e capturedEvents.push(event),\n        tools: [],\n      });\n\n      await streamRequest.promise;\n\n      // Should create a redacted thinking block and immediately close it\n      expect(capturedEvents).toEqual([\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"redacted_thinking\",\n            data: \"encrypted-signature-data\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-encrypted-only\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n      ]);\n    });\n  });\n\n  it(\"should handle reasoning block starting empty then getting summary content\", async () =\u003e {\n    await withNvimClient(async (nvim) =\u003e {\n      const profile = {\n        name: \"gpt-4o\",\n        provider: \"openai\" as ProviderName,\n        model: \"gpt-4o\",\n        fastModel: \"gpt-4o\",\n      };\n\n      // Test 3: Empty start, then summary content arrives\n      mockStreamEvents = [\n        {\n          type: \"response.output_item.added\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-delayed-content\",\n            encrypted_content: null,\n          },\n        },\n        // Summary content arrives later\n        {\n          type: \"response.reasoning_summary_part.added\",\n          summary_index: 0,\n          item_id: \"item-delayed-content\",\n        },\n        {\n          type: \"response.reasoning_summary_text.delta\",\n          summary_index: 0,\n          item_id: \"item-delayed-content\",\n          delta: \"Thinking that arrives later\",\n        },\n        {\n          type: \"response.reasoning_summary_text.done\",\n          summary_index: 0,\n          item_id: \"item-delayed-content\",\n        },\n        {\n          type: \"response.reasoning_summary_part.done\",\n          summary_index: 0,\n          item_id: \"item-delayed-content\",\n        },\n        {\n          type: \"response.output_item.done\",\n          output_index: 0,\n          item: {\n            type: \"reasoning\",\n            id: \"item-delayed-content\",\n            encrypted_content: null,\n          },\n        },\n        {\n          type: \"response.completed\",\n          response: {\n            usage: {\n              input_tokens: 100,\n              output_tokens: 50,\n            },\n          },\n        },\n      ];\n\n      const provider = getProvider(nvim, profile);\n      const capturedEvents: ProviderStreamEvent[] = [];\n\n      const streamRequest = provider.sendMessage({\n        model: \"gpt-4o\",\n        messages: [\n          { role: \"user\", content: [{ type: \"text\", text: \"Test message\" }] },\n        ],\n        onStreamEvent: (event) =\u003e capturedEvents.push(event),\n        tools: [],\n      });\n\n      await streamRequest.promise;\n\n      // Should create empty thinking block and immediately close it, then handle summary content separately\n      expect(capturedEvents).toEqual([\n        // Initial empty thinking block from reasoning item (immediately closed)\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-delayed-content\",\n            },\n          },\n        },\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n        // Summary part starts (new thinking block)\n        {\n          type: \"content_block_start\",\n          index: 0,\n          content_block: {\n            type: \"thinking\",\n            thinking: \"\",\n            signature: \"\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-delayed-content\",\n            },\n          },\n        },\n        // Content arrives\n        {\n          type: \"content_block_delta\",\n          index: 0,\n          delta: {\n            type: \"thinking_delta\",\n            thinking: \"Thinking that arrives later\",\n          },\n          providerMetadata: {\n            openai: {\n              itemId: \"item-delayed-content\",\n            },\n          },\n        },\n        // Summary part closes\n        {\n          type: \"content_block_stop\",\n          index: 0,\n        },\n      ]);\n    });\n  });\n});\n*/",
      "headingContext": "node/providers/openai.test.ts",
