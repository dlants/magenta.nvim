    {
      "text": "it(\"returns undefined for server_tool_use blocks\", async () =\u003e {\n    const mockClient = new MockAnthropicClient();\n    const agent = createAgent(mockClient);\n\n    agent.appendUserMessage([\n      {\n        type: \"text\",\n        text: \"Search\",\n        nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n      },\n    ]);\n    await delay(0);\n    agent.continueConversation();\n\n    const stream = await mockClient.awaitStream();\n\n    const blockIndex = stream.nextBlockIndex();\n\n    // Start a server_tool_use block\n    stream.emitEvent({\n      type: \"content_block_start\",\n      index: blockIndex,\n      content_block: {\n        type: \"server_tool_use\",\n        id: \"server-tool-1\",\n        name: \"web_search\",\n        input: {},\n      } as unknown as Anthropic.Messages.ContentBlock,\n    });\n\n    // server_tool_use should not be exposed via getStreamingBlock\n    expect(agent.getStreamingBlock()).toBeUndefined();\n\n    stream.emitEvent({\n      type: \"content_block_stop\",\n      index: blockIndex,\n    });\n\n    stream.finishResponse(\"end_turn\");\n    await stream.finalMessage();\n  });",
      "contextualizedText": "// node/providers/anthropic-agent.test.ts\n\nit(\"returns undefined for server_tool_use blocks\", async () =\u003e {\n    const mockClient = new MockAnthropicClient();\n    const agent = createAgent(mockClient);\n\n    agent.appendUserMessage([\n      {\n        type: \"text\",\n        text: \"Search\",\n        nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n      },\n    ]);\n    await delay(0);\n    agent.continueConversation();\n\n    const stream = await mockClient.awaitStream();\n\n    const blockIndex = stream.nextBlockIndex();\n\n    // Start a server_tool_use block\n    stream.emitEvent({\n      type: \"content_block_start\",\n      index: blockIndex,\n      content_block: {\n        type: \"server_tool_use\",\n        id: \"server-tool-1\",\n        name: \"web_search\",\n        input: {},\n      } as unknown as Anthropic.Messages.ContentBlock,\n    });\n\n    // server_tool_use should not be exposed via getStreamingBlock\n    expect(agent.getStreamingBlock()).toBeUndefined();\n\n    stream.emitEvent({\n      type: \"content_block_stop\",\n      index: blockIndex,\n    });\n\n    stream.finishResponse(\"end_turn\");\n    await stream.finalMessage();\n  });",
