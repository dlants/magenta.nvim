    {
      "text": "  countTokens(\n    messages: Array\u003cProviderMessage\u003e,\n    tools: Array\u003cProviderToolSpec\u003e,\n  ): number {\n    const CHARS_PER_TOKEN = 4;\n\n    let charCount = 5000;\n    charCount += JSON.stringify(tools).length;\n    charCount += JSON.stringify(messages).length;\n\n    return Math.ceil(charCount / CHARS_PER_TOKEN);\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method countTokens\n\n  countTokens(\n    messages: Array\u003cProviderMessage\u003e,\n    tools: Array\u003cProviderToolSpec\u003e,\n  ): number {\n    const CHARS_PER_TOKEN = 4;\n\n    let charCount = 5000;\n    charCount += JSON.stringify(tools).length;\n    charCount += JSON.stringify(messages).length;\n\n    return Math.ceil(charCount / CHARS_PER_TOKEN);\n  }",
      "headingContext": "node/providers/mock.ts \u003e class MockProvider \u003e method countTokens",
