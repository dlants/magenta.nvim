    {
      "text": "  sendMessage(_options: {\n    model: string;\n    messages: Array\u003cProviderMessage\u003e;\n    onStreamEvent: (event: ProviderStreamEvent) =\u003e void;\n    tools: Array\u003cProviderToolSpec\u003e;\n    systemPrompt?: string | undefined;\n    thinking?: {\n      enabled: boolean;\n      budgetTokens?: number;\n    };\n  }): ProviderStreamRequest {\n    throw new Error(\n      \"sendMessage is deprecated - use createAgent instead. Tests should use mockAnthropic.awaitPendingStream()\",\n    );\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method sendMessage\n\n  sendMessage(_options: {\n    model: string;\n    messages: Array\u003cProviderMessage\u003e;\n    onStreamEvent: (event: ProviderStreamEvent) =\u003e void;\n    tools: Array\u003cProviderToolSpec\u003e;\n    systemPrompt?: string | undefined;\n    thinking?: {\n      enabled: boolean;\n      budgetTokens?: number;\n    };\n  }): ProviderStreamRequest {\n    throw new Error(\n      \"sendMessage is deprecated - use createAgent instead. Tests should use mockAnthropic.awaitPendingStream()\",\n    );\n  }",
