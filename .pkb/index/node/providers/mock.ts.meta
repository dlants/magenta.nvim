    {
      "text": "  async awaitPendingForceToolUseRequest(message?: string) {\n    return pollUntil(() =\u003e {\n      const lastRequest =\n        this.forceToolUseRequests[this.forceToolUseRequests.length - 1];\n      if (lastRequest \u0026\u0026 !lastRequest.defer.resolved) {\n        return lastRequest;\n      }\n      throw new Error(`no pending force tool use requests: ${message}`);\n    });\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingForceToolUseRequest\n\n  async awaitPendingForceToolUseRequest(message?: string) {\n    return pollUntil(() =\u003e {\n      const lastRequest =\n        this.forceToolUseRequests[this.forceToolUseRequests.length - 1];\n      if (lastRequest \u0026\u0026 !lastRequest.defer.resolved) {\n        return lastRequest;\n      }\n      throw new Error(`no pending force tool use requests: ${message}`);\n    });\n  }",
      "headingContext": "node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingForceToolUseRequest",
