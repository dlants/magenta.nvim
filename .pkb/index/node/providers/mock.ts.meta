    {
      "text": "/**\n   * Completes a request with the given stop reason and usage statistics\n   */\n  async respondToForceToolUse({\n    toolRequest,\n    stopReason,\n  }: {\n    toolRequest: Result\u003cToolRequest, { rawRequest: unknown }\u003e;\n    stopReason: StopReason;\n  }) {\n    const lastRequest = await this.awaitPendingForceToolUseRequest();\n\n    lastRequest.defer.resolve({\n      toolRequest,\n      stopReason,\n      usage: {\n        inputTokens: 10,\n        outputTokens: 20,\n      },\n    });\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method respondToForceToolUse\n\n/**\n   * Completes a request with the given stop reason and usage statistics\n   */\n  async respondToForceToolUse({\n    toolRequest,\n    stopReason,\n  }: {\n    toolRequest: Result\u003cToolRequest, { rawRequest: unknown }\u003e;\n    stopReason: StopReason;\n  }) {\n    const lastRequest = await this.awaitPendingForceToolUseRequest();\n\n    lastRequest.defer.resolve({\n      toolRequest,\n      stopReason,\n      usage: {\n        inputTokens: 10,\n        outputTokens: 20,\n      },\n    });\n  }",
      "headingContext": "node/providers/mock.ts \u003e class MockProvider \u003e method respondToForceToolUse",
      "startLine": 343,
      "startCol": 3,
      "endLine": 363,
      "endCol": 4
    },
    {
      "text": "  createAgent(options: AgentOptions): Agent {\n    return new AnthropicAgent(\n      options,\n      this.mockClient as unknown as Anthropic,\n      {\n        authType: \"max\",\n        includeWebSearch: true,\n        disableParallelToolUseFlag: true,\n        logger: winston.createLogger(),\n        validateInput,\n      },\n    );\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method createAgent\n\n  createAgent(options: AgentOptions): Agent {\n    return new AnthropicAgent(\n      options,\n      this.mockClient as unknown as Anthropic,\n      {\n        authType: \"max\",\n        includeWebSearch: true,\n        disableParallelToolUseFlag: true,\n        logger: winston.createLogger(),\n        validateInput,\n      },\n    );\n  }",
