    {
      "text": "  createStreamParameters(options: {\n    model: string;\n    messages: Array\u003cProviderMessage\u003e;\n    tools: Array\u003cProviderToolSpec\u003e;\n    disableCaching?: boolean;\n    systemPrompt?: string | undefined;\n  }): unknown {\n    return { messages: options.messages, tools: options.tools };\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method createStreamParameters\n\n  createStreamParameters(options: {\n    model: string;\n    messages: Array\u003cProviderMessage\u003e;\n    tools: Array\u003cProviderToolSpec\u003e;\n    disableCaching?: boolean;\n    systemPrompt?: string | undefined;\n  }): unknown {\n    return { messages: options.messages, tools: options.tools };\n  }",
