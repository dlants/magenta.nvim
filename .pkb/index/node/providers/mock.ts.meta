    {
      "text": "  async awaitPendingStream(options?: {\n    predicate?: (request: MockStream) =\u003e boolean;\n    message?: string;\n    timeout?: number;\n  }): Promise\u003cMockStream\u003e {\n    return pollUntil(\n      () =\u003e {\n        // Check mock client streams first (new API) - find the latest unresolved stream\n        for (let i = this.mockClient.streams.length - 1; i \u003e= 0; i--) {\n          const stream = this.mockClient.streams[i];\n          if (stream \u0026\u0026 !stream.aborted \u0026\u0026 !stream.resolved) {\n            if (!options?.predicate || options.predicate(stream)) {\n              return stream;\n            }\n          }\n        }\n        // Fall back to legacy requests\n        throw new Error(`No pending streams${options?.predicate ? \" matching predicate\" : \"\"}! ${options?.message ?? \"\"}\nStreams: ${this.mockClient.streams.length}`);\n      },\n      { timeout: options?.timeout ?? 1000 },\n    );\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingStream\n\n  async awaitPendingStream(options?: {\n    predicate?: (request: MockStream) =\u003e boolean;\n    message?: string;\n    timeout?: number;\n  }): Promise\u003cMockStream\u003e {\n    return pollUntil(\n      () =\u003e {\n        // Check mock client streams first (new API) - find the latest unresolved stream\n        for (let i = this.mockClient.streams.length - 1; i \u003e= 0; i--) {\n          const stream = this.mockClient.streams[i];\n          if (stream \u0026\u0026 !stream.aborted \u0026\u0026 !stream.resolved) {\n            if (!options?.predicate || options.predicate(stream)) {\n              return stream;\n            }\n          }\n        }\n        // Fall back to legacy requests\n        throw new Error(`No pending streams${options?.predicate ? \" matching predicate\" : \"\"}! ${options?.message ?? \"\"}\nStreams: ${this.mockClient.streams.length}`);\n      },\n      { timeout: options?.timeout ?? 1000 },\n    );\n  }",
      "headingContext": "node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingStream",
      "startLine": 154,
      "startCol": 1,
      "endLine": 176,
      "endCol": 4
    },
    {
      "text": "  async awaitPendingStreamWithText(\n    text: string,\n    options?: { message?: string; timeout?: number },\n  ): Promise\u003cMockStream\u003e {\n    return this.awaitPendingStream",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingStreamWithText\n\n  async awaitPendingStreamWithText(\n    text: string,\n    options?: { message?: string; timeout?: number },\n  ): Promise\u003cMockStream\u003e {\n    return this.awaitPendingStream",
      "headingContext": "node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingStreamWithText",
      "startLine": 178,
      "startCol": 1,
      "endLine": 182,
      "endCol": 35
    },
    {
      "text": "      predicate: (stream) =\u003e {\n        // Check all recent user messages (last 3) since system reminders may follow tool results\n        const messagesToCheck = Math.min(3, stream.messages.length);\n        for (\n          let i = stream.messages.length - 1;\n          i \u003e= stream.messages.length - messagesToCheck;\n          i--\n        ) {\n          const msg = stream.messages[i];\n          if (msg.role !== \"user\") continue;\n\n          const content = msg.content;\n          if (typeof content === \"string\") {\n            if (content.includes(text)) return true;\n          } else {\n            for (const block of content) {\n              if (anthropicBlockIncludesText(block, text)) {\n                return true;\n              }\n            }\n          }\n        }\n        return false;\n      }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingStreamWithText \u003e function predicate\n\n      predicate: (stream) =\u003e {\n        // Check all recent user messages (last 3) since system reminders may follow tool results\n        const messagesToCheck = Math.min(3, stream.messages.length);\n        for (\n          let i = stream.messages.length - 1;\n          i \u003e= stream.messages.length - messagesToCheck;\n          i--\n        ) {\n          const msg = stream.messages[i];\n          if (msg.role !== \"user\") continue;\n\n          const content = msg.content;\n          if (typeof content === \"string\") {\n            if (content.includes(text)) return true;\n          } else {\n            for (const block of content) {\n              if (anthropicBlockIncludesText(block, text)) {\n                return true;\n              }\n            }\n          }\n        }\n        return false;\n      }",
      "headingContext": "node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingStreamWithText \u003e function predicate",
      "startLine": 183,
      "startCol": 1,
      "endLine": 206,
      "endCol": 8
    },
    {
      "text": "message: options?.message ?? `recent messages contain \"${text}\"`,\n      ...(options?.timeout !== undefined ? { timeout: options.timeout } : {}),\n    });\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method awaitPendingStreamWithText\n\nmessage: options?.message ?? `recent messages contain \"${text}\"`,\n      ...(options?.timeout !== undefined ? { timeout: options.timeout } : {}),\n    });\n  }",
