    {
      "text": "/**\n   * Find the last user message containing a tool_result in the stream's messages.\n   * Returns the message and its content array.\n   */\n  static findLastToolResultMessage(\n    messages: Anthropic.Messages.MessageParam[],\n  ): Anthropic.Messages.MessageParam | undefined {\n    for (let i = messages.length - 1; i \u003e= 0; i--) {\n      const msg = messages[i];\n      if (msg.role === \"user\" \u0026\u0026 Array.isArray(msg.content)) {\n        const hasToolResult = msg.content.some(\n          (block) =\u003e block.type === \"tool_result\",\n        );\n        if (hasToolResult) {\n          return msg;\n        }\n      }\n    }\n    return undefined;\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method findLastToolResultMessage\n\n/**\n   * Find the last user message containing a tool_result in the stream's messages.\n   * Returns the message and its content array.\n   */\n  static findLastToolResultMessage(\n    messages: Anthropic.Messages.MessageParam[],\n  ): Anthropic.Messages.MessageParam | undefined {\n    for (let i = messages.length - 1; i \u003e= 0; i--) {\n      const msg = messages[i];\n      if (msg.role === \"user\" \u0026\u0026 Array.isArray(msg.content)) {\n        const hasToolResult = msg.content.some(\n          (block) =\u003e block.type === \"tool_result\",\n        );\n        if (hasToolResult) {\n          return msg;\n        }\n      }\n    }\n    return undefined;\n  }",
      "headingContext": "node/providers/mock.ts \u003e class MockProvider \u003e method findLastToolResultMessage",
      "startLine": 221,
      "startCol": 3,
      "endLine": 240,
      "endCol": 4
    },
    {
      "text": "  async awaitStopped(): Promise\u003cMockStream\u003e {\n    return pollUntil(() =\u003e {\n      const lastStream =\n        this.mockClient.streams[this.mockClient.streams.length - 1];\n      if (lastStream?.resolved) {\n        return lastStream;\n      }\n      throw new Error(`has pending streams`);\n    });\n  }",
      "contextualizedText": "// node/providers/mock.ts \u003e class MockProvider \u003e method awaitStopped\n\n  async awaitStopped(): Promise\u003cMockStream\u003e {\n    return pollUntil(() =\u003e {\n      const lastStream =\n        this.mockClient.streams[this.mockClient.streams.length - 1];\n      if (lastStream?.resolved) {\n        return lastStream;\n      }\n      throw new Error(`has pending streams`);\n    });\n  }",
      "headingContext": "node/providers/mock.ts \u003e class MockProvider \u003e method awaitStopped",
      "startLine": 242,
