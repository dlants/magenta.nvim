      "text": "return d`⚡ May I run command ${withInlineCode(d`\\`${entry.prompt.command}\\``)}?\n${withBindings(\n  withExtmark(d`\u003e NO`, {\n    hl_group: [\"ErrorMsg\", \"@markup.strong.markdown\"],\n  }),\n  {\n    \"\u003cCR\u003e\": () =\u003e this.reject(id),\n  },\n)}\n${withBindings(\n  withExtmark(d`\u003e YES`, {\n    hl_group: [\"String\", \"@markup.strong.markdown\"],\n  }),\n  {\n    \"\u003cCR\u003e\": () =\u003e this.approve(id),\n  },\n)}\n`;\n})}${\n  entries.length \u003e 1\n    ? d`${withBindings(\n        withExtmark(d`\u003e REJECT ALL`, {\n          hl_group: [\"ErrorMsg\", \"@markup.strong.markdown\"],\n        }),\n        {\n          \"\u003cCR\u003e\": () =\u003e this.rejectAll(),\n        },\n      )}\n${withBindings(\n  withExtmark(d`\u003e APPROVE ALL`, {\n    hl_group: [\"String\", \"@markup.strong.markdown\"],\n  }),\n  {\n    \"\u003cCR\u003e\": () =\u003e this.approveAll(),\n  },\n)}\n`\n    : d``\n}`;\n  }",
