    {
      "text": "import type { ThreadId } from \"@magenta/core\";\nimport type { Chat } from \"../chat/chat.ts\";\nimport { d, type VDOMNode } from \"../tea/view.ts\";",
      "contextualizedText": "// node/capabilities/render-pending-approvals.ts\n\nimport type { ThreadId } from \"@magenta/core\";\nimport type { Chat } from \"../chat/chat.ts\";\nimport { d, type VDOMNode } from \"../tea/view.ts\";",
      "headingContext": "node/capabilities/render-pending-approvals.ts",
      "startLine": 1,
      "startCol": 1,
      "endLine": 3,
