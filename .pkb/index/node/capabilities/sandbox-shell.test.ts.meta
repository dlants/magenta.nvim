      "text": "  rejectAll: ReturnType\u003ctypeof vi.fn\u003e;\n  getPendingViolations: ReturnType\u003ctypeof vi.fn\u003e;\n  view: ReturnType\u003ctypeof vi.fn\u003e;\n} {\n  return {\n    promptForApproval: vi.fn(),\n    addViolation: vi.fn(),\n    promptForWriteApproval: vi.fn(),\n    promptForNetworkAccess: vi.fn(),\n    approve: vi.fn(),\n    reject: vi.fn(),\n    approveAll: vi.fn(),\n    rejectAll: vi.fn(),\n    getPendingViolations: vi.fn(),\n    view: vi.fn(),\n  } as unknown as ReturnType\u003ctypeof createMockViolationHandler\u003e;\n}\n\nconst defaultSandboxConfig: SandboxConfig = {\n  filesystem: {\n    allowWrite: [\"./\"],\n    denyWrite: [],\n    denyRead: [],\n    allowRead: [],\n  },\n  network: {\n    allowedDomains: [],\n    deniedDomains: [],\n    allowUnixSockets: [],\n    allowAllUnixSockets: false,\n    onUnknownHost: \"prompt\",\n  },\n  requireApprovalPatterns: [],\n  strace: {\n    autoAllowViolations: false,\n  },\n};\n\nfunction createContext() {\n  return {\n    cwd: \"/test/cwd\" as NvimCwd,\n    homeDir: \"/home/user\" as HomeDir,\n    threadId: \"test-thread\" as ThreadId,\n    getOptions: () =\u003e\n      ({\n        sandbox: defaultSandboxConfig,\n      }) as MagentaOptions,\n    isBypassed: () =\u003e false,\n  };\n}\n\nfunction createOpts() {\n  return {\n    toolRequestId: \"test-tool-1\",\n    onOutput: vi.fn(),\n    onStart: vi.fn(),\n  };\n}\n\nfunction setupSpawnSuccess(\n  stdout = \"hello world\",\n  exitCode = 0,\n): ReturnType\u003ctypeof createMockChildProcess\u003e {\n  const proc = createMockChildProcess();\n  mockSpawn.mockReturnValue(proc);\n\n  // Schedule output and close after spawn\n  setTimeout(() =\u003e {\n    if (stdout) {\n      proc._emit(\"stdout:data\", Buffer.from(stdout));\n    }\n    proc._emit(\"close\", exitCode, null);\n  }, 0);\n\n  return proc;\n}\n\ndescribe(\"SandboxShell\", () =\u003e {\n  beforeEach(() =\u003e {\n    vi.clearAllMocks();\n    mockGetSandboxState.mockReturnValue({ status: \"ready\" });\n    mockWrapWithSandbox.mockImplementation(\n      async (cmd: string) =\u003e `sandbox-wrapped:${cmd}`,\n    );\n    mockGetSandboxViolationStore.mockReturnValue({",
      "contextualizedText": "// node/capabilities/sandbox-shell.test.ts\n\n  rejectAll: ReturnType\u003ctypeof vi.fn\u003e;\n  getPendingViolations: ReturnType\u003ctypeof vi.fn\u003e;\n  view: ReturnType\u003ctypeof vi.fn\u003e;\n} {\n  return {\n    promptForApproval: vi.fn(),\n    addViolation: vi.fn(),\n    promptForWriteApproval: vi.fn(),\n    promptForNetworkAccess: vi.fn(),\n    approve: vi.fn(),\n    reject: vi.fn(),\n    approveAll: vi.fn(),\n    rejectAll: vi.fn(),\n    getPendingViolations: vi.fn(),\n    view: vi.fn(),\n  } as unknown as ReturnType\u003ctypeof createMockViolationHandler\u003e;\n}\n\nconst defaultSandboxConfig: SandboxConfig = {\n  filesystem: {\n    allowWrite: [\"./\"],\n    denyWrite: [],\n    denyRead: [],\n    allowRead: [],\n  },\n  network: {\n    allowedDomains: [],\n    deniedDomains: [],\n    allowUnixSockets: [],\n    allowAllUnixSockets: false,\n    onUnknownHost: \"prompt\",\n  },\n  requireApprovalPatterns: [],\n  strace: {\n    autoAllowViolations: false,\n  },\n};\n\nfunction createContext() {\n  return {\n    cwd: \"/test/cwd\" as NvimCwd,\n    homeDir: \"/home/user\" as HomeDir,\n    threadId: \"test-thread\" as ThreadId,\n    getOptions: () =\u003e\n      ({\n        sandbox: defaultSandboxConfig,\n      }) as MagentaOptions,\n    isBypassed: () =\u003e false,\n  };\n}\n\nfunction createOpts() {\n  return {\n    toolRequestId: \"test-tool-1\",\n    onOutput: vi.fn(),\n    onStart: vi.fn(),\n  };\n}\n\nfunction setupSpawnSuccess(\n  stdout = \"hello world\",\n  exitCode = 0,\n): ReturnType\u003ctypeof createMockChildProcess\u003e {\n  const proc = createMockChildProcess();\n  mockSpawn.mockReturnValue(proc);\n\n  // Schedule output and close after spawn\n  setTimeout(() =\u003e {\n    if (stdout) {\n      proc._emit(\"stdout:data\", Buffer.from(stdout));\n    }\n    proc._emit(\"close\", exitCode, null);\n  }, 0);\n\n  return proc;\n}\n\ndescribe(\"SandboxShell\", () =\u003e {\n  beforeEach(() =\u003e {\n    vi.clearAllMocks();\n    mockGetSandboxState.mockReturnValue({ status: \"ready\" });\n    mockWrapWithSandbox.mockImplementation(\n      async (cmd: string) =\u003e `sandbox-wrapped:${cmd}`,\n    );\n    mockGetSandboxViolationStore.mockReturnValue({",
