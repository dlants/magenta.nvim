    {
      "text": "  async isDirectory(path: string): Promise\u003cboolean\u003e {\n    try {\n      await execFile(\"docker\", [\"exec\", this.container, \"test\", \"-d\", path]);\n      return true;\n    } catch {\n      return false;\n    }\n  }",
      "contextualizedText": "// node/capabilities/docker-file-io.ts \u003e class DockerFileIO \u003e method isDirectory\n\n  async isDirectory(path: string): Promise\u003cboolean\u003e {\n    try {\n      await execFile(\"docker\", [\"exec\", this.container, \"test\", \"-d\", path]);\n      return true;\n    } catch {\n      return false;\n    }\n  }",
