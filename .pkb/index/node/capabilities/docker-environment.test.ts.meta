    {
      "text": "    function createDockerContextManager(fileIO: DockerFileIO) {\n      const mockLogger = {\n        error: vi.fn(),\n        warn: vi.fn(),\n        info: vi.fn(),\n        debug: vi.fn(),\n      };\n\n      const cm = new ContextManager(\n        mockLogger,\n        fileIO,\n        \"/tmp\" as NvimCwd,\n        \"/root\" as HomeDir,\n      );\n\n      return cm;\n    }",
