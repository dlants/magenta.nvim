      "text": "const { result } = await invocation.promise;\n        expect(result.status).toBe(\"ok\");\n        if (result.status === \"ok\") {\n          const text = result.value\n            .filter(\n              (c): c is Extract\u003cProviderToolResultContent, { type: \"text\" }\u003e =\u003e\n                c.type === \"text\",\n            )\n            .map((c) =\u003e c.text)\n            .join(\"\");\n          expect(text).toContain(\"hello from container\");\n        }\n      });\n    });\n  });\n\n  describe(\"ContextManager with DockerFileIO\", () =\u003e {\n    const CONTAINER_FILE = \"/tmp/context-test.txt\" as AbsFilePath;\n\n    const TEXT_FILE_TYPE = {\n      category: FileCategory.TEXT,\n      mimeType: \"text/plain\",\n      extension: \".txt\",\n    };",
