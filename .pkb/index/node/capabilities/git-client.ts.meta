    },
    {
      "text": "function runnerResult(\n  promise: Promise\u003c{ stdout: string }\u003e,\n): Promise\u003c{ stdout: string; exitCode: number }\u003e {\n  return promise\n    .then((r) =\u003e ({ stdout: r.stdout, exitCode: 0 }))\n    .catch((error: unknown) =\u003e {\n      const err = error as { stdout?: string; code?: number | string };\n      const exitCode = typeof err.code === \"number\" ? err.code : 1;\n      return { stdout: err.stdout ?? \"\", exitCode };\n    });\n}",
      "contextualizedText": "// node/capabilities/git-client.ts \u003e function runnerResult\n\nfunction runnerResult(\n  promise: Promise\u003c{ stdout: string }\u003e,\n): Promise\u003c{ stdout: string; exitCode: number }\u003e {\n  return promise\n    .then((r) =\u003e ({ stdout: r.stdout, exitCode: 0 }))\n    .catch((error: unknown) =\u003e {\n      const err = error as { stdout?: string; code?: number | string };\n      const exitCode = typeof err.code === \"number\" ? err.code : 1;\n      return { stdout: err.stdout ?? \"\", exitCode };\n    });\n}",
