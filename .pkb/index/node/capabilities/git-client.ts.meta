      "text": "import { execFile as execFileCb } from \"node:child_process\";\nimport { promisify } from \"node:util\";\nimport {\n  type GitClient,\n  type GitCommandRunner,\n  type GitState,\n  parseGitState,\n} from \"@magenta/core\";\n\nconst execFile = promisify(execFileCb);",
      "contextualizedText": "// node/capabilities/git-client.ts\n\nimport { execFile as execFileCb } from \"node:child_process\";\nimport { promisify } from \"node:util\";\nimport {\n  type GitClient,\n  type GitCommandRunner,\n  type GitState,\n  parseGitState,\n} from \"@magenta/core\";\n\nconst execFile = promisify(execFileCb);",
