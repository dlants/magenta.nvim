    {
      "text": "private compiledPatterns:\n    | { source: string[]; compiled: RegExp[] }\n    | undefined",
      "contextualizedText": "// node/capabilities/sandbox-shell.ts \u003e class SandboxShell\n\nprivate compiledPatterns:\n    | { source: string[]; compiled: RegExp[] }\n    | undefined",
      "headingContext": "node/capabilities/sandbox-shell.ts \u003e class SandboxShell",
      "startLine": 383,
