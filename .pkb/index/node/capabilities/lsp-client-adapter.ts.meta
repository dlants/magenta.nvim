    {
      "text": "  async requestTypeDefinition(\n    filePath: AbsFilePath,\n    position: { line: number; character: number },\n  ): Promise\u003cLspDefinitionResponse\u003e {\n    const buffer = await this.getBuffer(filePath);\n    return this.lsp.requestTypeDefinition(buffer, {\n      row: position.line as Row0Indexed,\n      col: position.character as StringIdx,\n    });\n  }",
      "contextualizedText": "// node/capabilities/lsp-client-adapter.ts \u003e class NvimLspClient \u003e method requestTypeDefinition\n\n  async requestTypeDefinition(\n    filePath: AbsFilePath,\n    position: { line: number; character: number },\n  ): Promise\u003cLspDefinitionResponse\u003e {\n    const buffer = await this.getBuffer(filePath);\n    return this.lsp.requestTypeDefinition(buffer, {\n      row: position.line as Row0Indexed,\n      col: position.character as StringIdx,\n    });\n  }",
      "headingContext": "node/capabilities/lsp-client-adapter.ts \u003e class NvimLspClient \u003e method requestTypeDefinition",
      "startLine": 59,
      "startCol": 1,
      "endLine": 68,
      "endCol": 4
    },
    {
      "text": "  private async getBuffer(filePath: AbsFilePath) {\n    const result = await getOrOpenBuffer({\n      unresolvedPath: filePath as string as UnresolvedFilePath,\n      context: {\n        nvim: this.nvim,\n        cwd: this.cwd,\n        homeDir: this.homeDir,\n      },\n    });\n\n    if (result.status !== \"ok\") {\n      throw new Error(`Failed to open buffer for ${filePath}: ${result.error}`);\n    }\n\n    return result.buffer;\n  }",
      "contextualizedText": "// node/capabilities/lsp-client-adapter.ts \u003e class NvimLspClient \u003e method getBuffer\n\n  private async getBuffer(filePath: AbsFilePath) {\n    const result = await getOrOpenBuffer({\n      unresolvedPath: filePath as string as UnresolvedFilePath,\n      context: {\n        nvim: this.nvim,\n        cwd: this.cwd,\n        homeDir: this.homeDir,\n      },\n    });\n\n    if (result.status !== \"ok\") {\n      throw new Error(`Failed to open buffer for ${filePath}: ${result.error}`);\n    }\n\n    return result.buffer;\n  }",
