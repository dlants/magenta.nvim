      "contextualizedText": "// node/capabilities/lsp-client-adapter.ts \u003e class NvimLspClient \u003e method requestDefinition\n\n  async requestDefinition(\n    filePath: AbsFilePath,\n    position: { line: number; character: number },\n  ): Promise\u003cLspDefinitionResponse\u003e {\n    const buffer = await this.getBuffer(filePath);\n    return this.lsp.requestDefinition(buffer, {\n      row: position.line as Row0Indexed,\n      col: position.character as StringIdx,\n    });\n  }",
      "headingContext": "node/capabilities/lsp-client-adapter.ts \u003e class NvimLspClient \u003e method requestDefinition",
