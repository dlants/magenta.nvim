    {
      "text": "export class NvimLspClient implements LspClient {\n  constructor(\n    private lsp: Lsp,\n    private nvim: Nvim,\n    private cwd: NvimCwd,\n    private homeDir: HomeDir,\n  ) {}",
      "contextualizedText": "// node/capabilities/lsp-client-adapter.ts \u003e class NvimLspClient\n\nexport class NvimLspClient implements LspClient {\n  constructor(\n    private lsp: Lsp,\n    private nvim: Nvim,\n    private cwd: NvimCwd,\n    private homeDir: HomeDir,\n  ) {}",
      "headingContext": "node/capabilities/lsp-client-adapter.ts \u003e class NvimLspClient",
      "startLine": 18,
      "startCol": 1,
      "endLine": 24,
      "endCol": 7
    },
    {
      "text": "  async requestHover(\n    filePath: AbsFilePath,\n    position: { line: number; character: number },\n  ): Promise\u003cLspHoverResponse\u003e {\n    const buffer = await this.getBuffer(filePath);\n    return this.lsp.requestHover(buffer, {\n      row: position.line as Row0Indexed,\n      col: position.character as StringIdx,\n    });\n  }",
      "contextualizedText": "// node/capabilities/lsp-client-adapter.ts \u003e class NvimLspClient \u003e method requestHover\n\n  async requestHover(\n    filePath: AbsFilePath,\n    position: { line: number; character: number },\n  ): Promise\u003cLspHoverResponse\u003e {\n    const buffer = await this.getBuffer(filePath);\n    return this.lsp.requestHover(buffer, {\n      row: position.line as Row0Indexed,\n      col: position.character as StringIdx,\n    });\n  }",
