      "text": "import type {\n  LspClient,\n  LspDefinitionResponse,\n  LspHoverResponse,\n  LspReferencesResponse,\n} from \"@magenta/core\";\nimport type { Nvim } from \"../nvim/nvim-node/index.ts\";\nimport type { Row0Indexed, StringIdx } from \"../nvim/window.ts\";\nimport { getOrOpenBuffer } from \"../utils/buffers.ts\";\nimport type {\n  AbsFilePath,\n  HomeDir,\n  NvimCwd,\n  UnresolvedFilePath,\n} from \"../utils/files.ts\";\nimport type { Lsp } from \"./lsp.ts\";",
      "contextualizedText": "// node/capabilities/lsp-client-adapter.ts\n\nimport type {\n  LspClient,\n  LspDefinitionResponse,\n  LspHoverResponse,\n  LspReferencesResponse,\n} from \"@magenta/core\";\nimport type { Nvim } from \"../nvim/nvim-node/index.ts\";\nimport type { Row0Indexed, StringIdx } from \"../nvim/window.ts\";\nimport { getOrOpenBuffer } from \"../utils/buffers.ts\";\nimport type {\n  AbsFilePath,\n  HomeDir,\n  NvimCwd,\n  UnresolvedFilePath,\n} from \"../utils/files.ts\";\nimport type { Lsp } from \"./lsp.ts\";",
