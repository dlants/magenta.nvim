      "contextualizedText": "// node/capabilities/render-pending-approvals.test.ts \u003e function predicate\n\n        predicate: (stream) =\u003e\n          stream.messages.some(\n            (m) =\u003e\n              m.role === \"user\" \u0026\u0026\n              Array.isArray(m.content) \u0026\u0026\n              m.content.some(\n                (b) =\u003e b.type === \"tool_result\" \u0026\u0026 b.tool_use_id === \"bash-1\",\n              ),\n          )",
