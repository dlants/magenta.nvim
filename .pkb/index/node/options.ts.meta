    {
      "text": "export function getActiveProfile(profiles: Profile[], activeProfile: string) {\n  const profile = profiles.find((p) =\u003e p.name === activeProfile);\n  if (!profile) {\n    throw new Error(`Profile ${activeProfile} not found.`);\n  }\n  return profile;\n}",
