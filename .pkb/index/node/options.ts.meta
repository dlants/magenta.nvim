    {
      "text": "function parseStringArray(\n  input: unknown,\n  fieldName: string,\n  logger?: { warn: (msg: string) =\u003e void },\n): string[] {\n  if (!Array.isArray(input)) {\n    logger?.warn(`${fieldName} must be an array`);\n    return [];\n  }\n\n  return input.filter((item) =\u003e {\n    if (typeof item === \"string\") {\n      return true;\n    } else {\n      logger?.warn(\n        `Skipping non-string item in ${fieldName}: ${JSON.stringify(item)}`,\n      );\n      return false;\n    }\n  }) as string[];\n}",
      "contextualizedText": "// node/options.ts \u003e function parseStringArray\n\nfunction parseStringArray(\n  input: unknown,\n  fieldName: string,\n  logger?: { warn: (msg: string) =\u003e void },\n): string[] {\n  if (!Array.isArray(input)) {\n    logger?.warn(`${fieldName} must be an array`);\n    return [];\n  }\n\n  return input.filter((item) =\u003e {\n    if (typeof item === \"string\") {\n      return true;\n    } else {\n      logger?.warn(\n        `Skipping non-string item in ${fieldName}: ${JSON.stringify(item)}`,\n      );\n      return false;\n    }\n  }) as string[];\n}",
