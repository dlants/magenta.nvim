      "text": "export function contextFilesView(\n  core: ContextManager,\n  context: ContextViewContext,\n  view: { expanded: boolean; onToggle: () =\u003e void },\n) {\n  const pending = core.getPendingUpdates();\n  const allPaths = Object.keys(core.files) as AbsFilePath[];\n  if (allPaths.length === 0) {\n    return \"\";\n  }\n\n  const pendingPaths = Object.keys(pending) as AbsFilePath[];\n  const otherPaths = allPaths\n    .filter((p) =\u003e !pending[p])\n    .sort() as AbsFilePath[];",
      "contextualizedText": "// node/context/context-manager.ts \u003e function contextFilesView\n\nexport function contextFilesView(\n  core: ContextManager,\n  context: ContextViewContext,\n  view: { expanded: boolean; onToggle: () =\u003e void },\n) {\n  const pending = core.getPendingUpdates();\n  const allPaths = Object.keys(core.files) as AbsFilePath[];\n  if (allPaths.length === 0) {\n    return \"\";\n  }\n\n  const pendingPaths = Object.keys(pending) as AbsFilePath[];\n  const otherPaths = allPaths\n    .filter((p) =\u003e !pending[p])\n    .sort() as AbsFilePath[];",
      "headingContext": "node/context/context-manager.ts \u003e function contextFilesView",
