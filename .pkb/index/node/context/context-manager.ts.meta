    },
    {
      "text": "  const renderFileLine = (\n    absFilePath: AbsFilePath,\n    indicator: string,\n  ): VDOMNode =\u003e {\n    const pathForDisplay = displayPath(\n      context.cwd,\n      absFilePath,\n      context.homeDir,\n    );\n    const fileInfo = core.files[absFilePath];\n    const summaryBadge =\n      fileInfo?.agentView?.type === \"summary\" ? \" (summary)\" : \"\";\n    return withBindings(\n      d`- ${withInlineCode(d`\\`${pathForDisplay}\\``)}${summaryBadge}${indicator}\\n`",
      "contextualizedText": "// node/context/context-manager.ts \u003e function contextFilesView \u003e function renderFileLine\n\n  const renderFileLine = (\n    absFilePath: AbsFilePath,\n    indicator: string,\n  ): VDOMNode =\u003e {\n    const pathForDisplay = displayPath(\n      context.cwd,\n      absFilePath,\n      context.homeDir,\n    );\n    const fileInfo = core.files[absFilePath];\n    const summaryBadge =\n      fileInfo?.agentView?.type === \"summary\" ? \" (summary)\" : \"\";\n    return withBindings(\n      d`- ${withInlineCode(d`\\`${pathForDisplay}\\``)}${summaryBadge}${indicator}\\n`",
