    {
      "text": "export function renderGitUpdate(\n  gitUpdate: GitContextUpdate | undefined,\n): VDOMNode {\n  if (!gitUpdate) {\n    return d``;\n  }\n  const { current } = gitUpdate;\n  if (!current) {\n    return d`󰊢 git: no longer in a git repository\\n`;\n  }\n  const branch = current.branch ?? \"(detached HEAD)\";\n  return d`󰊢 git: ${branch} @ ${formatGitHead(current)}\\n`;\n}",
      "contextualizedText": "// node/context/context-manager.ts \u003e function renderGitUpdate\n\nexport function renderGitUpdate(\n  gitUpdate: GitContextUpdate | undefined,\n): VDOMNode {\n  if (!gitUpdate) {\n    return d``;\n  }\n  const { current } = gitUpdate;\n  if (!current) {\n    return d`󰊢 git: no longer in a git repository\\n`;\n  }\n  const branch = current.branch ?? \"(detached HEAD)\";\n  return d`󰊢 git: ${branch} @ ${formatGitHead(current)}\\n`;\n}",
      "headingContext": "node/context/context-manager.ts \u003e function renderGitUpdate",
      "startLine": 166,
      "startCol": 1,
      "endLine": 178,
      "endCol": 2
