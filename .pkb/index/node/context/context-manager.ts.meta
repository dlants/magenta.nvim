    {
      "text": "import {\n  type ContextManager,\n  type FileUpdates,\n  formatGitHead,\n  type GitContextUpdate,\n} from \"@magenta/core\";\nimport open from \"open\";\nimport type { Nvim } from \"../nvim/nvim-node/index.ts\";\nimport { openFileInNonMagentaWindow } from \"../nvim/openFileInNonMagentaWindow.ts\";\nimport type { MagentaOptions } from \"../options.ts\";\nimport { d, type VDOMNode, withBindings, withInlineCode } from \"../tea/view.ts\";\nimport { assertUnreachable } from \"../utils/assertUnreachable.ts\";\nimport {\n  type AbsFilePath,\n  displayPath,\n  FileCategory,\n  type HomeDir,\n  type NvimCwd,\n} from \"../utils/files.ts\";\nimport { formatTokens } from \"../utils/tokens.ts\";\n\nexport type {\n  ContextFiles as Files,\n  DiffUpdate,\n  FileDeletedUpdate,\n  FileUpdate,\n  FileUpdates,\n  Patch,\n  ToolApplied as ToolApplication,\n  WholeFileUpdate,\n} from \"@magenta/core\";\n\nexport type ContextViewContext = {\n  cwd: NvimCwd;\n  homeDir: HomeDir;\n  nvim: Nvim;\n  options: MagentaOptions;\n};",
      "contextualizedText": "// node/context/context-manager.ts\n\nimport {\n  type ContextManager,\n  type FileUpdates,\n  formatGitHead,\n  type GitContextUpdate,\n} from \"@magenta/core\";\nimport open from \"open\";\nimport type { Nvim } from \"../nvim/nvim-node/index.ts\";\nimport { openFileInNonMagentaWindow } from \"../nvim/openFileInNonMagentaWindow.ts\";\nimport type { MagentaOptions } from \"../options.ts\";\nimport { d, type VDOMNode, withBindings, withInlineCode } from \"../tea/view.ts\";\nimport { assertUnreachable } from \"../utils/assertUnreachable.ts\";\nimport {\n  type AbsFilePath,\n  displayPath,\n  FileCategory,\n  type HomeDir,\n  type NvimCwd,\n} from \"../utils/files.ts\";\nimport { formatTokens } from \"../utils/tokens.ts\";\n\nexport type {\n  ContextFiles as Files,\n  DiffUpdate,\n  FileDeletedUpdate,\n  FileUpdate,\n  FileUpdates,\n  Patch,\n  ToolApplied as ToolApplication,\n  WholeFileUpdate,\n} from \"@magenta/core\";\n\nexport type ContextViewContext = {\n  cwd: NvimCwd;\n  homeDir: HomeDir;\n  nvim: Nvim;\n  options: MagentaOptions;\n};",
