    {
      "text": "async function git(cwd: string, args: string[]): Promise\u003cvoid\u003e {\n  await execFile(\n    \"git\",\n    [\"-c\", \"user.email=test@test.com\", \"-c\", \"user.name=test\", ...args],\n    { cwd },\n  );\n}",
      "contextualizedText": "// node/context/git-context.test.ts \u003e function git\n\nasync function git(cwd: string, args: string[]): Promise\u003cvoid\u003e {\n  await execFile(\n    \"git\",\n    [\"-c\", \"user.email=test@test.com\", \"-c\", \"user.name=test\", ...args],\n    { cwd },\n  );\n}",
      "headingContext": "node/context/git-context.test.ts \u003e function git",
