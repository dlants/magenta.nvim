      "startCol": 1,
      "endLine": 24,
      "endCol": 2
    },
    {
      "text": "function findUserText(\n  messages: Anthropic.MessageParam[],\n  needle: string,\n): string | undefined {\n  for (const msg of messages) {\n    if (msg.role !== \"user\" || !Array.isArray(msg.content)) continue;\n    for (const block of msg.content as ContentBlockParam[]) {\n      if (block.type === \"text\" \u0026\u0026 block.text.includes(needle)) {\n        return block.text;\n      }\n    }\n  }\n  return undefined;\n}",
      "contextualizedText": "// node/context/git-context.test.ts \u003e function findUserText\n\nfunction findUserText(\n  messages: Anthropic.MessageParam[],\n  needle: string,\n): string | undefined {\n  for (const msg of messages) {\n    if (msg.role !== \"user\" || !Array.isArray(msg.content)) continue;\n    for (const block of msg.content as ContentBlockParam[]) {\n      if (block.type === \"text\" \u0026\u0026 block.text.includes(needle)) {\n        return block.text;\n      }\n    }\n  }\n  return undefined;\n}",
      "headingContext": "node/context/git-context.test.ts \u003e function findUserText",
