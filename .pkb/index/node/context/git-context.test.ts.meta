      "endCol": 2
    },
    {
      "text": "async function initRepo(tmpDir: string): Promise\u003cvoid\u003e {\n  await git(tmpDir, [\"init\", \"-q\"]);\n  await git(tmpDir, [\"symbolic-ref\", \"HEAD\", \"refs/heads/main\"]);\n  await git(tmpDir, [\"add\", \"poem.txt\"]);\n  await git(tmpDir, [\"commit\", \"-q\", \"-m\", \"initial commit\"]);\n}",
      "contextualizedText": "// node/context/git-context.test.ts \u003e function initRepo\n\nasync function initRepo(tmpDir: string): Promise\u003cvoid\u003e {\n  await git(tmpDir, [\"init\", \"-q\"]);\n  await git(tmpDir, [\"symbolic-ref\", \"HEAD\", \"refs/heads/main\"]);\n  await git(tmpDir, [\"add\", \"poem.txt\"]);\n  await git(tmpDir, [\"commit\", \"-q\", \"-m\", \"initial commit\"]);\n}",
      "headingContext": "node/context/git-context.test.ts \u003e function initRepo",
