    {
      "text": "async (driver, dirs) =\u003e {\n      await driver.showSidebar();\n      await driver.inputMagentaText(\"first\");\n      await driver.send();\n\n      const request1 = await driver.mockAnthropic.awaitPendingStream();\n      request1.respond({\n        stopReason: \"end_turn\",\n        text: \"ok\",\n        toolRequests: [],\n      });\n\n      // Change the coarse git state out from under the thread.\n      await git(dirs.tmpDir, [\"checkout\", \"-q\", \"-b\", \"feature\"]);\n\n      await driver.inputMagentaText(\"second\");\n      await driver.send();\n\n      const request2 = await driver.mockAnthropic.awaitPendingStream();\n      const gitText = findUserText(request2.messages, \"# Git status update\");\n      expect(gitText).toBeDefined();\n      expect(gitText).toContain(\"Branch: feature\");\n\n      await driver.assertDisplayBufferContains(\"git: feature\");\n\n      request2.respond({\n        stopReason: \"end_turn\",\n        text: \"done\",\n        toolRequests: [],\n      });\n    }",
      "contextualizedText": "// node/context/git-context.test.ts\n\nasync (driver, dirs) =\u003e {\n      await driver.showSidebar();\n      await driver.inputMagentaText(\"first\");\n      await driver.send();\n\n      const request1 = await driver.mockAnthropic.awaitPendingStream();\n      request1.respond({\n        stopReason: \"end_turn\",\n        text: \"ok\",\n        toolRequests: [],\n      });\n\n      // Change the coarse git state out from under the thread.\n      await git(dirs.tmpDir, [\"checkout\", \"-q\", \"-b\", \"feature\"]);\n\n      await driver.inputMagentaText(\"second\");\n      await driver.send();\n\n      const request2 = await driver.mockAnthropic.awaitPendingStream();\n      const gitText = findUserText(request2.messages, \"# Git status update\");\n      expect(gitText).toBeDefined();\n      expect(gitText).toContain(\"Branch: feature\");\n\n      await driver.assertDisplayBufferContains(\"git: feature\");\n\n      request2.respond({\n        stopReason: \"end_turn\",\n        text: \"done\",\n        toolRequests: [],\n      });\n    }",
