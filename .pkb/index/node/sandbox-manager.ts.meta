      "headingContext": "node/sandbox-manager.ts \u003e interface Sandbox \u003e method popNetworkAskTarget",
      "startLine": 45,
      "startCol": 1,
      "endLine": 45,
      "endCol": 54
    },
    {
      "text": "  routeNetworkAsk(params: NetworkAskParams): Promise\u003cboolean\u003e",
      "contextualizedText": "// node/sandbox-manager.ts \u003e interface Sandbox \u003e method routeNetworkAsk\n\n  routeNetworkAsk(params: NetworkAskParams): Promise\u003cboolean\u003e",
      "headingContext": "node/sandbox-manager.ts \u003e interface Sandbox \u003e method routeNetworkAsk",
      "startLine": 46,
      "startCol": 1,
      "endLine": 46,
      "endCol": 62
    },
    {
      "text": "// Remember a host approved by the user for the rest of the session so the\n  // network-ask callback (and the underlying proxy, via merged allowedDomains)\n  // stops prompting for it.\n  recordSessionApprovedHost(host: string): void",
      "contextualizedText": "// node/sandbox-manager.ts \u003e interface Sandbox \u003e method recordSessionApprovedHost\n\n// Remember a host approved by the user for the rest of the session so the\n  // network-ask callback (and the underlying proxy, via merged allowedDomains)\n  // stops prompting for it.\n  recordSessionApprovedHost(host: string): void",
      "headingContext": "node/sandbox-manager.ts \u003e interface Sandbox \u003e method recordSessionApprovedHost",
      "startLine": 47,
      "startCol": 3,
      "endLine": 50,
      "endCol": 48
    },
    {
      "text": "// -- Path resolution helpers --",
      "contextualizedText": "// node/sandbox-manager.ts\n\n// -- Path resolution helpers --",
      "headingContext": "node/sandbox-manager.ts",
      "startLine": 53,
      "startCol": 1,
      "endLine": 53,
      "endCol": 33
    },
    {
      "text": "function resolvePath(p: string, cwd: NvimCwd, homeDir: HomeDir): string {\n  if (p.startsWith(\"~/\")) {\n    return path.join(homeDir, p.slice(2));\n  }\n  if (p.startsWith(\"./\")) {\n    return path.join(cwd, p.slice(2));\n  }\n  if (path.isAbsolute(p)) {\n    return p;\n  }\n  return path.join(cwd, p);\n}",
      "contextualizedText": "// node/sandbox-manager.ts \u003e function resolvePath\n\nfunction resolvePath(p: string, cwd: NvimCwd, homeDir: HomeDir): string {\n  if (p.startsWith(\"~/\")) {\n    return path.join(homeDir, p.slice(2));\n  }\n  if (p.startsWith(\"./\")) {\n    return path.join(cwd, p.slice(2));\n  }\n  if (path.isAbsolute(p)) {\n    return p;\n  }\n  return path.join(cwd, p);\n}",
      "headingContext": "node/sandbox-manager.ts \u003e function resolvePath",
      "startLine": 55,
      "startCol": 1,
      "endLine": 66,
      "endCol": 2
    },
    {
      "text": "function resolvePaths(\n  paths: string[],\n  cwd: NvimCwd,\n  homeDir: HomeDir,\n): string[] {\n  return paths.map((p) =\u003e resolvePath(p, cwd, homeDir));\n}",
      "contextualizedText": "// node/sandbox-manager.ts \u003e function resolvePaths\n\nfunction resolvePaths(\n  paths: string[],\n  cwd: NvimCwd,\n  homeDir: HomeDir,\n): string[] {\n  return paths.map((p) =\u003e resolvePath(p, cwd, homeDir));\n}",
      "headingContext": "node/sandbox-manager.ts \u003e function resolvePaths",
      "startLine": 68,
      "startCol": 1,
      "endLine": 74,
      "endCol": 2
    },
    {
      "text": "// Merge session-approved network hosts into the runtime allowedDomains list,\n// skipping any host that is already present so the proxy stops re-prompting.\nexport function mergeApprovedDomains(\n  allowedDomains: string[],\n  approvedHosts: string[],\n): string[] {\n  const merged = [...allowedDomains];\n  for (const host of approvedHosts) {\n    if (!merged.includes(host)) {\n      merged.push(host);\n    }\n  }\n  return merged;\n}",
      "contextualizedText": "// node/sandbox-manager.ts \u003e function mergeApprovedDomains\n\n// Merge session-approved network hosts into the runtime allowedDomains list,\n// skipping any host that is already present so the proxy stops re-prompting.\nexport function mergeApprovedDomains(\n  allowedDomains: string[],\n  approvedHosts: string[],\n): string[] {\n  const merged = [...allowedDomains];\n  for (const host of approvedHosts) {\n    if (!merged.includes(host)) {\n      merged.push(host);\n    }\n  }\n  return merged;\n}",
      "headingContext": "node/sandbox-manager.ts \u003e function mergeApprovedDomains",
      "startLine": 76,
      "startCol": 1,
      "endLine": 89,
      "endCol": 2
    },
    {
      "text": "function dedup(arr: string[]): string[] {\n  return [...new Set(arr)];\n}",
      "contextualizedText": "// node/sandbox-manager.ts \u003e function dedup\n\nfunction dedup(arr: string[]): string[] {\n  return [...new Set(arr)];\n}",
      "headingContext": "node/sandbox-manager.ts \u003e function dedup",
      "startLine": 91,
      "startCol": 1,
      "endLine": 93,
      "endCol": 2
    },
    {
      "text": "export function resolveConfigPaths(\n  config: SandboxConfig,\n  cwd: NvimCwd,\n  homeDir: HomeDir,\n): SandboxRuntimeConfig {\n  return {\n    filesystem: {\n      allowWrite: dedup(\n        resolvePaths(config.filesystem.allowWrite, cwd, homeDir),\n      ),\n      denyWrite: dedup(resolvePaths(config.filesystem.denyWrite, cwd, homeDir)),\n      denyRead: dedup(resolvePaths(config.filesystem.denyRead, cwd, homeDir)),\n      allowRead: dedup(resolvePaths(config.filesystem.allowRead, cwd, homeDir)),\n    },\n    network: {\n      allowedDomains: dedup(config.network.allowedDomains),\n      deniedDomains: dedup(config.network.deniedDomains),\n      allowUnixSockets: dedup(\n        resolvePaths(config.network.allowUnixSockets, cwd, homeDir),\n      ),\n      allowAllUnixSockets: config.network.allowAllUnixSockets,\n    },\n  };\n}",
      "contextualizedText": "// node/sandbox-manager.ts \u003e function resolveConfigPaths\n\nexport function resolveConfigPaths(\n  config: SandboxConfig,\n  cwd: NvimCwd,\n  homeDir: HomeDir,\n): SandboxRuntimeConfig {\n  return {\n    filesystem: {\n      allowWrite: dedup(\n        resolvePaths(config.filesystem.allowWrite, cwd, homeDir),\n      ),\n      denyWrite: dedup(resolvePaths(config.filesystem.denyWrite, cwd, homeDir)),\n      denyRead: dedup(resolvePaths(config.filesystem.denyRead, cwd, homeDir)),\n      allowRead: dedup(resolvePaths(config.filesystem.allowRead, cwd, homeDir)),\n    },\n    network: {\n      allowedDomains: dedup(config.network.allowedDomains),\n      deniedDomains: dedup(config.network.deniedDomains),\n      allowUnixSockets: dedup(\n        resolvePaths(config.network.allowUnixSockets, cwd, homeDir),\n      ),\n      allowAllUnixSockets: config.network.allowAllUnixSockets,\n    },\n  };\n}",
      "headingContext": "node/sandbox-manager.ts \u003e function resolveConfigPaths",
      "startLine": 95,
      "startCol": 1,
      "endLine": 118,
      "endCol": 2
    },
    {
      "text": "// Shared LIFO routing for the active network-ask target. Reused by RealSandbox\n// and test doubles so routing semantics stay identical.\nexport class NetworkAskStack {\n  private stack: NetworkAskTarget[] = [];\n  private approvedHosts = new Set\u003cstring\u003e()",
      "contextualizedText": "// node/sandbox-manager.ts \u003e class NetworkAskStack\n\n// Shared LIFO routing for the active network-ask target. Reused by RealSandbox\n// and test doubles so routing semantics stay identical.\nexport class NetworkAskStack {\n  private stack: NetworkAskTarget[] = [];\n  private approvedHosts = new Set\u003cstring\u003e()",
      "headingContext": "node/sandbox-manager.ts \u003e class NetworkAskStack",
      "startLine": 120,
      "startCol": 1,
      "endLine": 124,
      "endCol": 44
    },
    {
      "text": "  push(target: NetworkAskTarget): void {\n    this.stack.push(target);\n  }",
      "contextualizedText": "// node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method push\n\n  push(target: NetworkAskTarget): void {\n    this.stack.push(target);\n  }",
      "headingContext": "node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method push",
      "startLine": 126,
      "startCol": 1,
      "endLine": 128,
      "endCol": 4
    },
    {
      "text": "  pop(target: NetworkAskTarget): void {\n    const idx = this.stack.lastIndexOf(target);\n    if (idx !== -1) {\n      this.stack.splice(idx, 1);\n    }\n  }",
      "contextualizedText": "// node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method pop\n\n  pop(target: NetworkAskTarget): void {\n    const idx = this.stack.lastIndexOf(target);\n    if (idx !== -1) {\n      this.stack.splice(idx, 1);\n    }\n  }",
      "headingContext": "node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method pop",
      "startLine": 130,
      "startCol": 1,
      "endLine": 135,
      "endCol": 4
    },
    {
      "text": "// A host approved during this session is remembered so subsequent requests to\n  // the same host (within the command or in later commands) are auto-approved\n  // without re-prompting. Rejections are intentionally not remembered.\n  recordApprovedHost(host: string): void {\n    this.approvedHosts.add(host);\n  }",
      "contextualizedText": "// node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method recordApprovedHost\n\n// A host approved during this session is remembered so subsequent requests to\n  // the same host (within the command or in later commands) are auto-approved\n  // without re-prompting. Rejections are intentionally not remembered.\n  recordApprovedHost(host: string): void {\n    this.approvedHosts.add(host);\n  }",
      "headingContext": "node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method recordApprovedHost",
      "startLine": 137,
      "startCol": 3,
      "endLine": 142,
      "endCol": 4
    },
    {
      "text": "  getApprovedHosts(): string[] {\n    return [...this.approvedHosts];\n  }",
      "contextualizedText": "// node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method getApprovedHosts\n\n  getApprovedHosts(): string[] {\n    return [...this.approvedHosts];\n  }",
      "headingContext": "node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method getApprovedHosts",
      "startLine": 144,
      "startCol": 1,
      "endLine": 146,
      "endCol": 4
    },
    {
      "text": "  route(params: NetworkAskParams): Promise\u003cboolean\u003e {\n    if (this.approvedHosts.has(params.host)) {\n      return Promise.resolve(true);\n    }\n    const target = this.stack[this.stack.length - 1];\n    if (!target) {\n      return Promise.resolve(false);\n    }\n    return target(params);\n  }",
      "contextualizedText": "// node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method route\n\n  route(params: NetworkAskParams): Promise\u003cboolean\u003e {\n    if (this.approvedHosts.has(params.host)) {\n      return Promise.resolve(true);\n    }\n    const target = this.stack[this.stack.length - 1];\n    if (!target) {\n      return Promise.resolve(false);\n    }\n    return target(params);\n  }",
      "headingContext": "node/sandbox-manager.ts \u003e class NetworkAskStack \u003e method route",
      "startLine": 148,
      "startCol": 1,
      "endLine": 157,
      "endCol": 4
    },
    {
      "text": "// -- Real implementation wrapping @anthropic-ai/sandbox-runtime --",
