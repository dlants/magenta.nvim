    {
      "text": "it(\"skips redacted thinking blocks\", () =\u003e {\n    const messages: ProviderMessage[] = [\n      {\n        role: \"assistant\",\n        content: [\n          {\n            type: \"redacted_thinking\",\n            data: \"secret\",\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n          {\n            type: \"text\",\n            text: \"visible text\",\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n        ],\n      },\n    ];\n\n    const { markdown: result } = renderThreadToMarkdown(messages);\n    expect(result).not.toContain(\"secret\");\n    expect(result).toContain(\"visible text\");\n  });\n\n  it(\"skips system reminders\", () =\u003e {\n    const messages: ProviderMessage[] = [\n      {\n        role: \"user\",\n        content: [\n          {\n            type: \"text\",\n            text: \"My question\",\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n          {\n            type: \"system_reminder\",\n            text: \"Remember to be helpful\",\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n        ],\n      },\n    ];\n\n    const { markdown: result } = renderThreadToMarkdown(messages);\n    expect(result).not.toContain(\"Remember to be helpful\");\n    expect(result).toContain(\"My question\");\n  });",
      "contextualizedText": "// node/core/src/compact-renderer.test.ts\n\nit(\"skips redacted thinking blocks\", () =\u003e {\n    const messages: ProviderMessage[] = [\n      {\n        role: \"assistant\",\n        content: [\n          {\n            type: \"redacted_thinking\",\n            data: \"secret\",\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n          {\n            type: \"text\",\n            text: \"visible text\",\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n        ],\n      },\n    ];\n\n    const { markdown: result } = renderThreadToMarkdown(messages);\n    expect(result).not.toContain(\"secret\");\n    expect(result).toContain(\"visible text\");\n  });\n\n  it(\"skips system reminders\", () =\u003e {\n    const messages: ProviderMessage[] = [\n      {\n        role: \"user\",\n        content: [\n          {\n            type: \"text\",\n            text: \"My question\",\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n          {\n            type: \"system_reminder\",\n            text: \"Remember to be helpful\",\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n        ],\n      },\n    ];\n\n    const { markdown: result } = renderThreadToMarkdown(messages);\n    expect(result).not.toContain(\"Remember to be helpful\");\n    expect(result).toContain(\"My question\");\n  });",
