      "text": "it(\"does not truncate non-get_file tool results\", () =\u003e {\n    const messages: ProviderMessage[] = [\n      {\n        role: \"assistant\",\n        content: [\n          {\n            type: \"tool_use\",\n            id: \"tool_1\" as ToolRequestId,\n            name: \"bash_command\" as ToolName,\n            request: {\n              status: \"ok\",\n              value: {\n                id: \"tool_1\" as ToolRequestId,\n                toolName: \"bash_command\" as ToolName,\n                input: { command: \"echo hello\" },\n              },\n            },\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n        ],\n      },\n      {\n        role: \"user\",\n        content: [\n          {\n            type: \"tool_result\",\n            id: \"tool_1\" as ToolRequestId,\n            result: {\n              status: \"ok\",\n              value: [\n                {\n                  type: \"text\",\n                  text: \"hello\",\n                  nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n                },\n              ],\n              structuredResult: { toolName: \"get_file\" as ToolName },\n            },\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          },\n        ],\n      },\n    ];\n\n    const { markdown: result } = renderThreadToMarkdown(messages);\n    expect(result).toContain(\"hello\");\n    expect(result).not.toContain(\"[file contents omitted]\");\n  });",
