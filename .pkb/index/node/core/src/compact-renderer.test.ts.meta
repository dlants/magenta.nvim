    {
      "text": "it(\"preserves all content: concatenated chunks equal original\", () =\u003e {\n    const msgs = Array.from(\n      { length: 10 },\n      (_, i) =\u003e `msg${i}:${\"x\".repeat(12)}\\n`,\n    );\n    const md = msgs.join(\"\");\n    const boundaries = [];\n    let offset = 0;\n    for (const msg of msgs) {\n      boundaries.push(offset);\n      offset += msg.length;\n    }\n    const chunks = chunkMessages(md, boundaries, 40, 10);\n    expect(chunks.join(\"\")).toBe(md);\n  });",
      "contextualizedText": "// node/core/src/compact-renderer.test.ts\n\nit(\"preserves all content: concatenated chunks equal original\", () =\u003e {\n    const msgs = Array.from(\n      { length: 10 },\n      (_, i) =\u003e `msg${i}:${\"x\".repeat(12)}\\n`,\n    );\n    const md = msgs.join(\"\");\n    const boundaries = [];\n    let offset = 0;\n    for (const msg of msgs) {\n      boundaries.push(offset);\n      offset += msg.length;\n    }\n    const chunks = chunkMessages(md, boundaries, 40, 10);\n    expect(chunks.join(\"\")).toBe(md);\n  });",
      "headingContext": "node/core/src/compact-renderer.test.ts",
