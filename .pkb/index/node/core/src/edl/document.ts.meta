    {
      "text": "  splice(range: Range, replacement: string): void {\n    this._content =\n      this._content.slice(0, range.start) +\n      replacement +\n      this._content.slice(range.end);\n    this._lineStarts = computeLineStarts(this._content);\n  }",
      "contextualizedText": "// node/core/src/edl/document.ts \u003e class Document \u003e method splice\n\n  splice(range: Range, replacement: string): void {\n    this._content =\n      this._content.slice(0, range.start) +\n      replacement +\n      this._content.slice(range.end);\n    this._lineStarts = computeLineStarts(this._content);\n  }",
      "headingContext": "node/core/src/edl/document.ts \u003e class Document \u003e method splice",
      "startLine": 68,
