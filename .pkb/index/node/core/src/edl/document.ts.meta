    {
      "text": "  posToOffset(pos: Pos): number {\n    const idx = pos.line - 1;\n    if (idx \u003c 0 || idx \u003e= this._lineStarts.length) {\n      throw new Error(`Line ${pos.line} out of range (1-${this.lineCount})`);\n    }\n    return this._lineStarts[idx] + pos.col;\n  }",
      "contextualizedText": "// node/core/src/edl/document.ts \u003e class Document \u003e method posToOffset\n\n  posToOffset(pos: Pos): number {\n    const idx = pos.line - 1;\n    if (idx \u003c 0 || idx \u003e= this._lineStarts.length) {\n      throw new Error(`Line ${pos.line} out of range (1-${this.lineCount})`);\n    }\n    return this._lineStarts[idx] + pos.col;\n  }",
      "headingContext": "node/core/src/edl/document.ts \u003e class Document \u003e method posToOffset",
      "startLine": 24,
      "startCol": 1,
      "endLine": 30,
      "endCol": 4
    },
    {
      "text": "  offsetToPos(offset: number): Pos {\n    let lo = 0;\n    let hi = this._lineStarts.length - 1;\n    while (lo \u003c hi) {\n      const mid = (lo + hi + 1) \u003e\u003e 1;\n      if (this._lineStarts[mid] \u003c= offset) {\n        lo = mid;\n      } else {\n        hi = mid - 1;\n      }\n    }\n    return { line: lo + 1, col: offset - this._lineStarts[lo] };\n  }",
      "contextualizedText": "// node/core/src/edl/document.ts \u003e class Document \u003e method offsetToPos\n\n  offsetToPos(offset: number): Pos {\n    let lo = 0;\n    let hi = this._lineStarts.length - 1;\n    while (lo \u003c hi) {\n      const mid = (lo + hi + 1) \u003e\u003e 1;\n      if (this._lineStarts[mid] \u003c= offset) {\n        lo = mid;\n      } else {\n        hi = mid - 1;\n      }\n    }\n    return { line: lo + 1, col: offset - this._lineStarts[lo] };\n  }",
      "headingContext": "node/core/src/edl/document.ts \u003e class Document \u003e method offsetToPos",
      "startLine": 32,
      "startCol": 1,
      "endLine": 44,
      "endCol": 4
    },
    {
      "text": "  lineRange(line: number): Range {\n    const idx = line - 1;\n    if (idx \u003c 0 || idx \u003e= this._lineStarts.length) {\n      throw new Error(`Line ${line} out of range (1-${this.lineCount})`);\n    }\n    const start = this._lineStarts[idx];\n    const end =\n      idx + 1 \u003c this._lineStarts.length\n        ? this._lineStarts[idx + 1] - 1 // exclude the \\n\n        : this._content.length;\n    return { start, end };\n  }",
      "contextualizedText": "// node/core/src/edl/document.ts \u003e class Document \u003e method lineRange\n\n  lineRange(line: number): Range {\n    const idx = line - 1;\n    if (idx \u003c 0 || idx \u003e= this._lineStarts.length) {\n      throw new Error(`Line ${line} out of range (1-${this.lineCount})`);\n    }\n    const start = this._lineStarts[idx];\n    const end =\n      idx + 1 \u003c this._lineStarts.length\n        ? this._lineStarts[idx + 1] - 1 // exclude the \\n\n        : this._content.length;\n    return { start, end };\n  }",
      "headingContext": "node/core/src/edl/document.ts \u003e class Document \u003e method lineRange",
      "startLine": 46,
      "startCol": 1,
      "endLine": 57,
      "endCol": 4
    },
    {
      "text": "/** Full document range */\n  fullRange(): Range {\n    return { start: 0, end: this._content.length };\n  }",
