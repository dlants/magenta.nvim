      "endCol": 21
    },
    {
      "text": "export class ExecutionError extends Error {\n  constructor(\n    message: string,\n    public trace: TraceEntry[] = [],\n  ) {\n    super(message);\n  }\n}",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class ExecutionError\n\nexport class ExecutionError extends Error {\n  constructor(\n    message: string,\n    public trace: TraceEntry[] = [],\n  ) {\n    super(message);\n  }\n}",
      "headingContext": "node/core/src/edl/executor.ts \u003e class ExecutionError",
      "startLine": 14,
      "startCol": 1,
      "endLine": 21,
      "endCol": 2
    },
    {
      "text": "function formatPattern(pattern: Pattern): string {\n  switch (pattern.type) {\n    case \"regex\":\n      return `/${pattern.pattern.source}/${pattern.pattern.flags.replace(\"g\", \"\")}`;\n    case \"literal\": {\n      const text = pattern.text;\n      if (text.length \u003e 60) {\n        return `\u003c\u003cHEREDOC\\n${text.slice(0, 60)}...\\nHEREDOC`;\n      }\n      return `\u003c\u003cHEREDOC\\n${text}\\nHEREDOC`;\n    }\n    case \"line\":\n      return `${pattern.line}:`;\n    case \"lineCol\":\n      return `${pattern.line}:${pattern.col}`;\n    case \"bof\":\n      return \"bof\";\n    case \"eof\":\n      return \"eof\";\n    case \"range\":\n      return `${formatPattern(pattern.from)}-${formatPattern(pattern.to)}`;\n  }\n}",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e function formatPattern\n\nfunction formatPattern(pattern: Pattern): string {\n  switch (pattern.type) {\n    case \"regex\":\n      return `/${pattern.pattern.source}/${pattern.pattern.flags.replace(\"g\", \"\")}`;\n    case \"literal\": {\n      const text = pattern.text;\n      if (text.length \u003e 60) {\n        return `\u003c\u003cHEREDOC\\n${text.slice(0, 60)}...\\nHEREDOC`;\n      }\n      return `\u003c\u003cHEREDOC\\n${text}\\nHEREDOC`;\n    }\n    case \"line\":\n      return `${pattern.line}:`;\n    case \"lineCol\":\n      return `${pattern.line}:${pattern.col}`;\n    case \"bof\":\n      return \"bof\";\n    case \"eof\":\n      return \"eof\";\n    case \"range\":\n      return `${formatPattern(pattern.from)}-${formatPattern(pattern.to)}`;\n  }\n}",
      "headingContext": "node/core/src/edl/executor.ts \u003e function formatPattern",
      "startLine": 23,
      "startCol": 1,
      "endLine": 45,
      "endCol": 2
    },
    {
      "text": "/** An offset into the original (pre-mutation) file content. */\nexport type InitialDocIndex = number \u0026 { __initialDocIndex: true };\n\n/** Records a single mutation in the current-doc coordinate space at the time it occurred. */\nexport type Transform = {\n  start: number;\n  beforeEnd: number;\n  afterEnd: number;\n};",
      "contextualizedText": "// node/core/src/edl/executor.ts\n\n/** An offset into the original (pre-mutation) file content. */\nexport type InitialDocIndex = number \u0026 { __initialDocIndex: true };\n\n/** Records a single mutation in the current-doc coordinate space at the time it occurred. */\nexport type Transform = {\n  start: number;\n  beforeEnd: number;\n  afterEnd: number;\n};",
      "headingContext": "node/core/src/edl/executor.ts",
      "startLine": 47,
      "startCol": 1,
      "endLine": 55,
      "endCol": 3
    },
    {
      "text": "/** Maps an InitialDocIndex through accumulated transforms to a current-doc offset.\n * Throws if the index falls inside a previously replaced region, since the\n * original content there no longer exists and coordinates into it are meaningless. */\nexport function resolveIndex(\n  index: InitialDocIndex,\n  transforms: Transform[],\n): number {\n  let offset: number = index;\n  for (const t of transforms) {\n    if (offset \u003c= t.start) {\n      // Before the mutation, unchanged\n    } else if (offset \u003c t.beforeEnd) {\n      throw new ExecutionError(\n        `Cannot resolve position: original offset ${index} falls inside a previously replaced region [${t.start}, ${t.beforeEnd})`,\n      );\n    } else {\n      // After the mutation, shift by delta\n      offset += t.afterEnd - t.beforeEnd;\n    }\n  }\n  return offset;\n}",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e function resolveIndex\n\n/** Maps an InitialDocIndex through accumulated transforms to a current-doc offset.\n * Throws if the index falls inside a previously replaced region, since the\n * original content there no longer exists and coordinates into it are meaningless. */\nexport function resolveIndex(\n  index: InitialDocIndex,\n  transforms: Transform[],\n): number {\n  let offset: number = index;\n  for (const t of transforms) {\n    if (offset \u003c= t.start) {\n      // Before the mutation, unchanged\n    } else if (offset \u003c t.beforeEnd) {\n      throw new ExecutionError(\n        `Cannot resolve position: original offset ${index} falls inside a previously replaced region [${t.start}, ${t.beforeEnd})`,\n      );\n    } else {\n      // After the mutation, shift by delta\n      offset += t.afterEnd - t.beforeEnd;\n    }\n  }\n  return offset;\n}",
      "headingContext": "node/core/src/edl/executor.ts \u003e function resolveIndex",
      "startLine": 57,
      "startCol": 1,
      "endLine": 78,
      "endCol": 2
    },
    {
      "text": "export type FileState = {\n  doc: Document;\n  path: string;\n  mutations: FileMutationSummary;\n  originalContent: string;\n  isNew?: boolean;\n  originalLineStarts: readonly number[];\n  originalContentLength: number;\n  transforms: Transform[];\n};",
      "contextualizedText": "// node/core/src/edl/executor.ts\n\nexport type FileState = {\n  doc: Document;\n  path: string;\n  mutations: FileMutationSummary;\n  originalContent: string;\n  isNew?: boolean;\n  originalLineStarts: readonly number[];\n  originalContentLength: number;\n  transforms: Transform[];\n};",
      "headingContext": "node/core/src/edl/executor.ts",
      "startLine": 80,
      "startCol": 1,
      "endLine": 89,
      "endCol": 3
    },
    {
      "text": "export class Executor {\n  public trace: TraceEntry[] = [];\n  public warnings: string[] = [];\n  public registers = new Map\u003cstring, string\u003e();\n  public fileDocs = new Map\u003cstring, FileState\u003e();\n  public currentFile: FileState | undefined;\n  public selection: Range[] = [];\n  public savedRegisterCount = 0;\n  private fileIO: FileIO;\n\n  constructor(fileIO?: FileIO) {\n    this.fileIO = fileIO ?? new FsFileIO();\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor\n\nexport class Executor {\n  public trace: TraceEntry[] = [];\n  public warnings: string[] = [];\n  public registers = new Map\u003cstring, string\u003e();\n  public fileDocs = new Map\u003cstring, FileState\u003e();\n  public currentFile: FileState | undefined;\n  public selection: Range[] = [];\n  public savedRegisterCount = 0;\n  private fileIO: FileIO;\n\n  constructor(fileIO?: FileIO) {\n    this.fileIO = fileIO ?? new FsFileIO();\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor",
      "startLine": 91,
      "startCol": 1,
      "endLine": 103,
      "endCol": 4
    },
    {
      "text": "  async getOrLoadFile(path: string): Promise\u003cFileState\u003e {\n    let state = this.fileDocs.get(path);\n    if (!state) {\n      let content: string;\n      try {\n        content = await this.fileIO.readFile(path);\n      } catch (e) {\n        throw new ExecutionError(\n          `Failed to read file: ${path}: ${e instanceof Error ? e.message : String(e)}`,\n          this.trace,\n        );\n      }\n      const doc = new Document(content);\n      state = {\n        doc,\n        path,\n        originalContent: content,\n        mutations: {\n          insertions: 0,\n          deletions: 0,\n          replacements: 0,\n          linesAdded: 0,\n          linesRemoved: 0,\n        },\n        originalLineStarts: doc.lineStarts,\n        originalContentLength: content.length,\n        transforms: [],\n      };\n      this.fileDocs.set(path, state);\n    }\n    return state;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method getOrLoadFile\n\n  async getOrLoadFile(path: string): Promise\u003cFileState\u003e {\n    let state = this.fileDocs.get(path);\n    if (!state) {\n      let content: string;\n      try {\n        content = await this.fileIO.readFile(path);\n      } catch (e) {\n        throw new ExecutionError(\n          `Failed to read file: ${path}: ${e instanceof Error ? e.message : String(e)}`,\n          this.trace,\n        );\n      }\n      const doc = new Document(content);\n      state = {\n        doc,\n        path,\n        originalContent: content,\n        mutations: {\n          insertions: 0,\n          deletions: 0,\n          replacements: 0,\n          linesAdded: 0,\n          linesRemoved: 0,\n        },\n        originalLineStarts: doc.lineStarts,\n        originalContentLength: content.length,\n        transforms: [],\n      };\n      this.fileDocs.set(path, state);\n    }\n    return state;\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method getOrLoadFile",
      "startLine": 105,
      "startCol": 1,
      "endLine": 136,
      "endCol": 4
    },
    {
      "text": "  requireFile(): FileState {\n    if (!this.currentFile)\n      throw new ExecutionError(\n        \"No file selected. Use 'file' command first.\",\n        this.trace,\n      );\n    return this.currentFile;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method requireFile\n\n  requireFile(): FileState {\n    if (!this.currentFile)\n      throw new ExecutionError(\n        \"No file selected. Use 'file' command first.\",\n        this.trace,\n      );\n    return this.currentFile;\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method requireFile",
      "startLine": 138,
      "startCol": 1,
      "endLine": 145,
      "endCol": 4
    },
    {
      "text": "  requireSingleSelect(): Range {\n    if (this.selection.length !== 1) {\n      throw new ExecutionError(\n        `Expected single selection, got ${this.selection.length}`,\n        this.trace,\n      );\n    }\n    return this.selection[0];\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method requireSingleSelect\n\n  requireSingleSelect(): Range {\n    if (this.selection.length !== 1) {\n      throw new ExecutionError(\n        `Expected single selection, got ${this.selection.length}`,\n        this.trace,\n      );\n    }\n    return this.selection[0];\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method requireSingleSelect",
      "startLine": 147,
      "startCol": 1,
      "endLine": 155,
      "endCol": 4
    },
    {
      "text": "  findAllMatches(\n    pattern: Pattern,\n    doc: Document,\n    withinRanges: Range[],\n  ): Range[] {\n    const results: Range[] = [];\n    for (const scope of withinRanges) {\n      const scopeText = doc.getText(scope);\n      const matches = this.findInText(pattern, scopeText, doc, scope.start);\n      results.push(...matches);\n    }\n    return results;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method findAllMatches\n\n  findAllMatches(\n    pattern: Pattern,\n    doc: Document,\n    withinRanges: Range[],\n  ): Range[] {\n    const results: Range[] = [];\n    for (const scope of withinRanges) {\n      const scopeText = doc.getText(scope);\n      const matches = this.findInText(pattern, scopeText, doc, scope.start);\n      results.push(...matches);\n    }\n    return results;\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method findAllMatches",
      "startLine": 157,
      "startCol": 1,
      "endLine": 169,
      "endCol": 4
    },
    {
      "text": "  findInText(\n    pattern: Pattern,\n    text: string,\n    doc: Document,\n    baseOffset: number,\n  ): Range[] {\n    switch (pattern.type) {\n      case \"regex\": {\n        const results: Range[] = [];\n        const flags = pattern.pattern.flags.includes(\"g\")\n          ? pattern.pattern.flags\n          : `${pattern.pattern.flags}g`;\n        const re = new RegExp(pattern.pattern.source, flags);\n        let m: RegExpExecArray | null;\n        while ((m = re.exec(text)) !== null) {\n          results.push({\n            start: baseOffset + m.index,\n            end: baseOffset + m.index + m[0].length,\n          });\n          if (m[0].length === 0) re.lastIndex++;\n        }\n        return results;\n      }\n      case \"literal\": {\n        if (pattern.text.length === 0) {\n          throw new ExecutionError(\n            `Empty literal pattern will match everywhere. Use a non-empty pattern for select/narrow operations.`,\n          );\n        }\n        const results: Range[] = [];\n        let idx = 0;\n        while ((idx = text.indexOf(pattern.text, idx)) !== -1) {\n          const absStart = baseOffset + idx;\n          const absEnd = absStart + pattern.text.length;\n          const atLineStart =\n            absStart === 0 || doc.content[absStart - 1] === \"\\n\";\n          const atLineEnd =\n            absEnd === doc.content.length || doc.content[absEnd] === \"\\n\";\n          if (atLineStart \u0026\u0026 atLineEnd) {\n            const end =\n              absEnd \u003c doc.content.length \u0026\u0026 doc.content[absEnd] === \"\\n\"\n                ? absEnd + 1\n                : absEnd;\n            results.push({ start: absStart, end, isLineSelection: true });\n          }\n          idx += pattern.text.length;\n        }\n        return results;\n      }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method findInText\n\n  findInText(\n    pattern: Pattern,\n    text: string,\n    doc: Document,\n    baseOffset: number,\n  ): Range[] {\n    switch (pattern.type) {\n      case \"regex\": {\n        const results: Range[] = [];\n        const flags = pattern.pattern.flags.includes(\"g\")\n          ? pattern.pattern.flags\n          : `${pattern.pattern.flags}g`;\n        const re = new RegExp(pattern.pattern.source, flags);\n        let m: RegExpExecArray | null;\n        while ((m = re.exec(text)) !== null) {\n          results.push({\n            start: baseOffset + m.index,\n            end: baseOffset + m.index + m[0].length,\n          });\n          if (m[0].length === 0) re.lastIndex++;\n        }\n        return results;\n      }\n      case \"literal\": {\n        if (pattern.text.length === 0) {\n          throw new ExecutionError(\n            `Empty literal pattern will match everywhere. Use a non-empty pattern for select/narrow operations.`,\n          );\n        }\n        const results: Range[] = [];\n        let idx = 0;\n        while ((idx = text.indexOf(pattern.text, idx)) !== -1) {\n          const absStart = baseOffset + idx;\n          const absEnd = absStart + pattern.text.length;\n          const atLineStart =\n            absStart === 0 || doc.content[absStart - 1] === \"\\n\";\n          const atLineEnd =\n            absEnd === doc.content.length || doc.content[absEnd] === \"\\n\";\n          if (atLineStart \u0026\u0026 atLineEnd) {\n            const end =\n              absEnd \u003c doc.content.length \u0026\u0026 doc.content[absEnd] === \"\\n\"\n                ? absEnd + 1\n                : absEnd;\n            results.push({ start: absStart, end, isLineSelection: true });\n          }\n          idx += pattern.text.length;\n        }\n        return results;\n      }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method findInText",
      "startLine": 171,
      "startCol": 1,
      "endLine": 219,
      "endCol": 8
    },
    {
      "text": "case \"line\": {\n        const file = this.currentFile;\n        if (file) {\n          const ols = file.originalLineStarts;\n          const idx = pattern.line - 1;\n          if (idx \u003c 0 || idx \u003e= ols.length) {\n            throw new ExecutionError(\n              `Line ${pattern.line} out of range (1-${ols.length})`,\n              this.trace,\n            );\n          }\n          const start = resolveIndex(\n            ols[idx] as InitialDocIndex,\n            file.transforms,\n          );\n          const origEnd =\n            idx + 1 \u003c ols.length\n              ? ols[idx + 1] - 1\n              : file.originalContentLength;\n          const end = resolveIndex(origEnd as InitialDocIndex, file.transforms);\n          return [{ start, end }];\n        }\n        return [doc.lineRange(pattern.line)];\n      }\n      case \"lineCol\": {\n        const file = this.currentFile;\n        if (file) {\n          const ols = file.originalLineStarts;\n          const idx = pattern.line - 1;\n          if (idx \u003c 0 || idx \u003e= ols.length) {\n            throw new ExecutionError(\n              `Line ${pattern.line} out of range (1-${ols.length})`,\n              this.trace,\n            );\n          }\n          const origOffset = ols[idx] + pattern.col;\n          const offset = resolveIndex(\n            origOffset as InitialDocIndex,\n            file.transforms,\n          );\n          return [{ start: offset, end: offset }];\n        }\n        const offset = doc.posToOffset({\n          line: pattern.line,\n          col: pattern.col,\n        });\n        return [{ start: offset, end: offset }];\n      }\n      case \"bof\":\n        return [{ start: 0, end: 0 }];\n      case \"eof\":\n        return [{ start: doc.content.length, end: doc.content.length }];",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method findInText\n\ncase \"line\": {\n        const file = this.currentFile;\n        if (file) {\n          const ols = file.originalLineStarts;\n          const idx = pattern.line - 1;\n          if (idx \u003c 0 || idx \u003e= ols.length) {\n            throw new ExecutionError(\n              `Line ${pattern.line} out of range (1-${ols.length})`,\n              this.trace,\n            );\n          }\n          const start = resolveIndex(\n            ols[idx] as InitialDocIndex,\n            file.transforms,\n          );\n          const origEnd =\n            idx + 1 \u003c ols.length\n              ? ols[idx + 1] - 1\n              : file.originalContentLength;\n          const end = resolveIndex(origEnd as InitialDocIndex, file.transforms);\n          return [{ start, end }];\n        }\n        return [doc.lineRange(pattern.line)];\n      }\n      case \"lineCol\": {\n        const file = this.currentFile;\n        if (file) {\n          const ols = file.originalLineStarts;\n          const idx = pattern.line - 1;\n          if (idx \u003c 0 || idx \u003e= ols.length) {\n            throw new ExecutionError(\n              `Line ${pattern.line} out of range (1-${ols.length})`,\n              this.trace,\n            );\n          }\n          const origOffset = ols[idx] + pattern.col;\n          const offset = resolveIndex(\n            origOffset as InitialDocIndex,\n            file.transforms,\n          );\n          return [{ start: offset, end: offset }];\n        }\n        const offset = doc.posToOffset({\n          line: pattern.line,\n          col: pattern.col,\n        });\n        return [{ start: offset, end: offset }];\n      }\n      case \"bof\":\n        return [{ start: 0, end: 0 }];\n      case \"eof\":\n        return [{ start: doc.content.length, end: doc.content.length }];",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method findInText",
      "startLine": 220,
      "startCol": 7,
      "endLine": 271,
      "endCol": 73
    },
    {
      "text": "case \"range\": {\n        const fromMatches = this.findInText(\n          pattern.from,\n          text,\n          doc,\n          baseOffset,\n        );\n        const toMatches = this.findInText(pattern.to, text, doc, baseOffset);\n        if (fromMatches.length === 0 || toMatches.length === 0) return [];\n        return [{ start: fromMatches[0].start, end: toMatches[0].end }];\n      }\n    }\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method findInText\n\ncase \"range\": {\n        const fromMatches = this.findInText(\n          pattern.from,\n          text,\n          doc,\n          baseOffset,\n        );\n        const toMatches = this.findInText(pattern.to, text, doc, baseOffset);\n        if (fromMatches.length === 0 || toMatches.length === 0) return [];\n        return [{ start: fromMatches[0].start, end: toMatches[0].end }];\n      }\n    }\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method findInText",
      "startLine": 272,
      "startCol": 7,
      "endLine": 284,
      "endCol": 4
    },
    {
      "text": "  private warnIfLineNumber(pattern: Pattern, commandName: string): void {\n    switch (pattern.type) {\n      case \"line\":\n        this.warnings.push(\n          `⚠️ \"${commandName}\" used line number ${pattern.line}. Text/regex patterns are more reliable — line numbers shift after mutations.`,\n        );\n        break;\n      case \"lineCol\":\n        this.warnings.push(\n          `⚠️ \"${commandName}\" used line:col ${pattern.line}:${pattern.col}. Text/regex patterns are more reliable — line numbers shift after mutations.`,\n        );\n        break;\n      case \"range\":\n        this.warnIfLineNumber(pattern.from, commandName);\n        this.warnIfLineNumber(pattern.to, commandName);\n        break;\n    }\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method warnIfLineNumber\n\n  private warnIfLineNumber(pattern: Pattern, commandName: string): void {\n    switch (pattern.type) {\n      case \"line\":\n        this.warnings.push(\n          `⚠️ \"${commandName}\" used line number ${pattern.line}. Text/regex patterns are more reliable — line numbers shift after mutations.`,\n        );\n        break;\n      case \"lineCol\":\n        this.warnings.push(\n          `⚠️ \"${commandName}\" used line:col ${pattern.line}:${pattern.col}. Text/regex patterns are more reliable — line numbers shift after mutations.`,\n        );\n        break;\n      case \"range\":\n        this.warnIfLineNumber(pattern.from, commandName);\n        this.warnIfLineNumber(pattern.to, commandName);\n        break;\n    }\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method warnIfLineNumber",
      "startLine": 286,
      "startCol": 1,
      "endLine": 303,
      "endCol": 4
    },
    {
      "text": "  addTrace(command: string, ranges: Range[], doc: Document): void {\n    this.trace.push({\n      command,\n      ranges: [...ranges],\n      snippet: Executor.describeSelection(ranges, doc),\n    });\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method addTrace\n\n  addTrace(command: string, ranges: Range[], doc: Document): void {\n    this.trace.push({\n      command,\n      ranges: [...ranges],\n      snippet: Executor.describeSelection(ranges, doc),\n    });\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method addTrace",
      "startLine": 304,
      "startCol": 1,
      "endLine": 310,
      "endCol": 4
    },
    {
      "text": "  static describeSelection(ranges: Range[], doc: Document): string {\n    if (ranges.length === 0) return \"no selection\";\n    const lineCount = ranges.reduce(\n      (acc, r) =\u003e acc + Executor.countLines(doc.getText(r)),\n      0,\n    );\n    return `${ranges.length} range${ranges.length !== 1 ? \"s\" : \"\"}, ${lineCount} line${lineCount !== 1 ? \"s\" : \"\"}`;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method describeSelection\n\n  static describeSelection(ranges: Range[], doc: Document): string {\n    if (ranges.length === 0) return \"no selection\";\n    const lineCount = ranges.reduce(\n      (acc, r) =\u003e acc + Executor.countLines(doc.getText(r)),\n      0,\n    );\n    return `${ranges.length} range${ranges.length !== 1 ? \"s\" : \"\"}, ${lineCount} line${lineCount !== 1 ? \"s\" : \"\"}`;\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method describeSelection",
      "startLine": 312,
      "startCol": 1,
      "endLine": 319,
      "endCol": 4
    },
    {
      "text": "  static describeLines(count: number, verb: string): string {\n    return `${count} line${count !== 1 ? \"s\" : \"\"} ${verb}`;\n  }",
