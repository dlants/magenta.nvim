    {
      "text": "  private static getCommandText(cmd: Command): string | undefined {\n    if (\n      cmd.type === \"replace\" ||\n      cmd.type === \"insert_before\" ||\n      cmd.type === \"insert_after\"\n    ) {\n      return \"text\" in cmd ? cmd.text : undefined;\n    }\n    return undefined;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method getCommandText\n\n  private static getCommandText(cmd: Command): string | undefined {\n    if (\n      cmd.type === \"replace\" ||\n      cmd.type === \"insert_before\" ||\n      cmd.type === \"insert_after\"\n    ) {\n      return \"text\" in cmd ? cmd.text : undefined;\n    }\n    return undefined;\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method getCommandText",
      "startLine": 767,
      "startCol": 1,
      "endLine": 776,
      "endCol": 4
    },
    {
      "text": "private static readonly MUTATION_COMMANDS = new Set([\n    \"replace\",\n    \"delete\",\n    \"insert_before\",\n    \"insert_after\",\n    \"cut\",\n  ])",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor\n\nprivate static readonly MUTATION_COMMANDS = new Set([\n    \"replace\",\n    \"delete\",\n    \"insert_before\",\n    \"insert_after\",\n    \"cut\",\n  ])",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor",
      "startLine": 778,
      "startCol": 3,
      "endLine": 784,
      "endCol": 5
    },
    {
      "text": "  private countMutationCommands(\n    commands: Command[],\n    startIdx: number,\n    endIdx: number,\n  ): number {\n    let count = 0;\n    for (let j = startIdx; j \u003c endIdx; j++) {\n      if (Executor.MUTATION_COMMANDS.has(commands[j].type)) {\n        count++;\n      }\n    }\n    return count;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method countMutationCommands\n\n  private countMutationCommands(\n    commands: Command[],\n    startIdx: number,\n    endIdx: number,\n  ): number {\n    let count = 0;\n    for (let j = startIdx; j \u003c endIdx; j++) {\n      if (Executor.MUTATION_COMMANDS.has(commands[j].type)) {\n        count++;\n      }\n    }\n    return count;\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method countMutationCommands",
      "startLine": 786,
      "startCol": 1,
      "endLine": 798,
      "endCol": 4
    },
    {
      "text": "  private saveCommandTexts(\n    commands: Command[],\n    startIdx: number,\n    endIdx: number,\n  ): SavedRegisterInfo[] {\n    const saved: SavedRegisterInfo[] = [];\n    for (let j = startIdx; j \u003c endIdx; j++) {\n      const text = Executor.getCommandText(commands[j]);\n      if (text !== undefined) {\n        const name = `_saved_${++this.savedRegisterCount}`;\n        this.registers.set(name, text);\n        saved.push({ name, sizeChars: text.length });\n      }\n    }\n    return saved;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method saveCommandTexts\n\n  private saveCommandTexts(\n    commands: Command[],\n    startIdx: number,\n    endIdx: number,\n  ): SavedRegisterInfo[] {\n    const saved: SavedRegisterInfo[] = [];\n    for (let j = startIdx; j \u003c endIdx; j++) {\n      const text = Executor.getCommandText(commands[j]);\n      if (text !== undefined) {\n        const name = `_saved_${++this.savedRegisterCount}`;\n        this.registers.set(name, text);\n        saved.push({ name, sizeChars: text.length });\n      }\n    }\n    return saved;\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method saveCommandTexts",
      "startLine": 800,
      "startCol": 1,
      "endLine": 815,
      "endCol": 4
    },
    {
      "text": "  async execute(commands: Command[]): Promise\u003cScriptResult\u003e {\n    const fileErrors: FileError[] = [];\n    const failedFiles = new Set\u003cstring\u003e();\n    let i = 0;\n\n    while (i \u003c commands.length) {\n      const cmd = commands[i];\n\n      try {\n        await this.executeCommand(cmd);\n        i++;\n      } catch (e) {\n        if (e instanceof ExecutionError) {\n          const errorPath =\n            cmd.type === \"file\" || cmd.type === \"newfile\"\n              ? cmd.path\n              : this.currentFile?.path;\n\n          if (errorPath) {\n            failedFiles.add(errorPath);\n\n            const nextIdx = this.findNextFileCommand(\n              commands,\n              i + 1,\n              errorPath,\n            );\n            const skipEnd = nextIdx === -1 ? commands.length : nextIdx;\n\n            const savedRegisters = this.saveCommandTexts(commands, i, skipEnd);\n            const failedMutations = this.countMutationCommands(\n              commands,\n              i,\n              skipEnd,\n            );\n\n            fileErrors.push({\n              path: errorPath,\n              error: e.message,\n              failedMutations,\n              trace: [...e.trace],\n              savedRegisters,\n            });\n\n            if (nextIdx === -1) {\n              break;\n            }\n            i = nextIdx;\n            this.currentFile = undefined;\n            this.selection = [];\n          } else {\n            throw e;\n          }\n        } else {\n          throw e;\n        }\n      }\n    }\n\n    const mutations = new Map\u003cstring, FileMutationSummary\u003e();\n    const fileContents = new Map\u003c\n      string,\n      { content: string; previousContent: string }\n    \u003e();\n    const newFiles = new Set\u003cstring\u003e();",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method execute\n\n  async execute(commands: Command[]): Promise\u003cScriptResult\u003e {\n    const fileErrors: FileError[] = [];\n    const failedFiles = new Set\u003cstring\u003e();\n    let i = 0;\n\n    while (i \u003c commands.length) {\n      const cmd = commands[i];\n\n      try {\n        await this.executeCommand(cmd);\n        i++;\n      } catch (e) {\n        if (e instanceof ExecutionError) {\n          const errorPath =\n            cmd.type === \"file\" || cmd.type === \"newfile\"\n              ? cmd.path\n              : this.currentFile?.path;\n\n          if (errorPath) {\n            failedFiles.add(errorPath);\n\n            const nextIdx = this.findNextFileCommand(\n              commands,\n              i + 1,\n              errorPath,\n            );\n            const skipEnd = nextIdx === -1 ? commands.length : nextIdx;\n\n            const savedRegisters = this.saveCommandTexts(commands, i, skipEnd);\n            const failedMutations = this.countMutationCommands(\n              commands,\n              i,\n              skipEnd,\n            );\n\n            fileErrors.push({\n              path: errorPath,\n              error: e.message,\n              failedMutations,\n              trace: [...e.trace],\n              savedRegisters,\n            });\n\n            if (nextIdx === -1) {\n              break;\n            }\n            i = nextIdx;\n            this.currentFile = undefined;\n            this.selection = [];\n          } else {\n            throw e;\n          }\n        } else {\n          throw e;\n        }\n      }\n    }\n\n    const mutations = new Map\u003cstring, FileMutationSummary\u003e();\n    const fileContents = new Map\u003c\n      string,\n      { content: string; previousContent: string }\n    \u003e();\n    const newFiles = new Set\u003cstring\u003e();",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method execute",
      "startLine": 816,
      "startCol": 1,
      "endLine": 879,
      "endCol": 40
    },
    {
      "text": "for (const [path, state] of this.fileDocs) {\n      if (failedFiles.has(path)) continue;\n\n      const m = state.mutations;\n      if (m.insertions \u003e 0 || m.deletions \u003e 0 || m.replacements \u003e 0) {\n        mutations.set(path, m);\n        fileContents.set(path, {\n          content: state.doc.content,\n          previousContent: state.originalContent,\n        });\n      }\n      if (state.isNew) {\n        newFiles.add(path);\n        fileContents.set(path, {\n          content: state.doc.content,\n          previousContent: state.originalContent,\n        });\n      }\n    }\n\n    for (const path of new Set([...mutations.keys(), ...newFiles])) {\n      const state = this.fileDocs.get(path)!;\n      const dir = path.substring(0, path.lastIndexOf(\"/\"));\n      if (dir) {\n        await this.fileIO.mkdir(dir);\n      }\n      await this.fileIO.writeFile(path, state.doc.content);\n    }\n\n    let finalSelection: { ranges: RangeWithPos[] } | undefined;\n    if (this.selection.length \u003e 0 \u0026\u0026 this.currentFile) {\n      const doc = this.currentFile.doc;\n      finalSelection = {\n        ranges: this.selection.map((r) =\u003e ({\n          range: r,\n          startPos: doc.offsetToPos(r.start),\n          endPos: doc.offsetToPos(r.end),\n          content: doc.getText(r),\n        })),\n      };\n    }\n\n    return {\n      warnings: this.warnings,\n      trace: this.trace,\n      finalSelection,\n      mutations,\n      fileContents,\n      fileErrors,\n    };\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method execute\n\nfor (const [path, state] of this.fileDocs) {\n      if (failedFiles.has(path)) continue;\n\n      const m = state.mutations;\n      if (m.insertions \u003e 0 || m.deletions \u003e 0 || m.replacements \u003e 0) {\n        mutations.set(path, m);\n        fileContents.set(path, {\n          content: state.doc.content,\n          previousContent: state.originalContent,\n        });\n      }\n      if (state.isNew) {\n        newFiles.add(path);\n        fileContents.set(path, {\n          content: state.doc.content,\n          previousContent: state.originalContent,\n        });\n      }\n    }\n\n    for (const path of new Set([...mutations.keys(), ...newFiles])) {\n      const state = this.fileDocs.get(path)!;\n      const dir = path.substring(0, path.lastIndexOf(\"/\"));\n      if (dir) {\n        await this.fileIO.mkdir(dir);\n      }\n      await this.fileIO.writeFile(path, state.doc.content);\n    }\n\n    let finalSelection: { ranges: RangeWithPos[] } | undefined;\n    if (this.selection.length \u003e 0 \u0026\u0026 this.currentFile) {\n      const doc = this.currentFile.doc;\n      finalSelection = {\n        ranges: this.selection.map((r) =\u003e ({\n          range: r,\n          startPos: doc.offsetToPos(r.start),\n          endPos: doc.offsetToPos(r.end),\n          content: doc.getText(r),\n        })),\n      };\n    }\n\n    return {\n      warnings: this.warnings,\n      trace: this.trace,\n      finalSelection,\n      mutations,\n      fileContents,\n      fileErrors,\n    };\n  }",
