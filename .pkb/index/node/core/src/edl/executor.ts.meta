      "text": "  private findNextFileCommand(\n    commands: Command[],\n    startIndex: number,\n    excludePath: string,\n  ): number {\n    for (let i = startIndex; i \u003c commands.length; i++) {\n      const cmd = commands[i];\n      if (\n        (cmd.type === \"file\" || cmd.type === \"newfile\") \u0026\u0026\n        cmd.path !== excludePath\n      ) {\n        return i;\n      }\n    }\n    return -1;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method findNextFileCommand\n\n  private findNextFileCommand(\n    commands: Command[],\n    startIndex: number,\n    excludePath: string,\n  ): number {\n    for (let i = startIndex; i \u003c commands.length; i++) {\n      const cmd = commands[i];\n      if (\n        (cmd.type === \"file\" || cmd.type === \"newfile\") \u0026\u0026\n        cmd.path !== excludePath\n      ) {\n        return i;\n      }\n    }\n    return -1;\n  }",
