    {
      "text": "  static countLines(text: string): number {\n    if (text.length === 0) return 0;\n    let count = 1;\n    for (let i = 0; i \u003c text.length; i++) {\n      if (text[i] === \"\\n\") count++;\n    }\n    return count;\n  }",
      "contextualizedText": "// node/core/src/edl/executor.ts \u003e class Executor \u003e method countLines\n\n  static countLines(text: string): number {\n    if (text.length === 0) return 0;\n    let count = 1;\n    for (let i = 0; i \u003c text.length; i++) {\n      if (text[i] === \"\\n\") count++;\n    }\n    return count;\n  }",
      "headingContext": "node/core/src/edl/executor.ts \u003e class Executor \u003e method countLines",
      "startLine": 329,
      "startCol": 1,
      "endLine": 336,
