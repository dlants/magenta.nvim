    {
      "text": "import { type FileIO, FsFileIO } from \"../capabilities/file-io.ts\";\nimport { Document } from \"./document.ts\";\nimport type { Command, MutationText, Pattern } from \"./parser.ts\";\nimport type {\n  FileError,\n  FileMutationSummary,\n  Range,\n  RangeWithPos,\n  SavedRegisterInfo,\n  ScriptResult,\n  TraceEntry,\n} from \"./types.ts\";",
      "contextualizedText": "// node/core/src/edl/executor.ts\n\nimport { type FileIO, FsFileIO } from \"../capabilities/file-io.ts\";\nimport { Document } from \"./document.ts\";\nimport type { Command, MutationText, Pattern } from \"./parser.ts\";\nimport type {\n  FileError,\n  FileMutationSummary,\n  Range,\n  RangeWithPos,\n  SavedRegisterInfo,\n  ScriptResult,\n  TraceEntry,\n} from \"./types.ts\";",
      "headingContext": "node/core/src/edl/executor.ts",
