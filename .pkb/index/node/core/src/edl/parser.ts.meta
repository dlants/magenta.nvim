    {
      "text": "function tryParsePositionalPattern(s: string): PositionalPattern | undefined {\n  if (s === \"bof\") return { type: \"bof\" };\n  if (s === \"eof\") return { type: \"eof\" };\n  const lineColMatch = s.match(/^(\\d+):(\\d+)$/);\n  if (lineColMatch) {\n    return {\n      type: \"lineCol\",\n      line: parseInt(lineColMatch[1], 10),\n      col: parseInt(lineColMatch[2], 10),\n    };\n  }\n  const lineMatch = s.match(/^(\\d+):?$/);\n  if (lineMatch) {\n    return { type: \"line\", line: parseInt(lineMatch[1], 10) };\n  }\n  return undefined;\n}",
      "contextualizedText": "// node/core/src/edl/parser.ts \u003e function tryParsePositionalPattern\n\nfunction tryParsePositionalPattern(s: string): PositionalPattern | undefined {\n  if (s === \"bof\") return { type: \"bof\" };\n  if (s === \"eof\") return { type: \"eof\" };\n  const lineColMatch = s.match(/^(\\d+):(\\d+)$/);\n  if (lineColMatch) {\n    return {\n      type: \"lineCol\",\n      line: parseInt(lineColMatch[1], 10),\n      col: parseInt(lineColMatch[2], 10),\n    };\n  }\n  const lineMatch = s.match(/^(\\d+):?$/);\n  if (lineMatch) {\n    return { type: \"line\", line: parseInt(lineMatch[1], 10) };\n  }\n  return undefined;\n}",
      "headingContext": "node/core/src/edl/parser.ts \u003e function tryParsePositionalPattern",
      "startLine": 421,
      "startCol": 1,
      "endLine": 437,
      "endCol": 2
    },
    {
      "text": "function assertNotPositionalArg(command: string, word: string): void {\n  const pos = tryParsePositionalPattern(word);\n  const isRange =\n    word.includes(\"-\") \u0026\u0026\n    word.split(\"-\").every((part) =\u003e {\n      return tryParsePositionalPattern(part) !== undefined;\n    });\n  if (pos || isRange) {\n    throw new ParseError(\n      `\\`${command}\\` does not take a positional argument like \\`${word}\\` — it operates on the current selection. Position the selection first (e.g. \\`select bof\\` or \\`select eof\\`), then call \\`${command}\\` with a heredoc, quoted string, or register name.`,\n    );\n  }\n}",
      "contextualizedText": "// node/core/src/edl/parser.ts \u003e function assertNotPositionalArg\n\nfunction assertNotPositionalArg(command: string, word: string): void {\n  const pos = tryParsePositionalPattern(word);\n  const isRange =\n    word.includes(\"-\") \u0026\u0026\n    word.split(\"-\").every((part) =\u003e {\n      return tryParsePositionalPattern(part) !== undefined;\n    });\n  if (pos || isRange) {\n    throw new ParseError(\n      `\\`${command}\\` does not take a positional argument like \\`${word}\\` — it operates on the current selection. Position the selection first (e.g. \\`select bof\\` or \\`select eof\\`), then call \\`${command}\\` with a heredoc, quoted string, or register name.`,\n    );\n  }\n}",
      "headingContext": "node/core/src/edl/parser.ts \u003e function assertNotPositionalArg",
      "startLine": 439,
      "startCol": 1,
      "endLine": 451,
      "endCol": 2
