    {
      "text": "export function* lex(script: string): Generator\u003cToken\u003e {\n  const tokenizer = new Tokenizer(script);\n  let tok: Token | undefined;\n  while ((tok = tokenizer.next()) !== undefined) {\n    yield tok;\n  }\n}",
      "contextualizedText": "// node/core/src/edl/parser.ts \u003e function lex\n\nexport function* lex(script: string): Generator\u003cToken\u003e {\n  const tokenizer = new Tokenizer(script);\n  let tok: Token | undefined;\n  while ((tok = tokenizer.next()) !== undefined) {\n    yield tok;\n  }\n}",
      "headingContext": "node/core/src/edl/parser.ts \u003e function lex",
      "startLine": 269,
      "startCol": 1,
      "endLine": 275,
      "endCol": 2
    },
    {
      "text": "export type PositionedToken = { token: Token; start: number };",
      "contextualizedText": "// node/core/src/edl/parser.ts\n\nexport type PositionedToken = { token: Token; start: number };",
      "headingContext": "node/core/src/edl/parser.ts",
      "startLine": 277,
      "startCol": 1,
      "endLine": 277,
      "endCol": 63
    },
    {
      "text": "/**\n * Tolerant variant of `lex` that yields each token together with its start\n * offset in the script, and stops gracefully (returns) instead of throwing on\n * truncated/incomplete input. Display-only; never used by the executor.\n */\nexport function* lexWithPos(script: string): Generator\u003cPositionedToken\u003e {\n  let pos = 0;\n\n  while (pos \u003c script.length) {\n    while (pos \u003c script.length \u0026\u0026 /\\s/.test(script[pos])) pos++;\n    if (pos \u003e= script.length) break;\n\n    const start = pos;\n    const ch = script[pos];\n\n    if (ch === \"#\") {\n      while (pos \u003c script.length \u0026\u0026 script[pos] !== \"\\n\") pos++;\n      continue;\n    }\n\n    if (ch === \"/\") {\n      pos++;\n      const patStart = pos;\n      while (pos \u003c script.length) {\n        const c = script[pos];\n        if (c === \"\\n\") break;\n        if (c === \"\\\\\") {\n          pos += 2;\n          continue;\n        }\n        if (c === \"/\") break;\n        pos++;\n      }\n      if (pos \u003e= script.length || script[pos] !== \"/\") return;\n      const pattern = script.slice(patStart, pos);\n      pos++;\n      const flagStart = pos;\n      while (pos \u003c script.length \u0026\u0026 FLAG_CHARS.has(script[pos])) pos++;\n      yield {\n        token: { type: \"regex\", pattern, flags: script.slice(flagStart, pos) },\n        start,\n      };\n      continue;\n    }\n\n    if (ch === \"`\") {\n      pos++;\n      const pathStart = pos;\n      while (pos \u003c script.length \u0026\u0026 script[pos] !== \"`\") pos++;\n      if (pos \u003e= script.length) return;\n      yield {\n        token: { type: \"path\", value: script.slice(pathStart, pos) },\n        start,\n      };\n      pos++;\n      continue;\n    }",
      "contextualizedText": "// node/core/src/edl/parser.ts \u003e function lexWithPos\n\n/**\n * Tolerant variant of `lex` that yields each token together with its start\n * offset in the script, and stops gracefully (returns) instead of throwing on\n * truncated/incomplete input. Display-only; never used by the executor.\n */\nexport function* lexWithPos(script: string): Generator\u003cPositionedToken\u003e {\n  let pos = 0;\n\n  while (pos \u003c script.length) {\n    while (pos \u003c script.length \u0026\u0026 /\\s/.test(script[pos])) pos++;\n    if (pos \u003e= script.length) break;\n\n    const start = pos;\n    const ch = script[pos];\n\n    if (ch === \"#\") {\n      while (pos \u003c script.length \u0026\u0026 script[pos] !== \"\\n\") pos++;\n      continue;\n    }\n\n    if (ch === \"/\") {\n      pos++;\n      const patStart = pos;\n      while (pos \u003c script.length) {\n        const c = script[pos];\n        if (c === \"\\n\") break;\n        if (c === \"\\\\\") {\n          pos += 2;\n          continue;\n        }\n        if (c === \"/\") break;\n        pos++;\n      }\n      if (pos \u003e= script.length || script[pos] !== \"/\") return;\n      const pattern = script.slice(patStart, pos);\n      pos++;\n      const flagStart = pos;\n      while (pos \u003c script.length \u0026\u0026 FLAG_CHARS.has(script[pos])) pos++;\n      yield {\n        token: { type: \"regex\", pattern, flags: script.slice(flagStart, pos) },\n        start,\n      };\n      continue;\n    }\n\n    if (ch === \"`\") {\n      pos++;\n      const pathStart = pos;\n      while (pos \u003c script.length \u0026\u0026 script[pos] !== \"`\") pos++;\n      if (pos \u003e= script.length) return;\n      yield {\n        token: { type: \"path\", value: script.slice(pathStart, pos) },\n        start,\n      };\n      pos++;\n      continue;\n    }",
