    {
      "text": "function findConflictingHeredocDelimiters(script: string): string[] {\n  const heredocPattern = /\u003c\u003c'?(\\w+)'?/g;\n  const delimiters = new Set\u003cstring\u003e();\n  let match;\n  while ((match = heredocPattern.exec(script)) !== null) {\n    delimiters.add(match[1]);\n  }\n\n  const lines = script.split(\"\\n\");\n  const conflicts: string[] = [];\n  for (const delim of delimiters) {\n    let count = 0;\n    for (const line of lines) {\n      if (line === delim) count++;\n    }\n    if (count \u003e 1) {\n      conflicts.push(delim);\n    }\n  }\n  return conflicts;\n}",
      "contextualizedText": "// node/core/src/edl/parser.ts \u003e function findConflictingHeredocDelimiters\n\nfunction findConflictingHeredocDelimiters(script: string): string[] {\n  const heredocPattern = /\u003c\u003c'?(\\w+)'?/g;\n  const delimiters = new Set\u003cstring\u003e();\n  let match;\n  while ((match = heredocPattern.exec(script)) !== null) {\n    delimiters.add(match[1]);\n  }\n\n  const lines = script.split(\"\\n\");\n  const conflicts: string[] = [];\n  for (const delim of delimiters) {\n    let count = 0;\n    for (const line of lines) {\n      if (line === delim) count++;\n    }\n    if (count \u003e 1) {\n      conflicts.push(delim);\n    }\n  }\n  return conflicts;\n}",
