      "text": "    function next(expected?: string): Token | undefined {\n      const tok = tokenizer.next();\n      if (tok === undefined) {\n        if (expected) {\n          throw new ParseError(`Expected ${expected}, got end of input`);\n        }\n        return undefined;\n      }\n      return tok;\n    }",
