    {
      "text": "    function nextPath(): string {\n      const path = tokenizer.nextPath();\n      if (path === undefined || path.length === 0) {\n        throw new ParseError(`Expected file path, got end of input`);\n      }\n      return path;\n    }",
      "contextualizedText": "// node/core/src/edl/parser.ts \u003e function parse \u003e function nextPath\n\n    function nextPath(): string {\n      const path = tokenizer.nextPath();\n      if (path === undefined || path.length === 0) {\n        throw new ParseError(`Expected file path, got end of input`);\n      }\n      return path;\n    }",
      "headingContext": "node/core/src/edl/parser.ts \u003e function parse \u003e function nextPath",
