{
  "blobSha": "5a2bb013ee5c898311b3f81472a6db0625177c72",
  "modelName": "voyage-context-4@256",
  "chunks": [
    {
      "text": "import * as fs from \"node:fs/promises\";\nimport * as path from \"node:path\";\nimport { describe, expect, it } from \"vitest\";\nimport { Executor, type InitialDocIndex, resolveIndex } from \"./executor.ts\";\nimport { parse } from \"./parser.ts\";\n\nlet testCounter = 0;",
      "contextualizedText": "// node/core/src/edl/executor.test.ts\n\nimport * as fs from \"node:fs/promises\";\nimport * as path from \"node:path\";\nimport { describe, expect, it } from \"vitest\";\nimport { Executor, type InitialDocIndex, resolveIndex } from \"./executor.ts\";\nimport { parse } from \"./parser.ts\";\n\nlet testCounter = 0;",
      "headingContext": "node/core/src/edl/executor.test.ts",
      "startLine": 1,
      "startCol": 1,
      "endLine": 7,
      "endCol": 21
    },
    {
      "text": "async function withTmpDir(fn: (tmpDir: string) =\u003e Promise\u003cvoid\u003e) {\n  const tmpDir = path.join(\n    \"/tmp/magenta-test\",\n    `executor-${Date.now()}-${testCounter++}`,\n  );\n  await fs.mkdir(tmpDir, { recursive: true });\n  try {\n    await fn(tmpDir);\n  } finally {\n    await fs.rm(tmpDir, { recursive: true, force: true });\n  }\n}",
      "contextualizedText": "// node/core/src/edl/executor.test.ts \u003e function withTmpDir\n\nasync function withTmpDir(fn: (tmpDir: string) =\u003e Promise\u003cvoid\u003e) {\n  const tmpDir = path.join(\n    \"/tmp/magenta-test\",\n    `executor-${Date.now()}-${testCounter++}`,\n  );\n  await fs.mkdir(tmpDir, { recursive: true });\n  try {\n    await fn(tmpDir);\n  } finally {\n    await fs.rm(tmpDir, { recursive: true, force: true });\n  }\n}",
      "headingContext": "node/core/src/edl/executor.test.ts \u003e function withTmpDir",
      "startLine": 9,
      "startCol": 1,
      "endLine": 20,
      "endCol": 2
    },
    {
      "text": "function executor(commands: ReturnType\u003ctypeof parse\u003e) {\n  return new Executor().execute(commands);\n}",
      "contextualizedText": "// node/core/src/edl/executor.test.ts \u003e function executor\n\nfunction executor(commands: ReturnType\u003ctypeof parse\u003e) {\n  return new Executor().execute(commands);\n}",
      "headingContext": "node/core/src/edl/executor.test.ts \u003e function executor",
      "startLine": 22,
      "startCol": 1,
      "endLine": 24,
      "endCol": 2
    },
    {
      "text": "function expectFileError(\n  result: Awaited\u003cReturnType\u003ctypeof executor\u003e\u003e,\n  pathSubstring: string,\n  errorSubstring: string,\n) {\n  const error = result.fileErrors.find(\n    (e) =\u003e e.path.includes(pathSubstring) \u0026\u0026 e.error.includes(errorSubstring),\n  );\n  expect(error).toBeDefined();\n  return error!;\n}",
      "contextualizedText": "// node/core/src/edl/executor.test.ts \u003e function expectFileError\n\nfunction expectFileError(\n  result: Awaited\u003cReturnType\u003ctypeof executor\u003e\u003e,\n  pathSubstring: string,\n  errorSubstring: string,\n) {\n  const error = result.fileErrors.find(\n    (e) =\u003e e.path.includes(pathSubstring) \u0026\u0026 e.error.includes(errorSubstring),\n  );\n  expect(error).toBeDefined();\n  return error!;\n}",
      "headingContext": "node/core/src/edl/executor.test.ts \u003e function expectFileError",
      "startLine": 26,
      "startCol": 1,
      "endLine": 36,
      "endCol": 2
    },
    {
      "text": "it(\"should find and replace text in a file\", async () =\u003e {\n  await withTmpDir(async (tmpDir) =\u003e {\n    const filePath = path.join(tmpDir, \"test.txt\");\n    await fs.writeFile(\n      filePath,\n      `\\\nhello world\ngoodbye world\n`,\n      \"utf-8\",\n    );\n\n    const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /world/\nreplace \"planet\"`;\n    const commands = parse(script);\n    const executor = new Executor();\n    const result = await executor.execute(commands);\n\n    const content = await fs.readFile(filePath, \"utf-8\");\n    expect(content).toBe(`\\\nhello planet\ngoodbye planet\n`);\n    expect(result.mutations.get(filePath)?.replacements).toBe(2);\n  });\n});\n\ndescribe(\"selection commands\", () =\u003e {\n  it(\"select: refines within existing selection\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /aaa/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxx bbb xxx bbb xxx\\n\");\n      expect(result.mutations.get(filePath)?.replacements).toBe(3);\n    });\n  });\n\n  it(\"select: errors when no match\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"hello world\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /zzz/`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      expectFileError(result, \"test.txt\", \"no matches\");\n    });\n  });",
      "contextualizedText": "// node/core/src/edl/executor.test.ts\n\nit(\"should find and replace text in a file\", async () =\u003e {\n  await withTmpDir(async (tmpDir) =\u003e {\n    const filePath = path.join(tmpDir, \"test.txt\");\n    await fs.writeFile(\n      filePath,\n      `\\\nhello world\ngoodbye world\n`,\n      \"utf-8\",\n    );\n\n    const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /world/\nreplace \"planet\"`;\n    const commands = parse(script);\n    const executor = new Executor();\n    const result = await executor.execute(commands);\n\n    const content = await fs.readFile(filePath, \"utf-8\");\n    expect(content).toBe(`\\\nhello planet\ngoodbye planet\n`);\n    expect(result.mutations.get(filePath)?.replacements).toBe(2);\n  });\n});\n\ndescribe(\"selection commands\", () =\u003e {\n  it(\"select: refines within existing selection\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /aaa/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxx bbb xxx bbb xxx\\n\");\n      expect(result.mutations.get(filePath)?.replacements).toBe(3);\n    });\n  });\n\n  it(\"select: errors when no match\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"hello world\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /zzz/`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      expectFileError(result, \"test.txt\", \"no matches\");\n    });\n  });",
      "headingContext": "node/core/src/edl/executor.test.ts",
      "startLine": 38,
      "startCol": 1,
      "endLine": 97,
      "endCol": 6
    },
    {
      "text": "it(\"select_first: selects only the first match\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /aaa/\nretain_first\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxx bbb aaa bbb aaa\\n\");\n    });\n  });\n\n  it(\"select_last: selects only the last match\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /aaa/\nretain_last\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"aaa bbb aaa bbb xxx\\n\");\n    });\n  });\n\n  it(\"narrow: selects when exactly one match\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb ccc\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"aaa xxx ccc\\n\");\n    });\n  });\n\n  it(\"narrow: errors when multiple matches\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /aaa/`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      expectFileError(result, \"test.txt\", \"expected 1 match, got 2\");\n    });\n  });",
      "contextualizedText": "// node/core/src/edl/executor.test.ts\n\nit(\"select_first: selects only the first match\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /aaa/\nretain_first\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxx bbb aaa bbb aaa\\n\");\n    });\n  });\n\n  it(\"select_last: selects only the last match\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /aaa/\nretain_last\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"aaa bbb aaa bbb xxx\\n\");\n    });\n  });\n\n  it(\"narrow: selects when exactly one match\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb ccc\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"aaa xxx ccc\\n\");\n    });\n  });\n\n  it(\"narrow: errors when multiple matches\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /aaa/`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      expectFileError(result, \"test.txt\", \"expected 1 match, got 2\");\n    });\n  });",
      "headingContext": "node/core/src/edl/executor.test.ts",
      "startLine": 99,
      "startCol": 3,
      "endLine": 161,
      "endCol": 6
    },
    {
      "text": "it(\"select_next: searches from end of current selection (non-overlapping)\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaabbbbbb\", \"utf-8\");\n\n      // Selection is \"aaabbb\" (positions 0-6), searching for \"bbb\"\n      // Should find \"bbb\" at positions 6-9, not re-match within the selection\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /aaabbb/\nretain_first\nselect_next /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"aaabbbxxx\");\n    });\n  });\n\n  it(\"select_next: does not find overlapping match within current selection\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaabbbccc\", \"utf-8\");\n\n      // Selection is \"aaabbb\" (positions 0-6), searching for \"bbb\"\n      // \"bbb\" exists at positions 3-6 but overlaps with selection\n      // No match exists after position 6, so this should error\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /aaabbb/\nretain_first\nselect_next /bbb/`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      expectFileError(result, \"test.txt\", \"no matches after selection\");\n    });\n  });",
      "contextualizedText": "// node/core/src/edl/executor.test.ts\n\nit(\"select_next: searches from end of current selection (non-overlapping)\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaabbbbbb\", \"utf-8\");\n\n      // Selection is \"aaabbb\" (positions 0-6), searching for \"bbb\"\n      // Should find \"bbb\" at positions 6-9, not re-match within the selection\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /aaabbb/\nretain_first\nselect_next /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"aaabbbxxx\");\n    });\n  });\n\n  it(\"select_next: does not find overlapping match within current selection\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaabbbccc\", \"utf-8\");\n\n      // Selection is \"aaabbb\" (positions 0-6), searching for \"bbb\"\n      // \"bbb\" exists at positions 3-6 but overlaps with selection\n      // No match exists after position 6, so this should error\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /aaabbb/\nretain_first\nselect_next /bbb/`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      expectFileError(result, \"test.txt\", \"no matches after selection\");\n    });\n  });",
      "headingContext": "node/core/src/edl/executor.test.ts",
      "startLine": 163,
      "startCol": 3,
      "endLine": 200,
      "endCol": 6
    },
    {
      "text": "it(\"select_prev: searches up to start of current selection (non-overlapping)\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"bbbbbbaaa\", \"utf-8\");\n\n      // Selection is \"bbbaaa\" (positions 3-9), searching for \"bbb\"\n      // Should find \"bbb\" at positions 0-3, not re-match within the selection\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /bbbaaa/\nretain_last\nselect_prev /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxxbbbaaa\");\n    });\n  });\n\n  it(\"select_prev: does not find overlapping match within current selection\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"cccbbbaaa\", \"utf-8\");\n\n      // Selection is \"bbbaaa\" (positions 3-9), searching for \"bbb\"\n      // \"bbb\" exists at positions 3-6 but overlaps with selection\n      // No match exists before position 3, so this should error\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /bbbaaa/\nretain_last\nselect_prev /bbb/`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      expectFileError(result, \"test.txt\", \"no matches before selection\");\n    });\n  });",
      "contextualizedText": "// node/core/src/edl/executor.test.ts\n\nit(\"select_prev: searches up to start of current selection (non-overlapping)\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"bbbbbbaaa\", \"utf-8\");\n\n      // Selection is \"bbbaaa\" (positions 3-9), searching for \"bbb\"\n      // Should find \"bbb\" at positions 0-3, not re-match within the selection\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /bbbaaa/\nretain_last\nselect_prev /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxxbbbaaa\");\n    });\n  });\n\n  it(\"select_prev: does not find overlapping match within current selection\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"cccbbbaaa\", \"utf-8\");\n\n      // Selection is \"bbbaaa\" (positions 3-9), searching for \"bbb\"\n      // \"bbb\" exists at positions 3-6 but overlaps with selection\n      // No match exists before position 3, so this should error\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /bbbaaa/\nretain_last\nselect_prev /bbb/`;\n      const commands = parse(script);\n      const result = await executor(commands);\n      expectFileError(result, \"test.txt\", \"no matches before selection\");\n    });\n  });",
      "headingContext": "node/core/src/edl/executor.test.ts",
      "startLine": 202,
      "startCol": 3,
      "endLine": 239,
      "endCol": 6
    },
    {
      "text": "it(\"extend_forward: searches from end of current selection (non-overlapping)\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaabbbbbb\", \"utf-8\");\n\n      // Selection is \"aaabbb\" (positions 0-6), extending forward to \"bbb\"\n      // Should extend to include positions 6-9, giving \"aaabbbbbb\"\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /aaabbb/\nretain_first\nextend_forward /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxx\");\n    });\n  });\n\n  it(\"extend_back: searches up to start of current selection (non-overlapping)\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"bbbbbbaaa\", \"utf-8\");\n\n      // Selection is \"bbbaaa\" (positions 3-9), extending back to \"bbb\"\n      // Should extend to include positions 0-3, giving \"bbbbbbaaa\"\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /bbbaaa/\nretain_last\nextend_back /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxx\");\n    });\n  });\n  it(\"select_next: selects next occurrence after current selection\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /bbb/\nretain_first\nselect_next /aaa/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"aaa bbb xxx bbb aaa\\n\");\n    });\n  });",
      "contextualizedText": "// node/core/src/edl/executor.test.ts\n\nit(\"extend_forward: searches from end of current selection (non-overlapping)\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaabbbbbb\", \"utf-8\");\n\n      // Selection is \"aaabbb\" (positions 0-6), extending forward to \"bbb\"\n      // Should extend to include positions 6-9, giving \"aaabbbbbb\"\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /aaabbb/\nretain_first\nextend_forward /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxx\");\n    });\n  });\n\n  it(\"extend_back: searches up to start of current selection (non-overlapping)\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"bbbbbbaaa\", \"utf-8\");\n\n      // Selection is \"bbbaaa\" (positions 3-9), extending back to \"bbb\"\n      // Should extend to include positions 0-3, giving \"bbbbbbaaa\"\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow /bbbaaa/\nretain_last\nextend_back /bbb/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"xxx\");\n    });\n  });\n  it(\"select_next: selects next occurrence after current selection\", async () =\u003e {\n    await withTmpDir(async (tmpDir) =\u003e {\n      const filePath = path.join(tmpDir, \"test.txt\");\n      await fs.writeFile(filePath, \"aaa bbb aaa bbb aaa\\n\", \"utf-8\");\n\n      const script = `\\\nfile \\`${filePath}\\`\nnarrow_multiple /bbb/\nretain_first\nselect_next /aaa/\nreplace \"xxx\"`;\n      const commands = parse(script);\n      await executor(commands);\n      const content = await fs.readFile(filePath, \"utf-8\");\n      expect(content).toBe(\"aaa bbb xxx bbb aaa\\n\");\n    });\n  });",
