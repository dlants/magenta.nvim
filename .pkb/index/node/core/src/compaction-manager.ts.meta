    {
      "text": "const invocation = createTool(request, toolContext);\n      activeTools.set(request.id, {\n        handle: invocation,\n        progress: \"progress\" in invocation ? invocation.progress : undefined,\n        toolName: request.toolName,\n        request,\n      });\n\n      void invocation.promise\n        .then((result) =\u003e {\n          this.send({ type: \"tool-complete\", id: request.id, result });\n        })\n        .catch((err: Error) =\u003e {\n          this.send({\n            type: \"tool-complete\",\n            id: request.id,\n            result: {\n              type: \"tool_result\",\n              id: request.id,\n              result: {\n                status: \"error\",\n                error: `Tool execution failed: ${err.message}`,\n              },\n              nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n            },\n          });\n        });\n    }\n\n    return { activeTools, malformedResults };\n  }",
      "contextualizedText": "// node/core/src/compaction-manager.ts \u003e class CompactionManager \u003e method buildToolEntries\n\nconst invocation = createTool(request, toolContext);\n      activeTools.set(request.id, {\n        handle: invocation,\n        progress: \"progress\" in invocation ? invocation.progress : undefined,\n        toolName: request.toolName,\n        request,\n      });\n\n      void invocation.promise\n        .then((result) =\u003e {\n          this.send({ type: \"tool-complete\", id: request.id, result });\n        })\n        .catch((err: Error) =\u003e {\n          this.send({\n            type: \"tool-complete\",\n            id: request.id,\n            result: {\n              type: \"tool_result\",\n              id: request.id,\n              result: {\n                status: \"error\",\n                error: `Tool execution failed: ${err.message}`,\n              },\n              nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n            },\n          });\n        });\n    }\n\n    return { activeTools, malformedResults };\n  }",
