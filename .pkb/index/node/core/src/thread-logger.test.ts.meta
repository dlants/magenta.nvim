    {
      "text": "function msg(text: string): ProviderMessage {\n  return {\n    role: \"user\",\n    content: [{ type: \"text\", text, nativeMessageIdx: 0 as never }],\n  };\n}",
      "contextualizedText": "// node/core/src/thread-logger.test.ts \u003e function msg\n\nfunction msg(text: string): ProviderMessage {\n  return {\n    role: \"user\",\n    content: [{ type: \"text\", text, nativeMessageIdx: 0 as never }],\n  };\n}",
