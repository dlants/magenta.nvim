    {
      "text": "return { logger, errors };\n}",
      "contextualizedText": "// node/core/src/thread-logger.test.ts \u003e function makeLogger\n\nreturn { logger, errors };\n}",
      "headingContext": "node/core/src/thread-logger.test.ts \u003e function makeLogger",
