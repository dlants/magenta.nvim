    {
      "text": "      requestRender: () =\u003e this.emit(\"update\")",
      "contextualizedText": "// node/core/src/thread-core.ts \u003e class ThreadCore \u003e method startCompaction \u003e function requestRender\n\n      requestRender: () =\u003e this.emit(\"update\")",
      "headingContext": "node/core/src/thread-core.ts \u003e class ThreadCore \u003e method startCompaction \u003e function requestRender",
