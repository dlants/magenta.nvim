    {
      "text": "  getLastStopTokenCount(): number {\n    const state = this.agent.getState();\n    if (state.inputTokenCount !== undefined) {\n      return state.inputTokenCount;\n    }\n\n    const latestUsage = state.latestUsage;\n    if (!latestUsage) {\n      return 0;\n    }\n\n    return (\n      latestUsage.inputTokens +\n      latestUsage.outputTokens +\n      (latestUsage.cacheHits || 0) +\n      (latestUsage.cacheMisses || 0)\n    );\n  }",
      "contextualizedText": "// node/core/src/thread-core.ts \u003e class ThreadCore \u003e method getLastStopTokenCount\n\n  getLastStopTokenCount(): number {\n    const state = this.agent.getState();\n    if (state.inputTokenCount !== undefined) {\n      return state.inputTokenCount;\n    }\n\n    const latestUsage = state.latestUsage;\n    if (!latestUsage) {\n      return 0;\n    }\n\n    return (\n      latestUsage.inputTokens +\n      latestUsage.outputTokens +\n      (latestUsage.cacheHits || 0) +\n      (latestUsage.cacheMisses || 0)\n    );\n  }",
      "headingContext": "node/core/src/thread-core.ts \u003e class ThreadCore \u003e method getLastStopTokenCount",
