      "endLine": 644,
      "endCol": 4
    },
    {
      "text": "  setTitle(title: string): void {\n    this.update({ type: \"set-title\", title });\n  }",
      "contextualizedText": "// node/core/src/thread-core.ts \u003e class ThreadCore \u003e method setTitle\n\n  setTitle(title: string): void {\n    this.update({ type: \"set-title\", title });\n  }",
