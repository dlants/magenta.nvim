    {
      "text": "  async handleSendMessageRequest(\n    messages: InputMessage[],\n    isAsync?: boolean,\n  ): Promise\u003cvoid\u003e {\n    if (this.state.threadType === \"compact\") {\n      this.sendRawMessage(messages);\n      return;\n    }\n\n    const agentStatus = this.agent.getState().status;\n    const isBusy =\n      agentStatus.type === \"streaming\" || this.state.mode.type === \"tool_use\";\n\n    if (isBusy) {\n      if (isAsync) {\n        this.update(\n          { type: \"push-pending-messages\", messages },\n          { silent: true },\n        );\n        return;\n      } else {\n        await this.abortAndWait();\n      }\n    }\n\n    await this.sendMessage(messages);\n\n    if (!this.state.title) {\n      this.setThreadTitle(messages.map((m) =\u003e m.text).join(\"\\n\")).catch(\n        (err: Error) =\u003e\n          this.context.logger.error(\n            `Error getting thread title: ${err.message}\\n${err.stack}`,\n          ),\n      );\n    }\n\n    if (messages.length) {\n      setTimeout(() =\u003e this.emit(\"scrollToLastMessage\"), 100);\n    }\n  }",
      "contextualizedText": "// node/core/src/thread-core.ts \u003e class ThreadCore \u003e method handleSendMessageRequest\n\n  async handleSendMessageRequest(\n    messages: InputMessage[],\n    isAsync?: boolean,\n  ): Promise\u003cvoid\u003e {\n    if (this.state.threadType === \"compact\") {\n      this.sendRawMessage(messages);\n      return;\n    }\n\n    const agentStatus = this.agent.getState().status;\n    const isBusy =\n      agentStatus.type === \"streaming\" || this.state.mode.type === \"tool_use\";\n\n    if (isBusy) {\n      if (isAsync) {\n        this.update(\n          { type: \"push-pending-messages\", messages },\n          { silent: true },\n        );\n        return;\n      } else {\n        await this.abortAndWait();\n      }\n    }\n\n    await this.sendMessage(messages);\n\n    if (!this.state.title) {\n      this.setThreadTitle(messages.map((m) =\u003e m.text).join(\"\\n\")).catch(\n        (err: Error) =\u003e\n          this.context.logger.error(\n            `Error getting thread title: ${err.message}\\n${err.stack}`,\n          ),\n      );\n    }\n\n    if (messages.length) {\n      setTimeout(() =\u003e this.emit(\"scrollToLastMessage\"), 100);\n    }\n  }",
      "headingContext": "node/core/src/thread-core.ts \u003e class ThreadCore \u003e method handleSendMessageRequest",
      "startLine": 1079,
      "startCol": 1,
      "endLine": 1118,
      "endCol": 4
    },
    {
      "text": "  maybeAutoRespond():\n    | { type: \"did-autorespond\" }\n    | { type: \"waiting-for-tool-input\" }\n    | { type: \"yielded-to-parent\" }\n    | { type: \"no-action-needed\" } {\n    const mode = this.state.mode;\n    const agentStatus = this.agent.getState().status;\n\n    if (this.state.mode.type === \"yielded\") {\n      return { type: \"yielded-to-parent\" };\n    }\n    if (\n      agentStatus.type === \"stopped\" \u0026\u0026\n      agentStatus.stopReason === \"aborted\"\n    ) {\n      return { type: \"no-action-needed\" };\n    }\n\n    if (mode.type === \"compacting\") {\n      return { type: \"no-action-needed\" };\n    }\n\n    if (mode.type === \"tool_use\")",
      "contextualizedText": "// node/core/src/thread-core.ts \u003e class ThreadCore \u003e method maybeAutoRespond\n\n  maybeAutoRespond():\n    | { type: \"did-autorespond\" }\n    | { type: \"waiting-for-tool-input\" }\n    | { type: \"yielded-to-parent\" }\n    | { type: \"no-action-needed\" } {\n    const mode = this.state.mode;\n    const agentStatus = this.agent.getState().status;\n\n    if (this.state.mode.type === \"yielded\") {\n      return { type: \"yielded-to-parent\" };\n    }\n    if (\n      agentStatus.type === \"stopped\" \u0026\u0026\n      agentStatus.stopReason === \"aborted\"\n    ) {\n      return { type: \"no-action-needed\" };\n    }\n\n    if (mode.type === \"compacting\") {\n      return { type: \"no-action-needed\" };\n    }\n\n    if (mode.type === \"tool_use\")",
      "headingContext": "node/core/src/thread-core.ts \u003e class ThreadCore \u003e method maybeAutoRespond",
      "startLine": 1120,
