    {
      "text": "  private getLastAssistantMessage():\n    | ReadonlyArray\u003cProviderMessageContent\u003e\n    | undefined {\n    const messages = this.agent.getState().messages;\n    for (let i = messages.length - 1; i \u003e= 0; i--) {\n      if (messages[i].role === \"assistant\") {\n        return messages[i].content;\n      }\n    }\n    return undefined;\n  }",
      "contextualizedText": "// node/core/src/thread-core.ts \u003e class ThreadCore \u003e method getLastAssistantMessage\n\n  private getLastAssistantMessage():\n    | ReadonlyArray\u003cProviderMessageContent\u003e\n    | undefined {\n    const messages = this.agent.getState().messages;\n    for (let i = messages.length - 1; i \u003e= 0; i--) {\n      if (messages[i].role === \"assistant\") {\n        return messages[i].content;\n      }\n    }\n    return undefined;\n  }",
