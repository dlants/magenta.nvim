    {
      "text": "  private handleCompactionResult(result: CompactionResult): void {\n    this.compactionController = undefined;\n    this.update({ type: \"set-mode\", mode: { type: \"normal\" } });\n\n    if (result.type === \"complete\") {\n      this.handleCompactComplete(\n        result.summary,\n        result.nextPrompt,\n        result.steps,\n      ).catch((e: Error) =\u003e {\n        this.context.logger.error(\n          `Failed during compact-complete: ${e.message}`,\n        );\n      });\n    } else {\n      this.update({\n        type: \"push-compaction-record\",\n        record: { steps: result.steps, finalSummary: undefined },\n      });\n    }\n  }",
      "contextualizedText": "// node/core/src/thread-core.ts \u003e class ThreadCore \u003e method handleCompactionResult\n\n  private handleCompactionResult(result: CompactionResult): void {\n    this.compactionController = undefined;\n    this.update({ type: \"set-mode\", mode: { type: \"normal\" } });\n\n    if (result.type === \"complete\") {\n      this.handleCompactComplete(\n        result.summary,\n        result.nextPrompt,\n        result.steps,\n      ).catch((e: Error) =\u003e {\n        this.context.logger.error(\n          `Failed during compact-complete: ${e.message}`,\n        );\n      });\n    } else {\n      this.update({\n        type: \"push-compaction-record\",\n        record: { steps: result.steps, finalSummary: undefined },\n      });\n    }\n  }",
      "headingContext": "node/core/src/thread-core.ts \u003e class ThreadCore \u003e method handleCompactionResult",
      "startLine": 1513,
      "startCol": 1,
      "endLine": 1533,
      "endCol": 4
    },
    {
      "text": "  private async handleCompactComplete(\n    summary: string,\n    nextPrompt: string | undefined,\n    steps: CompactionStep[],\n  ): Promise\u003cvoid\u003e {\n    this.update({\n      type: \"push-compaction-record\",\n      record: { steps, finalSummary: summary },\n    });\n\n    this.unlistenContextManager();\n    this.contextManager.destroy();\n    this.contextManager = new ContextManager(\n      this.context.logger,\n      this.context.fileIO,\n      this.context.cwd,\n      this.context.homeDir,\n      undefined,\n      CONTEXT_MANAGER_POLL_INTERVAL_MS,\n    );\n    this.contextManager.start();\n    this.listenToContextManager();\n\n    this.agent = this.createFreshAgent();\n    this.threadLogger.recordCompaction({ summary, chunkCount: steps.length });\n    this.threadLogger.resetCursor();\n\n    this.update({ type: \"reset-after-compaction\" });\n\n    const summaryText = `\u003cconversation-summary\u003e\\n${summary}\\n\u003c/conversation-summary\u003e`;\n    this.agent.appendUserMessage([\n      {\n        type: \"text\",\n        text: summaryText,\n        nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n      },\n    ]);\n\n    if (nextPrompt) {\n      await this.sendMessage([{ type: \"user\", text: nextPrompt }]);\n    } else {\n      await this.sendMessage([\n        { type: \"user\", text: \"Please continue from where you left off.\" },\n      ]);\n    }\n  }",
      "contextualizedText": "// node/core/src/thread-core.ts \u003e class ThreadCore \u003e method handleCompactComplete\n\n  private async handleCompactComplete(\n    summary: string,\n    nextPrompt: string | undefined,\n    steps: CompactionStep[],\n  ): Promise\u003cvoid\u003e {\n    this.update({\n      type: \"push-compaction-record\",\n      record: { steps, finalSummary: summary },\n    });\n\n    this.unlistenContextManager();\n    this.contextManager.destroy();\n    this.contextManager = new ContextManager(\n      this.context.logger,\n      this.context.fileIO,\n      this.context.cwd,\n      this.context.homeDir,\n      undefined,\n      CONTEXT_MANAGER_POLL_INTERVAL_MS,\n    );\n    this.contextManager.start();\n    this.listenToContextManager();\n\n    this.agent = this.createFreshAgent();\n    this.threadLogger.recordCompaction({ summary, chunkCount: steps.length });\n    this.threadLogger.resetCursor();\n\n    this.update({ type: \"reset-after-compaction\" });\n\n    const summaryText = `\u003cconversation-summary\u003e\\n${summary}\\n\u003c/conversation-summary\u003e`;\n    this.agent.appendUserMessage([\n      {\n        type: \"text\",\n        text: summaryText,\n        nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n      },\n    ]);\n\n    if (nextPrompt) {\n      await this.sendMessage([{ type: \"user\", text: nextPrompt }]);\n    } else {\n      await this.sendMessage([\n        { type: \"user\", text: \"Please continue from where you left off.\" },\n      ]);\n    }\n  }",
