    {
      "text": "  abort(): void {\n    this._resolved = true;\n    this._abortController.abort();\n    try {\n      this.readableController.close();\n    } catch {\n      // already closed\n    }\n    this.realStream.abort();\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method abort\n\n  abort(): void {\n    this._resolved = true;\n    this._abortController.abort();\n    try {\n      this.readableController.close();\n    } catch {\n      // already closed\n    }\n    this.realStream.abort();\n  }",
