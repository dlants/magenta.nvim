    {
      "text": "  finishResponse(\n    stopReason: StopReason,\n    usage: Usage = { inputTokens: 1000, outputTokens: 5000 },\n  ): void {\n    this._resolved = true;\n    this.ensureMessageStart();\n    this.pushEvent({\n      type: \"message_delta\",\n      delta: {\n        stop_reason: stopReason as Anthropic.Message[\"stop_reason\"],\n        stop_sequence: null,\n        container: null,\n        stop_details: null,\n      },\n      usage: {\n        output_tokens: usage.outputTokens,\n        input_tokens: usage.inputTokens,\n        cache_creation_input_tokens: usage.cacheMisses ?? null,\n        cache_read_input_tokens: usage.cacheHits ?? null,\n        server_tool_use: null,\n        output_tokens_details: null,\n      },\n    });\n    this.pushEvent({ type: \"message_stop\" });\n    this.readableController.close();\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method finishResponse\n\n  finishResponse(\n    stopReason: StopReason,\n    usage: Usage = { inputTokens: 1000, outputTokens: 5000 },\n  ): void {\n    this._resolved = true;\n    this.ensureMessageStart();\n    this.pushEvent({\n      type: \"message_delta\",\n      delta: {\n        stop_reason: stopReason as Anthropic.Message[\"stop_reason\"],\n        stop_sequence: null,\n        container: null,\n        stop_details: null,\n      },\n      usage: {\n        output_tokens: usage.outputTokens,\n        input_tokens: usage.inputTokens,\n        cache_creation_input_tokens: usage.cacheMisses ?? null,\n        cache_read_input_tokens: usage.cacheHits ?? null,\n        server_tool_use: null,\n        output_tokens_details: null,\n      },\n    });\n    this.pushEvent({ type: \"message_stop\" });\n    this.readableController.close();\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method finishResponse",
