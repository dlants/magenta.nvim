    {
      "text": "/** A mock stream that tests can control to simulate Anthropic API responses.\n *  Drives a real MessageStream via a ReadableStream so all event accumulation,\n *  partialParse, and finalMessage() assembly use the real SDK code path.\n */\nexport class MockStream {\n  private readableController!: ReadableStreamDefaultController\u003cUint8Array\u003e;\n  private realStream: MessageStream;\n  private blockCounter = 0;\n  private messageStartEmitted = false;\n  private _resolved = false;\n  private _abortController = new AbortController();\n  private _pushedEventCount = 0;\n  private _processedEventCount = 0;\n  private _partialToolIndex?: number;\n\n  constructor(public params: Anthropic.Messages.MessageStreamParams) {\n    const readable = new ReadableStream\u003cUint8Array\u003e",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream\n\n/** A mock stream that tests can control to simulate Anthropic API responses.\n *  Drives a real MessageStream via a ReadableStream so all event accumulation,\n *  partialParse, and finalMessage() assembly use the real SDK code path.\n */\nexport class MockStream {\n  private readableController!: ReadableStreamDefaultController\u003cUint8Array\u003e;\n  private realStream: MessageStream;\n  private blockCounter = 0;\n  private messageStartEmitted = false;\n  private _resolved = false;\n  private _abortController = new AbortController();\n  private _pushedEventCount = 0;\n  private _processedEventCount = 0;\n  private _partialToolIndex?: number;\n\n  constructor(public params: Anthropic.Messages.MessageStreamParams) {\n    const readable = new ReadableStream\u003cUint8Array\u003e",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream",
      "startLine": 10,
      "startCol": 1,
      "endLine": 26,
      "endCol": 52
    },
    {
      "text": "      start: (controller) =\u003e {\n        this.readableController = controller;\n      }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e function start\n\n      start: (controller) =\u003e {\n        this.readableController = controller;\n      }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e function start",
      "startLine": 27,
      "startCol": 1,
      "endLine": 29,
      "endCol": 8
    },
    {
      "text": "this.realStream = MessageStream.fromReadableStream(readable);\n\n    this.realStream.on(\"streamEvent\", () =\u003e {\n      this._processedEventCount++;\n    });",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream\n\nthis.realStream = MessageStream.fromReadableStream(readable);\n\n    this.realStream.on(\"streamEvent\", () =\u003e {\n      this._processedEventCount++;\n    });",
