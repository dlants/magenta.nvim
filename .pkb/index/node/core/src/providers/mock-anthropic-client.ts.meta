    {
      "text": "  finalMessage(): Promise\u003cAnthropic.Message\u003e {\n    return this.realStream.finalMessage();\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method finalMessage\n\n  finalMessage(): Promise\u003cAnthropic.Message\u003e {\n    return this.realStream.finalMessage();\n  }",
