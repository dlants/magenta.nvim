      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method getProviderMessages\n\n  getProviderMessages(): ProviderMessage[] {\n    return convertAnthropicMessagesToProvider(\n      validateInput,\n      this.params.messages,\n    );\n  }",
