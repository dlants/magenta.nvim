    {
      "text": "  get resolved(): boolean {\n    return this._resolved;\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method resolved\n\n  get resolved(): boolean {\n    return this._resolved;\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method resolved",
      "startLine": 94,
      "startCol": 1,
      "endLine": 96,
      "endCol": 4
    },
    {
      "text": "  private pushEvent(event: Anthropic.Messages.MessageStreamEvent): void {\n    this._pushedEventCount++;\n    const json = `${JSON.stringify(event)}\\n`;\n    const bytes = new TextEncoder().encode(json);\n    this.readableController.enqueue(bytes);\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method pushEvent\n\n  private pushEvent(event: Anthropic.Messages.MessageStreamEvent): void {\n    this._pushedEventCount++;\n    const json = `${JSON.stringify(event)}\\n`;\n    const bytes = new TextEncoder().encode(json);\n    this.readableController.enqueue(bytes);\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method pushEvent",
      "startLine": 98,
      "startCol": 1,
      "endLine": 103,
      "endCol": 4
    },
    {
      "text": "  private ensureMessageStart(): void {\n    if (!this.messageStartEmitted) {\n      this.messageStartEmitted = true;\n      this.pushEvent({\n        type: \"message_start\",\n        message: {\n          id: `msg_mock_${Date.now()}`,\n          type: \"message\",\n          role: \"assistant\",\n          content: [],\n          model: \"mock-model\",\n          stop_reason: null,\n          stop_sequence: null,\n          container: null,\n          stop_details: null,\n          usage: {\n            input_tokens: 0,\n            output_tokens: 0,\n            cache_creation_input_tokens: null,\n            cache_read_input_tokens: null,\n            cache_creation: null,\n            inference_geo: null,\n            server_tool_use: null,\n            service_tier: null,\n            output_tokens_details: null,\n          },\n        },\n      });\n    }\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method ensureMessageStart\n\n  private ensureMessageStart(): void {\n    if (!this.messageStartEmitted) {\n      this.messageStartEmitted = true;\n      this.pushEvent({\n        type: \"message_start\",\n        message: {\n          id: `msg_mock_${Date.now()}`,\n          type: \"message\",\n          role: \"assistant\",\n          content: [],\n          model: \"mock-model\",\n          stop_reason: null,\n          stop_sequence: null,\n          container: null,\n          stop_details: null,\n          usage: {\n            input_tokens: 0,\n            output_tokens: 0,\n            cache_creation_input_tokens: null,\n            cache_read_input_tokens: null,\n            cache_creation: null,\n            inference_geo: null,\n            server_tool_use: null,\n            service_tier: null,\n            output_tokens_details: null,\n          },\n        },\n      });\n    }\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method ensureMessageStart",
      "startLine": 105,
      "startCol": 1,
      "endLine": 134,
      "endCol": 4
    },
    {
      "text": "/** Wait for all pushed events to be processed by the real MessageStream. */\n  async settle(): Promise\u003cvoid\u003e {\n    while (this._processedEventCount \u003c this._pushedEventCount) {\n      await new Promise\u003cvoid\u003e((resolve) =\u003e queueMicrotask(resolve));\n    }\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method settle\n\n/** Wait for all pushed events to be processed by the real MessageStream. */\n  async settle(): Promise\u003cvoid\u003e {\n    while (this._processedEventCount \u003c this._pushedEventCount) {\n      await new Promise\u003cvoid\u003e((resolve) =\u003e queueMicrotask(resolve));\n    }\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method settle",
      "startLine": 136,
      "startCol": 3,
      "endLine": 141,
      "endCol": 4
    },
    {
      "text": "// --- Test helper methods ---",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream\n\n// --- Test helper methods ---",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream",
      "startLine": 143,
      "startCol": 3,
      "endLine": 143,
      "endCol": 33
    },
    {
      "text": "  streamText(text: string): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: { type: \"text\", text: \"\", citations: null },\n    });\n    this.pushEvent({\n      type: \"content_block_delta\",\n      index,\n      delta: { type: \"text_delta\", text },\n    });\n    this.pushEvent({ type: \"content_block_stop\", index });\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamText\n\n  streamText(text: string): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: { type: \"text\", text: \"\", citations: null },\n    });\n    this.pushEvent({\n      type: \"content_block_delta\",\n      index,\n      delta: { type: \"text_delta\", text },\n    });\n    this.pushEvent({ type: \"content_block_stop\", index });\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamText",
      "startLine": 145,
      "startCol": 1,
      "endLine": 160,
      "endCol": 4
    },
    {
      "text": "  streamToolUse(\n    id: ToolRequestId,\n    name: ToolName,\n    input: Record\u003cstring, unknown\u003e,\n  ): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: {\n        type: \"tool_use\",\n        id,\n        name,\n        input: {},\n        caller: { type: \"direct\" as const },\n      },\n    });\n    this.pushEvent({\n      type: \"content_block_delta\",\n      index,\n      delta: { type: \"input_json_delta\", partial_json: JSON.stringify(input) },\n    });\n    this.pushEvent({ type: \"content_block_stop\", index });\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamToolUse\n\n  streamToolUse(\n    id: ToolRequestId,\n    name: ToolName,\n    input: Record\u003cstring, unknown\u003e,\n  ): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: {\n        type: \"tool_use\",\n        id,\n        name,\n        input: {},\n        caller: { type: \"direct\" as const },\n      },\n    });\n    this.pushEvent({\n      type: \"content_block_delta\",\n      index,\n      delta: { type: \"input_json_delta\", partial_json: JSON.stringify(input) },\n    });\n    this.pushEvent({ type: \"content_block_stop\", index });\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamToolUse",
      "startLine": 162,
      "startCol": 1,
      "endLine": 187,
      "endCol": 4
    },
    {
      "text": "/** Start a tool_use block and stream the given partial JSON chunks WITHOUT\n   *  emitting content_block_stop, leaving the block as the live streaming block.\n   *  Use to test streaming-input previews. Follow up with\n   *  `continueToolUsePartial` to append more chunks to the same block. */\n  streamToolUsePartial(\n    id: ToolRequestId,\n    name: ToolName,\n    chunks: string[],\n  ): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n    this._partialToolIndex = index;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: {\n        type: \"tool_use\",\n        id,\n        name,\n        input: {},\n        caller: { type: \"direct\" as const },\n      },\n    });\n    for (const chunk of chunks) {\n      this.pushEvent({\n        type: \"content_block_delta\",\n        index,\n        delta: { type: \"input_json_delta\", partial_json: chunk },\n      });\n    }\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamToolUsePartial\n\n/** Start a tool_use block and stream the given partial JSON chunks WITHOUT\n   *  emitting content_block_stop, leaving the block as the live streaming block.\n   *  Use to test streaming-input previews. Follow up with\n   *  `continueToolUsePartial` to append more chunks to the same block. */\n  streamToolUsePartial(\n    id: ToolRequestId,\n    name: ToolName,\n    chunks: string[],\n  ): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n    this._partialToolIndex = index;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: {\n        type: \"tool_use\",\n        id,\n        name,\n        input: {},\n        caller: { type: \"direct\" as const },\n      },\n    });\n    for (const chunk of chunks) {\n      this.pushEvent({\n        type: \"content_block_delta\",\n        index,\n        delta: { type: \"input_json_delta\", partial_json: chunk },\n      });\n    }\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamToolUsePartial",
      "startLine": 189,
      "startCol": 3,
      "endLine": 220,
      "endCol": 4
    },
    {
      "text": "/** Append more partial JSON chunks to the block started by\n   *  `streamToolUsePartial`, without closing it. */\n  continueToolUsePartial(chunks: string[]): void {\n    const index = this._partialToolIndex;\n    if (index === undefined) {\n      throw new Error(\n        \"continueToolUsePartial called before streamToolUsePartial\",\n      );\n    }\n    for (const chunk of chunks) {\n      this.pushEvent({\n        type: \"content_block_delta\",\n        index,\n        delta: { type: \"input_json_delta\", partial_json: chunk },\n      });\n    }\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method continueToolUsePartial\n\n/** Append more partial JSON chunks to the block started by\n   *  `streamToolUsePartial`, without closing it. */\n  continueToolUsePartial(chunks: string[]): void {\n    const index = this._partialToolIndex;\n    if (index === undefined) {\n      throw new Error(\n        \"continueToolUsePartial called before streamToolUsePartial\",\n      );\n    }\n    for (const chunk of chunks) {\n      this.pushEvent({\n        type: \"content_block_delta\",\n        index,\n        delta: { type: \"input_json_delta\", partial_json: chunk },\n      });\n    }\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method continueToolUsePartial",
      "startLine": 222,
      "startCol": 3,
      "endLine": 238,
      "endCol": 4
    },
    {
      "text": "  streamThinking(thinking: string, signature: string = \"\"): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: { type: \"thinking\", thinking: \"\", signature: \"\" },\n    });\n    this.pushEvent({\n      type: \"content_block_delta\",\n      index,\n      delta: { type: \"thinking_delta\", thinking },\n    });\n    if (signature) {\n      this.pushEvent({\n        type: \"content_block_delta\",\n        index,\n        delta: {\n          type: \"signature_delta\",\n          signature,\n        } as Anthropic.Messages.ContentBlockDeltaEvent[\"delta\"],\n      });\n    }\n    this.pushEvent({ type: \"content_block_stop\", index });\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamThinking\n\n  streamThinking(thinking: string, signature: string = \"\"): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: { type: \"thinking\", thinking: \"\", signature: \"\" },\n    });\n    this.pushEvent({\n      type: \"content_block_delta\",\n      index,\n      delta: { type: \"thinking_delta\", thinking },\n    });\n    if (signature) {\n      this.pushEvent({\n        type: \"content_block_delta\",\n        index,\n        delta: {\n          type: \"signature_delta\",\n          signature,\n        } as Anthropic.Messages.ContentBlockDeltaEvent[\"delta\"],\n      });\n    }\n    this.pushEvent({ type: \"content_block_stop\", index });\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamThinking",
      "startLine": 240,
      "startCol": 1,
      "endLine": 265,
      "endCol": 4
    },
    {
      "text": "  streamRedactedThinking(data: string): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: { type: \"redacted_thinking\", data },\n    });\n    this.pushEvent({ type: \"content_block_stop\", index });\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamRedactedThinking\n\n  streamRedactedThinking(data: string): void {\n    this.ensureMessageStart();\n    const index = this.blockCounter++;\n\n    this.pushEvent({\n      type: \"content_block_start\",\n      index,\n      content_block: { type: \"redacted_thinking\", data },\n    });\n    this.pushEvent({ type: \"content_block_stop\", index });\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method streamRedactedThinking",
      "startLine": 267,
