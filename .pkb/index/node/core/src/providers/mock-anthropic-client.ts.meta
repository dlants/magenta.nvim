      "endCol": 6
    },
    {
      "text": "    countTokens: (\n      _params: Anthropic.Messages.MessageCountTokensParams,\n    ): Promise\u003c{ input_tokens: number }\u003e =\u003e {\n      return Promise.resolve({ input_tokens: this.mockInputTokenCount ?? 0 });\n    }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockAnthropicClient \u003e function countTokens\n\n    countTokens: (\n      _params: Anthropic.Messages.MessageCountTokensParams,\n    ): Promise\u003c{ input_tokens: number }\u003e =\u003e {\n      return Promise.resolve({ input_tokens: this.mockInputTokenCount ?? 0 });\n    }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockAnthropicClient \u003e function countTokens",
      "startLine": 494,
      "startCol": 1,
      "endLine": 498,
      "endCol": 6
    },
    {
      "text": "  get lastStream(): MockStream | undefined {\n    return this.streams[this.streams.length - 1];\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockAnthropicClient \u003e method lastStream\n\n  get lastStream(): MockStream | undefined {\n    return this.streams[this.streams.length - 1];\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockAnthropicClient \u003e method lastStream",
      "startLine": 501,
      "startCol": 1,
      "endLine": 503,
      "endCol": 4
    },
    {
      "text": "  async awaitStream(): Promise\u003cMockStream\u003e {\n    return pollUntil(() =\u003e {\n      const stream = this.lastStream;\n      if (stream \u0026\u0026 !stream.aborted) {\n        return stream;\n      }\n      throw new Error(\"No pending stream\");\n    });\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockAnthropicClient \u003e method awaitStream\n\n  async awaitStream(): Promise\u003cMockStream\u003e {\n    return pollUntil(() =\u003e {\n      const stream = this.lastStream;\n      if (stream \u0026\u0026 !stream.aborted) {\n        return stream;\n      }\n      throw new Error(\"No pending stream\");\n    });\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockAnthropicClient \u003e method awaitStream",
