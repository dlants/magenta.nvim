      "endLine": 56,
      "endCol": 4
    },
    {
      "text": "  on(\n    event: \"streamEvent\",\n    callback: (\n      event: Anthropic.Messages.MessageStreamEvent,\n      snapshot: Anthropic.Message,\n    ) =\u003e void,\n  ): this {\n    if (event === \"streamEvent\") {\n      this.realStream.on(\"streamEvent\", callback);\n    }\n    return this;\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method on\n\n  on(\n    event: \"streamEvent\",\n    callback: (\n      event: Anthropic.Messages.MessageStreamEvent,\n      snapshot: Anthropic.Message,\n    ) =\u003e void,\n  ): this {\n    if (event === \"streamEvent\") {\n      this.realStream.on(\"streamEvent\", callback);\n    }\n    return this;\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method on",
