    {
      "text": "  get systemPrompt(): string | undefined {\n    const system = this.params.system;\n    if (!system) return undefined;\n    if (typeof system === \"string\") return system;\n    return system\n      .map((block) =\u003e (\"text\" in block ? block.text : \"\"))\n      .join(\"\\n\");\n  }",
      "contextualizedText": "// node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method systemPrompt\n\n  get systemPrompt(): string | undefined {\n    const system = this.params.system;\n    if (!system) return undefined;\n    if (typeof system === \"string\") return system;\n    return system\n      .map((block) =\u003e (\"text\" in block ? block.text : \"\"))\n      .join(\"\\n\");\n  }",
      "headingContext": "node/core/src/providers/mock-anthropic-client.ts \u003e class MockStream \u003e method systemPrompt",
      "startLine": 49,
