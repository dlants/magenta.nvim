    },
    {
      "text": "  off\u003cK extends keyof AgentEvents\u003e(\n    event: K,\n    listener: (...args: AgentEvents[K]) =\u003e void,\n  ): void",
      "contextualizedText": "// node/core/src/providers/provider-types.ts \u003e interface Agent \u003e method off\n\n  off\u003cK extends keyof AgentEvents\u003e(\n    event: K,\n    listener: (...args: AgentEvents[K]) =\u003e void,\n  ): void",
