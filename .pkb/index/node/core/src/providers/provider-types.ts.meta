      "headingContext": "node/core/src/providers/provider-types.ts \u003e interface Agent \u003e method getState",
      "startLine": 328,
      "startCol": 1,
      "endLine": 328,
      "endCol": 25
    },
    {
      "text": "  getStreamingBlock(): AgentStreamingBlock | undefined",
      "contextualizedText": "// node/core/src/providers/provider-types.ts \u003e interface Agent \u003e method getStreamingBlock\n\n  getStreamingBlock(): AgentStreamingBlock | undefined",
      "headingContext": "node/core/src/providers/provider-types.ts \u003e interface Agent \u003e method getStreamingBlock",
      "startLine": 330,
