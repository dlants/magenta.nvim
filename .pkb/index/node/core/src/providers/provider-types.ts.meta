    {
      "text": "aborted: boolean;\n  promise: Promise\u003cProviderToolUseResponse\u003e;\n}",
      "contextualizedText": "// node/core/src/providers/provider-types.ts \u003e interface ProviderToolUseRequest\n\naborted: boolean;\n  promise: Promise\u003cProviderToolUseResponse\u003e;\n}",
