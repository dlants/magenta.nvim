      "text": "  getStreamingBlock(): AgentStreamingBlock | undefined {\n    if (!this.currentAnthropicBlock) {\n      return undefined;\n    }\n    // Only expose types that AgentStreamingBlock supports\n    switch (this.currentAnthropicBlock.type) {\n      case \"text\":\n      case \"thinking\":\n      case \"tool_use\":\n        return this.currentAnthropicBlock;\n      default:\n        return undefined;\n    }\n  }",
      "contextualizedText": "// node/core/src/providers/anthropic-agent.ts \u003e class AnthropicAgent \u003e method getStreamingBlock\n\n  getStreamingBlock(): AgentStreamingBlock | undefined {\n    if (!this.currentAnthropicBlock) {\n      return undefined;\n    }\n    // Only expose types that AgentStreamingBlock supports\n    switch (this.currentAnthropicBlock.type) {\n      case \"text\":\n      case \"thinking\":\n      case \"tool_use\":\n        return this.currentAnthropicBlock;\n      default:\n        return undefined;\n    }\n  }",
