    {
      "text": "    const processResponse = (response: Anthropic.Message) =\u003e {\n      if (response.stop_reason === \"max_tokens\") {\n        throw new Error(\"Response exceeded max_tokens limit\");\n      }\n\n      if (response.content.length !== 1) {\n        throw new Error(\n          `Expected a single response but got ${response.content.length}`,\n        );\n      }\n\n      const contentBlock = response.content[0];",
      "contextualizedText": "// node/core/src/providers/anthropic.ts \u003e class AnthropicProvider \u003e method forceToolUse \u003e function processResponse\n\n    const processResponse = (response: Anthropic.Message) =\u003e {\n      if (response.stop_reason === \"max_tokens\") {\n        throw new Error(\"Response exceeded max_tokens limit\");\n      }\n\n      if (response.content.length !== 1) {\n        throw new Error(\n          `Expected a single response but got ${response.content.length}`,\n        );\n      }\n\n      const contentBlock = response.content[0];",
      "headingContext": "node/core/src/providers/anthropic.ts \u003e class AnthropicProvider \u003e method forceToolUse \u003e function processResponse",
      "startLine": 582,
