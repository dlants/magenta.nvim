      "text": "  debug: () =\u003e {}",
      "contextualizedText": "// node/core/src/providers/anthropic-agent-auth-refresh.test.ts \u003e function debug\n\n  debug: () =\u003e {}",
      "headingContext": "node/core/src/providers/anthropic-agent-auth-refresh.test.ts \u003e function debug",
      "startLine": 22,
