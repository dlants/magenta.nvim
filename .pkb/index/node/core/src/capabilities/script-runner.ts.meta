    },
    {
      "text": "/**\n * Root-injected capability that lets the `run_script` tool enumerate and\n * trigger discovered scripts. The actual invocation lives outside the\n * triggering thread's lifecycle (fire-and-forget); the triggering thread id is\n * passed so the root can seed the new script invocation's sandbox state.\n */\nexport interface ScriptRunner",
      "contextualizedText": "// node/core/src/capabilities/script-runner.ts \u003e interface ScriptRunner\n\n/**\n * Root-injected capability that lets the `run_script` tool enumerate and\n * trigger discovered scripts. The actual invocation lives outside the\n * triggering thread's lifecycle (fire-and-forget); the triggering thread id is\n * passed so the root can seed the new script invocation's sandbox state.\n */\nexport interface ScriptRunner",
      "headingContext": "node/core/src/capabilities/script-runner.ts \u003e interface ScriptRunner",
      "startLine": 10,
      "startCol": 1,
      "endLine": 16,
      "endCol": 30
    },
    {
      "text": "/**\n   * Re-scan the configured script paths and rebuild the catalog. Awaited\n   * during thread creation so each new thread starts with an up-to-date\n   * catalog.\n   */\n  discover(): Promise\u003cvoid\u003e",
      "contextualizedText": "// node/core/src/capabilities/script-runner.ts \u003e interface ScriptRunner \u003e method discover\n\n/**\n   * Re-scan the configured script paths and rebuild the catalog. Awaited\n   * during thread creation so each new thread starts with an up-to-date\n   * catalog.\n   */\n  discover(): Promise\u003cvoid\u003e",
      "headingContext": "node/core/src/capabilities/script-runner.ts \u003e interface ScriptRunner \u003e method discover",
      "startLine": 17,
      "startCol": 3,
      "endLine": 22,
      "endCol": 28
    },
    {
      "text": "  getScriptCatalog(): ScriptCatalogEntry[]",
      "contextualizedText": "// node/core/src/capabilities/script-runner.ts \u003e interface ScriptRunner \u003e method getScriptCatalog\n\n  getScriptCatalog(): ScriptCatalogEntry[]",
      "headingContext": "node/core/src/capabilities/script-runner.ts \u003e interface ScriptRunner \u003e method getScriptCatalog",
