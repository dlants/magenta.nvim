    {
      "text": "import type { ThreadId } from \"../chat-types.ts\";\n\nexport type ScriptCatalogEntry = {\n  name: string;\n  description: string;\n  parameterSchema: Record\u003cstring, unknown\u003e;\n  file: string;\n};",
      "contextualizedText": "// node/core/src/capabilities/script-runner.ts\n\nimport type { ThreadId } from \"../chat-types.ts\";\n\nexport type ScriptCatalogEntry = {\n  name: string;\n  description: string;\n  parameterSchema: Record\u003cstring, unknown\u003e;\n  file: string;\n};",
