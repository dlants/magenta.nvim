    {
      "text": "export class FsFileIO implements FileIO",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO\n\nexport class FsFileIO implements FileIO",
      "headingContext": "node/core/src/capabilities/file-io.ts \u003e class FsFileIO",
      "startLine": 14,
      "startCol": 1,
      "endLine": 14,
      "endCol": 40
    },
    {
      "text": "  async readFile(path: string): Promise\u003cstring\u003e {\n    return fs.readFile(path, \"utf-8\");\n  }",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method readFile\n\n  async readFile(path: string): Promise\u003cstring\u003e {\n    return fs.readFile(path, \"utf-8\");\n  }",
      "headingContext": "node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method readFile",
      "startLine": 15,
      "startCol": 1,
      "endLine": 17,
      "endCol": 4
    },
    {
      "text": "  async readBinaryFile(path: string): Promise\u003cBuffer\u003e {\n    return fs.readFile(path);\n  }",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method readBinaryFile\n\n  async readBinaryFile(path: string): Promise\u003cBuffer\u003e {\n    return fs.readFile(path);\n  }",
      "headingContext": "node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method readBinaryFile",
      "startLine": 18,
      "startCol": 1,
      "endLine": 20,
      "endCol": 4
    },
    {
      "text": "  async writeFile(path: string, content: string): Promise\u003cvoid\u003e {\n    await fs.writeFile(path, content, \"utf-8\");\n  }",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method writeFile\n\n  async writeFile(path: string, content: string): Promise\u003cvoid\u003e {\n    await fs.writeFile(path, content, \"utf-8\");\n  }",
      "headingContext": "node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method writeFile",
      "startLine": 22,
      "startCol": 1,
      "endLine": 24,
      "endCol": 4
    },
    {
      "text": "  async fileExists(path: string): Promise\u003cboolean\u003e {\n    try {\n      await fs.access(path);\n      return true;\n    } catch {\n      return false;\n    }\n  }",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method fileExists\n\n  async fileExists(path: string): Promise\u003cboolean\u003e {\n    try {\n      await fs.access(path);\n      return true;\n    } catch {\n      return false;\n    }\n  }",
      "headingContext": "node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method fileExists",
      "startLine": 26,
      "startCol": 1,
      "endLine": 33,
      "endCol": 4
    },
    {
      "text": "  async mkdir(path: string): Promise\u003cvoid\u003e {\n    await fs.mkdir(path, { recursive: true });\n  }",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method mkdir\n\n  async mkdir(path: string): Promise\u003cvoid\u003e {\n    await fs.mkdir(path, { recursive: true });\n  }",
      "headingContext": "node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method mkdir",
      "startLine": 35,
      "startCol": 1,
      "endLine": 37,
      "endCol": 4
    },
    {
      "text": "  async stat(\n    path: string,\n  ): Promise\u003c{ mtimeMs: number; size: number } | undefined\u003e {\n    try {\n      const stats = await fs.stat(path);\n      return { mtimeMs: stats.mtimeMs, size: stats.size };\n    } catch {\n      return undefined;\n    }\n  }",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method stat\n\n  async stat(\n    path: string,\n  ): Promise\u003c{ mtimeMs: number; size: number } | undefined\u003e {\n    try {\n      const stats = await fs.stat(path);\n      return { mtimeMs: stats.mtimeMs, size: stats.size };\n    } catch {\n      return undefined;\n    }\n  }",
      "headingContext": "node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method stat",
      "startLine": 38,
      "startCol": 1,
      "endLine": 47,
      "endCol": 4
    },
    {
      "text": "  async readdir(path: string): Promise\u003cstring[]\u003e {\n    return fs.readdir(path);\n  }",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method readdir\n\n  async readdir(path: string): Promise\u003cstring[]\u003e {\n    return fs.readdir(path);\n  }",
      "headingContext": "node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method readdir",
      "startLine": 49,
      "startCol": 1,
      "endLine": 51,
      "endCol": 4
    },
    {
      "text": "  async isDirectory(path: string): Promise\u003cboolean\u003e {\n    try {\n      const stats = await fs.stat(path);\n      return stats.isDirectory();\n    } catch {\n      return false;\n    }\n  }",
      "contextualizedText": "// node/core/src/capabilities/file-io.ts \u003e class FsFileIO \u003e method isDirectory\n\n  async isDirectory(path: string): Promise\u003cboolean\u003e {\n    try {\n      const stats = await fs.stat(path);\n      return stats.isDirectory();\n    } catch {\n      return false;\n    }\n  }",
