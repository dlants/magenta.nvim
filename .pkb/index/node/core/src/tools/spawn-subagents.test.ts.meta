      "endLine": 24,
      "endCol": 66
    },
    {
      "text": "function createMockThreadManager(\n  overrides: Partial\u003cThreadManager\u003e = {},\n): MockThreadManager {\n  const results = new Map\u003cstring, { status: \"done\"; result: Result\u003cstring\u003e }\u003e();\n  const callbacks = new Map\u003cstring, Array\u003c() =\u003e void\u003e\u003e();\n\n  const manager: MockThreadManager = {\n    spawnThread: vi.fn().mockResolvedValue(\"thread-1\" as ThreadId),\n    onThreadYielded: vi.fn((threadId: ThreadId, callback: () =\u003e void) =\u003e {\n      let cbs = callbacks.get(threadId);\n      if (!cbs) {\n        cbs = [];\n        callbacks.set(threadId, cbs);\n      }\n      cbs.push(callback);\n      // If already yielded, fire immediately\n      if (results.has(threadId)) {\n        callback();\n      }\n    }),\n    getThreadResult: vi.fn((threadId: ThreadId) =\u003e {\n      return results.get(threadId) ?? { status: \"pending\" as const };\n    })",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.test.ts \u003e function createMockThreadManager\n\nfunction createMockThreadManager(\n  overrides: Partial\u003cThreadManager\u003e = {},\n): MockThreadManager {\n  const results = new Map\u003cstring, { status: \"done\"; result: Result\u003cstring\u003e }\u003e();\n  const callbacks = new Map\u003cstring, Array\u003c() =\u003e void\u003e\u003e();\n\n  const manager: MockThreadManager = {\n    spawnThread: vi.fn().mockResolvedValue(\"thread-1\" as ThreadId),\n    onThreadYielded: vi.fn((threadId: ThreadId, callback: () =\u003e void) =\u003e {\n      let cbs = callbacks.get(threadId);\n      if (!cbs) {\n        cbs = [];\n        callbacks.set(threadId, cbs);\n      }\n      cbs.push(callback);\n      // If already yielded, fire immediately\n      if (results.has(threadId)) {\n        callback();\n      }\n    }),\n    getThreadResult: vi.fn((threadId: ThreadId) =\u003e {\n      return results.get(threadId) ?? { status: \"pending\" as const };\n    })",
      "headingContext": "node/core/src/tools/spawn-subagents.test.ts \u003e function createMockThreadManager",
      "startLine": 27,
      "startCol": 1,
      "endLine": 49,
      "endCol": 7
    },
    {
      "text": "    simulateYield(threadId: ThreadId, result: Result\u003cstring\u003e) {\n      results.set(threadId, { status: \"done\", result });\n      const cbs = callbacks.get(threadId);\n      if (cbs) {\n        for (const cb of cbs) {\n          cb();\n        }\n      }\n    }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.test.ts \u003e function createMockThreadManager \u003e method simulateYield\n\n    simulateYield(threadId: ThreadId, result: Result\u003cstring\u003e) {\n      results.set(threadId, { status: \"done\", result });\n      const cbs = callbacks.get(threadId);\n      if (cbs) {\n        for (const cb of cbs) {\n          cb();\n        }\n      }\n    }",
      "headingContext": "node/core/src/tools/spawn-subagents.test.ts \u003e function createMockThreadManager \u003e method simulateYield",
