    {
      "text": "  simulateYield(threadId: ThreadId, result: Result\u003cstring\u003e): void",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.test.ts \u003e method simulateYield\n\n  simulateYield(threadId: ThreadId, result: Result\u003cstring\u003e): void",
      "headingContext": "node/core/src/tools/spawn-subagents.test.ts \u003e method simulateYield",
      "startLine": 24,
