      "endLine": 70,
      "endCol": 32
    },
    {
      "text": "      execLua: () =\u003e new Promise((r) =\u003e (resolve = r))",
      "contextualizedText": "// node/core/src/tools/nvimLua.test.ts \u003e function execLua\n\n      execLua: () =\u003e new Promise((r) =\u003e (resolve = r))",
