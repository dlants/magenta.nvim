      "headingContext": "node/core/src/tools/nvimLua.test.ts \u003e function execLua",
      "startLine": 34,
      "startCol": 1,
      "endLine": 34,
      "endCol": 58
    },
    {
      "text": "const result = await getResultText(createTool(\"return {}\", executor));\n    expect(result.status).toBe(\"ok\");\n    expect(JSON.parse(result.text)).toEqual({ a: 1, b: [2, 3] });\n  });\n\n  it(\"reports a no-return-value message for undefined\", async () =\u003e {\n    const executor: LuaExecutor",
      "contextualizedText": "// node/core/src/tools/nvimLua.test.ts\n\nconst result = await getResultText(createTool(\"return {}\", executor));\n    expect(result.status).toBe(\"ok\");\n    expect(JSON.parse(result.text)).toEqual({ a: 1, b: [2, 3] });\n  });\n\n  it(\"reports a no-return-value message for undefined\", async () =\u003e {\n    const executor: LuaExecutor",
