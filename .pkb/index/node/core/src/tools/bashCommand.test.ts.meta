      "text": "      execute: async (_command, opts) =\u003e {\n        opts.onStart?.();\n        opts.onOutput?.({ stream: \"stdout\", text: \"error output 1\" });\n        opts.onOutput?.({ stream: \"stderr\", text: \"error output 2\" });\n        return new Promise\u003cShellResult\u003e((_resolve, reject) =\u003e {\n          rejectShell = reject;\n        });\n      }",
