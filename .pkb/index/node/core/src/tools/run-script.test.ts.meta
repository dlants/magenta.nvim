      "text": "  function makeRequest(input: RunScript.Input): RunScript.ToolRequest {\n    return {\n      id: \"req-1\" as ToolRequestId,\n      toolName: \"run_script\",\n      input,\n    };\n  }",
      "contextualizedText": "// node/core/src/tools/run-script.test.ts \u003e function makeRequest\n\n  function makeRequest(input: RunScript.Input): RunScript.ToolRequest {\n    return {\n      id: \"req-1\" as ToolRequestId,\n      toolName: \"run_script\",\n      input,\n    };\n  }",
