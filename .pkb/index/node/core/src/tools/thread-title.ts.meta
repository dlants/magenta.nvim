      "endLine": 103,
      "endCol": 61
    },
    {
      "text": "export function validateInput(input: {\n  [key: string]: unknown;\n}): Result\u003cInput\u003e {\n  if (typeof input.title !== \"string\") {\n    return {\n      status: \"error\",\n      error: \"expected req.input.title to be a string\",\n    };\n  }\n\n  return {\n    status: \"ok\",\n    value: input as Input,\n  };\n}",
      "contextualizedText": "// node/core/src/tools/thread-title.ts \u003e function validateInput\n\nexport function validateInput(input: {\n  [key: string]: unknown;\n}): Result\u003cInput\u003e {\n  if (typeof input.title !== \"string\") {\n    return {\n      status: \"error\",\n      error: \"expected req.input.title to be a string\",\n    };\n  }\n\n  return {\n    status: \"ok\",\n    value: input as Input,\n  };\n}",
