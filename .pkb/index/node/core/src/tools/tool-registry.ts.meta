    {
      "text": "export const STATIC_TOOL_NAMES = [\n  \"get_file\",\n  \"hover\",\n  \"find_references\",\n  \"bash_command\",\n  \"thread_title\",\n  \"spawn_subagents\",\n  \"yield_to_parent\",\n  \"edl\",\n  \"docs\",\n  \"run_script\",\n  \"nvim_lua\",\n  \"scratchpad\",\n] as const;\n\nexport type StaticToolName = (typeof STATIC_TOOL_NAMES)[number];\n\nexport const CHAT_STATIC_TOOL_NAMES: StaticToolName[] = [\n  \"get_file\",\n  \"hover\",\n  \"find_references\",\n  \"bash_command\",\n  \"spawn_subagents\",\n  \"edl\",\n  \"docs\",\n  \"run_script\",\n  \"nvim_lua\",\n  \"scratchpad\",\n];\n\nexport const COMPACT_STATIC_TOOL_NAMES: StaticToolName[] = [\"get_file\", \"edl\"];\nexport const DOCKER_ROOT_STATIC_TOOL_NAMES: StaticToolName[] = [\n  ...CHAT_STATIC_TOOL_NAMES,\n  \"yield_to_parent\",\n];\nexport const SUBAGENT_STATIC_TOOL_NAMES: StaticToolName[] = [\n  \"get_file\",\n  \"hover\",\n  \"find_references\",\n  \"bash_command\",\n  \"yield_to_parent\",\n  \"edl\",\n  \"docs\",\n  \"scratchpad\",\n];\n\nexport const TOOL_CAPABILITIES = [\n  \"lsp\",\n  \"shell\",\n  \"threads\",\n  \"file-io\",\n  \"scripts\",\n  \"nvim\",\n] as const;\n\nexport type ToolCapability = (typeof TOOL_CAPABILITIES)[number];\n\nexport const TOOL_REQUIRED_CAPABILITIES: Record\u003c\n  StaticToolName,\n  Set\u003cToolCapability\u003e\n\u003e = {\n  get_file: new Set([\"file-io\"]),\n  edl: new Set([\"file-io\"]),\n  hover: new Set([\"lsp\"]),\n  find_references: new Set([\"lsp\"]),\n  bash_command: new Set([\"shell\"]),\n  spawn_subagents: new Set([\"threads\"]),\n  thread_title: new Set(),\n  yield_to_parent: new Set(),\n  docs: new Set(),\n  run_script: new Set([\"scripts\"]),\n  nvim_lua: new Set([\"nvim\"]),\n  scratchpad: new Set(),\n};",
      "contextualizedText": "// node/core/src/tools/tool-registry.ts\n\nexport const STATIC_TOOL_NAMES = [\n  \"get_file\",\n  \"hover\",\n  \"find_references\",\n  \"bash_command\",\n  \"thread_title\",\n  \"spawn_subagents\",\n  \"yield_to_parent\",\n  \"edl\",\n  \"docs\",\n  \"run_script\",\n  \"nvim_lua\",\n  \"scratchpad\",\n] as const;\n\nexport type StaticToolName = (typeof STATIC_TOOL_NAMES)[number];\n\nexport const CHAT_STATIC_TOOL_NAMES: StaticToolName[] = [\n  \"get_file\",\n  \"hover\",\n  \"find_references\",\n  \"bash_command\",\n  \"spawn_subagents\",\n  \"edl\",\n  \"docs\",\n  \"run_script\",\n  \"nvim_lua\",\n  \"scratchpad\",\n];\n\nexport const COMPACT_STATIC_TOOL_NAMES: StaticToolName[] = [\"get_file\", \"edl\"];\nexport const DOCKER_ROOT_STATIC_TOOL_NAMES: StaticToolName[] = [\n  ...CHAT_STATIC_TOOL_NAMES,\n  \"yield_to_parent\",\n];\nexport const SUBAGENT_STATIC_TOOL_NAMES: StaticToolName[] = [\n  \"get_file\",\n  \"hover\",\n  \"find_references\",\n  \"bash_command\",\n  \"yield_to_parent\",\n  \"edl\",\n  \"docs\",\n  \"scratchpad\",\n];\n\nexport const TOOL_CAPABILITIES = [\n  \"lsp\",\n  \"shell\",\n  \"threads\",\n  \"file-io\",\n  \"scripts\",\n  \"nvim\",\n] as const;\n\nexport type ToolCapability = (typeof TOOL_CAPABILITIES)[number];\n\nexport const TOOL_REQUIRED_CAPABILITIES: Record\u003c\n  StaticToolName,\n  Set\u003cToolCapability\u003e\n\u003e = {\n  get_file: new Set([\"file-io\"]),\n  edl: new Set([\"file-io\"]),\n  hover: new Set([\"lsp\"]),\n  find_references: new Set([\"lsp\"]),\n  bash_command: new Set([\"shell\"]),\n  spawn_subagents: new Set([\"threads\"]),\n  thread_title: new Set(),\n  yield_to_parent: new Set(),\n  docs: new Set(),\n  run_script: new Set([\"scripts\"]),\n  nvim_lua: new Set([\"nvim\"]),\n  scratchpad: new Set(),\n};",
