    {
      "text": "  respondWithError(error: string): void {\n    const call = this.pendingCalls.shift();\n    if (call) {\n      call.defer.reject(new Error(error));\n      this.calls.push({ args: call.args, result: error });\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockToolStub \u003e method respondWithError\n\n  respondWithError(error: string): void {\n    const call = this.pendingCalls.shift();\n    if (call) {\n      call.defer.reject(new Error(error));\n      this.calls.push({ args: call.args, result: error });\n    }\n  }",
