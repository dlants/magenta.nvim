    {
      "text": "export class MockToolStub {\n  public calls: Array\u003c{ args: unknown; result: unknown }\u003e = [];\n  private pendingCalls: Array\u003c{ args: unknown; defer: Defer\u003cunknown\u003e }\u003e = [];\n\n  constructor(public name: string) {}",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockToolStub\n\nexport class MockToolStub {\n  public calls: Array\u003c{ args: unknown; result: unknown }\u003e = [];\n  private pendingCalls: Array\u003c{ args: unknown; defer: Defer\u003cunknown\u003e }\u003e = [];\n\n  constructor(public name: string) {}",
      "headingContext": "node/core/src/tools/mcp/mock-server.ts \u003e class MockToolStub",
      "startLine": 9,
      "startCol": 1,
      "endLine": 13,
      "endCol": 38
    },
    {
      "text": "  async awaitCall(timeout = 1000): Promise\u003c{ args: unknown }\u003e {\n    return pollUntil(\n      () =\u003e {\n        const call = this.pendingCalls[0];\n        if (!call) {\n          throw new Error(`No pending call to tool ${this.name}`);\n        }\n        return call;\n      },\n      { timeout },\n    );\n  }",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockToolStub \u003e method awaitCall\n\n  async awaitCall(timeout = 1000): Promise\u003c{ args: unknown }\u003e {\n    return pollUntil(\n      () =\u003e {\n        const call = this.pendingCalls[0];\n        if (!call) {\n          throw new Error(`No pending call to tool ${this.name}`);\n        }\n        return call;\n      },\n      { timeout },\n    );\n  }",
      "headingContext": "node/core/src/tools/mcp/mock-server.ts \u003e class MockToolStub \u003e method awaitCall",
      "startLine": 15,
      "startCol": 1,
      "endLine": 26,
      "endCol": 4
    },
    {
      "text": "  respondWith(result: unknown): void {\n    const call = this.pendingCalls.shift();\n    if (call) {\n      call.defer.resolve(result);\n      this.calls.push({ args: call.args, result });\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockToolStub \u003e method respondWith\n\n  respondWith(result: unknown): void {\n    const call = this.pendingCalls.shift();\n    if (call) {\n      call.defer.resolve(result);\n      this.calls.push({ args: call.args, result });\n    }\n  }",
