    {
      "text": "export class MockMCPServer {\n  private server: McpServer;\n  private transport: InMemoryTransport | undefined;\n  private clientTransport: InMemoryTransport | undefined;\n  private tools: MCPMockToolConfig[];\n  public toolCalls: Array\u003c{ name: string; args: unknown; result: unknown }\u003e =\n    [];\n  private toolStubs: Map\u003cstring, MockToolStub\u003e = new Map();\n\n  constructor(\n    public serverName: ServerName,\n    tools: MCPMockToolConfig[] = [],\n  ) {\n    this.tools = tools;\n    this.server = new McpServer(\n      {\n        name: serverName,\n        version: \"1.0.0\",\n      },\n      {\n        capabilities: {\n          tools: {},\n        },\n      },\n    );\n\n    this.setupTools();\n    mockServers[this.serverName] = this;\n  }",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer\n\nexport class MockMCPServer {\n  private server: McpServer;\n  private transport: InMemoryTransport | undefined;\n  private clientTransport: InMemoryTransport | undefined;\n  private tools: MCPMockToolConfig[];\n  public toolCalls: Array\u003c{ name: string; args: unknown; result: unknown }\u003e =\n    [];\n  private toolStubs: Map\u003cstring, MockToolStub\u003e = new Map();\n\n  constructor(\n    public serverName: ServerName,\n    tools: MCPMockToolConfig[] = [],\n  ) {\n    this.tools = tools;\n    this.server = new McpServer(\n      {\n        name: serverName,\n        version: \"1.0.0\",\n      },\n      {\n        capabilities: {\n          tools: {},\n        },\n      },\n    );\n\n    this.setupTools();\n    mockServers[this.serverName] = this;\n  }",
      "headingContext": "node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer",
      "startLine": 56,
      "startCol": 1,
      "endLine": 84,
      "endCol": 4
    },
    {
      "text": "  private createZodSchema(inputSchema: {\n    [param: string]: MCPMockToolSchemaType;\n  }): z.ZodRawShape {\n    const shape: z.ZodRawShape = {};\n\n    for (const [key, type] of Object.entries(inputSchema)) {\n      switch (type) {\n        case \"string\":\n          shape[key] = z.string();\n          break;\n        case \"number\":\n          shape[key] = z.number();\n          break;\n        case \"boolean\":\n          shape[key] = z.boolean();\n          break;\n\n        default:\n          assertUnreachable(type);\n      }\n    }\n\n    return shape;\n  }",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method createZodSchema\n\n  private createZodSchema(inputSchema: {\n    [param: string]: MCPMockToolSchemaType;\n  }): z.ZodRawShape {\n    const shape: z.ZodRawShape = {};\n\n    for (const [key, type] of Object.entries(inputSchema)) {\n      switch (type) {\n        case \"string\":\n          shape[key] = z.string();\n          break;\n        case \"number\":\n          shape[key] = z.number();\n          break;\n        case \"boolean\":\n          shape[key] = z.boolean();\n          break;\n\n        default:\n          assertUnreachable(type);\n      }\n    }\n\n    return shape;\n  }",
      "headingContext": "node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method createZodSchema",
      "startLine": 86,
      "startCol": 1,
      "endLine": 109,
      "endCol": 4
    },
    {
      "text": "  private setupTools(): void {\n    // Create stubs and register tools with the server using the proper API\n    for (const tool of this.tools",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method setupTools\n\n  private setupTools(): void {\n    // Create stubs and register tools with the server using the proper API\n    for (const tool of this.tools",
      "headingContext": "node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method setupTools",
      "startLine": 111,
      "startCol": 1,
      "endLine": 113,
      "endCol": 34
    },
    {
      "text": "{\n      const stub = new MockToolStub(tool.name);\n      this.toolStubs.set(tool.name, stub);\n\n      if (tool.inputSchema \u0026\u0026 Object.keys(tool.inputSchema).length \u003e 0) {\n        const zodShape = this.createZodSchema(tool.inputSchema);\n\n        this.server.registerTool(\n          tool.name,\n          {\n            description: tool.description || \"\",\n            inputSchema: zodShape,\n          },\n          async (args) =\u003e {\n            try {\n              const result = await stub.invoke(args);\n              return {\n                content: [\n                  {\n                    type: \"text\",\n                    text:\n                      typeof result === \"string\"\n                        ? result\n                        : JSON.stringify(result),\n                  },\n                ],\n              };\n            } catch (error) {\n              return {\n                content: [\n                  {\n                    type: \"text\",\n                    text: `Error: ${error instanceof Error ? error.message : String(error)}`,\n                  },\n                ],\n                isError: true,\n              };\n            }\n          },\n        );\n      } else {\n        // Tool without input schema\n        this.server.tool(tool.name, tool.description || \"\", async () =\u003e {\n          try {\n            const result = await stub.invoke(undefined);\n            return {\n              content: [\n                {\n                  type: \"text\",\n                  text:\n                    typeof result === \"string\"\n                      ? result\n                      : JSON.stringify(result),\n                },\n              ],\n            };\n          } catch (error) {\n            return {\n              content: [\n                {\n                  type: \"text\",\n                  text: `Error: ${error instanceof Error ? error.message : String(error)}`,\n                },\n              ],\n              isError: true,\n            };\n          }\n        });\n      }\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method setupTools\n\n{\n      const stub = new MockToolStub(tool.name);\n      this.toolStubs.set(tool.name, stub);\n\n      if (tool.inputSchema \u0026\u0026 Object.keys(tool.inputSchema).length \u003e 0) {\n        const zodShape = this.createZodSchema(tool.inputSchema);\n\n        this.server.registerTool(\n          tool.name,\n          {\n            description: tool.description || \"\",\n            inputSchema: zodShape,\n          },\n          async (args) =\u003e {\n            try {\n              const result = await stub.invoke(args);\n              return {\n                content: [\n                  {\n                    type: \"text\",\n                    text:\n                      typeof result === \"string\"\n                        ? result\n                        : JSON.stringify(result),\n                  },\n                ],\n              };\n            } catch (error) {\n              return {\n                content: [\n                  {\n                    type: \"text\",\n                    text: `Error: ${error instanceof Error ? error.message : String(error)}`,\n                  },\n                ],\n                isError: true,\n              };\n            }\n          },\n        );\n      } else {\n        // Tool without input schema\n        this.server.tool(tool.name, tool.description || \"\", async () =\u003e {\n          try {\n            const result = await stub.invoke(undefined);\n            return {\n              content: [\n                {\n                  type: \"text\",\n                  text:\n                    typeof result === \"string\"\n                      ? result\n                      : JSON.stringify(result),\n                },\n              ],\n            };\n          } catch (error) {\n            return {\n              content: [\n                {\n                  type: \"text\",\n                  text: `Error: ${error instanceof Error ? error.message : String(error)}`,\n                },\n              ],\n              isError: true,\n            };\n          }\n        });\n      }\n    }\n  }",
      "headingContext": "node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method setupTools",
      "startLine": 113,
      "startCol": 36,
      "endLine": 183,
      "endCol": 4
    },
    {
      "text": "  async start(): Promise\u003cInMemoryTransport\u003e {\n    // Create paired transports for in-memory communication\n    const [clientTransport, serverTransport] =\n      InMemoryTransport.createLinkedPair();\n\n    this.transport = serverTransport;\n    this.clientTransport = clientTransport;\n\n    await this.server.connect(this.transport);\n\n    return this.clientTransport;\n  }",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method start\n\n  async start(): Promise\u003cInMemoryTransport\u003e {\n    // Create paired transports for in-memory communication\n    const [clientTransport, serverTransport] =\n      InMemoryTransport.createLinkedPair();\n\n    this.transport = serverTransport;\n    this.clientTransport = clientTransport;\n\n    await this.server.connect(this.transport);\n\n    return this.clientTransport;\n  }",
      "headingContext": "node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method start",
      "startLine": 185,
      "startCol": 1,
      "endLine": 196,
      "endCol": 4
    },
    {
      "text": "  async stop(): Promise\u003cvoid\u003e {\n    if (this.transport) {\n      await this.transport.close();\n      this.transport = undefined;\n    }\n    if (this.clientTransport) {\n      await this.clientTransport.close();\n      this.clientTransport = undefined;\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method stop\n\n  async stop(): Promise\u003cvoid\u003e {\n    if (this.transport) {\n      await this.transport.close();\n      this.transport = undefined;\n    }\n    if (this.clientTransport) {\n      await this.clientTransport.close();\n      this.clientTransport = undefined;\n    }\n  }",
      "headingContext": "node/core/src/tools/mcp/mock-server.ts \u003e class MockMCPServer \u003e method stop",
