    {
      "text": "  async awaitToolCall(\n    toolName: string,\n    timeout = 1000,\n  ): Promise\u003c{ name: string; args: unknown; result: unknown }\u003e {\n    return pollUntil(\n      () =\u003e {\n        const call = this.toolCalls.find((c) =\u003e c.name === toolName);\n        if (!call) {\n          throw new Error(`No call to tool ${toolName} found`);\n        }\n        return call;\n      },\n      { timeout },\n    );\n  }",
