      "text": "import { InMemoryTransport } from \"@modelcontextprotocol/sdk/inMemory.js\";\nimport { McpServer } from \"@modelcontextprotocol/sdk/server/mcp.js\";\nimport { z } from \"zod\";\nimport { assertUnreachable } from \"../../utils/assertUnreachable.ts\";\nimport { Defer, pollUntil } from \"../../utils/async.ts\";\nimport type { MCPMockToolConfig, MCPMockToolSchemaType } from \"./options.ts\";\nimport type { ServerName } from \"./types.ts\";",
      "contextualizedText": "// node/core/src/tools/mcp/mock-server.ts\n\nimport { InMemoryTransport } from \"@modelcontextprotocol/sdk/inMemory.js\";\nimport { McpServer } from \"@modelcontextprotocol/sdk/server/mcp.js\";\nimport { z } from \"zod\";\nimport { assertUnreachable } from \"../../utils/assertUnreachable.ts\";\nimport { Defer, pollUntil } from \"../../utils/async.ts\";\nimport type { MCPMockToolConfig, MCPMockToolSchemaType } from \"./options.ts\";\nimport type { ServerName } from \"./types.ts\";",
