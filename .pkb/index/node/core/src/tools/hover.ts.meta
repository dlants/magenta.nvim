    {
      "text": "export function execute(\n  request: ToolRequest,\n  context: {\n    cwd: NvimCwd;\n    homeDir: HomeDir;\n    lspClient: LspClient;\n    fileIO: FileIO;\n  },\n): ToolInvocation {\n  let aborted = false;\n\n  const promise = (async (): Promise\u003cProviderToolResult\u003e =\u003e {\n    try {\n      const filePath = request.input.filePath;\n      const absFilePath = resolveFilePath(\n        context.cwd,\n        filePath,\n        context.homeDir,\n      );\n\n      let bufferContent: string;\n      try {\n        bufferContent = await context.fileIO.readFile(absFilePath);\n      } catch (e) {\n        return {\n          type: \"tool_result\",\n          id: request.id,\n          result: {\n            status: \"error\",\n            error: `Failed to read file ${absFilePath}: ${e instanceof Error ? e.message : String(e)}`,\n          },\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        };\n      }\n\n      if (aborted) {\n        return {\n          type: \"tool_result\",\n          id: request.id,\n          result: {\n            status: \"error\",\n            error: \"Request was aborted by the user.\",\n          },\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        };\n      }\n      // Find the symbol bounded by non-alphanumeric characters\n      let symbolStart: StringIdx;",
      "contextualizedText": "// node/core/src/tools/hover.ts \u003e function execute\n\nexport function execute(\n  request: ToolRequest,\n  context: {\n    cwd: NvimCwd;\n    homeDir: HomeDir;\n    lspClient: LspClient;\n    fileIO: FileIO;\n  },\n): ToolInvocation {\n  let aborted = false;\n\n  const promise = (async (): Promise\u003cProviderToolResult\u003e =\u003e {\n    try {\n      const filePath = request.input.filePath;\n      const absFilePath = resolveFilePath(\n        context.cwd,\n        filePath,\n        context.homeDir,\n      );\n\n      let bufferContent: string;\n      try {\n        bufferContent = await context.fileIO.readFile(absFilePath);\n      } catch (e) {\n        return {\n          type: \"tool_result\",\n          id: request.id,\n          result: {\n            status: \"error\",\n            error: `Failed to read file ${absFilePath}: ${e instanceof Error ? e.message : String(e)}`,\n          },\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        };\n      }\n\n      if (aborted) {\n        return {\n          type: \"tool_result\",\n          id: request.id,\n          result: {\n            status: \"error\",\n            error: \"Request was aborted by the user.\",\n          },\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        };\n      }\n      // Find the symbol bounded by non-alphanumeric characters\n      let symbolStart: StringIdx;",
      "headingContext": "node/core/src/tools/hover.ts \u003e function execute",
      "startLine": 33,
      "startCol": 1,
      "endLine": 80,
      "endCol": 34
    },
    {
      "text": "if (request.input.context) {\n        const contextIndex = bufferContent.indexOf(request.input.context);\n        if (contextIndex === -1) {\n          return {\n            type: \"tool_result\",\n            id: request.id,\n            result: {\n              status: \"error\",\n              error: `Context \"${request.input.context}\" not found in file.`,\n            },\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          };\n        }\n\n        const contextContent = bufferContent.substring(\n          contextIndex,\n          contextIndex + request.input.context.length,\n        );\n        const symbolRegex = new RegExp(\n          `(?\u003c![a-zA-Z0-9_])${request.input.symbol.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$\u0026\")}(?![a-zA-Z0-9_])`,\n        );\n        const match = contextContent.match(symbolRegex);\n        if (!match || match.index === undefined) {\n          return {\n            type: \"tool_result\",\n            id: request.id,\n            result: {\n              status: \"error\",\n              error: `Symbol \"${request.input.symbol}\" not found within the provided context.`,\n            },\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          };\n        }\n        symbolStart = (contextIndex + match.index) as StringIdx;\n      } else {\n        const symbolRegex = new RegExp(\n          `(?\u003c![a-zA-Z0-9_])${request.input.symbol.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$\u0026\")}(?![a-zA-Z0-9_])`,\n        );\n        const match = bufferContent.match(symbolRegex);\n        if (!match || match.index === undefined) {\n          return {\n            type: \"tool_result\",\n            id: request.id,\n            result: {\n              status: \"error\",\n              error: `Symbol \"${request.input.symbol}\" not found in file.`,\n            },\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          };\n        }\n        symbolStart = match.index as StringIdx;\n      }",
      "contextualizedText": "// node/core/src/tools/hover.ts \u003e function execute\n\nif (request.input.context) {\n        const contextIndex = bufferContent.indexOf(request.input.context);\n        if (contextIndex === -1) {\n          return {\n            type: \"tool_result\",\n            id: request.id,\n            result: {\n              status: \"error\",\n              error: `Context \"${request.input.context}\" not found in file.`,\n            },\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          };\n        }\n\n        const contextContent = bufferContent.substring(\n          contextIndex,\n          contextIndex + request.input.context.length,\n        );\n        const symbolRegex = new RegExp(\n          `(?\u003c![a-zA-Z0-9_])${request.input.symbol.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$\u0026\")}(?![a-zA-Z0-9_])`,\n        );\n        const match = contextContent.match(symbolRegex);\n        if (!match || match.index === undefined) {\n          return {\n            type: \"tool_result\",\n            id: request.id,\n            result: {\n              status: \"error\",\n              error: `Symbol \"${request.input.symbol}\" not found within the provided context.`,\n            },\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          };\n        }\n        symbolStart = (contextIndex + match.index) as StringIdx;\n      } else {\n        const symbolRegex = new RegExp(\n          `(?\u003c![a-zA-Z0-9_])${request.input.symbol.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$\u0026\")}(?![a-zA-Z0-9_])`,\n        );\n        const match = bufferContent.match(symbolRegex);\n        if (!match || match.index === undefined) {\n          return {\n            type: \"tool_result\",\n            id: request.id,\n            result: {\n              status: \"error\",\n              error: `Symbol \"${request.input.symbol}\" not found in file.`,\n            },\n            nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n          };\n        }\n        symbolStart = match.index as StringIdx;\n      }",
      "headingContext": "node/core/src/tools/hover.ts \u003e function execute",
      "startLine": 82,
      "startCol": 7,
      "endLine": 133,
      "endCol": 8
    },
    {
      "text": "const symbolPos = calculateStringPosition(\n        { row: 0, col: 0 } as PositionString,\n        bufferContent,\n        (symbolStart + request.input.symbol.length - 1) as StringIdx,\n      );\n\n      const lspPosition = { line: symbolPos.row, character: symbolPos.col };",
      "contextualizedText": "// node/core/src/tools/hover.ts \u003e function execute\n\nconst symbolPos = calculateStringPosition(\n        { row: 0, col: 0 } as PositionString,\n        bufferContent,\n        (symbolStart + request.input.symbol.length - 1) as StringIdx,\n      );\n\n      const lspPosition = { line: symbolPos.row, character: symbolPos.col };",
      "headingContext": "node/core/src/tools/hover.ts \u003e function execute",
      "startLine": 135,
      "startCol": 7,
      "endLine": 141,
      "endCol": 77
    },
    {
      "text": "      const lspTimeout = \u003cT\u003e(p: Promise\u003cT\u003e, label: string): Promise\u003cT\u003e =\u003e\n        Promise.race([\n          p,\n          new Promise\u003cnever\u003e((_, reject) =\u003e\n            setTimeout(\n              () =\u003e reject(new Error(`LSP ${label} request timed out`)),\n              10_000,\n            ),\n          ),\n        ])",
      "contextualizedText": "// node/core/src/tools/hover.ts \u003e function execute \u003e function lspTimeout\n\n      const lspTimeout = \u003cT\u003e(p: Promise\u003cT\u003e, label: string): Promise\u003cT\u003e =\u003e\n        Promise.race([\n          p,\n          new Promise\u003cnever\u003e((_, reject) =\u003e\n            setTimeout(\n              () =\u003e reject(new Error(`LSP ${label} request timed out`)),\n              10_000,\n            ),\n          ),\n        ])",
      "headingContext": "node/core/src/tools/hover.ts \u003e function execute \u003e function lspTimeout",
      "startLine": 143,
      "startCol": 1,
      "endLine": 152,
      "endCol": 11
    },
    {
      "text": "const [hoverResult, definitionResult, typeDefinitionResult] =\n        await Promise.all([\n          lspTimeout(\n            context.lspClient.requestHover(absFilePath, lspPosition),\n            \"hover\",\n          ),\n          lspTimeout(\n            context.lspClient.requestDefinition(absFilePath, lspPosition),\n            \"definition\",\n          ).catch(() =\u003e null),\n          lspTimeout(\n            context.lspClient.requestTypeDefinition(absFilePath, lspPosition),\n            \"typeDefinition\",\n          ).catch(() =\u003e null),\n        ]);\n\n      if (aborted) {\n        return {\n          type: \"tool_result\",\n          id: request.id,\n          result: {\n            status: \"error\",\n            error: \"Request was aborted by the user.\",\n          },\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        };\n      }\n\n      let content = \"\";\n\n      for (const lspResult of hoverResult) {\n        if (lspResult != null) {\n          content += `${lspResult.result.contents.value}\\n`;\n        }\n      }",
      "contextualizedText": "// node/core/src/tools/hover.ts \u003e function execute\n\nconst [hoverResult, definitionResult, typeDefinitionResult] =\n        await Promise.all([\n          lspTimeout(\n            context.lspClient.requestHover(absFilePath, lspPosition),\n            \"hover\",\n          ),\n          lspTimeout(\n            context.lspClient.requestDefinition(absFilePath, lspPosition),\n            \"definition\",\n          ).catch(() =\u003e null),\n          lspTimeout(\n            context.lspClient.requestTypeDefinition(absFilePath, lspPosition),\n            \"typeDefinition\",\n          ).catch(() =\u003e null),\n        ]);\n\n      if (aborted) {\n        return {\n          type: \"tool_result\",\n          id: request.id,\n          result: {\n            status: \"error\",\n            error: \"Request was aborted by the user.\",\n          },\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        };\n      }\n\n      let content = \"\";\n\n      for (const lspResult of hoverResult) {\n        if (lspResult != null) {\n          content += `${lspResult.result.contents.value}\\n`;\n        }\n      }",
      "headingContext": "node/core/src/tools/hover.ts \u003e function execute",
      "startLine": 154,
      "startCol": 7,
      "endLine": 188,
      "endCol": 8
    },
    {
      "text": "      const extractLocationInfo = (\n        def: NonNullable\u003cLspDefinitionResponse[number]\u003e[\"result\"][number],\n      ): {\n        uri: string;\n        range: LspRange;\n      } | null =\u003e {\n        if (\"uri\" in def \u0026\u0026 \"range\" in def) {\n          return { uri: def.uri, range: def.range };\n        }\n        if (\"targetUri\" in def \u0026\u0026 \"targetRange\" in def) {\n          return { uri: def.targetUri, range: def.targetRange };\n        }\n        return null;\n      }",
      "contextualizedText": "// node/core/src/tools/hover.ts \u003e function execute \u003e function extractLocationInfo\n\n      const extractLocationInfo = (\n        def: NonNullable\u003cLspDefinitionResponse[number]\u003e[\"result\"][number],\n      ): {\n        uri: string;\n        range: LspRange;\n      } | null =\u003e {\n        if (\"uri\" in def \u0026\u0026 \"range\" in def) {\n          return { uri: def.uri, range: def.range };\n        }\n        if (\"targetUri\" in def \u0026\u0026 \"targetRange\" in def) {\n          return { uri: def.targetUri, range: def.targetRange };\n        }\n        return null;\n      }",
      "headingContext": "node/core/src/tools/hover.ts \u003e function execute \u003e function extractLocationInfo",
      "startLine": 190,
      "startCol": 1,
      "endLine": 203,
      "endCol": 8
    },
    {
      "text": "if (definitionResult) {\n        const definitions = definitionResult\n          .filter((result) =\u003e result != null)\n          .flatMap((result) =\u003e result.result)\n          .map(extractLocationInfo)\n          .filter((loc): loc is NonNullable\u003ctypeof loc\u003e =\u003e loc !== null);\n\n        if (definitions.length \u003e 0) {\n          content += \"\\nDefinition locations:\\n\";\n          for (const def of definitions) {\n            const absolutePath = def.uri.replace(/^file:\\/\\//, \"\");\n            const pathForDisplay = displayPath(\n              context.cwd,\n              absolutePath as AbsFilePath,\n              context.homeDir,\n            );\n            const line = def.range.start.line + 1;\n            const char = def.range.start.character + 1;\n            content += `  ${pathForDisplay}:${line}:${char}\\n`;\n          }\n        }\n      }\n\n      if (typeDefinitionResult) {\n        const typeDefinitions = typeDefinitionResult\n          .filter((result) =\u003e result != null)\n          .flatMap((result) =\u003e result.result)\n          .map(extractLocationInfo)\n          .filter((loc): loc is NonNullable\u003ctypeof loc\u003e =\u003e loc !== null);\n\n        if (typeDefinitions.length \u003e 0) {\n          content += \"\\nType definition locations:\\n\";\n          for (const typeDef of typeDefinitions) {\n            const absolutePath = typeDef.uri.replace(/^file:\\/\\//, \"\");\n            const pathForDisplay = displayPath(\n              context.cwd,\n              absolutePath as AbsFilePath,\n              context.homeDir,\n            );\n            const line = typeDef.range.start.line + 1;\n            const char = typeDef.range.start.character + 1;\n            content += `  ${pathForDisplay}:${line}:${char}\\n`;\n          }\n        }\n      }",
      "contextualizedText": "// node/core/src/tools/hover.ts \u003e function execute\n\nif (definitionResult) {\n        const definitions = definitionResult\n          .filter((result) =\u003e result != null)\n          .flatMap((result) =\u003e result.result)\n          .map(extractLocationInfo)\n          .filter((loc): loc is NonNullable\u003ctypeof loc\u003e =\u003e loc !== null);\n\n        if (definitions.length \u003e 0) {\n          content += \"\\nDefinition locations:\\n\";\n          for (const def of definitions) {\n            const absolutePath = def.uri.replace(/^file:\\/\\//, \"\");\n            const pathForDisplay = displayPath(\n              context.cwd,\n              absolutePath as AbsFilePath,\n              context.homeDir,\n            );\n            const line = def.range.start.line + 1;\n            const char = def.range.start.character + 1;\n            content += `  ${pathForDisplay}:${line}:${char}\\n`;\n          }\n        }\n      }\n\n      if (typeDefinitionResult) {\n        const typeDefinitions = typeDefinitionResult\n          .filter((result) =\u003e result != null)\n          .flatMap((result) =\u003e result.result)\n          .map(extractLocationInfo)\n          .filter((loc): loc is NonNullable\u003ctypeof loc\u003e =\u003e loc !== null);\n\n        if (typeDefinitions.length \u003e 0) {\n          content += \"\\nType definition locations:\\n\";\n          for (const typeDef of typeDefinitions) {\n            const absolutePath = typeDef.uri.replace(/^file:\\/\\//, \"\");\n            const pathForDisplay = displayPath(\n              context.cwd,\n              absolutePath as AbsFilePath,\n              context.homeDir,\n            );\n            const line = typeDef.range.start.line + 1;\n            const char = typeDef.range.start.character + 1;\n            content += `  ${pathForDisplay}:${line}:${char}\\n`;\n          }\n        }\n      }",
      "headingContext": "node/core/src/tools/hover.ts \u003e function execute",
      "startLine": 205,
      "startCol": 7,
      "endLine": 249,
      "endCol": 8
    },
    {
      "text": "return {\n        type: \"tool_result\",\n        id: request.id,\n        result: {\n          status: \"ok\",\n          value: [\n            {\n              type: \"text\",\n              text: content,\n              nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n            },\n          ],\n          structuredResult: { toolName: \"hover\" },\n        },\n        nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n      };\n    } catch (error) {\n      if (aborted) {\n        return {\n          type: \"tool_result\",\n          id: request.id,\n          result: {\n            status: \"error\",\n            error: \"Request was aborted by the user.\",\n          },\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        };\n      }\n      return {\n        type: \"tool_result\",\n        id: request.id,\n        result: {\n          status: \"error\",\n          error: `Error requesting hover: ${error instanceof Error ? error.message : String(error)}`,\n        },\n        nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n      };\n    }\n  })();\n\n  return {\n    promise",
      "contextualizedText": "// node/core/src/tools/hover.ts \u003e function execute\n\nreturn {\n        type: \"tool_result\",\n        id: request.id,\n        result: {\n          status: \"ok\",\n          value: [\n            {\n              type: \"text\",\n              text: content,\n              nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n            },\n          ],\n          structuredResult: { toolName: \"hover\" },\n        },\n        nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n      };\n    } catch (error) {\n      if (aborted) {\n        return {\n          type: \"tool_result\",\n          id: request.id,\n          result: {\n            status: \"error\",\n            error: \"Request was aborted by the user.\",\n          },\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        };\n      }\n      return {\n        type: \"tool_result\",\n        id: request.id,\n        result: {\n          status: \"error\",\n          error: `Error requesting hover: ${error instanceof Error ? error.message : String(error)}`,\n        },\n        nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n      };\n    }\n  })();\n\n  return {\n    promise",
