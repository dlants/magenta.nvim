    {
      "text": "    abort: () =\u003e {\n      aborted = true;\n    }",
      "contextualizedText": "// node/core/src/tools/findReferences.ts \u003e function execute \u003e function abort\n\n    abort: () =\u003e {\n      aborted = true;\n    }",
      "headingContext": "node/core/src/tools/findReferences.ts \u003e function execute \u003e function abort",
