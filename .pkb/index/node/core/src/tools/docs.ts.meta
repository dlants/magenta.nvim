    },
    {
      "text": "    abort: () =\u003e {\n      aborted = true;\n    }",
      "contextualizedText": "// node/core/src/tools/docs.ts \u003e function execute \u003e function abort\n\n    abort: () =\u003e {\n      aborted = true;\n    }",
