      "endCol": 6
    },
    {
      "text": "export function getSpec(): ProviderToolSpec {\n  return {\n    name: \"docs\" as ToolName,\n    description:\n      \"Search neovim help tags across all runtime help files (magenta docs, neovim builtins, plugin help). Returns matching tags with their file paths and line numbers.\",\n    input_schema: {\n      type: \"object\",\n      properties: {\n        query: {\n          type: \"string\",\n          description:\n            \"Substring to match against help tag names (case-insensitive).\",\n        },\n      },\n      required: [\"query\"],\n      additionalProperties: false,\n    },\n  };\n}",
      "contextualizedText": "// node/core/src/tools/docs.ts \u003e function getSpec\n\nexport function getSpec(): ProviderToolSpec {\n  return {\n    name: \"docs\" as ToolName,\n    description:\n      \"Search neovim help tags across all runtime help files (magenta docs, neovim builtins, plugin help). Returns matching tags with their file paths and line numbers.\",\n    input_schema: {\n      type: \"object\",\n      properties: {\n        query: {\n          type: \"string\",\n          description:\n            \"Substring to match against help tag names (case-insensitive).\",\n        },\n      },\n      required: [\"query\"],\n      additionalProperties: false,\n    },\n  };\n}",
      "headingContext": "node/core/src/tools/docs.ts \u003e function getSpec",
      "startLine": 231,
      "startCol": 1,
      "endLine": 249,
      "endCol": 2
    },
    {
      "text": "export function validateInput(input: {\n  [key: string]: unknown;\n}): Result\u003cInput\u003e {\n  if (typeof input.query !== \"string\") {\n    return {\n      status: \"error\",\n      error: \"expected req.input.query to be a string\",\n    };\n  }\n  if (input.query.trim().length === 0) {\n    return {\n      status: \"error\",\n      error: \"expected req.input.query to be a non-empty string\",\n    };\n  }\n  return {\n    status: \"ok\",\n    value: input as Input,\n  };\n}",
      "contextualizedText": "// node/core/src/tools/docs.ts \u003e function validateInput\n\nexport function validateInput(input: {\n  [key: string]: unknown;\n}): Result\u003cInput\u003e {\n  if (typeof input.query !== \"string\") {\n    return {\n      status: \"error\",\n      error: \"expected req.input.query to be a string\",\n    };\n  }\n  if (input.query.trim().length === 0) {\n    return {\n      status: \"error\",\n      error: \"expected req.input.query to be a non-empty string\",\n    };\n  }\n  return {\n    status: \"ok\",\n    value: input as Input,\n  };\n}",
      "headingContext": "node/core/src/tools/docs.ts \u003e function validateInput",
      "startLine": 251,
      "startCol": 1,
      "endLine": 270,
      "endCol": 2
    }
  ]
