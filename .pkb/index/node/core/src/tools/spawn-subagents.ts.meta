    {
      "text": "    abort: () =\u003e {\n      abortController.aborted = true;\n    }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function execute \u003e function abort\n\n    abort: () =\u003e {\n      abortController.aborted = true;\n    }",
