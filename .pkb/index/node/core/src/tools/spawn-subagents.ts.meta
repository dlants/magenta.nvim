    {
      "text": "    const startNext = (): void =\u003e {\n      if (nextIdx \u003e= elements.length || abortController.aborted) return;\n      const element = elements[nextIdx++];\n      const p = runElement(element).then(() =\u003e {\n        inFlight.delete(p);\n      });\n      inFlight.add(p);\n    }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function execute \u003e function runQueue \u003e function startNext\n\n    const startNext = (): void =\u003e {\n      if (nextIdx \u003e= elements.length || abortController.aborted) return;\n      const element = elements[nextIdx++];\n      const p = runElement(element).then(() =\u003e {\n        inFlight.delete(p);\n      });\n      inFlight.add(p);\n    }",
