    {
      "text": "  const runQueue = async (\n    elements: SpawnSubagentsProgress[\"elements\"],\n    limit: number,\n  ): Promise\u003cvoid\u003e =\u003e {\n    let nextIdx = 0;\n    const inFlight = new Set\u003cPromise\u003cvoid\u003e\u003e();",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function execute \u003e function runQueue\n\n  const runQueue = async (\n    elements: SpawnSubagentsProgress[\"elements\"],\n    limit: number,\n  ): Promise\u003cvoid\u003e =\u003e {\n    let nextIdx = 0;\n    const inFlight = new Set\u003cPromise\u003cvoid\u003e\u003e();",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function execute \u003e function runQueue",
      "startLine": 574,
      "startCol": 1,
      "endLine": 579,
      "endCol": 47
