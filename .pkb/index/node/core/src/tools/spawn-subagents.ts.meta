    {
      "text": "resultText =\n    resultText.slice(0, \"All sub-agents completed:\\n\\n\".length) +\n    totalLine +\n    resultText.slice(\"All sub-agents completed:\\n\\n\".length);\n\n  return {\n    type: \"tool_result\",\n    id: requestId,\n    result: {\n      status: \"ok\",\n      value: [\n        {\n          type: \"text\",\n          text: resultText,\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        },\n      ],\n      structuredResult: {\n        toolName: \"spawn_subagents\" as const,\n        agents,\n      },\n    },\n    nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n  };\n}",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function buildResult\n\nresultText =\n    resultText.slice(0, \"All sub-agents completed:\\n\\n\".length) +\n    totalLine +\n    resultText.slice(\"All sub-agents completed:\\n\\n\".length);\n\n  return {\n    type: \"tool_result\",\n    id: requestId,\n    result: {\n      status: \"ok\",\n      value: [\n        {\n          type: \"text\",\n          text: resultText,\n          nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n        },\n      ],\n      structuredResult: {\n        toolName: \"spawn_subagents\" as const,\n        agents,\n      },\n    },\n    nativeMessageIdx: PLACEHOLDER_NATIVE_MESSAGE_IDX,\n  };\n}",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function buildResult",
