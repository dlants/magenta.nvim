      "startLine": 194,
      "startCol": 1,
      "endLine": 212,
      "endCol": 4
    },
    {
      "text": "  function parseAgentEntry(entry: PartialSubagentEntry): void {\n    pos++; // {\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"}\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] !== '\"') throw EOF;\n      const key = parseString();\n      skipWs();\n      if (s[pos] === \":\") pos++;\n      switch (key) {\n        case \"prompt\":\n          entry.prompt = parseString();\n          break;\n        case \"agentType\":\n          entry.agentType = parseString();\n          break;\n        case \"environment\":\n          entry.environment = parseString();\n          break;\n        case \"directory\":\n          entry.directory = parseString();\n          break;\n        case \"dockerfile\":\n          entry.dockerfile = parseString();\n          break;\n        case \"workspacePath\":\n          entry.workspacePath = parseString();\n          break;\n        case \"contextFiles\": {\n          const arr: string[] = [];\n          entry.contextFiles = arr; // attach before filling\n          parseStringArray(arr);\n          break;\n        }\n        default:\n          skipValue();\n      }\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseAgentEntry\n\n  function parseAgentEntry(entry: PartialSubagentEntry): void {\n    pos++; // {\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"}\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] !== '\"') throw EOF;\n      const key = parseString();\n      skipWs();\n      if (s[pos] === \":\") pos++;\n      switch (key) {\n        case \"prompt\":\n          entry.prompt = parseString();\n          break;\n        case \"agentType\":\n          entry.agentType = parseString();\n          break;\n        case \"environment\":\n          entry.environment = parseString();\n          break;\n        case \"directory\":\n          entry.directory = parseString();\n          break;\n        case \"dockerfile\":\n          entry.dockerfile = parseString();\n          break;\n        case \"workspacePath\":\n          entry.workspacePath = parseString();\n          break;\n        case \"contextFiles\": {\n          const arr: string[] = [];\n          entry.contextFiles = arr; // attach before filling\n          parseStringArray(arr);\n          break;\n        }\n        default:\n          skipValue();\n      }\n    }\n  }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseAgentEntry",
      "startLine": 214,
      "startCol": 1,
      "endLine": 259,
      "endCol": 4
    },
    {
      "text": "  function parseAgents(target: PartialSubagentEntry[]): void {\n    skipWs();\n    if (s[pos] !== \"[\") throw EOF;\n    pos++;\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"]\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] === \"{\") {\n        const entry: PartialSubagentEntry = {};\n        target.push(entry); // attach before filling\n        parseAgentEntry(entry);\n      } else {\n        throw EOF;\n      }\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseAgents\n\n  function parseAgents(target: PartialSubagentEntry[]): void {\n    skipWs();\n    if (s[pos] !== \"[\") throw EOF;\n    pos++;\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"]\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] === \"{\") {\n        const entry: PartialSubagentEntry = {};\n        target.push(entry); // attach before filling\n        parseAgentEntry(entry);\n      } else {\n        throw EOF;\n      }\n    }\n  }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseAgents",
      "startLine": 261,
      "startCol": 1,
      "endLine": 283,
      "endCol": 4
    },
    {
      "text": "  function parseTopLevel(): void {\n    skipWs();\n    if (s[pos] !== \"{\") return;\n    pos++;\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"}\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] !== '\"') throw EOF;\n      const key = parseString();\n      skipWs();\n      if (s[pos] === \":\") pos++;\n      switch (key) {\n        case \"sharedPrompt\":\n          result.sharedPrompt = parseString();\n          break;\n        case \"sharedContextFiles\": {\n          const arr: string[] = [];\n          result.sharedContextFiles = arr; // attach before filling\n          parseStringArray(arr);\n          break;\n        }\n        case \"agents\":\n          parseAgents(result.agents);\n          break;\n        default:\n          skipValue();\n      }\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseTopLevel\n\n  function parseTopLevel(): void {\n    skipWs();\n    if (s[pos] !== \"{\") return;\n    pos++;\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"}\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] !== '\"') throw EOF;\n      const key = parseString();\n      skipWs();\n      if (s[pos] === \":\") pos++;\n      switch (key) {\n        case \"sharedPrompt\":\n          result.sharedPrompt = parseString();\n          break;\n        case \"sharedContextFiles\": {\n          const arr: string[] = [];\n          result.sharedContextFiles = arr; // attach before filling\n          parseStringArray(arr);\n          break;\n        }\n        case \"agents\":\n          parseAgents(result.agents);\n          break;\n        default:\n          skipValue();\n      }\n    }\n  }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseTopLevel",
      "startLine": 285,
      "startCol": 1,
      "endLine": 320,
      "endCol": 4
    },
    {
      "text": "try {\n    parseTopLevel();\n  } catch (e) {\n    if (e !== EOF) throw e;\n  }\n\n  return result;\n}",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput\n\ntry {\n    parseTopLevel();\n  } catch (e) {\n    if (e !== EOF) throw e;\n  }\n\n  return result;\n}",
