      "startCol": 3,
      "endLine": 557,
      "endCol": 38
    },
    {
      "text": "      const check = () =\u003e {\n        if (abortController.aborted) {\n          resolve();\n          return;\n        }\n        const result = context.threadManager.getThreadResult(threadId);\n        if (result.status === \"done\") {\n          resolve();\n        }\n      }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function execute \u003e function runElement \u003e function check\n\n      const check = () =\u003e {\n        if (abortController.aborted) {\n          resolve();\n          return;\n        }\n        const result = context.threadManager.getThreadResult(threadId);\n        if (result.status === \"done\") {\n          resolve();\n        }\n      }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function execute \u003e function runElement \u003e function check",
      "startLine": 558,
