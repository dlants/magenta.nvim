      "text": "minItems: 1,\n        },\n      },\n      required: [\"agents\"],\n    },\n  };\n}",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function getSpec\n\nminItems: 1,\n        },\n      },\n      required: [\"agents\"],\n    },\n  };\n}",
