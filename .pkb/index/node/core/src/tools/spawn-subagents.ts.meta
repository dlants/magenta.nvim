    {
      "text": "/**\n * Tolerant recursive-descent parser that turns a partial (possibly truncated)\n * JSON string for a spawn_subagents input into a best-effort view object.\n * Never throws on any prefix of a valid input — returns whatever is known so far,\n * including a trailing partial string token.\n */\nexport function parsePartialSpawnSubagentsInput(\n  inputJson: string,\n): PartialSpawnSubagentsInput {\n  const s = inputJson;\n  const result: PartialSpawnSubagentsInput = { agents: [] };\n  const EOF = Symbol(\"eof\");\n  let pos = 0;",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput\n\n/**\n * Tolerant recursive-descent parser that turns a partial (possibly truncated)\n * JSON string for a spawn_subagents input into a best-effort view object.\n * Never throws on any prefix of a valid input — returns whatever is known so far,\n * including a trailing partial string token.\n */\nexport function parsePartialSpawnSubagentsInput(\n  inputJson: string,\n): PartialSpawnSubagentsInput {\n  const s = inputJson;\n  const result: PartialSpawnSubagentsInput = { agents: [] };\n  const EOF = Symbol(\"eof\");\n  let pos = 0;",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput",
      "startLine": 68,
      "startCol": 1,
      "endLine": 80,
      "endCol": 15
    },
    {
      "text": "  function skipWs(): void {\n    while (pos \u003c s.length \u0026\u0026 /\\s/.test(s[pos])) pos++;\n    if (pos \u003e= s.length) throw EOF;\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function skipWs\n\n  function skipWs(): void {\n    while (pos \u003c s.length \u0026\u0026 /\\s/.test(s[pos])) pos++;\n    if (pos \u003e= s.length) throw EOF;\n  }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function skipWs",
      "startLine": 82,
      "startCol": 1,
      "endLine": 85,
      "endCol": 4
    },
    {
      "text": "  function parseString(): string {\n    skipWs();\n    if (s[pos] !== '\"') throw EOF;\n    pos++; // opening quote\n    let value = \"\";\n    while (pos \u003c s.length) {\n      const c = s[pos++];\n      if (c === \"\\\\\") {\n        if (pos \u003e= s.length) return value; // truncated escape\n        const e = s[pos++];\n        switch (e) {\n          case \"n\":\n            value += \"\\n\";\n            break;\n          case \"t\":\n            value += \"\\t\";\n            break;\n          case \"r\":\n            value += \"\\r\";\n            break;\n          case '\"':\n            value += '\"';\n            break;\n          case \"\\\\\":\n            value += \"\\\\\";\n            break;\n          case \"/\":\n            value += \"/\";\n            break;\n          case \"u\": {\n            const hex = s.slice(pos, pos + 4);\n            if (hex.length \u003c 4) return value; // truncated unicode escape\n            value += String.fromCharCode(parseInt(hex, 16));\n            pos += 4;\n            break;\n          }\n          default:\n            value += e;\n        }\n      } else if (c === '\"') {\n        return value; // closed\n      } else {\n        value += c;\n      }\n    }\n    return value; // truncated, no closing quote\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseString\n\n  function parseString(): string {\n    skipWs();\n    if (s[pos] !== '\"') throw EOF;\n    pos++; // opening quote\n    let value = \"\";\n    while (pos \u003c s.length) {\n      const c = s[pos++];\n      if (c === \"\\\\\") {\n        if (pos \u003e= s.length) return value; // truncated escape\n        const e = s[pos++];\n        switch (e) {\n          case \"n\":\n            value += \"\\n\";\n            break;\n          case \"t\":\n            value += \"\\t\";\n            break;\n          case \"r\":\n            value += \"\\r\";\n            break;\n          case '\"':\n            value += '\"';\n            break;\n          case \"\\\\\":\n            value += \"\\\\\";\n            break;\n          case \"/\":\n            value += \"/\";\n            break;\n          case \"u\": {\n            const hex = s.slice(pos, pos + 4);\n            if (hex.length \u003c 4) return value; // truncated unicode escape\n            value += String.fromCharCode(parseInt(hex, 16));\n            pos += 4;\n            break;\n          }\n          default:\n            value += e;\n        }\n      } else if (c === '\"') {\n        return value; // closed\n      } else {\n        value += c;\n      }\n    }\n    return value; // truncated, no closing quote\n  }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseString",
      "startLine": 87,
      "startCol": 1,
      "endLine": 133,
      "endCol": 4
    },
    {
      "text": "  function parseStringArray(target: string[]): void {\n    skipWs();\n    if (s[pos] !== \"[\") throw EOF;\n    pos++;\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"]\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] === '\"') {\n        target.push(parseString());\n      } else {\n        throw EOF;\n      }\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseStringArray\n\n  function parseStringArray(target: string[]): void {\n    skipWs();\n    if (s[pos] !== \"[\") throw EOF;\n    pos++;\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"]\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] === '\"') {\n        target.push(parseString());\n      } else {\n        throw EOF;\n      }\n    }\n  }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function parseStringArray",
      "startLine": 135,
      "startCol": 1,
      "endLine": 155,
      "endCol": 4
    },
    {
      "text": "  function skipValue(): void {\n    skipWs();\n    const c = s[pos];\n    if (c === '\"') {\n      parseString();\n      return;\n    }\n    if (c === \"[\") {\n      skipArray();\n      return;\n    }\n    if (c === \"{\") {\n      skipObject();\n      return;\n    }\n    while (pos \u003c s.length \u0026\u0026 !\",]}\".includes(s[pos]) \u0026\u0026 !/\\s/.test(s[pos])) {\n      pos++;\n    }\n    if (pos \u003e= s.length) throw EOF;\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function skipValue\n\n  function skipValue(): void {\n    skipWs();\n    const c = s[pos];\n    if (c === '\"') {\n      parseString();\n      return;\n    }\n    if (c === \"[\") {\n      skipArray();\n      return;\n    }\n    if (c === \"{\") {\n      skipObject();\n      return;\n    }\n    while (pos \u003c s.length \u0026\u0026 !\",]}\".includes(s[pos]) \u0026\u0026 !/\\s/.test(s[pos])) {\n      pos++;\n    }\n    if (pos \u003e= s.length) throw EOF;\n  }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function skipValue",
      "startLine": 157,
      "startCol": 1,
      "endLine": 176,
      "endCol": 4
    },
    {
      "text": "  function skipArray(): void {\n    pos++; // [\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"]\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      skipValue();\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function skipArray\n\n  function skipArray(): void {\n    pos++; // [\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"]\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      skipValue();\n    }\n  }",
      "headingContext": "node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function skipArray",
      "startLine": 178,
      "startCol": 1,
      "endLine": 192,
      "endCol": 4
    },
    {
      "text": "  function skipObject(): void {\n    pos++; // {\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"}\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] !== '\"') throw EOF;\n      parseString(); // key\n      skipWs();\n      if (s[pos] === \":\") pos++;\n      skipValue();\n    }\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function parsePartialSpawnSubagentsInput \u003e function skipObject\n\n  function skipObject(): void {\n    pos++; // {\n    for (;;) {\n      skipWs();\n      if (s[pos] === \"}\") {\n        pos++;\n        return;\n      }\n      if (s[pos] === \",\") {\n        pos++;\n        continue;\n      }\n      if (s[pos] !== '\"') throw EOF;\n      parseString(); // key\n      skipWs();\n      if (s[pos] === \":\") pos++;\n      skipValue();\n    }\n  }",
