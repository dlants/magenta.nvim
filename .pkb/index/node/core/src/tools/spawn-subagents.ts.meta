    {
      "text": "const VALID_ENVIRONMENTS = [\"host\", \"docker\", \"docker_unsupervised\"] as const;",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts\n\nconst VALID_ENVIRONMENTS = [\"host\", \"docker\", \"docker_unsupervised\"] as const;",
      "headingContext": "node/core/src/tools/spawn-subagents.ts",
