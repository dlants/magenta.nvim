    {
      "text": "context.threadManager.onThreadYielded(threadId, check);\n      // Check immediately in case the thread already yielded\n      check();\n    });\n  }",
      "contextualizedText": "// node/core/src/tools/spawn-subagents.ts \u003e function execute \u003e function runElement\n\ncontext.threadManager.onThreadYielded(threadId, check);\n      // Check immediately in case the thread already yielded\n      check();\n    });\n  }",
