    {
      "text": "  off\u003cK extends keyof Events\u003e(event: K, listener: Listener\u003cEvents[K]\u003e): void {\n    this.listeners[event]?.delete(listener);\n  }",
      "contextualizedText": "// node/core/src/emitter.ts \u003e class Emitter \u003e method off\n\n  off\u003cK extends keyof Events\u003e(event: K, listener: Listener\u003cEvents[K]\u003e): void {\n    this.listeners[event]?.delete(listener);\n  }",
