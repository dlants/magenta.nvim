    {
      "text": "export function delay(ms: number) {\n  return new Promise((resolve) =\u003e {\n    setTimeout(resolve, ms);\n  });\n}",
      "contextualizedText": "// node/core/src/utils/async.ts \u003e function delay\n\nexport function delay(ms: number) {\n  return new Promise((resolve) =\u003e {\n    setTimeout(resolve, ms);\n  });\n}",
