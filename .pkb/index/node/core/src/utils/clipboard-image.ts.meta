    {
      "text": "import { exec } from \"node:child_process\";\nimport * as fs from \"node:fs/promises\";\nimport * as os from \"node:os\";\nimport * as path from \"node:path\";\nimport { promisify } from \"node:util\";\n\nconst execAsync = promisify(exec);\n\nexport type ClipboardProbeResult =\n  | { kind: \"image\"; tmpPath: string }\n  | { kind: \"none\" };",
      "contextualizedText": "// node/core/src/utils/clipboard-image.ts\n\nimport { exec } from \"node:child_process\";\nimport * as fs from \"node:fs/promises\";\nimport * as os from \"node:os\";\nimport * as path from \"node:path\";\nimport { promisify } from \"node:util\";\n\nconst execAsync = promisify(exec);\n\nexport type ClipboardProbeResult =\n  | { kind: \"image\"; tmpPath: string }\n  | { kind: \"none\" };",
      "headingContext": "node/core/src/utils/clipboard-image.ts",
      "startLine": 1,
