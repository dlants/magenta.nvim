    {
      "text": "export type StringIdx = number \u0026 { __charIdx: true };\n\nexport type Row0Indexed = number \u0026 { __row0Indexed: true };\n\nexport type PositionString = {\n  row: Row0Indexed;\n  col: StringIdx;\n};",
      "contextualizedText": "// node/core/src/utils/string-position.ts\n\nexport type StringIdx = number \u0026 { __charIdx: true };\n\nexport type Row0Indexed = number \u0026 { __row0Indexed: true };\n\nexport type PositionString = {\n  row: Row0Indexed;\n  col: StringIdx;\n};",
      "headingContext": "node/core/src/utils/string-position.ts",
