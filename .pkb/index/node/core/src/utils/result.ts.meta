    {
      "text": "export type Success\u003cT\u003e = {\n  status: \"ok\";\n  value: T;\n};\n\nexport type ResultError\u003cE\u003e = {\n  status: \"error\";\n  error: string;\n} \u0026 E;\n\nexport type Result\u003cT, E = {}\u003e = Success\u003cT\u003e | ResultError\u003cE\u003e;\n\nexport type ExtractSuccess\u003cR extends Result\u003cunknown, unknown\u003e\u003e = Extract\u003c\n  R,\n  { status: \"ok\" }\n\u003e;",
      "contextualizedText": "// node/core/src/utils/result.ts\n\nexport type Success\u003cT\u003e = {\n  status: \"ok\";\n  value: T;\n};\n\nexport type ResultError\u003cE\u003e = {\n  status: \"error\";\n  error: string;\n} \u0026 E;\n\nexport type Result\u003cT, E = {}\u003e = Success\u003cT\u003e | ResultError\u003cE\u003e;\n\nexport type ExtractSuccess\u003cR extends Result\u003cunknown, unknown\u003e\u003e = Extract\u003c\n  R,\n  { status: \"ok\" }\n\u003e;",
