    {
      "text": "export function extendError\u003cT, E1, E2\u003e(\n  result: Result\u003cT, E1\u003e,\n  additionalErrorProps: E2,\n): Result\u003cT, E1 \u0026 E2\u003e {\n  if (result.status === \"ok\") {\n    return result;\n  }\n\n  return {\n    ...result,\n    ...additionalErrorProps,\n  };\n}",
      "contextualizedText": "// node/core/src/utils/result.ts \u003e function extendError\n\nexport function extendError\u003cT, E1, E2\u003e(\n  result: Result\u003cT, E1\u003e,\n  additionalErrorProps: E2,\n): Result\u003cT, E1 \u0026 E2\u003e {\n  if (result.status === \"ok\") {\n    return result;\n  }\n\n  return {\n    ...result,\n    ...additionalErrorProps,\n  };\n}",
