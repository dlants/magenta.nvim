      "text": "export type ToolManagerToolMsg = {\n  type: \"tool-msg\";\n  msg: {\n    id: ToolRequestId;\n    toolName: ToolName;\n    msg: ToolMsg;\n  };\n};\n\nexport type ToolMsg = { __toolMsg: true };\n\nexport type ToolInvocation = {\n  promise: Promise\u003cProviderToolResult\u003e;\n  abort: () =\u003e void;\n};\n\nexport type ValidateInput = (\n  toolName: unknown,\n  input: { [key: string]: unknown },\n) =\u003e Result\u003cRecord\u003cstring, unknown\u003e\u003e;",
      "contextualizedText": "// node/core/src/tool-types.ts\n\nexport type ToolManagerToolMsg = {\n  type: \"tool-msg\";\n  msg: {\n    id: ToolRequestId;\n    toolName: ToolName;\n    msg: ToolMsg;\n  };\n};\n\nexport type ToolMsg = { __toolMsg: true };\n\nexport type ToolInvocation = {\n  promise: Promise\u003cProviderToolResult\u003e;\n  abort: () =\u003e void;\n};\n\nexport type ValidateInput = (\n  toolName: unknown,\n  input: { [key: string]: unknown },\n) =\u003e Result\u003cRecord\u003cstring, unknown\u003e\u003e;",
