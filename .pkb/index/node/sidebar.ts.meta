    {
      "text": "  private getDisplayWindowTitle(): string {\n    return \"Magenta Chat\";\n  }",
      "contextualizedText": "// node/sidebar.ts \u003e class Sidebar \u003e method getDisplayWindowTitle\n\n  private getDisplayWindowTitle(): string {\n    return \"Magenta Chat\";\n  }",
      "headingContext": "node/sidebar.ts \u003e class Sidebar \u003e method getDisplayWindowTitle",
