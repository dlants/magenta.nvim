    {
      "text": "```typescript\n// Consider line length when formatting\nd`\nThis is a very long line that might wrap in narrow terminals\nConsider breaking long text into multiple lines\n`;\n```\n\n### Visual Separators\n\nUse ASCII art for visual structure:\n\n```typescript\nd`\n===================\nSection Header\n===================\n\nContent goes here\n\n-------------------\n\nFooter\n`;\n```\n\n## Common Patterns\n\n### Loading States\n\n```typescript\nview() {\n  if (this.state.loading) {\n    return d`Loading...`;\n  }\n\n  return d`\n${this.state.data}\n\n${withBindings(d`[Refresh]`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"refresh\" }),\n})}\n`;\n}\n```\n\n### Error Display\n\n```typescript\nview() {\n  if (this.state.error) {\n    return d`\nERROR: ${this.state.error.message}\n\n${withBindings(d`[Retry]`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"retry\" }),\n})}\n`;\n  }\n\n  // Normal view...\n}\n```\n\n### Conditional Sections\n\n```typescript\nview() {\n  return d`\nMain content\n\n${this.state.showDetails ? d`\nDetails:\n${this.state.details}\n` : d``}\n\n${withBindings(d`[${this.state.showDetails ? \"Hide\" : \"Show\"} Details]`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"toggle-details\" }),\n})}\n`;\n}\n```\n\n### Lists with Actions\n\n```typescript\nview() {\n  return d`\nTasks:\n\n${this.state.tasks.map((task, idx) =\u003e d`\n${withBindings(d`[${task.done ? \"âś“\" : \" \"}] ${task.name}`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"toggle-task\", index: idx }),\n  d: () =\u003e this.myDispatch({ type: \"delete-task\", index: idx }),\n})}\n`)}\n\n${withBindings(d`[Add Task]`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"add-task\" }),\n})}\n`;\n}\n```\n\n### Multi-Column Layouts\n\nUse spacing to create columns:\n\n```typescript\nfunction formatRow(name: string, value: string) {\n  const nameWidth = 20;\n  const paddedName = name.padEnd(nameWidth);\n  return d`${paddedName} ${value}`;\n}",
      "contextualizedText": "```typescript\n// Consider line length when formatting\nd`\nThis is a very long line that might wrap in narrow terminals\nConsider breaking long text into multiple lines\n`;\n```\n\n### Visual Separators\n\nUse ASCII art for visual structure:\n\n```typescript\nd`\n===================\nSection Header\n===================\n\nContent goes here\n\n-------------------\n\nFooter\n`;\n```\n\n## Common Patterns\n\n### Loading States\n\n```typescript\nview() {\n  if (this.state.loading) {\n    return d`Loading...`;\n  }\n\n  return d`\n${this.state.data}\n\n${withBindings(d`[Refresh]`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"refresh\" }),\n})}\n`;\n}\n```\n\n### Error Display\n\n```typescript\nview() {\n  if (this.state.error) {\n    return d`\nERROR: ${this.state.error.message}\n\n${withBindings(d`[Retry]`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"retry\" }),\n})}\n`;\n  }\n\n  // Normal view...\n}\n```\n\n### Conditional Sections\n\n```typescript\nview() {\n  return d`\nMain content\n\n${this.state.showDetails ? d`\nDetails:\n${this.state.details}\n` : d``}\n\n${withBindings(d`[${this.state.showDetails ? \"Hide\" : \"Show\"} Details]`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"toggle-details\" }),\n})}\n`;\n}\n```\n\n### Lists with Actions\n\n```typescript\nview() {\n  return d`\nTasks:\n\n${this.state.tasks.map((task, idx) =\u003e d`\n${withBindings(d`[${task.done ? \"âś“\" : \" \"}] ${task.name}`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"toggle-task\", index: idx }),\n  d: () =\u003e this.myDispatch({ type: \"delete-task\", index: idx }),\n})}\n`)}\n\n${withBindings(d`[Add Task]`, {\n  \"\u003cCR\u003e\": () =\u003e this.myDispatch({ type: \"add-task\" }),\n})}\n`;\n}\n```\n\n### Multi-Column Layouts\n\nUse spacing to create columns:\n\n```typescript\nfunction formatRow(name: string, value: string) {\n  const nameWidth = 20;\n  const paddedName = name.padEnd(nameWidth);\n  return d`${paddedName} ${value}`;\n}",
      "headingContext": "",
