{
  "blobSha": "f856362671c5013432a9dcdc4df2e0a73602c2d0",
  "modelName": "voyage-context-4@256",
  "chunks": [
    {
      "text": "name: pkb index\n# Rebuild the checked-in semantic search index whenever code lands on main, then\n# commit the refreshed index back. The follow-up commit only touches pkb.db /\n# pkb-state.toml, which are in paths-ignore, so it does not re-trigger this\n# workflow (and GITHUB_TOKEN pushes don't trigger workflows anyway).\non:\n  push:\n    branches: [main]\n    paths-ignore:\n      - pkb.db\n      - pkb-state.toml\nconcurrency:\n  group: pkb-index-\\${{ github.ref }}\n  cancel-in-progress: false\npermissions:\n  contents: write\njobs:\n  reindex:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n        with:\n          lfs: true\n          fetch-depth: 0\n      - uses: actions/setup-go@v5\n        with:\n          go-version: \"1.26.4\"\n          cache: false\n      - name: Install pkb\n        run: go install github.com/dlants/pkb/cmd/pkb@latest\n      - name: Reindex\n        env:\n          VOYAGE_API_KEY: \\${{ secrets.VOYAGE_API_KEY }}\n          ANTHROPIC_API_KEY: \\${{ secrets.ANTHROPIC_API_KEY }}\n        run: pkb reindex\n      - name: Commit refreshed index\n        run: |\n          if git diff --quiet -- pkb.db pkb-state.toml; then\n            echo \"index unchanged; nothing to commit\"\n            exit 0\n          fi\n          git config user.name \"github-actions[bot]\"\n          git config user.email \"github-actions[bot]@users.noreply.github.com\"\n          git lfs install --local\n          git add -- pkb.db pkb-state.toml\n          git commit -m \"pkb: reindex for \\${GITHUB_SHA} [skip ci]\"\n          git lfs push origin HEAD\n          # If main advanced while indexing, this push fails by design: the\n          # commit that advanced main triggers its own reindex run, which will\n          # produce an up-to-date index.\n          git push\n",
      "contextualizedText": "# .github/workflows/pkb-index.yml\n\nname: pkb index\n# Rebuild the checked-in semantic search index whenever code lands on main, then\n# commit the refreshed index back. The follow-up commit only touches pkb.db /\n# pkb-state.toml, which are in paths-ignore, so it does not re-trigger this\n# workflow (and GITHUB_TOKEN pushes don't trigger workflows anyway).\non:\n  push:\n    branches: [main]\n    paths-ignore:\n      - pkb.db\n      - pkb-state.toml\nconcurrency:\n  group: pkb-index-\\${{ github.ref }}\n  cancel-in-progress: false\npermissions:\n  contents: write\njobs:\n  reindex:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n        with:\n          lfs: true\n          fetch-depth: 0\n      - uses: actions/setup-go@v5\n        with:\n          go-version: \"1.26.4\"\n          cache: false\n      - name: Install pkb\n        run: go install github.com/dlants/pkb/cmd/pkb@latest\n      - name: Reindex\n        env:\n          VOYAGE_API_KEY: \\${{ secrets.VOYAGE_API_KEY }}\n          ANTHROPIC_API_KEY: \\${{ secrets.ANTHROPIC_API_KEY }}\n        run: pkb reindex\n      - name: Commit refreshed index\n        run: |\n          if git diff --quiet -- pkb.db pkb-state.toml; then\n            echo \"index unchanged; nothing to commit\"\n            exit 0\n          fi\n          git config user.name \"github-actions[bot]\"\n          git config user.email \"github-actions[bot]@users.noreply.github.com\"\n          git lfs install --local\n          git add -- pkb.db pkb-state.toml\n          git commit -m \"pkb: reindex for \\${GITHUB_SHA} [skip ci]\"\n          git lfs push origin HEAD\n          # If main advanced while indexing, this push fails by design: the\n          # commit that advanced main triggers its own reindex run, which will\n          # produce an up-to-date index.\n          git push\n",
