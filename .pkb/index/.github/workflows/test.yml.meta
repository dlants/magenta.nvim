  "chunks": [
    {
      "text": "name: Tests\n\non:\n  push:\n    branches: [main]\n  pull_request:\n    branches: [main]\n\njobs:\n  test:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v3\n\n      - name: Setup Node.js\n        uses: actions/setup-node@v3\n        with:\n          node-version: \"24\"\n          cache: \"npm\"\n\n      - name: Install dependencies\n        run: npm ci\n\n      - name: Setup Neovim\n        uses: rhysd/action-setup-vim@v1\n        with:\n          neovim: true\n          version: stable\n\n      - name: Install typescript-language-server\n        run: npm install -g typescript-language-server typescript\n\n      - name: Install fzf and fd\n        run: sudo apt-get update \u0026\u0026 sudo apt-get install -y fzf fd-find\n\n      - name: Install tree-sitter TypeScript parser for Neovim\n        run: |\n          git clone --depth 1 https://github.com/tree-sitter/tree-sitter-typescript\n          cd tree-sitter-typescript\n          cc -shared -fPIC -O2 -I typescript/src typescript/src/parser.c typescript/src/scanner.c -o typescript.so\n          mkdir -p ~/.local/share/nvim/parser\n          cp typescript.so ~/.local/share/nvim/parser/\n\n      - name: Run tests\n        run: npx vitest\n        env:\n          FORCE_SETUP: true\n\n  lint-and-format:\n    runs-on: ubuntu-latest\n    strategy:\n      matrix:\n        command:\n          - name: \"typecheck\"\n            run: \"npx tsgo -b\"\n          - name: \"biome\"\n            run: \"npx biome check .\"\n    name: ${{ matrix.command.name }}\n    steps:\n      - uses: actions/checkout@v3\n\n      - name: Setup Node.js\n        uses: actions/setup-node@v3\n        with:\n          node-version: \"24\"\n          cache: \"npm\"\n\n      - name: Install dependencies\n        run: npm ci\n\n      - name: Run ${{ matrix.command.name }}\n        run: ${{ matrix.command.run }}\n",
      "contextualizedText": "# .github/workflows/test.yml\n\nname: Tests\n\non:\n  push:\n    branches: [main]\n  pull_request:\n    branches: [main]\n\njobs:\n  test:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v3\n\n      - name: Setup Node.js\n        uses: actions/setup-node@v3\n        with:\n          node-version: \"24\"\n          cache: \"npm\"\n\n      - name: Install dependencies\n        run: npm ci\n\n      - name: Setup Neovim\n        uses: rhysd/action-setup-vim@v1\n        with:\n          neovim: true\n          version: stable\n\n      - name: Install typescript-language-server\n        run: npm install -g typescript-language-server typescript\n\n      - name: Install fzf and fd\n        run: sudo apt-get update \u0026\u0026 sudo apt-get install -y fzf fd-find\n\n      - name: Install tree-sitter TypeScript parser for Neovim\n        run: |\n          git clone --depth 1 https://github.com/tree-sitter/tree-sitter-typescript\n          cd tree-sitter-typescript\n          cc -shared -fPIC -O2 -I typescript/src typescript/src/parser.c typescript/src/scanner.c -o typescript.so\n          mkdir -p ~/.local/share/nvim/parser\n          cp typescript.so ~/.local/share/nvim/parser/\n\n      - name: Run tests\n        run: npx vitest\n        env:\n          FORCE_SETUP: true\n\n  lint-and-format:\n    runs-on: ubuntu-latest\n    strategy:\n      matrix:\n        command:\n          - name: \"typecheck\"\n            run: \"npx tsgo -b\"\n          - name: \"biome\"\n            run: \"npx biome check .\"\n    name: ${{ matrix.command.name }}\n    steps:\n      - uses: actions/checkout@v3\n\n      - name: Setup Node.js\n        uses: actions/setup-node@v3\n        with:\n          node-version: \"24\"\n          cache: \"npm\"\n\n      - name: Install dependencies\n        run: npm ci\n\n      - name: Run ${{ matrix.command.name }}\n        run: ${{ matrix.command.run }}\n",
